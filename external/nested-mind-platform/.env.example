MIND_ROOT_ID=00000000-0000-0000-0000-000000000001
MIND_ROOT_KIND=root

# Bootstrap tokens remain available for local/dev. Production should use trusted OIDC/mTLS headers from a gateway.
MIND_BOOTSTRAP_TOKEN=replace-with-random-hex
MIND_BOOTSTRAP_PRINCIPAL=tamirat
MIND_OPERATOR_TOKEN=
MIND_OPERATOR_PRINCIPAL=operator
MIND_AUDITOR_TOKEN=
MIND_AUDITOR_PRINCIPAL=auditor
MIND_MAINTAINER_TOKEN=
MIND_MAINTAINER_PRINCIPAL=maintainer

# v7 trusted upstream identity boundary.
MIND_TRUSTED_IDENTITY_HEADERS=false
MIND_IDENTITY_ALLOWED_ISSUERS=https://issuer.example
MIND_IDENTITY_REQUIRED_AUDIENCES=nested-mind-api
MIND_IDENTITY_REQUIRED_CLIENT_CERT_SHA256=

# Commit signing. env_ed25519 is inline; hsm/kms/secret_manager/external_request are modeled as external completion backends.
MIND_REQUIRE_SIGNATURES=true
MIND_SIGNING_BACKEND=env_ed25519
MIND_COMMIT_SIGNING_KEY_ID=root-runtime-ed25519
MIND_COMMIT_SIGNING_SEED_HEX=replace-with-32-byte-hex-seed

MIND_EVENT_DB=./data/mind-events.sqlite
MIND_EVENT_LOG=
MIND_SNAPSHOT_DB=
MIND_SNAPSHOT_LOG=./data/root.snapshots.jsonl

MIND_SNAPSHOT_KEEP_LATEST=3
MIND_SNAPSHOT_MIN_EVENTS_BETWEEN=25

MIND_OBSERVABILITY_LOG=./data/observability.jsonl
MIND_OBSERVABILITY=on
MIND_TRACE_LEVEL=mind_api=info,tower_http=info

MIND_LOG_LEVEL=mind_api=info,tower_http=info
RUST_LOG=
MIND_TRACE_JSON=false

# Request safety
MIND_MAX_BODY_BYTES=65536
MIND_RATE_LIMIT_REQUESTS=60
MIND_RATE_LIMIT_WINDOW_SECONDS=60

# Telemetry / observability persistence
MIND_OBSERVABILITY_DB=
MIND_OBSERVABILITY_USE_EVENT_DB=true

# Backup/export examples
MIND_BACKUP_DIR=./data/backups
MIND_BACKUP_OBJECT_DIR=./data/object-store
MIND_BACKUP_OBJECT_BUCKET=mind-backups

# v7 distributed event-store strategy guard.
MIND_EVENT_STORE_STRATEGY=single_writer
MIND_NODE_ID=local
MIND_NODE_ROLE=single
MIND_VOTING_MEMBERS=1
MIND_QUORUM_SIZE=1
MIND_ALLOW_LOCAL_APPENDS=true

# v8 direct OIDC/JWKS verifier. When configured, bearer JWTs can authenticate directly.
MIND_OIDC_JWKS_FILE=
MIND_OIDC_ISSUER=https://issuer.example
MIND_OIDC_AUDIENCES=nested-mind-api
MIND_OIDC_ALLOWED_ALGORITHMS=RS256
MIND_OIDC_DEFAULT_ROLE=observer

# v8 managed signing adapters. These generate provider commands; vendor SDK execution remains external.
MIND_MANAGED_SIGNING_PROVIDER=aws_kms
MIND_MANAGED_SIGNING_KEY_RESOURCE=arn:aws:kms:us-east-1:111122223333:key/demo
MIND_MANAGED_SIGNING_PUBLIC_KEY_HEX=

# v8 cloud object backup planning.
MIND_CLOUD_BACKUP_PROVIDER=s3
MIND_CLOUD_BACKUP_BUCKET=mind-backups
MIND_CLOUD_BACKUP_PREFIX=root
MIND_CLOUD_BACKUP_REGION=us-east-1
MIND_CLOUD_BACKUP_ENDPOINT=
MIND_CLOUD_BACKUP_KMS_KEY_ID=

# v8 leader replication protocol defaults.
MIND_REPLICATION_TERM=1
MIND_REPLICATION_LEADER_ID=leader-a
MIND_REPLICATION_MAX_RECORDS_PER_BATCH=100
MIND_REPLICATION_REQUIRED_ACKS=1

# v9/v10 OIDC discovery/JWKS refresh. v10 can fetch discovery/JWKS live over HTTPS.
MIND_OIDC_DISCOVERY_FILE=
MIND_OIDC_REFRESH_TTL_SECONDS=3600

# v9 executable local mirror for cloud backup transfer rehearsals.
MIND_CLOUD_OBJECT_MIRROR_DIR=./data/cloud-mirror

# v9 replication inbox and follower list.
MIND_REPLICATION_INBOX_LOG=./data/replication-inbox.jsonl
MIND_REPLICATION_FOLLOWERS=node-b=http://node-b:8080,node-c=http://node-c:8080

# v9 consensus membership model.
MIND_CONSENSUS_CLUSTER_ID=mind-cluster
MIND_CONSENSUS_MEMBERS=node-a,node-b,node-c
MIND_CONSENSUS_LEADER_ID=node-a


# v10 live adapter controls
MIND_REPLICATION_RETRY_MAX_ATTEMPTS=3
MIND_REPLICATION_RETRY_INITIAL_DELAY_MS=250
MIND_REPLICATION_RETRY_MAX_DELAY_MS=5000
MIND_REPLICATION_RETRY_MULTIPLIER=2
MIND_REPLICATION_BEARER_TOKEN=

# POST /system/backups/root/signed-url-upload accepts provider/url/bucket/key in the request body.
# The signed URL itself should be short lived and never stored in Git.


# v10 live connector controls
MIND_OIDC_REFRESH_ALLOWED=true
MIND_REPLICATION_BEARER_TOKEN=
MIND_REPLICATION_MAX_ATTEMPTS=3
MIND_REPLICATION_INITIAL_DELAY_MS=250
MIND_REPLICATION_MAX_DELAY_MS=5000
MIND_REPLICATION_DELAY_MULTIPLIER=2
MIND_REPLICATION_FOLLOWERS=follower-a=http://127.0.0.1:8081


# v11 durable scheduler defaults
MIND_SCHEDULER_LEASE_SECONDS=60
MIND_SCHEDULER_MAX_CLAIMS_PER_POLL=10
MIND_SCHEDULER_LOG=./data/scheduler.jsonl

# v11 provider execution evidence. Receipts are posted to /system/provider/execution-receipts.
MIND_PROVIDER_EXECUTION_MODE=dry_run

# v11 consensus commit certificate defaults.
MIND_CONSENSUS_COMMIT_REQUIRED=true

# v12 worker runtime / scheduler lease API defaults.
# Request bodies may override lease_seconds and limit per call.
MIND_WORKER_ID=worker-a
MIND_WORKER_PLAN_ONLY=true

# v12 provider SDK dry-run receipts.
MIND_PROVIDER_SDK_MODE=dry_run

# v12 consensus apply route uses the active consensus membership and the posted certificate.
MIND_CONSENSUS_APPLY_ENABLED=true


# v13 always-on worker daemon. The worker uses the SQLite event DB and DB-backed lease claims.
MIND_WORKER_MODE=plan
MIND_WORKER_MAX_TICKS=1
MIND_WORKER_MAX_JOBS_PER_TICK=10
MIND_WORKER_TICK_INTERVAL_MS=1000
MIND_WORKER_LEASE_SECONDS=60
MIND_WORKER_STOP_AFTER_IDLE_TICKS=0
MIND_WORKER_LOG_LEVEL=mind_worker=info

# v13 provider feature matrix. Native SDK feature flags are intentionally disabled until vendor crates are wired.
MIND_PROVIDER_FEATURE_MATRIX=conservative_default

# v13 consensus idempotency and compaction defaults.
MIND_CONSENSUS_KEEP_LATEST_COMMITTED=64
MIND_CONSENSUS_MIN_COMMITTED_BETWEEN_COMPACTIONS=128


# v14 distributed lease service boundary.
MIND_DISTRIBUTED_LEASE_SERVICE_ID=local-scheduler-lease
MIND_DISTRIBUTED_LEASE_SECONDS=60
# Set for an external lease gateway; empty uses SQLite CAS boundary.
MIND_DISTRIBUTED_LEASE_ENDPOINT=

# v14 native provider feature flags are compile-time features on mind-core/mind-connectors.
# Example: cargo run -p mind-cli --features provider-local-mirror -- native-provider-adapters

# v14 physical consensus compaction should be used only after backup verification.
MIND_CONSENSUS_PHYSICAL_COMPACTION_REQUIRE_BACKUP=true

# v15 domain executor / lease / provider / retention controls
MIND_LEASE_GATEWAY_URL=http://127.0.0.1:8088
MIND_DOMAIN_JOB_EXECUTION=plan
MIND_CONSENSUS_RETENTION_DELETE_APPLY_REPORTS=false
MIND_CONSENSUS_RETENTION_KEEP_LATEST_APPLY_REPORTS=128
MIND_NATIVE_PROVIDER_ALLOW_DRY_RUN=false

# v16 live execution boundaries
MIND_LIVE_JOB_EXECUTION=plan
MIND_LEASE_BACKEND=sqlite
DATABASE_URL=postgres://user:password@localhost:5432/mind
ETCD_ENDPOINTS=http://127.0.0.1:2379
MIND_PROVIDER_SDK_POLICY=dry_run_allowed
MIND_RETENTION_MIN_APPROVALS=2

# v19 readiness promotion controls
MIND_STAGING_CHAOS_NAMESPACE=nested-mind-staging
MIND_STAGING_CHAOS_REQUIRE_APPROVAL=true
MIND_CI_REQUIRE_STAGING_CHAOS=false
MIND_WAIVER_MIN_APPROVALS=2
MIND_WAIVER_MIN_TEAMS=2
MIND_IMPLEMENTATION_EVIDENCE_REPOSITORY=mullusi/nested-mind-platform

# v20 GitHub readiness evidence connector
MIND_GITHUB_TOKEN=
MIND_GITHUB_API_BASE=https://api.github.com
MIND_GITHUB_REPOSITORY=mullusi/nested-mind-platform
MIND_BRANCH_PROTECTION_BRANCH=main

# v21 GitHub/Kubernetes action layer
MIND_GITHUB_APP_SLUG=nested-mind-readiness
MIND_GITHUB_BRANCH_PROTECTION_DRY_RUN=true
MIND_KUBERNETES_STAGING_NAMESPACE=nested-mind-staging
MIND_KUBERNETES_CHAOS_SERVICE_ACCOUNT=nested-mind-chaos-runner
MIND_WAIVER_ESCALATION_AFTER_HOURS=24

# v22 GitHub App/action execution boundary
MIND_GITHUB_APP_ID=
MIND_GITHUB_APP_INSTALLATION_ID=
MIND_GITHUB_APP_PRIVATE_KEY_PATH=
MIND_GITHUB_APP_PRIVATE_KEY_FINGERPRINT=
MIND_GITHUB_API_BASE=https://api.github.com

# v22 Kubernetes dry-run execution boundary
MIND_KUBERNETES_CONTEXT=staging
MIND_KUBERNETES_FIELD_MANAGER=nested-mind-platform
MIND_KUBERNETES_ALLOW_LIVE_CHAOS=false

# v22 waiver notification boundary
MIND_WAIVER_NOTIFICATION_CHANNEL=manual
MIND_WAIVER_NOTIFICATION_WEBHOOK_URL=


# v23 secret/action evidence layer
MIND_SECRET_BACKEND=external_gateway
MIND_GITHUB_APP_PRIVATE_KEY_SECRET_REF=github-app/private-key
MIND_CONNECTOR_WORKER_ID=connector-worker-a
MIND_KUBERNETES_AUDIT_REQUIRED=true
MIND_WAIVER_NOTIFICATION_ADAPTER=manual

# v24 live worker connector evidence
MIND_SECRET_CONNECTOR_WORKER_MODE=plan
MIND_GITHUB_TOKEN_EXCHANGE_WORKER_MODE=plan
MIND_KUBERNETES_AUDIT_LOG_SOURCE=file://var/log/kubernetes/audit.log
MIND_NOTIFICATION_DELIVERY_MODE=plan

# v25 connector orchestration
MIND_CONNECTOR_WORKER_ID=connector-worker-a
MIND_CONNECTOR_REQUIRE_SECRET_EVIDENCE=true
MIND_CONNECTOR_REQUIRE_GITHUB_TOKEN_EVIDENCE=true
MIND_CONNECTOR_REQUIRE_KUBERNETES_AUDIT_EVIDENCE=true
MIND_CONNECTOR_REQUIRE_NOTIFICATION_EVIDENCE=true
MIND_KUBERNETES_AUDIT_SOURCE=external_gateway
MIND_NOTIFICATION_PROVIDER=generic_webhook
