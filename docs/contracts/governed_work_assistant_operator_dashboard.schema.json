{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:governed-work-assistant-operator-dashboard:1",
  "title": "Governed Work Assistant Operator Dashboard Projection",
  "description": "Read-only, fixture-backed operator dashboard projection for Governed Work Assistant Demo v0.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "dashboard_id",
    "product_name",
    "legacy_internal_pilot_id",
    "stage",
    "read_only",
    "fixture_backed",
    "governed",
    "source_refs",
    "panels",
    "effect_boundary",
    "blocked_claims",
    "next_safe_steps"
  ],
  "properties": {
    "dashboard_id": {"const": "governed_work_assistant_demo_operator_dashboard_v0"},
    "product_name": {"const": "Governed Work Assistant Demo v0"},
    "legacy_internal_pilot_id": {"const": "governed_team_assistant_pilot_v0"},
    "stage": {"const": "no_effect_operator_projection"},
    "read_only": {"const": true},
    "fixture_backed": {"const": true},
    "governed": {"const": true},
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "panels": {
      "type": "array",
      "minItems": 8,
      "items": {"$ref": "#/$defs/panel"}
    },
    "effect_boundary": {"$ref": "#/$defs/effect_boundary"},
    "blocked_claims": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "next_safe_steps": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    }
  },
  "$defs": {
    "panel": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "panel_id",
        "label",
        "source_ref",
        "visible",
        "read_only",
        "effect_allowed"
      ],
      "properties": {
        "panel_id": {"type": "string", "minLength": 1},
        "label": {"type": "string", "minLength": 1},
        "source_ref": {"type": "string", "minLength": 1},
        "route_ref": {"type": "string", "minLength": 1},
        "visible": {"const": true},
        "read_only": {"const": true},
        "effect_allowed": {"const": false}
      }
    },
    "effect_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "live_connector_execution_allowed",
        "mailbox_read_allowed",
        "mailbox_mutation_allowed",
        "external_send_allowed",
        "calendar_write_allowed",
        "repository_write_allowed",
        "worker_dispatch_allowed",
        "live_receipt_append_allowed",
        "production_readiness_claim_allowed",
        "customer_readiness_claim_allowed",
        "autonomous_execution_authority_allowed"
      ],
      "properties": {
        "live_connector_execution_allowed": {"const": false},
        "mailbox_read_allowed": {"const": false},
        "mailbox_mutation_allowed": {"const": false},
        "external_send_allowed": {"const": false},
        "calendar_write_allowed": {"const": false},
        "repository_write_allowed": {"const": false},
        "worker_dispatch_allowed": {"const": false},
        "live_receipt_append_allowed": {"const": false},
        "production_readiness_claim_allowed": {"const": false},
        "customer_readiness_claim_allowed": {"const": false},
        "autonomous_execution_authority_allowed": {"const": false}
      }
    }
  }
}
