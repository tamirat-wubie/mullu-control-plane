{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:gci-rejected-path-receipt:1",
  "title": "GCI Rejected Path Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receipt_id",
    "capability",
    "actor_id",
    "tenant_id",
    "status",
    "reasons",
    "ledger_event_id",
    "ledger_event_hash",
    "occurred_at",
    "metadata"
  ],
  "properties": {
    "receipt_id": {
      "type": "string",
      "minLength": 1
    },
    "capability": {
      "type": "string",
      "minLength": 1
    },
    "actor_id": {
      "type": "string",
      "minLength": 1
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "const": "phi_gov_blocked"
    },
    "reasons": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "ledger_event_id": {
      "type": "string",
      "minLength": 1
    },
    "ledger_event_hash": {
      "type": "string",
      "minLength": 1
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": {
      "type": "object"
    }
  }
}
