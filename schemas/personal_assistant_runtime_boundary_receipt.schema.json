{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:personal-assistant-runtime-boundary-receipt:1",
  "title": "Mullu Personal Assistant Runtime Boundary Receipt",
  "description": "No-effect receipt proving Personal Assistant runtime modules remain projection-only, connector-execution-free, secretless, and non-mutating in Foundation Mode.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "receipt_id",
    "generated_at",
    "proof_state",
    "solver_outcome",
    "governed",
    "receipt_is_not_execution_authority",
    "receipt_is_not_terminal_closure",
    "source_refs",
    "runtime_boundary_summary",
    "module_records",
    "capability_runtime_records",
    "effect_boundary",
    "lineage"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "personal_assistant.runtime_boundary_receipt.v1" },
    "receipt_id": { "type": "string", "pattern": "^personal-assistant-runtime-boundary-[0-9a-f]{16}$" },
    "generated_at": { "type": "string", "format": "date-time" },
    "proof_state": { "type": "string", "enum": ["Pass", "Fail"] },
    "solver_outcome": { "type": "string", "enum": ["SolvedVerified", "AwaitingEvidence"] },
    "governed": { "type": "boolean", "const": true },
    "receipt_is_not_execution_authority": { "type": "boolean", "const": true },
    "receipt_is_not_terminal_closure": { "type": "boolean", "const": true },
    "source_refs": {
      "type": "array",
      "minItems": 3,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/source_ref" }
    },
    "runtime_boundary_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime_boundary_closed",
        "policy_matrix_closed",
        "required_module_count",
        "observed_module_count",
        "capability_count",
        "required_modules_bound",
        "all_modules_have_headers",
        "all_modules_parse",
        "no_forbidden_imports",
        "no_forbidden_calls",
        "no_runtime_authority_markers",
        "capability_pack_fixture_only",
        "capability_pack_secretless",
        "capability_pack_networkless",
        "capability_pack_non_mutating",
        "no_effect_boundary_verified",
        "production_ready",
        "customer_ready",
        "next_allowed_action"
      ],
      "properties": {
        "runtime_boundary_closed": { "type": "boolean" },
        "policy_matrix_closed": { "type": "boolean" },
        "required_module_count": { "type": "integer", "minimum": 1 },
        "observed_module_count": { "type": "integer", "minimum": 1 },
        "capability_count": { "type": "integer", "minimum": 1 },
        "required_modules_bound": { "type": "boolean" },
        "all_modules_have_headers": { "type": "boolean" },
        "all_modules_parse": { "type": "boolean" },
        "no_forbidden_imports": { "type": "boolean" },
        "no_forbidden_calls": { "type": "boolean" },
        "no_runtime_authority_markers": { "type": "boolean" },
        "capability_pack_fixture_only": { "type": "boolean" },
        "capability_pack_secretless": { "type": "boolean" },
        "capability_pack_networkless": { "type": "boolean" },
        "capability_pack_non_mutating": { "type": "boolean" },
        "no_effect_boundary_verified": { "type": "boolean" },
        "production_ready": { "type": "boolean", "const": false },
        "customer_ready": { "type": "boolean", "const": false },
        "next_allowed_action": { "type": "string", "const": "continue_foundation_hardening_only" }
      }
    },
    "module_records": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/module_record" }
    },
    "capability_runtime_records": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/capability_runtime_record" }
    },
    "effect_boundary": { "$ref": "#/$defs/effect_boundary" },
    "lineage": { "$ref": "#/$defs/lineage" }
  },
  "$defs": {
    "source_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "source_ref", "source_kind", "bound"],
      "properties": {
        "source_id": { "type": "string", "minLength": 1 },
        "source_ref": { "type": "string", "minLength": 1 },
        "source_kind": {
          "type": "string",
          "enum": ["runtime_modules", "capability_pack", "policy_matrix_receipt"]
        },
        "bound": { "type": "boolean" }
      }
    },
    "module_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "module_name",
        "module_ref",
        "source_sha256",
        "parse_status",
        "import_roots",
        "public_entry_points",
        "public_entry_point_count",
        "has_governance_header",
        "forbidden_imports",
        "forbidden_import_count",
        "forbidden_calls",
        "forbidden_call_count",
        "runtime_authority_markers",
        "runtime_authority_marker_count",
        "module_boundary_closed"
      ],
      "properties": {
        "module_name": { "type": "string", "minLength": 1 },
        "module_ref": { "type": "string", "minLength": 1 },
        "source_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "parse_status": { "type": "string", "enum": ["parsed", "syntax_error"] },
        "import_roots": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "public_entry_points": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "public_entry_point_count": { "type": "integer", "minimum": 0 },
        "has_governance_header": { "type": "boolean" },
        "forbidden_imports": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "forbidden_import_count": { "type": "integer", "minimum": 0 },
        "forbidden_calls": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "forbidden_call_count": { "type": "integer", "minimum": 0 },
        "runtime_authority_markers": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "runtime_authority_marker_count": { "type": "integer", "minimum": 0 },
        "module_boundary_closed": { "type": "boolean" }
      }
    },
    "capability_runtime_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "capability_id",
        "certification_status",
        "fixture_only",
        "production_ready",
        "secret_scope",
        "network_allowlist_empty",
        "world_mutating",
        "receipt_required",
        "verification_required",
        "runtime_boundary_closed"
      ],
      "properties": {
        "capability_id": { "type": "string", "minLength": 1 },
        "certification_status": { "type": "string", "minLength": 1 },
        "fixture_only": { "type": "boolean" },
        "production_ready": { "type": "boolean" },
        "secret_scope": { "type": "string" },
        "network_allowlist_empty": { "type": "boolean" },
        "world_mutating": { "type": "boolean" },
        "receipt_required": { "type": "boolean" },
        "verification_required": { "type": "boolean" },
        "runtime_boundary_closed": { "type": "boolean" }
      }
    },
    "effect_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime_execution_authority_granted",
        "live_connector_execution_allowed",
        "connector_mutation_allowed",
        "external_effect_allowed",
        "system_of_record_write_allowed",
        "memory_write_allowed",
        "deployment_mutation_allowed",
        "money_legal_public_allowed",
        "production_ready_claim_allowed",
        "customer_ready_claim_allowed",
        "live_nested_mind_activation_allowed"
      ],
      "properties": {
        "runtime_execution_authority_granted": { "type": "boolean", "const": false },
        "live_connector_execution_allowed": { "type": "boolean", "const": false },
        "connector_mutation_allowed": { "type": "boolean", "const": false },
        "external_effect_allowed": { "type": "boolean", "const": false },
        "system_of_record_write_allowed": { "type": "boolean", "const": false },
        "memory_write_allowed": { "type": "boolean", "const": false },
        "deployment_mutation_allowed": { "type": "boolean", "const": false },
        "money_legal_public_allowed": { "type": "boolean", "const": false },
        "production_ready_claim_allowed": { "type": "boolean", "const": false },
        "customer_ready_claim_allowed": { "type": "boolean", "const": false },
        "live_nested_mind_activation_allowed": { "type": "boolean", "const": false }
      }
    },
    "lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["accepted_deltas", "rejected_deltas"],
      "properties": {
        "accepted_deltas": {
          "type": "array",
          "items": { "$ref": "#/$defs/lineage_delta" }
        },
        "rejected_deltas": {
          "type": "array",
          "items": { "$ref": "#/$defs/lineage_delta" }
        }
      }
    },
    "lineage_delta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["delta_id", "reason", "logged_in_lineage"],
      "properties": {
        "delta_id": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 },
        "logged_in_lineage": { "type": "boolean" }
      }
    }
  }
}
