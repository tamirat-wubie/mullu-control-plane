{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:agentic-service-harness-task-creation-admission-preflight:1",
  "title": "Agentic Service Harness Task Creation Admission Preflight",
  "description": "Read-only admission preflight for task creation in the Mullusi Agentic Service Harness. This contract records prerequisite evidence and keeps the task creation route, runtime writes, adapter execution, receipt append, branch workspace creation, dashboard UI, secrets, and terminal closure denied.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "report_id",
    "schema_version",
    "generated_at",
    "solver_outcome",
    "scope",
    "source_contract_refs",
    "admission_request",
    "prerequisite_evidence",
    "admission_decision",
    "authority_denials",
    "validators",
    "next_action",
    "report_is_not_terminal_closure",
    "terminal_closure_required"
  ],
  "properties": {
    "report_id": { "type": "string", "const": "agentic_service_harness_task_creation_admission_preflight" },
    "schema_version": { "type": "integer", "const": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "solver_outcome": { "type": "string", "const": "AwaitingEvidence" },
    "scope": { "$ref": "#/$defs/scope" },
    "source_contract_refs": {
      "type": "array",
      "minItems": 8,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/ref" }
    },
    "admission_request": { "$ref": "#/$defs/admission_request" },
    "prerequisite_evidence": { "$ref": "#/$defs/prerequisite_evidence" },
    "admission_decision": { "$ref": "#/$defs/admission_decision" },
    "authority_denials": { "$ref": "#/$defs/authority_denials" },
    "validators": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/validator_ref" }
    },
    "next_action": { "type": "string", "minLength": 1 },
    "report_is_not_terminal_closure": { "type": "boolean", "const": true },
    "terminal_closure_required": { "type": "boolean", "const": true }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/#$-]*$"
    },
    "ref_list": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/ref" }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tenant_id",
        "organization_id",
        "project_id",
        "repository_connection_id",
        "task_creation_preflight_id",
        "read_only",
        "preflight_only",
        "task_creation_route_admitted",
        "dashboard_ui_admitted",
        "runtime_state_write_enabled",
        "receipt_store_append_enabled",
        "adapter_execution_enabled",
        "branch_workspace_creation_enabled",
        "secret_values_serialized",
        "terminal_closure_granted"
      ],
      "properties": {
        "tenant_id": { "$ref": "#/$defs/identifier" },
        "organization_id": { "$ref": "#/$defs/identifier" },
        "project_id": { "$ref": "#/$defs/identifier" },
        "repository_connection_id": { "$ref": "#/$defs/identifier" },
        "task_creation_preflight_id": { "$ref": "#/$defs/identifier" },
        "read_only": { "type": "boolean", "const": true },
        "preflight_only": { "type": "boolean", "const": true },
        "task_creation_route_admitted": { "type": "boolean", "const": false },
        "dashboard_ui_admitted": { "type": "boolean", "const": false },
        "runtime_state_write_enabled": { "type": "boolean", "const": false },
        "receipt_store_append_enabled": { "type": "boolean", "const": false },
        "adapter_execution_enabled": { "type": "boolean", "const": false },
        "branch_workspace_creation_enabled": { "type": "boolean", "const": false },
        "secret_values_serialized": { "type": "boolean", "const": false },
        "terminal_closure_granted": { "type": "boolean", "const": false }
      }
    },
    "admission_request": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "request_ref",
        "source_task_ref",
        "requested_action_class",
        "requested_route_ref",
        "project_id",
        "repository_connection_id",
        "requested_mode",
        "requested_outcome",
        "risk_level",
        "approval_required_for_effects",
        "read_only"
      ],
      "properties": {
        "request_ref": { "$ref": "#/$defs/ref" },
        "source_task_ref": { "$ref": "#/$defs/ref" },
        "requested_action_class": { "type": "string", "const": "task_create_preflight" },
        "requested_route_ref": { "$ref": "#/$defs/ref" },
        "project_id": { "$ref": "#/$defs/identifier" },
        "repository_connection_id": { "$ref": "#/$defs/identifier" },
        "requested_mode": { "type": "string", "const": "read_only_preflight" },
        "requested_outcome": { "type": "string", "const": "create_agent_task_record" },
        "risk_level": { "type": "string", "enum": ["low", "medium", "high"] },
        "approval_required_for_effects": { "type": "boolean", "const": true },
        "read_only": { "type": "boolean", "const": true }
      }
    },
    "prerequisite_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "github_repo_task_intake_closed",
        "dashboard_data_contract_closed",
        "receipt_evidence_read_models_closed",
        "loopstatus_projection_closed",
        "approval_collected",
        "uao_admission_verified",
        "required_evidence_refs",
        "missing_evidence_refs"
      ],
      "properties": {
        "github_repo_task_intake_closed": { "type": "boolean", "const": true },
        "dashboard_data_contract_closed": { "type": "boolean", "const": true },
        "receipt_evidence_read_models_closed": { "type": "boolean", "const": true },
        "loopstatus_projection_closed": { "type": "boolean", "const": true },
        "approval_collected": { "type": "boolean", "const": false },
        "uao_admission_verified": { "type": "boolean", "const": false },
        "required_evidence_refs": { "$ref": "#/$defs/ref_list" },
        "missing_evidence_refs": { "$ref": "#/$defs/ref_list" }
      }
    },
    "admission_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision",
        "solver_outcome",
        "proof_state",
        "task_scope_valid",
        "repository_connection_valid",
        "task_creation_route_admitted",
        "runtime_state_write_admitted",
        "task_record_persisted",
        "adapter_execution_admitted",
        "branch_workspace_creation_admitted",
        "receipt_emission_admitted",
        "terminal_closure_allowed",
        "next_required_evidence_refs",
        "blocked_reason_refs"
      ],
      "properties": {
        "decision": { "type": "string", "const": "TASK_CREATION_ROUTE_BLOCKED_AWAITING_EVIDENCE" },
        "solver_outcome": { "type": "string", "const": "AwaitingEvidence" },
        "proof_state": { "type": "string", "const": "Unknown" },
        "task_scope_valid": { "type": "boolean", "const": true },
        "repository_connection_valid": { "type": "boolean", "const": true },
        "task_creation_route_admitted": { "type": "boolean", "const": false },
        "runtime_state_write_admitted": { "type": "boolean", "const": false },
        "task_record_persisted": { "type": "boolean", "const": false },
        "adapter_execution_admitted": { "type": "boolean", "const": false },
        "branch_workspace_creation_admitted": { "type": "boolean", "const": false },
        "receipt_emission_admitted": { "type": "boolean", "const": false },
        "terminal_closure_allowed": { "type": "boolean", "const": false },
        "next_required_evidence_refs": { "$ref": "#/$defs/ref_list" },
        "blocked_reason_refs": { "$ref": "#/$defs/ref_list" }
      }
    },
    "authority_denials": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_creation_route_enabled",
        "runtime_state_write_enabled",
        "task_record_persistence_enabled",
        "live_adapter_execution_enabled",
        "branch_workspace_creation_enabled",
        "branch_write_enabled",
        "pull_request_creation_enabled",
        "repository_write_enabled",
        "receipt_store_append_enabled",
        "mutation_route_enabled",
        "dashboard_ui_enabled",
        "deployment_enabled",
        "dns_mutation_enabled",
        "secret_mutation_enabled",
        "destructive_operation_enabled",
        "terminal_closure",
        "default_high_risk_authority"
      ],
      "properties": {
        "task_creation_route_enabled": { "type": "boolean", "const": false },
        "runtime_state_write_enabled": { "type": "boolean", "const": false },
        "task_record_persistence_enabled": { "type": "boolean", "const": false },
        "live_adapter_execution_enabled": { "type": "boolean", "const": false },
        "branch_workspace_creation_enabled": { "type": "boolean", "const": false },
        "branch_write_enabled": { "type": "boolean", "const": false },
        "pull_request_creation_enabled": { "type": "boolean", "const": false },
        "repository_write_enabled": { "type": "boolean", "const": false },
        "receipt_store_append_enabled": { "type": "boolean", "const": false },
        "mutation_route_enabled": { "type": "boolean", "const": false },
        "dashboard_ui_enabled": { "type": "boolean", "const": false },
        "deployment_enabled": { "type": "boolean", "const": false },
        "dns_mutation_enabled": { "type": "boolean", "const": false },
        "secret_mutation_enabled": { "type": "boolean", "const": false },
        "destructive_operation_enabled": { "type": "boolean", "const": false },
        "terminal_closure": { "type": "boolean", "const": false },
        "default_high_risk_authority": { "type": "boolean", "const": false }
      }
    },
    "validator_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["validator_id", "command", "required_for_closure"],
      "properties": {
        "validator_id": { "$ref": "#/$defs/identifier" },
        "command": { "type": "string", "minLength": 1 },
        "required_for_closure": { "type": "boolean", "const": true }
      }
    }
  }
}
