{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:agentic-control:control-action-output:1",
  "title": "Agentic Control Action Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "capability_id",
    "request_id",
    "outcome",
    "decision_ref",
    "proof_state",
    "evidence_refs",
    "blocked_actions",
    "next_actions",
    "metadata"
  ],
  "properties": {
    "capability_id": {
      "type": "string",
      "enum": [
        "agentic_control.mission.define",
        "agentic_control.priority.rank",
        "agentic_control.governance_gate.evaluate",
        "agentic_control.verification.plan",
        "agentic_control.resource_budget.bound",
        "agentic_control.math_algorithm.analyze",
        "agentic_control.security_threat_model.build",
        "agentic_control.swarm.coordinate",
        "agentic_control.product_management.plan",
        "agentic_control.interrogation.plan",
        "agentic_control.self_audit.refine",
        "agentic_control.evidence.append"
      ]
    },
    "request_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "outcome": {
      "type": "string",
      "enum": [
        "SolvedVerified",
        "SolvedUnverified",
        "AwaitingEvidence",
        "SafeHalt",
        "GovernanceBlocked",
        "BudgetExhausted",
        "ImpossibleProved",
        "ModelInvalidated"
      ]
    },
    "decision_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]*$"
    },
    "proof_state": {
      "type": "string",
      "enum": ["Pass", "Fail", "Unknown", "BudgetUnknown"]
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 256
      }
    },
    "blocked_actions": {
      "type": "array",
      "maxItems": 32,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 256
      }
    },
    "next_actions": {
      "type": "array",
      "maxItems": 32,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 256
      }
    },
    "metadata": {
      "type": "object",
      "maxProperties": 32,
      "propertyNames": {
        "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
      },
      "additionalProperties": true
    }
  }
}
