{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:component-route-family-promotion-authority-decision-report:1",
  "title": "Mullu Component Route-Family Promotion Authority Decision Report",
  "description": "Read-only Component Harness report that consumes gate-satisfaction evidence and records denial-only promotion authority decisions without granting live action.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "authority_decision_report_id",
    "mode",
    "governed",
    "target_surface_id",
    "target_component_id",
    "decision",
    "preflight_outcome",
    "outcome",
    "authority_decision_state",
    "promotion_decision",
    "all_record_evidence_gates_satisfied",
    "all_action_gates_satisfied",
    "all_authority_decisions_issued",
    "all_authority_decisions_denied",
    "all_authority_grants_blocked",
    "authority_fuse_enforced",
    "all_required_followup_decisions_pending",
    "authority_decision_is_not_authority_grant",
    "authority_decision_is_not_promotion_approval",
    "authority_decision_is_not_route_binding",
    "authority_decision_is_not_lifecycle_transition",
    "foundation_fixture_decision_is_not_live_operator_evidence",
    "separate_route_binding_decision_required",
    "separate_lifecycle_transition_required",
    "separate_authority_upgrade_witness_required",
    "separate_product_ownership_decision_required",
    "terminal_closure_required",
    "live_execution_enabled",
    "live_connector_send_enabled",
    "can_execute",
    "can_mutate",
    "can_call_connector",
    "can_claim_terminal_closure",
    "mutates_router_inventory",
    "ready_for_promotion",
    "source_refs",
    "summary",
    "authority_decisions",
    "authority_decision_refs",
    "satisfied_gate_evaluation_refs",
    "accepted_record_refs",
    "authority_fuse_refs",
    "authority_fuse_blocking_refs",
    "authority_grant_refs",
    "promotion_approval_refs",
    "route_binding_decision_refs",
    "lifecycle_transition_refs",
    "terminal_closure_refs",
    "accepted_evidence_refs",
    "rejected_evidence_refs",
    "approval_evidence_required",
    "required_followup_decisions",
    "missing_authority_witnesses",
    "operator_submission_channels",
    "blocked_actions",
    "expected_receipts",
    "validators",
    "next_action"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "authority_decision_report_id": { "$ref": "#/$defs/identifier" },
    "mode": { "type": "string", "enum": ["foundation", "read_only"] },
    "governed": { "type": "boolean", "const": true },
    "target_surface_id": { "$ref": "#/$defs/identifier" },
    "target_component_id": { "$ref": "#/$defs/identifier" },
    "decision": { "type": "string", "const": "blocked" },
    "preflight_outcome": { "type": "string", "const": "GovernanceBlocked" },
    "outcome": { "type": "string", "const": "AwaitingEvidence" },
    "authority_decision_state": {
      "type": "string",
      "const": "denied_pending_governed_witnesses"
    },
    "promotion_decision": {
      "type": "string",
      "const": "blocked_authority_not_granted"
    },
    "all_record_evidence_gates_satisfied": { "type": "boolean", "const": true },
    "all_action_gates_satisfied": { "type": "boolean", "const": false },
    "all_authority_decisions_issued": { "type": "boolean", "const": true },
    "all_authority_decisions_denied": { "type": "boolean", "const": true },
    "all_authority_grants_blocked": { "type": "boolean", "const": true },
    "authority_fuse_enforced": { "type": "boolean", "const": true },
    "all_required_followup_decisions_pending": { "type": "boolean", "const": true },
    "authority_decision_is_not_authority_grant": { "type": "boolean", "const": true },
    "authority_decision_is_not_promotion_approval": { "type": "boolean", "const": true },
    "authority_decision_is_not_route_binding": { "type": "boolean", "const": true },
    "authority_decision_is_not_lifecycle_transition": { "type": "boolean", "const": true },
    "foundation_fixture_decision_is_not_live_operator_evidence": { "type": "boolean", "const": true },
    "separate_route_binding_decision_required": { "type": "boolean", "const": true },
    "separate_lifecycle_transition_required": { "type": "boolean", "const": true },
    "separate_authority_upgrade_witness_required": { "type": "boolean", "const": true },
    "separate_product_ownership_decision_required": { "type": "boolean", "const": true },
    "terminal_closure_required": { "type": "boolean", "const": true },
    "live_execution_enabled": { "type": "boolean", "const": false },
    "live_connector_send_enabled": { "type": "boolean", "const": false },
    "can_execute": { "type": "boolean", "const": false },
    "can_mutate": { "type": "boolean", "const": false },
    "can_call_connector": { "type": "boolean", "const": false },
    "can_claim_terminal_closure": { "type": "boolean", "const": false },
    "mutates_router_inventory": { "type": "boolean", "const": false },
    "ready_for_promotion": { "type": "boolean", "const": false },
    "source_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gate_satisfaction_evaluator",
        "operator_submitted_evidence_records",
        "promotion_preflight",
        "component_authority_fuse",
        "proof_matrix"
      ],
      "properties": {
        "gate_satisfaction_evaluator": { "$ref": "#/$defs/repo_path" },
        "operator_submitted_evidence_records": { "$ref": "#/$defs/repo_path" },
        "promotion_preflight": { "$ref": "#/$defs/repo_path" },
        "component_authority_fuse": { "$ref": "#/$defs/repo_path" },
        "proof_matrix": { "$ref": "#/$defs/repo_path" }
      }
    },
    "summary": { "$ref": "#/$defs/summary" },
    "authority_decisions": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/authority_decision" }
    },
    "authority_decision_refs": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/identifier" }
    },
    "satisfied_gate_evaluation_refs": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/identifier" }
    },
    "accepted_record_refs": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/identifier" }
    },
    "authority_fuse_refs": { "$ref": "#/$defs/single_ref" },
    "authority_fuse_blocking_refs": { "$ref": "#/$defs/single_ref" },
    "authority_grant_refs": { "$ref": "#/$defs/empty_refs" },
    "promotion_approval_refs": { "$ref": "#/$defs/empty_refs" },
    "route_binding_decision_refs": { "$ref": "#/$defs/empty_refs" },
    "lifecycle_transition_refs": { "$ref": "#/$defs/empty_refs" },
    "terminal_closure_refs": { "$ref": "#/$defs/empty_refs" },
    "accepted_evidence_refs": { "$ref": "#/$defs/empty_refs" },
    "rejected_evidence_refs": { "$ref": "#/$defs/empty_refs" },
    "approval_evidence_required": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/identifier_or_ref" }
    },
    "required_followup_decisions": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/identifier" }
    },
    "missing_authority_witnesses": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/identifier" }
    },
    "operator_submission_channels": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/identifier_or_ref" }
    },
    "blocked_actions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/identifier" }
    },
    "expected_receipts": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/identifier" }
    },
    "validators": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/identifier" }
    },
    "next_action": { "type": "string", "minLength": 1, "maxLength": 420 }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "identifier_or_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/#{}@+ -]*$"
    },
    "repo_path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9._~:/{}@+ -]+$"
    },
    "empty_refs": {
      "type": "array",
      "maxItems": 0,
      "items": { "$ref": "#/$defs/identifier_or_ref" }
    },
    "single_ref": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/identifier" }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "authority_decision_count",
        "authority_denial_count",
        "authority_grant_count",
        "record_evidence_satisfied_gate_count",
        "action_satisfied_gate_count",
        "blocking_decision_count",
        "route_binding_authorization_count",
        "lifecycle_transition_authorization_count",
        "connector_authorization_count",
        "terminal_closure_authorization_count",
        "promotion_approval_count",
        "accepted_evidence_count",
        "rejected_evidence_count",
        "accepted_record_count",
        "authority_fuse_blocking_count",
        "approval_artifact_requirement_count",
        "required_followup_decision_count"
      ],
      "properties": {
        "authority_decision_count": { "type": "integer", "const": 4 },
        "authority_denial_count": { "type": "integer", "const": 4 },
        "authority_grant_count": { "type": "integer", "const": 0 },
        "record_evidence_satisfied_gate_count": { "type": "integer", "const": 4 },
        "action_satisfied_gate_count": { "type": "integer", "const": 0 },
        "blocking_decision_count": { "type": "integer", "const": 4 },
        "route_binding_authorization_count": { "type": "integer", "const": 0 },
        "lifecycle_transition_authorization_count": { "type": "integer", "const": 0 },
        "connector_authorization_count": { "type": "integer", "const": 0 },
        "terminal_closure_authorization_count": { "type": "integer", "const": 0 },
        "promotion_approval_count": { "type": "integer", "const": 0 },
        "accepted_evidence_count": { "type": "integer", "const": 0 },
        "rejected_evidence_count": { "type": "integer", "const": 0 },
        "accepted_record_count": { "type": "integer", "const": 4 },
        "authority_fuse_blocking_count": { "type": "integer", "const": 1 },
        "approval_artifact_requirement_count": { "type": "integer", "minimum": 1 },
        "required_followup_decision_count": { "type": "integer", "const": 5 }
      }
    },
    "authority_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "authority_decision_id",
        "source_gate_evaluation_id",
        "source_operator_submitted_record_id",
        "gate_id",
        "record_kind",
        "evidence_key",
        "decision_state",
        "decision_basis",
        "proof_state",
        "record_evidence_satisfied",
        "action_requirement_satisfied",
        "blocks_promotion",
        "authority_fuse_blocks_promotion",
        "requires_external_authority_upgrade_evidence",
        "authority_granted",
        "route_binding_authorized",
        "lifecycle_transition_authorized",
        "connector_authority_authorized",
        "terminal_closure_authorized",
        "can_execute",
        "can_mutate",
        "can_call_connector",
        "can_claim_terminal_closure",
        "mutates_router_inventory",
        "requires_route_binding_decision",
        "requires_lifecycle_transition",
        "requires_authority_upgrade_witness",
        "requires_product_ownership_decision",
        "requires_terminal_closure",
        "decision_is_not_authority_grant",
        "decision_is_not_promotion_approval",
        "decision_is_not_route_binding",
        "decision_is_not_lifecycle_transition",
        "foundation_fixture_decision_is_not_live_operator_evidence",
        "satisfied_gate_evaluation_refs",
        "accepted_record_refs",
        "authority_fuse_refs",
        "authority_fuse_blocking_refs",
        "authority_grant_refs",
        "promotion_approval_refs",
        "accepted_evidence_refs",
        "rejected_evidence_refs",
        "missing_authority_witnesses",
        "decision_reason"
      ],
      "properties": {
        "authority_decision_id": { "$ref": "#/$defs/identifier" },
        "source_gate_evaluation_id": { "$ref": "#/$defs/identifier" },
        "source_operator_submitted_record_id": { "$ref": "#/$defs/identifier" },
        "gate_id": {
          "type": "string",
          "enum": [
            "route_binding_gate",
            "lifecycle_gate",
            "authority_upgrade_gate",
            "product_specific_boundary_gate"
          ]
        },
        "record_kind": {
          "type": "string",
          "enum": [
            "route_binding",
            "lifecycle_transition",
            "authority_upgrade",
            "product_specific_ownership"
          ]
        },
        "evidence_key": { "$ref": "#/$defs/identifier" },
        "decision_state": { "type": "string", "const": "denied" },
        "decision_basis": { "type": "string", "const": "record_evidence_only" },
        "proof_state": { "type": "string", "const": "Pass" },
        "record_evidence_satisfied": { "type": "boolean", "const": true },
        "action_requirement_satisfied": { "type": "boolean", "const": false },
        "blocks_promotion": { "type": "boolean", "const": true },
        "authority_fuse_blocks_promotion": { "type": "boolean", "const": true },
        "requires_external_authority_upgrade_evidence": { "type": "boolean", "const": true },
        "authority_granted": { "type": "boolean", "const": false },
        "route_binding_authorized": { "type": "boolean", "const": false },
        "lifecycle_transition_authorized": { "type": "boolean", "const": false },
        "connector_authority_authorized": { "type": "boolean", "const": false },
        "terminal_closure_authorized": { "type": "boolean", "const": false },
        "can_execute": { "type": "boolean", "const": false },
        "can_mutate": { "type": "boolean", "const": false },
        "can_call_connector": { "type": "boolean", "const": false },
        "can_claim_terminal_closure": { "type": "boolean", "const": false },
        "mutates_router_inventory": { "type": "boolean", "const": false },
        "requires_route_binding_decision": { "type": "boolean", "const": true },
        "requires_lifecycle_transition": { "type": "boolean", "const": true },
        "requires_authority_upgrade_witness": { "type": "boolean", "const": true },
        "requires_product_ownership_decision": { "type": "boolean", "const": true },
        "requires_terminal_closure": { "type": "boolean", "const": true },
        "decision_is_not_authority_grant": { "type": "boolean", "const": true },
        "decision_is_not_promotion_approval": { "type": "boolean", "const": true },
        "decision_is_not_route_binding": { "type": "boolean", "const": true },
        "decision_is_not_lifecycle_transition": { "type": "boolean", "const": true },
        "foundation_fixture_decision_is_not_live_operator_evidence": { "type": "boolean", "const": true },
        "satisfied_gate_evaluation_refs": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/identifier" }
        },
        "accepted_record_refs": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/identifier" }
        },
        "authority_fuse_refs": { "$ref": "#/$defs/single_ref" },
        "authority_fuse_blocking_refs": { "$ref": "#/$defs/single_ref" },
        "authority_grant_refs": { "$ref": "#/$defs/empty_refs" },
        "promotion_approval_refs": { "$ref": "#/$defs/empty_refs" },
        "accepted_evidence_refs": { "$ref": "#/$defs/empty_refs" },
        "rejected_evidence_refs": { "$ref": "#/$defs/empty_refs" },
        "missing_authority_witnesses": {
          "type": "array",
          "minItems": 5,
          "maxItems": 5,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/identifier" }
        },
        "decision_reason": { "type": "string", "minLength": 1, "maxLength": 320 }
      }
    }
  }
}
