        "blocked_reason_refs"
      ],
      "properties": {
        "source_command_preview_id": { "type": "string", "const": "github-pr-creation-command-preview-foundation" },
        "source_operator_approval_request_binding_id": {
          "type": "string",
          "const": "agentic_service_harness_github_pr_operator_approval_request_actual_non_empty_diff_binding"
        },
        "source_operator_approval_request_id": {
          "type": "string",
          "const": "agentic_service_harness_github_pr_operator_approval_request"
        },
        "approval_request_id": { "type": "string", "const": "approval-request.github-pr-admission" },
        "requested_evidence_ref": {
          "type": "string",
          "const": "approval://operator-github-pr-admission-required"
        },
        "command_preview_ref": {
          "type": "string",
          "const": "examples/agentic_service_harness_github_pr_creation_command_preview.foundation.json"
        },
        "operator_approval_request_binding_ref": {
          "type": "string",
          "const": "examples/agentic_service_harness_github_pr_operator_approval_request_actual_non_empty_diff_binding.foundation.json"
        },
        "operator_approval_request_ref": {
          "type": "string",
          "const": "examples/agentic_service_harness_github_pr_operator_approval_request.foundation.json"
        },
        "redacted_command_preview": { "type": "string", "minLength": 1 },
        "argument_vector_template": { "$ref": "#/$defs/string_list" },
        "placeholder_refs": { "$ref": "#/$defs/evidence_ref_list" },
        "approval_request_bound": { "type": "boolean", "const": true },
        "command_preview_bound": { "type": "boolean", "const": true },
        "preview_rendered": { "type": "boolean", "const": true },
        "operator_response_collected": { "type": "boolean", "const": false },
        "operator_approval_granted": { "type": "boolean", "const": false },
        "operator_approval_rejected": { "type": "boolean", "const": false },
        "command_execution_admitted": { "type": "boolean", "const": false },
        "adapter_execution_enabled": { "type": "boolean", "const": false },
        "branch_write_enabled": { "type": "boolean", "const": false },
        "pull_request_creation_enabled": { "type": "boolean", "const": false },
        "repository_write_enabled": { "type": "boolean", "const": false },
        "connector_call_enabled": { "type": "boolean", "const": false },
        "mutation_route_enabled": { "type": "boolean", "const": false },
        "receipt_store_append_enabled": { "type": "boolean", "const": false },
        "terminal_certificate_verified": { "type": "boolean", "const": false },
        "required_before_execution_refs": { "$ref": "#/$defs/evidence_ref_list" },
        "blocked_reason_refs": { "$ref": "#/$defs/evidence_ref_list" }
      }
    },
    "command_preview_execution_admission_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_command_preview_ref",
