{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:agentic-service-harness-github-pr-operator-approval-request-command-preview-binding:1",
  "title": "Agentic Service Harness GitHub PR Operator Approval Request Command Preview Binding",
  "description": "Foundation Mode witness binding that connects the GitHub pull-request operator approval request evidence to the redacted command preview. This schema records only evidence binding and does not collect approval, execute commands, create branches, open pull requests, write repositories, call connectors, admit mutation routes, append receipt stores, serialize raw content or secrets, perform destructive operations, or provide terminal closure.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "binding_id",
    "schema_version",
    "generated_at",
    "solver_outcome",
    "source_command_preview_ref",
    "source_operator_approval_request_actual_non_empty_diff_binding_ref",
    "source_operator_approval_request_ref",
    "witness_kind",
    "binding_status",
    "planning_only",
    "read_only",
    "preview_only",
    "report_is_not_terminal_closure",
    "terminal_closure",
    "scope",
    "approval_command_preview_binding",
    "command_preview_execution_admission_evidence",
    "remaining_witnesses",
    "authority_denials",
    "effect_boundary",
    "receipt_refs",
    "validators",
    "next_action"
  ],
  "properties": {
    "binding_id": {
      "type": "string",
      "const": "agentic_service_harness_github_pr_operator_approval_request_command_preview_binding"
    },
    "schema_version": { "type": "integer", "const": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "solver_outcome": { "type": "string", "const": "AwaitingEvidence" },
    "source_command_preview_ref": {
      "type": "string",
      "const": "examples/agentic_service_harness_github_pr_creation_command_preview.foundation.json"
    },
    "source_operator_approval_request_actual_non_empty_diff_binding_ref": {
      "type": "string",
      "const": "examples/agentic_service_harness_github_pr_operator_approval_request_actual_non_empty_diff_binding.foundation.json"
    },
    "source_operator_approval_request_ref": {
      "type": "string",
      "const": "examples/agentic_service_harness_github_pr_operator_approval_request.foundation.json"
    },
    "witness_kind": {
      "type": "string",
      "const": "github_pr_operator_approval_request_command_preview_binding"
    },
    "binding_status": {
      "type": "string",
      "const": "operator_approval_request_bound_to_command_preview_without_execution_authority"
    },
    "planning_only": { "type": "boolean", "const": true },
    "read_only": { "type": "boolean", "const": true },
    "preview_only": { "type": "boolean", "const": true },
    "report_is_not_terminal_closure": { "type": "boolean", "const": true },
    "terminal_closure": { "type": "boolean", "const": false },
    "scope": { "$ref": "#/$defs/scope" },
    "approval_command_preview_binding": { "$ref": "#/$defs/approval_command_preview_binding" },
    "command_preview_execution_admission_evidence": {
      "$ref": "#/$defs/command_preview_execution_admission_evidence"
    },
    "remaining_witnesses": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/remaining_witness" }
    },
    "authority_denials": { "$ref": "#/$defs/authority_denials" },
    "effect_boundary": { "$ref": "#/$defs/effect_boundary" },
    "receipt_refs": { "$ref": "#/$defs/receipt_refs" },
    "validators": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/validator_ref" }
    },
    "next_action": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "evidence_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/#$<>-]*$"
    },
    "evidence_ref_list": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/evidence_ref" }
    },
    "string_list": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tenant_id",
        "organization_id",
        "project_id",
        "repository_connection_id",
        "repository_slug",
        "task_service_id",
        "foundation_phase",
        "read_only",
        "preview_only",
        "approval_request_only",
        "execution_admitted",
        "pr_creation_enabled",
        "repository_write_enabled",
        "external_adapter_integrated",
        "receipt_store_append_enabled",
        "secret_values_serialized"
      ],
      "properties": {
        "tenant_id": { "$ref": "#/$defs/identifier" },
        "organization_id": { "$ref": "#/$defs/identifier" },
        "project_id": { "$ref": "#/$defs/identifier" },
        "repository_connection_id": { "$ref": "#/$defs/identifier" },
        "repository_slug": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$" },
        "task_service_id": { "type": "string", "const": "github-repo-task-service-read-only-foundation" },
        "foundation_phase": {
          "type": "string",
          "const": "foundation_pr_creation_command_preview_operator_approval_bound"
        },
        "read_only": { "type": "boolean", "const": true },
        "preview_only": { "type": "boolean", "const": true },
        "approval_request_only": { "type": "boolean", "const": true },
        "execution_admitted": { "type": "boolean", "const": false },
        "pr_creation_enabled": { "type": "boolean", "const": false },
        "repository_write_enabled": { "type": "boolean", "const": false },
        "external_adapter_integrated": { "type": "boolean", "const": false },
        "receipt_store_append_enabled": { "type": "boolean", "const": false },
        "secret_values_serialized": { "type": "boolean", "const": false }
      }
    },
    "approval_command_preview_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_command_preview_id",
        "source_operator_approval_request_binding_id",
        "source_operator_approval_request_id",
        "approval_request_id",
        "requested_evidence_ref",
        "command_preview_ref",
        "operator_approval_request_binding_ref",
        "operator_approval_request_ref",
        "redacted_command_preview",
        "argument_vector_template",
        "placeholder_refs",
        "approval_request_bound",
        "command_preview_bound",
        "preview_rendered",
        "operator_response_collected",
        "operator_approval_granted",
        "operator_approval_rejected",
        "command_execution_admitted",
        "adapter_execution_enabled",
        "branch_write_enabled",
        "pull_request_creation_enabled",
        "repository_write_enabled",
        "connector_call_enabled",
        "mutation_route_enabled",
        "receipt_store_append_enabled",
        "terminal_certificate_verified",
