{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:universal-symbol-receipt-store-operator-revocation-witness:1",
  "title": "Universal Symbol Receipt Store Operator Revocation Witness",
  "description": "Foundation Mode witness for a future UniversalSymbol receipt-store operator revocation boundary. This witness defines revocation evidence obligations while denying revocation binding, approval recording, approval decision recording, writer registration, write-path registration, receipt append, raw payload storage, raw secret storage, runtime dispatch, connector calls, state mutation, terminal closure, and production readiness.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "witness_id",
    "schema_version",
    "generated_at",
    "witness_scope",
    "solver_outcome",
    "foundation_mode",
    "revocation_decision",
    "revocation_witness_is_not_revocation_authority",
    "revocation_requirements",
    "authority_denials",
    "revocation_constraints",
    "rejection_policy",
    "blocked_reasons",
    "next_actions",
    "evidence_refs",
    "contract_summary"
  ],
  "properties": {
    "witness_id": { "type": "string", "const": "universal-symbol-receipt-store-operator-revocation-witness-foundation" },
    "schema_version": { "type": "integer", "const": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "witness_scope": { "type": "string", "const": "foundation-mode-universal-symbol-receipt-store-operator-revocation" },
    "solver_outcome": { "type": "string", "const": "AwaitingEvidence" },
    "foundation_mode": { "type": "boolean", "const": true },
    "revocation_decision": { "type": "string", "const": "blocked_pending_live_revocation_state_scope_and_audit_evidence" },
    "revocation_witness_is_not_revocation_authority": { "type": "boolean", "const": true },
    "revocation_requirements": {
      "type": "array",
      "minItems": 8,
      "items": { "$ref": "#/$defs/revocation_requirement" },
      "uniqueItems": true
    },
    "authority_denials": { "$ref": "#/$defs/authority_denials" },
    "revocation_constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operator_identity_witness_required",
        "approval_decision_ref_required",
        "revocation_state_required",
        "revocation_scope_required",
        "revocation_reason_required",
        "effective_at_required",
        "propagation_receipt_required",
        "audit_receipt_required"
      ],
      "properties": {
        "operator_identity_witness_required": { "type": "boolean", "const": true },
        "approval_decision_ref_required": { "type": "boolean", "const": true },
        "revocation_state_required": { "type": "boolean", "const": true },
        "revocation_scope_required": { "type": "boolean", "const": true },
        "revocation_reason_required": { "type": "boolean", "const": true },
        "effective_at_required": { "type": "boolean", "const": true },
        "propagation_receipt_required": { "type": "boolean", "const": true },
        "audit_receipt_required": { "type": "boolean", "const": true }
      }
    },
    "rejection_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "missing_operator_identity_blocks_revocation",
        "missing_approval_decision_blocks_revocation",
        "missing_revocation_state_blocks_revocation",
        "missing_revocation_scope_blocks_revocation",
        "unknown_hard_constraint_blocks_revocation",
        "failed_precondition_logs_delta_reject"
      ],
      "properties": {
        "missing_operator_identity_blocks_revocation": { "type": "boolean", "const": true },
        "missing_approval_decision_blocks_revocation": { "type": "boolean", "const": true },
        "missing_revocation_state_blocks_revocation": { "type": "boolean", "const": true },
        "missing_revocation_scope_blocks_revocation": { "type": "boolean", "const": true },
        "unknown_hard_constraint_blocks_revocation": { "type": "boolean", "const": true },
        "failed_precondition_logs_delta_reject": { "type": "boolean", "const": true }
      }
    },
    "blocked_reasons": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "string",
        "enum": [
          "operator_identity_witness_missing",
          "approval_decision_ref_missing",
          "revocation_state_missing",
          "revocation_scope_missing",
          "revocation_reason_missing",
          "effective_at_missing",
          "propagation_receipt_missing",
          "audit_receipt_missing",
          "receipt_store_revocation_binding_forbidden",
          "terminal_closure_not_allowed"
        ]
      },
      "uniqueItems": true
    },
    "next_actions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/ref" },
      "uniqueItems": true
    },
    "contract_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "revocation_requirement_count",
        "authority_denial_count",
        "revocation_constraint_count",
        "rejection_check_count",
        "blocked_reason_count",
        "evidence_ref_count"
      ],
      "properties": {
        "revocation_requirement_count": { "type": "integer", "minimum": 8 },
        "authority_denial_count": { "type": "integer", "const": 13 },
        "revocation_constraint_count": { "type": "integer", "const": 8 },
        "rejection_check_count": { "type": "integer", "const": 6 },
        "blocked_reason_count": { "type": "integer", "minimum": 8 },
        "evidence_ref_count": { "type": "integer", "minimum": 1 }
      }
    }
  },
  "$defs": {
    "ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/#-]*$"
    },
    "revocation_requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requirement_id",
        "proof_state",
        "required_evidence_ref",
        "current_decision",
        "delta_reject_ref"
      ],
      "properties": {
        "requirement_id": { "$ref": "#/$defs/ref" },
        "proof_state": { "type": "string", "enum": ["Unknown", "BudgetUnknown", "Fail"] },
        "required_evidence_ref": { "$ref": "#/$defs/ref" },
        "current_decision": { "type": "string", "const": "revocation_blocked" },
        "delta_reject_ref": { "$ref": "#/$defs/ref" }
      }
    },
    "authority_denials": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_store_revocation_bound",
        "receipt_store_approval_decision_recorded",
        "receipt_store_operator_approval_recorded",
        "receipt_store_writer_identity_registered",
        "receipt_store_writer_registered",
        "receipt_store_write_path_registered",
        "receipt_store_append_performed",
        "raw_payload_stored",
        "raw_secret_stored",
        "runtime_dispatch_performed",
        "connector_call_performed",
        "state_mutation_performed",
        "terminal_closure_allowed"
      ],
      "properties": {
        "receipt_store_revocation_bound": { "type": "boolean", "const": false },
        "receipt_store_approval_decision_recorded": { "type": "boolean", "const": false },
        "receipt_store_operator_approval_recorded": { "type": "boolean", "const": false },
        "receipt_store_writer_identity_registered": { "type": "boolean", "const": false },
        "receipt_store_writer_registered": { "type": "boolean", "const": false },
        "receipt_store_write_path_registered": { "type": "boolean", "const": false },
        "receipt_store_append_performed": { "type": "boolean", "const": false },
        "raw_payload_stored": { "type": "boolean", "const": false },
        "raw_secret_stored": { "type": "boolean", "const": false },
        "runtime_dispatch_performed": { "type": "boolean", "const": false },
        "connector_call_performed": { "type": "boolean", "const": false },
        "state_mutation_performed": { "type": "boolean", "const": false },
        "terminal_closure_allowed": { "type": "boolean", "const": false }
      }
    }
  }
}
