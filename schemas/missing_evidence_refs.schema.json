{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:missing-evidence-refs:1",
  "title": "Missing Evidence Refs",
  "description": "Read-only missing approval, evidence, rollback, replay, promotion, and live-action refs for one selected capability closure lane.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "refs_id",
    "mode",
    "refs_are_not_execution_authority",
    "live_execution_enabled",
    "selected_capability_id",
    "selected_debt_id",
    "selected_category",
    "source_refs",
    "selected_missing_refs",
    "selected_missing_ref_count",
    "missing_refs_by_category",
    "approval_refs",
    "evidence_refs",
    "rollback_refs",
    "replay_refs",
    "promotion_refs",
    "live_action_refs",
    "next_action"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "refs_id": { "$ref": "#/$defs/identifier" },
    "mode": { "type": "string", "const": "foundation" },
    "refs_are_not_execution_authority": { "type": "boolean", "const": true },
    "live_execution_enabled": { "type": "boolean", "const": false },
    "selected_capability_id": { "$ref": "#/$defs/identifier" },
    "selected_debt_id": { "$ref": "#/$defs/identifier" },
    "selected_category": { "$ref": "#/$defs/category" },
    "source_refs": { "$ref": "#/$defs/source_refs" },
    "selected_missing_refs": { "$ref": "#/$defs/string_list" },
    "selected_missing_ref_count": { "type": "integer", "minimum": 1 },
    "missing_refs_by_category": {
      "type": "object",
      "additionalProperties": false,
      "required": ["approval", "evidence", "rollback", "replay", "promotion", "live_action"],
      "properties": {
        "approval": { "$ref": "#/$defs/string_list" },
        "evidence": { "$ref": "#/$defs/string_list" },
        "rollback": { "$ref": "#/$defs/string_list" },
        "replay": { "$ref": "#/$defs/string_list" },
        "promotion": { "$ref": "#/$defs/string_list" },
        "live_action": { "$ref": "#/$defs/string_list" }
      }
    },
    "approval_refs": { "$ref": "#/$defs/string_list" },
    "evidence_refs": { "$ref": "#/$defs/string_list" },
    "rollback_refs": { "$ref": "#/$defs/string_list" },
    "replay_refs": { "$ref": "#/$defs/string_list" },
    "promotion_refs": { "$ref": "#/$defs/string_list" },
    "live_action_refs": { "$ref": "#/$defs/string_list" },
    "next_action": { "type": "string", "minLength": 1, "maxLength": 640 }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 260,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "category": {
      "type": "string",
      "enum": ["approval", "evidence", "rollback", "replay", "promotion", "live_action"]
    },
    "string_list": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 320 }
    },
    "source_refs": {
      "type": "object",
      "additionalProperties": { "type": "string", "minLength": 1, "maxLength": 320 },
      "required": [
        "debt_report_id",
        "debt_row_id",
        "selected_debt_id",
        "evidence_passport_id"
      ]
    }
  }
}
