{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:sandbox-to-live-promotion:1",
  "title": "Mullu Sandbox-to-Live Promotion Paths",
  "description": "Foundation-stage read model for moving governed capabilities through sandbox, local demo, dry-run, operator review, pilot, limited live, approved live, and production stages without granting execution authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "promotion_path_set_id",
    "mode",
    "promotion_path_set_is_not_execution_authority",
    "live_execution_enabled",
    "source_refs",
    "stage_order",
    "summary",
    "promotion_paths",
    "validators",
    "next_action"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "promotion_path_set_id": { "$ref": "#/$defs/identifier" },
    "mode": { "type": "string", "const": "foundation" },
    "promotion_path_set_is_not_execution_authority": { "type": "boolean", "const": true },
    "live_execution_enabled": { "type": "boolean", "const": false },
    "source_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "passport_set_id",
        "gate_registry_id",
        "evidence_passport_set_id"
      ],
      "properties": {
        "passport_set_id": { "$ref": "#/$defs/identifier" },
        "gate_registry_id": { "$ref": "#/$defs/identifier" },
        "evidence_passport_set_id": { "$ref": "#/$defs/identifier" }
      }
    },
    "stage_order": {
      "type": "array",
      "prefixItems": [
        { "const": "sandbox" },
        { "const": "local_demo" },
        { "const": "dry_run" },
        { "const": "operator_review" },
        { "const": "pilot" },
        { "const": "limited_live" },
        { "const": "approved_live" },
        { "const": "production" }
      ],
      "minItems": 8,
      "maxItems": 8
    },
    "summary": { "$ref": "#/$defs/summary" },
    "promotion_paths": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/promotion_path" }
    },
    "validators": {
      "type": "array",
      "minItems": 2,
      "items": { "$ref": "#/$defs/validator_ref" }
    },
    "next_action": {
      "type": "string",
      "minLength": 1,
      "maxLength": 480
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 220,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "stage_id": {
      "type": "string",
      "enum": [
        "sandbox",
        "local_demo",
        "dry_run",
        "operator_review",
        "pilot",
        "limited_live",
        "approved_live",
        "production"
      ]
    },
    "stage_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sandbox",
        "local_demo",
        "dry_run",
        "operator_review",
        "pilot",
        "limited_live",
        "approved_live",
        "production"
      ],
      "properties": {
        "sandbox": { "type": "integer", "minimum": 0 },
        "local_demo": { "type": "integer", "minimum": 0 },
        "dry_run": { "type": "integer", "minimum": 0 },
        "operator_review": { "type": "integer", "minimum": 0 },
        "pilot": { "type": "integer", "minimum": 0 },
        "limited_live": { "type": "integer", "minimum": 0 },
        "approved_live": { "type": "integer", "minimum": 0 },
        "production": { "type": "integer", "minimum": 0 }
      }
    },
    "string_list": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 320
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "capability_count",
        "promotion_path_count",
        "family_counts",
        "current_stage_counts",
        "blocked_path_count",
        "live_action_enabled_count",
        "production_stage_count"
      ],
      "properties": {
        "capability_count": { "type": "integer", "minimum": 1 },
        "promotion_path_count": { "type": "integer", "minimum": 1 },
        "family_counts": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "current_stage_counts": { "$ref": "#/$defs/stage_counts" },
        "blocked_path_count": { "type": "integer", "minimum": 0 },
        "live_action_enabled_count": { "type": "integer", "const": 0 },
        "production_stage_count": { "type": "integer", "const": 0 }
      }
    },
    "promotion_path": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "promotion_path_id",
        "capability_id",
        "capability_name",
        "family",
        "current_unlock_level",
        "operator_status",
        "current_stage",
        "next_stage",
        "stage_count",
        "stages",
        "blocked_stage_ids",
        "promotion_blocked",
        "live_action_enabled",
        "next_promotion_step",
        "promotion_path_is_not_execution_authority"
      ],
      "properties": {
        "promotion_path_id": { "$ref": "#/$defs/identifier" },
        "capability_id": { "$ref": "#/$defs/identifier" },
        "capability_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 180
        },
        "family": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "current_unlock_level": {
          "type": "string",
          "enum": ["C0", "C1", "C2", "C3", "C4", "C5", "C6", "C7"]
        },
        "operator_status": {
          "type": "string",
          "enum": [
            "Ready",
            "Prepare-only",
            "Needs approval",
            "Blocked",
            "Evidence missing",
            "Live action disabled"
          ]
        },
        "current_stage": { "$ref": "#/$defs/stage_id" },
        "next_stage": { "$ref": "#/$defs/stage_id" },
        "stage_count": { "type": "integer", "const": 8 },
        "stages": {
          "type": "array",
          "minItems": 8,
          "maxItems": 8,
          "items": { "$ref": "#/$defs/stage" }
        },
        "blocked_stage_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/stage_id" }
        },
        "promotion_blocked": { "type": "boolean" },
        "live_action_enabled": { "type": "boolean", "const": false },
        "next_promotion_step": {
          "type": "string",
          "minLength": 1,
          "maxLength": 420
        },
        "promotion_path_is_not_execution_authority": { "type": "boolean", "const": true }
      }
    },
    "stage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stage_id",
        "label",
        "sequence",
        "stage_status",
        "description",
        "required_controls",
        "missing_controls",
        "live_execution_allowed"
      ],
      "properties": {
        "stage_id": { "$ref": "#/$defs/stage_id" },
        "label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "sequence": {
          "type": "integer",
          "minimum": 1,
          "maximum": 8
        },
        "stage_status": {
          "type": "string",
          "enum": ["complete", "current", "pending", "blocked"]
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 240
        },
        "required_controls": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/identifier" }
        },
        "missing_controls": { "$ref": "#/$defs/string_list" },
        "live_execution_allowed": { "type": "boolean", "const": false }
      }
    },
    "validator_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["validator_id", "command", "required_for_closure"],
      "properties": {
        "validator_id": { "$ref": "#/$defs/identifier" },
        "command": {
          "type": "string",
          "minLength": 1,
          "maxLength": 240
        },
        "required_for_closure": { "type": "boolean", "const": true }
      }
    }
  }
}
