{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:universal-symbol-receipt-store-operator-approval-witness:1",
  "title": "Universal Symbol Receipt Store Operator Approval Witness",
  "description": "Foundation Mode witness for a future UniversalSymbol receipt-store operator approval boundary. This witness defines approval evidence obligations while denying approval recording, writer identity registration, writer registration, write-path registration, receipt append, raw payload storage, raw secret storage, runtime dispatch, connector calls, state mutation, terminal closure, and production readiness.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "witness_id",
    "schema_version",
    "generated_at",
    "witness_scope",
    "solver_outcome",
    "foundation_mode",
    "operator_approval_decision",
    "operator_approval_witness_is_not_approval_authority",
    "approval_requirements",
    "authority_denials",
    "approval_constraints",
    "rejection_policy",
    "blocked_reasons",
    "next_actions",
    "evidence_refs",
    "contract_summary"
  ],
  "properties": {
    "witness_id": { "type": "string", "const": "universal-symbol-receipt-store-operator-approval-witness-foundation" },
    "schema_version": { "type": "integer", "const": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "witness_scope": { "type": "string", "const": "foundation-mode-universal-symbol-receipt-store-operator-approval" },
    "solver_outcome": { "type": "string", "const": "AwaitingEvidence" },
    "foundation_mode": { "type": "boolean", "const": true },
    "operator_approval_decision": { "type": "string", "const": "blocked_pending_live_operator_decision_tenant_scope_and_reapproval_evidence" },
    "operator_approval_witness_is_not_approval_authority": { "type": "boolean", "const": true },
    "approval_requirements": {
      "type": "array",
      "minItems": 8,
      "items": { "$ref": "#/$defs/approval_requirement" },
      "uniqueItems": true
    },
    "authority_denials": { "$ref": "#/$defs/authority_denials" },
    "approval_constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operator_identity_required",
        "explicit_approval_decision_required",
        "approval_scope_required",
        "tenant_scope_required",
        "expiry_or_reapproval_required",
        "revocation_path_required",
        "audit_receipt_required",
        "terminal_closure_claim_forbidden"
      ],
      "properties": {
        "operator_identity_required": { "type": "boolean", "const": true },
        "explicit_approval_decision_required": { "type": "boolean", "const": true },
        "approval_scope_required": { "type": "boolean", "const": true },
        "tenant_scope_required": { "type": "boolean", "const": true },
        "expiry_or_reapproval_required": { "type": "boolean", "const": true },
        "revocation_path_required": { "type": "boolean", "const": true },
        "audit_receipt_required": { "type": "boolean", "const": true },
        "terminal_closure_claim_forbidden": { "type": "boolean", "const": true }
      }
    },
    "rejection_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "missing_operator_identity_blocks_approval",
        "missing_explicit_decision_blocks_approval",
        "missing_scope_blocks_approval",
        "missing_tenant_scope_blocks_approval",
        "unknown_hard_constraint_blocks_approval",
        "failed_precondition_logs_delta_reject"
      ],
      "properties": {
        "missing_operator_identity_blocks_approval": { "type": "boolean", "const": true },
        "missing_explicit_decision_blocks_approval": { "type": "boolean", "const": true },
        "missing_scope_blocks_approval": { "type": "boolean", "const": true },
        "missing_tenant_scope_blocks_approval": { "type": "boolean", "const": true },
        "unknown_hard_constraint_blocks_approval": { "type": "boolean", "const": true },
        "failed_precondition_logs_delta_reject": { "type": "boolean", "const": true }
      }
    },
    "blocked_reasons": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "string",
        "enum": [
          "operator_identity_missing",
          "explicit_approval_decision_missing",
          "approval_scope_missing",
          "tenant_scope_witness_missing",
          "expiry_or_reapproval_missing",
          "revocation_path_missing",
          "audit_receipt_missing",
          "receipt_store_operator_approval_forbidden",
          "state_mutation_forbidden",
          "terminal_closure_not_allowed"
        ]
      },
      "uniqueItems": true
    },
    "next_actions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/ref" },
      "uniqueItems": true
    },
    "contract_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "approval_requirement_count",
        "authority_denial_count",
        "approval_constraint_count",
        "rejection_check_count",
        "blocked_reason_count",
        "evidence_ref_count"
      ],
      "properties": {
        "approval_requirement_count": { "type": "integer", "minimum": 8 },
        "authority_denial_count": { "type": "integer", "const": 11 },
        "approval_constraint_count": { "type": "integer", "const": 8 },
        "rejection_check_count": { "type": "integer", "const": 6 },
        "blocked_reason_count": { "type": "integer", "minimum": 8 },
        "evidence_ref_count": { "type": "integer", "minimum": 1 }
      }
    }
  },
  "$defs": {
    "ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/#-]*$"
    },
    "approval_requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requirement_id",
        "proof_state",
        "required_evidence_ref",
        "current_decision",
        "delta_reject_ref"
      ],
      "properties": {
        "requirement_id": { "$ref": "#/$defs/ref" },
        "proof_state": { "type": "string", "enum": ["Unknown", "BudgetUnknown", "Fail"] },
        "required_evidence_ref": { "$ref": "#/$defs/ref" },
        "current_decision": { "type": "string", "const": "operator_approval_blocked" },
        "delta_reject_ref": { "$ref": "#/$defs/ref" }
      }
    },
    "authority_denials": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_store_operator_approval_recorded",
        "receipt_store_writer_identity_registered",
        "receipt_store_writer_registered",
        "receipt_store_write_path_registered",
        "receipt_store_append_performed",
        "raw_payload_stored",
        "raw_secret_stored",
        "runtime_dispatch_performed",
        "connector_call_performed",
        "state_mutation_performed",
        "terminal_closure_allowed"
      ],
      "properties": {
        "receipt_store_operator_approval_recorded": { "type": "boolean", "const": false },
        "receipt_store_writer_identity_registered": { "type": "boolean", "const": false },
        "receipt_store_writer_registered": { "type": "boolean", "const": false },
        "receipt_store_write_path_registered": { "type": "boolean", "const": false },
        "receipt_store_append_performed": { "type": "boolean", "const": false },
        "raw_payload_stored": { "type": "boolean", "const": false },
        "raw_secret_stored": { "type": "boolean", "const": false },
        "runtime_dispatch_performed": { "type": "boolean", "const": false },
        "connector_call_performed": { "type": "boolean", "const": false },
        "state_mutation_performed": { "type": "boolean", "const": false },
        "terminal_closure_allowed": { "type": "boolean", "const": false }
      }
    }
  }
}
