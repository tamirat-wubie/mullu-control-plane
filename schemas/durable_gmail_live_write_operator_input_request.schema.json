{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:durable-gmail-live-write-operator-input-request:1",
  "title": "Durable Gmail Live Write Operator Input Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_id",
    "adapter_id",
    "connector_id",
    "mode",
    "operation_family",
    "ready_for_operator_review",
    "write_action_allowed",
    "solver_outcome",
    "proof_state",
    "required_inputs",
    "blocked_actions",
    "source_artifacts",
    "operation_summary",
    "no_secret_values_serialized",
    "raw_mailbox_address_disclosed",
    "raw_message_content_disclosed",
    "live_write_executed",
    "external_provider_call_performed",
    "external_mailbox_write_performed",
    "external_draft_created",
    "external_send_performed",
    "provider_mutation_performed",
    "production_ready_claimed",
    "write_authority_claimed",
    "calendar_authority_claimed",
    "next_action"
  ],
  "properties": {
    "request_id": {
      "type": "string",
      "pattern": "^durable-gmail-live-write-input-request-[0-9a-f]{16}$"
    },
    "adapter_id": {
      "type": "string",
      "const": "communication.gmail_oauth"
    },
    "connector_id": {
      "type": "string",
      "const": "gmail"
    },
    "mode": {
      "type": "string",
      "const": "foundation-local"
    },
    "operation_family": {
      "type": "string",
      "minLength": 1
    },
    "ready_for_operator_review": {
      "type": "boolean"
    },
    "write_action_allowed": {
      "type": "boolean",
      "const": false
    },
    "solver_outcome": {
      "type": "string",
      "enum": ["AwaitingEvidence", "GovernanceBlocked", "SolvedVerified"]
    },
    "proof_state": {
      "type": "string",
      "enum": ["Unknown", "Fail", "Pass"]
    },
    "required_inputs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/operator_input"
      }
    },
    "blocked_actions": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "calendar_authority_claim",
          "external_provider_call",
          "gmail_live_draft_create",
          "gmail_live_send",
          "gmail_write_authority_claim",
          "mailbox_write",
          "production_readiness_claim"
        ]
      }
    },
    "source_artifacts": {
      "$ref": "#/$defs/source_artifacts"
    },
    "operation_summary": {
      "$ref": "#/$defs/operation_summary"
    },
    "no_secret_values_serialized": {
      "type": "boolean",
      "const": true
    },
    "raw_mailbox_address_disclosed": {
      "type": "boolean",
      "const": false
    },
    "raw_message_content_disclosed": {
      "type": "boolean",
      "const": false
    },
    "live_write_executed": {
      "type": "boolean",
      "const": false
    },
    "external_provider_call_performed": {
      "type": "boolean",
      "const": false
    },
    "external_mailbox_write_performed": {
      "type": "boolean",
      "const": false
    },
    "external_draft_created": {
      "type": "boolean",
      "const": false
    },
    "external_send_performed": {
      "type": "boolean",
      "const": false
    },
    "provider_mutation_performed": {
      "type": "boolean",
      "const": false
    },
    "production_ready_claimed": {
      "type": "boolean",
      "const": false
    },
    "write_authority_claimed": {
      "type": "boolean",
      "const": false
    },
    "calendar_authority_claimed": {
      "type": "boolean",
      "const": false
    },
    "next_action": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "operator_input": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "input_id",
        "blocker",
        "input_kind",
        "required_names",
        "current_state",
        "evidence_source",
        "next_action"
      ],
      "properties": {
        "input_id": {
          "type": "string",
          "pattern": "^durable-gmail-live-write-input-[0-9a-f]{12}$"
        },
        "blocker": {
          "type": "string",
          "minLength": 1
        },
        "input_kind": {
          "type": "string",
          "enum": [
            "account_binding_receipt_ref",
            "gmail_scope_binding",
            "source_live_receipt_ref",
            "valid_account_binding_receipt_ref",
            "valid_operation_family",
            "valid_source_live_receipt_ref",
            "valid_write_approval_receipt_ref",
            "valid_write_rehearsal_receipt_ref",
            "write_approval_receipt_ref",
            "write_rehearsal_receipt_ref"
          ]
        },
        "required_names": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "GMAIL_SCOPE_ID",
              "MULLU_GMAIL_ACCOUNT_BINDING_RECEIPT_REF",
              "MULLU_GMAIL_WRITE_APPROVAL_RECEIPT_REF",
              "MULLU_GMAIL_WRITE_OPERATION_FAMILY",
              "MULLU_GMAIL_WRITE_REHEARSAL_RECEIPT_REF",
              "MULLU_GMAIL_WRITE_SOURCE_LIVE_RECEIPT_REF"
            ]
          }
        },
        "current_state": {
          "type": "string",
          "enum": ["missing", "present_invalid"]
        },
        "evidence_source": {
          "type": "string",
          "const": "durable_gmail_live_write_operator_input_request"
        },
        "next_action": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "source_artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "account_binding_receipt_ref",
        "source_live_receipt_ref",
        "write_rehearsal_receipt_ref",
        "write_approval_receipt_ref"
      ],
      "properties": {
        "account_binding_receipt_ref": {
          "type": "string"
        },
        "source_live_receipt_ref": {
          "type": "string"
        },
        "write_rehearsal_receipt_ref": {
          "type": "string"
        },
        "write_approval_receipt_ref": {
          "type": "string"
        }
      }
    },
    "operation_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "approval_required",
        "draft_send_split_required",
        "operator_review_required",
        "required_scope_ref"
      ],
      "properties": {
        "approval_required": {
          "type": "boolean",
          "const": true
        },
        "draft_send_split_required": {
          "type": "boolean",
          "const": true
        },
        "operator_review_required": {
          "type": "boolean",
          "const": true
        },
        "required_scope_ref": {
          "type": "string",
          "enum": ["oauth:gmail.compose", "oauth:gmail.send"]
        }
      }
    }
  }
}
