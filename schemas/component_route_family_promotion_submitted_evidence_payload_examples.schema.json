{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:component-route-family-promotion-submitted-evidence-payload-examples:1",
  "title": "Mullu Component Route-Family Promotion Submitted Evidence Payload Examples",
  "description": "Read-only Component Harness report that defines concrete example payload values and acceptance-rule contracts for blocked route-family promotion submitted-evidence envelopes without submitting evidence or granting authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "payload_examples_id",
    "mode",
    "governed",
    "target_surface_id",
    "target_component_id",
    "decision",
    "preflight_outcome",
    "outcome",
    "payload_decision",
    "acceptance_decision",
    "payload_examples_are_not_submitted_evidence",
    "acceptance_rules_are_not_execution_authority",
    "live_execution_enabled",
    "live_connector_send_enabled",
    "can_execute",
    "can_mutate",
    "can_call_connector",
    "can_claim_terminal_closure",
    "mutates_router_inventory",
    "ready_for_promotion",
    "terminal_closure_required",
    "source_refs",
    "summary",
    "payload_examples",
    "submitted_evidence_refs",
    "accepted_evidence_refs",
    "rejected_evidence_refs",
    "approval_evidence_required",
    "operator_submission_channels",
    "blocked_actions",
    "expected_receipts",
    "validators",
    "next_action"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "payload_examples_id": { "$ref": "#/$defs/identifier" },
    "mode": {
      "type": "string",
      "enum": ["foundation", "read_only"]
    },
    "governed": { "type": "boolean", "const": true },
    "target_surface_id": { "$ref": "#/$defs/identifier" },
    "target_component_id": { "$ref": "#/$defs/identifier" },
    "decision": { "type": "string", "const": "blocked" },
    "preflight_outcome": { "type": "string", "const": "GovernanceBlocked" },
    "outcome": { "type": "string", "const": "AwaitingEvidence" },
    "payload_decision": { "type": "string", "const": "example_only" },
    "acceptance_decision": { "type": "string", "const": "defined_not_applied" },
    "payload_examples_are_not_submitted_evidence": { "type": "boolean", "const": true },
    "acceptance_rules_are_not_execution_authority": { "type": "boolean", "const": true },
    "live_execution_enabled": { "type": "boolean", "const": false },
    "live_connector_send_enabled": { "type": "boolean", "const": false },
    "can_execute": { "type": "boolean", "const": false },
    "can_mutate": { "type": "boolean", "const": false },
    "can_call_connector": { "type": "boolean", "const": false },
    "can_claim_terminal_closure": { "type": "boolean", "const": false },
    "mutates_router_inventory": { "type": "boolean", "const": false },
    "ready_for_promotion": { "type": "boolean", "const": false },
    "terminal_closure_required": { "type": "boolean", "const": true },
    "source_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "submitted_evidence_records",
        "submitted_evidence_verifier",
        "promotion_approval_intake",
        "promotion_preflight",
        "proof_matrix"
      ],
      "properties": {
        "submitted_evidence_records": { "$ref": "#/$defs/repo_path" },
        "submitted_evidence_verifier": { "$ref": "#/$defs/repo_path" },
        "promotion_approval_intake": { "$ref": "#/$defs/repo_path" },
        "promotion_preflight": { "$ref": "#/$defs/repo_path" },
        "proof_matrix": { "$ref": "#/$defs/repo_path" }
      }
    },
    "summary": { "$ref": "#/$defs/summary" },
    "payload_examples": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/payload_example" }
    },
    "submitted_evidence_refs": { "$ref": "#/$defs/empty_refs" },
    "accepted_evidence_refs": { "$ref": "#/$defs/empty_refs" },
    "rejected_evidence_refs": { "$ref": "#/$defs/empty_refs" },
    "approval_evidence_required": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/identifier_or_ref" }
    },
    "operator_submission_channels": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/identifier_or_ref" }
    },
    "blocked_actions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/identifier" }
    },
    "expected_receipts": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/identifier" }
    },
    "validators": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/identifier" }
    },
    "next_action": {
      "type": "string",
      "minLength": 1,
      "maxLength": 420
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "identifier_or_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/#{}@+ -]*$"
    },
    "repo_path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9._~:/{}@+ -]+$"
    },
    "empty_refs": {
      "type": "array",
      "maxItems": 0,
      "items": { "$ref": "#/$defs/identifier_or_ref" }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "payload_example_count",
        "example_only_payload_count",
        "not_submitted_payload_count",
        "not_evaluated_payload_count",
        "submitted_payload_count",
        "accepted_evidence_count",
        "rejected_evidence_count",
        "acceptance_rule_count",
        "applied_acceptance_rule_count",
        "passing_acceptance_rule_count",
        "failing_acceptance_rule_count",
        "satisfied_requirement_count",
        "blocking_payload_count",
        "approval_artifact_requirement_count",
        "authority_grant_count"
      ],
      "properties": {
        "payload_example_count": { "type": "integer", "const": 4 },
        "example_only_payload_count": { "type": "integer", "const": 4 },
        "not_submitted_payload_count": { "type": "integer", "const": 4 },
        "not_evaluated_payload_count": { "type": "integer", "const": 4 },
        "submitted_payload_count": { "type": "integer", "const": 0 },
        "accepted_evidence_count": { "type": "integer", "const": 0 },
        "rejected_evidence_count": { "type": "integer", "const": 0 },
        "acceptance_rule_count": { "type": "integer", "minimum": 1 },
        "applied_acceptance_rule_count": { "type": "integer", "const": 0 },
        "passing_acceptance_rule_count": { "type": "integer", "const": 0 },
        "failing_acceptance_rule_count": { "type": "integer", "const": 0 },
        "satisfied_requirement_count": { "type": "integer", "const": 0 },
        "blocking_payload_count": { "type": "integer", "const": 4 },
        "approval_artifact_requirement_count": { "type": "integer", "minimum": 1 },
        "authority_grant_count": { "type": "integer", "const": 0 }
      }
    },
    "payload_example": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "payload_example_id",
        "source_record_envelope_id",
        "source_verifier_request_id",
        "source_intake_request_id",
        "gate_id",
        "record_kind",
        "evidence_key",
        "payload_state",
        "submission_state",
        "verification_state",
        "acceptance_state",
        "proof_state",
        "blocks_promotion",
        "satisfies_requirement",
        "payload_values_present",
        "payload_values_are_examples_only",
        "payload_example_is_not_submitted_evidence",
        "mutates_router_inventory",
        "grants_execution_authority",
        "grants_connector_authority",
        "grants_terminal_closure",
        "required_artifacts",
        "required_payload_fields",
        "example_payload",
        "acceptance_rules",
        "rejection_conditions",
        "submitted_evidence_refs",
        "accepted_evidence_refs",
        "rejected_evidence_refs",
        "missing_submission_reason"
      ],
      "properties": {
        "payload_example_id": { "$ref": "#/$defs/identifier" },
        "source_record_envelope_id": { "$ref": "#/$defs/identifier" },
        "source_verifier_request_id": { "$ref": "#/$defs/identifier" },
        "source_intake_request_id": { "$ref": "#/$defs/identifier" },
        "gate_id": {
          "type": "string",
          "enum": [
            "route_binding_gate",
            "lifecycle_gate",
            "authority_upgrade_gate",
            "product_specific_boundary_gate"
          ]
        },
        "record_kind": {
          "type": "string",
          "enum": [
            "route_binding",
            "lifecycle_transition",
            "authority_upgrade",
            "product_specific_ownership"
          ]
        },
        "evidence_key": { "$ref": "#/$defs/identifier" },
        "payload_state": { "type": "string", "const": "example_only" },
        "submission_state": { "type": "string", "const": "not_submitted" },
        "verification_state": { "type": "string", "const": "not_verified" },
        "acceptance_state": { "type": "string", "const": "not_evaluated" },
        "proof_state": { "type": "string", "const": "Unknown" },
        "blocks_promotion": { "type": "boolean", "const": true },
        "satisfies_requirement": { "type": "boolean", "const": false },
        "payload_values_present": { "type": "boolean", "const": true },
        "payload_values_are_examples_only": { "type": "boolean", "const": true },
        "payload_example_is_not_submitted_evidence": { "type": "boolean", "const": true },
        "mutates_router_inventory": { "type": "boolean", "const": false },
        "grants_execution_authority": { "type": "boolean", "const": false },
        "grants_connector_authority": { "type": "boolean", "const": false },
        "grants_terminal_closure": { "type": "boolean", "const": false },
        "required_artifacts": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/identifier_or_ref" }
        },
        "required_payload_fields": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/identifier_or_ref" }
        },
        "example_payload": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "$ref": "#/$defs/example_payload_value" }
        },
        "acceptance_rules": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/acceptance_rule" }
        },
        "rejection_conditions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/identifier_or_ref" }
        },
        "submitted_evidence_refs": { "$ref": "#/$defs/empty_refs" },
        "accepted_evidence_refs": { "$ref": "#/$defs/empty_refs" },
        "rejected_evidence_refs": { "$ref": "#/$defs/empty_refs" },
        "missing_submission_reason": {
          "type": "string",
          "minLength": 1,
          "maxLength": 240
        }
      }
    },
    "acceptance_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "source_record_envelope_id",
        "gate_id",
        "rule_state",
        "proof_state",
        "required_for_submission",
        "blocks_submission_until_pass",
        "rule_is_not_execution_authority",
        "mutates_router_inventory",
        "grants_execution_authority",
        "grants_connector_authority",
        "grants_terminal_closure",
        "source_payload_fields",
        "failure_condition"
      ],
      "properties": {
        "rule_id": { "$ref": "#/$defs/identifier_or_ref" },
        "source_record_envelope_id": { "$ref": "#/$defs/identifier" },
        "gate_id": {
          "type": "string",
          "enum": [
            "route_binding_gate",
            "lifecycle_gate",
            "authority_upgrade_gate",
            "product_specific_boundary_gate"
          ]
        },
        "rule_state": { "type": "string", "const": "defined_not_applied" },
        "proof_state": { "type": "string", "const": "Unknown" },
        "required_for_submission": { "type": "boolean", "const": true },
        "blocks_submission_until_pass": { "type": "boolean", "const": true },
        "rule_is_not_execution_authority": { "type": "boolean", "const": true },
        "mutates_router_inventory": { "type": "boolean", "const": false },
        "grants_execution_authority": { "type": "boolean", "const": false },
        "grants_connector_authority": { "type": "boolean", "const": false },
        "grants_terminal_closure": { "type": "boolean", "const": false },
        "source_payload_fields": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/identifier_or_ref" }
        },
        "failure_condition": { "$ref": "#/$defs/identifier_or_ref" }
      }
    },
    "example_payload_value": {
      "anyOf": [
        { "type": "string", "minLength": 1, "maxLength": 512 },
        { "type": "integer", "minimum": 0 },
        { "type": "boolean" },
        {
          "type": "array",
          "items": { "$ref": "#/$defs/identifier_or_ref" }
        },
        {
          "type": "object",
          "additionalProperties": { "type": "boolean" }
        }
      ]
    }
  }
}
