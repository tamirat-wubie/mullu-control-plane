{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:agentic-service-harness-live-producer-admission-gate:1",
  "title": "Agentic Service Harness Live Producer Admission Gate",
  "description": "Read-only admission gate contract for future live task/run producer implementation. This schema records blocked admission requirements and does not admit UI, mutation endpoints, live adapters, branch writes, pull-request creation, deployment, DNS mutation, secret mutation, destructive operations, runtime state writes, or terminal closure.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "gate_id",
    "schema_version",
    "generated_at",
    "gate_state",
    "solver_outcome",
    "source_rehearsal_report_id",
    "source_fixture_ref",
    "planning_only",
    "local_rehearsal_only",
    "live_producer_implemented",
    "read_only",
    "report_is_not_terminal_closure",
    "terminal_closure",
    "admission_decision",
    "scope",
    "required_evidence",
    "authority_denials",
    "effect_boundary",
    "blocked_reasons",
    "validators",
    "next_action"
  ],
  "properties": {
    "gate_id": {
      "type": "string",
      "const": "agentic-service-harness-live-producer-admission-gate"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "gate_state": {
      "type": "string",
      "enum": [
        "blocked_pending_live_authority",
        "blocked_invalid_rehearsal"
      ]
    },
    "solver_outcome": {
      "type": "string",
      "enum": [
        "AwaitingEvidence",
        "GovernanceBlocked"
      ]
    },
    "source_rehearsal_report_id": {
      "type": "string",
      "minLength": 1
    },
    "source_fixture_ref": {
      "$ref": "#/$defs/evidence_ref"
    },
    "planning_only": {
      "type": "boolean",
      "const": true
    },
    "local_rehearsal_only": {
      "type": "boolean",
      "const": true
    },
    "live_producer_implemented": {
      "type": "boolean",
      "const": false
    },
    "read_only": {
      "type": "boolean",
      "const": true
    },
    "report_is_not_terminal_closure": {
      "type": "boolean",
      "const": true
    },
    "terminal_closure": {
      "type": "boolean",
      "const": false
    },
    "admission_decision": {
      "type": "string",
      "const": "blocked"
    },
    "scope": {
      "$ref": "#/$defs/scope"
    },
    "required_evidence": {
      "$ref": "#/$defs/required_evidence"
    },
    "authority_denials": {
      "$ref": "#/$defs/authority_denials"
    },
    "effect_boundary": {
      "$ref": "#/$defs/effect_boundary"
    },
    "blocked_reasons": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "live_producer_authority_not_granted",
          "operator_approval_missing",
          "effect_receipt_missing",
          "external_adapter_evidence_missing",
          "mutation_route_not_admitted",
          "secret_handoff_missing",
          "terminal_closure_not_allowed",
          "invalid_local_rehearsal"
        ]
      },
      "uniqueItems": true
    },
    "validators": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/validator_ref"
      }
    },
    "next_action": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "evidence_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/#-]*$"
    },
    "evidence_ref_list": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidence_ref"
      },
      "uniqueItems": true
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tenant_id",
        "organization_id",
        "project_id",
        "repository_connection_id",
        "read_only"
      ],
      "properties": {
        "tenant_id": { "$ref": "#/$defs/identifier" },
        "organization_id": { "$ref": "#/$defs/identifier" },
        "project_id": { "$ref": "#/$defs/identifier" },
        "repository_connection_id": { "$ref": "#/$defs/identifier" },
        "read_only": { "type": "boolean", "const": true }
      }
    },
    "required_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "local_rehearsal_report_ref",
        "live_task_run_producer_evidence_ref",
        "read_only_status_route_ref",
        "approval_gate_ref",
        "effect_receipt_ref",
        "external_adapter_evidence_ref",
        "secret_handoff_ref",
        "rollback_plan_ref"
      ],
      "properties": {
        "local_rehearsal_report_ref": { "$ref": "#/$defs/evidence_ref" },
        "live_task_run_producer_evidence_ref": { "$ref": "#/$defs/evidence_ref" },
        "read_only_status_route_ref": { "$ref": "#/$defs/evidence_ref" },
        "approval_gate_ref": { "$ref": "#/$defs/evidence_ref" },
        "effect_receipt_ref": { "$ref": "#/$defs/evidence_ref" },
        "external_adapter_evidence_ref": { "$ref": "#/$defs/evidence_ref" },
        "secret_handoff_ref": { "$ref": "#/$defs/evidence_ref" },
        "rollback_plan_ref": { "$ref": "#/$defs/evidence_ref" }
      }
    },
    "authority_denials": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ui_created",
        "mutation_endpoints_admitted",
        "external_adapter_integrated",
        "branch_write_enabled",
        "pull_request_creation_enabled",
        "deployment_enabled",
        "dns_mutation_enabled",
        "secret_mutation_enabled",
        "destructive_operation_enabled",
        "runtime_state_written",
        "live_execution_authorized"
      ],
      "properties": {
        "ui_created": { "type": "boolean", "const": false },
        "mutation_endpoints_admitted": { "type": "boolean", "const": false },
        "external_adapter_integrated": { "type": "boolean", "const": false },
        "branch_write_enabled": { "type": "boolean", "const": false },
        "pull_request_creation_enabled": { "type": "boolean", "const": false },
        "deployment_enabled": { "type": "boolean", "const": false },
        "dns_mutation_enabled": { "type": "boolean", "const": false },
        "secret_mutation_enabled": { "type": "boolean", "const": false },
        "destructive_operation_enabled": { "type": "boolean", "const": false },
        "runtime_state_written": { "type": "boolean", "const": false },
        "live_execution_authorized": { "type": "boolean", "const": false }
      }
    },
    "effect_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ui_created",
        "mutation_endpoints_admitted",
        "external_adapter_integrated",
        "branch_write_enabled",
        "pull_request_creation_enabled",
        "deployment_enabled",
        "dns_mutation_enabled",
        "secret_mutation_enabled",
        "destructive_operation_enabled",
        "runtime_state_written",
        "network_policy"
      ],
      "properties": {
        "ui_created": { "type": "boolean", "const": false },
        "mutation_endpoints_admitted": { "type": "boolean", "const": false },
        "external_adapter_integrated": { "type": "boolean", "const": false },
        "branch_write_enabled": { "type": "boolean", "const": false },
        "pull_request_creation_enabled": { "type": "boolean", "const": false },
        "deployment_enabled": { "type": "boolean", "const": false },
        "dns_mutation_enabled": { "type": "boolean", "const": false },
        "secret_mutation_enabled": { "type": "boolean", "const": false },
        "destructive_operation_enabled": { "type": "boolean", "const": false },
        "runtime_state_written": { "type": "boolean", "const": false },
        "network_policy": { "type": "string", "const": "none" }
      }
    },
    "validator_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "validator_id",
        "command",
        "required_for_closure"
      ],
      "properties": {
        "validator_id": { "$ref": "#/$defs/identifier" },
        "command": { "type": "string", "minLength": 1 },
        "required_for_closure": { "type": "boolean", "const": true }
      }
    }
  }
}
