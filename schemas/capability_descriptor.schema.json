{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:capability-descriptor:1",
  "title": "Capability Descriptor",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "capability_id",
    "subject_id",
    "name",
    "version",
    "scope",
    "constraints"
  ],
  "properties": {
    "capability_id": {
      "type": "string",
      "minLength": 1
    },
    "subject_id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "string",
      "minLength": 1
    },
    "constraints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "risk_tier": {
      "type": "string"
    },
    "declared_effects": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "forbidden_effects": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidence_required": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "rollback": {
      "type": "object",
      "additionalProperties": true
    },
    "graph_projection": {
      "type": "object",
      "additionalProperties": true
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
