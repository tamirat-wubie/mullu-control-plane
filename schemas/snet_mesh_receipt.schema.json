{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:snet-mesh-receipt:1",
  "title": "SNet Mesh Receipt",
  "description": "Read-only, non-terminal receipt for one bounded SNet recursive WH symbolic mesh projection.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receipt_id",
    "snet_version",
    "semantics_hash",
    "mesh_digest",
    "surface",
    "symbol_count",
    "question_count",
    "answer_count",
    "metadata_count",
    "relation_count",
    "unknown_count",
    "contradiction_count",
    "max_depth",
    "promotion_threshold",
    "settlement_counts",
    "terminal_closure_required",
    "receipt_is_not_terminal_closure",
    "raw_answers_exposed",
    "raw_metadata_values_exposed",
    "execution_authority_granted",
    "connector_authority_granted",
    "route_authority_granted",
    "filesystem_authority_granted",
    "evidence_refs"
  ],
  "properties": {
    "receipt_id": {
      "type": "string",
      "pattern": "^snet-mesh-[0-9a-f]{16}$"
    },
    "snet_version": {
      "type": "string",
      "minLength": 1
    },
    "semantics_hash": {
      "type": "string",
      "pattern": "^sha256:.+"
    },
    "mesh_digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "surface": {
      "type": "string",
      "const": "read_only_snet_recursive_mesh"
    },
    "symbol_count": {
      "$ref": "#/$defs/non_negative_integer"
    },
    "question_count": {
      "$ref": "#/$defs/non_negative_integer"
    },
    "answer_count": {
      "$ref": "#/$defs/non_negative_integer"
    },
    "metadata_count": {
      "$ref": "#/$defs/non_negative_integer"
    },
    "relation_count": {
      "$ref": "#/$defs/non_negative_integer"
    },
    "unknown_count": {
      "$ref": "#/$defs/non_negative_integer"
    },
    "contradiction_count": {
      "$ref": "#/$defs/non_negative_integer"
    },
    "max_depth": {
      "$ref": "#/$defs/non_negative_integer"
    },
    "promotion_threshold": {
      "$ref": "#/$defs/unit_number"
    },
    "settlement_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "active",
        "expanding",
        "settled",
        "dormant",
        "contradictory",
        "unknown_heavy",
        "deprecated"
      ],
      "properties": {
        "active": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "expanding": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "settled": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "dormant": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "contradictory": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "unknown_heavy": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "deprecated": {
          "$ref": "#/$defs/non_negative_integer"
        }
      }
    },
    "terminal_closure_required": {
      "type": "boolean",
      "const": true
    },
    "receipt_is_not_terminal_closure": {
      "type": "boolean",
      "const": true
    },
    "raw_answers_exposed": {
      "type": "boolean",
      "const": false
    },
    "raw_metadata_values_exposed": {
      "type": "boolean",
      "const": false
    },
    "execution_authority_granted": {
      "type": "boolean",
      "const": false
    },
    "connector_authority_granted": {
      "type": "boolean",
      "const": false
    },
    "route_authority_granted": {
      "type": "boolean",
      "const": false
    },
    "filesystem_authority_granted": {
      "type": "boolean",
      "const": false
    },
    "evidence_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    }
  },
  "$defs": {
    "unit_number": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "non_negative_integer": {
      "type": "integer",
      "minimum": 0
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
