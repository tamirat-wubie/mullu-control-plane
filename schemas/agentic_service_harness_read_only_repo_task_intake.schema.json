{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:agentic-service-harness-read-only-repo-task-intake:1",
  "title": "Agentic Service Harness Read-Only Repository Task Intake",
  "description": "Contract-only intake preflight for GitHub repository tasks. It validates repository connection identity and bounded task scope without running code, writing files, creating branches, opening pull requests, calling live adapters, exposing secrets, or claiming terminal closure.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "report_id",
    "schema_version",
    "generated_at",
    "solver_outcome",
    "scope",
    "repository_connection_binding",
    "task_intake",
    "preflight_gates",
    "authority_denials",
    "validators",
    "next_action",
    "report_is_not_terminal_closure",
    "terminal_closure_required"
  ],
  "properties": {
    "report_id": {
      "type": "string",
      "const": "agentic_service_harness_read_only_repo_task_intake"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "solver_outcome": {
      "type": "string",
      "const": "AwaitingEvidence"
    },
    "scope": {
      "$ref": "#/$defs/scope"
    },
    "repository_connection_binding": {
      "$ref": "#/$defs/repository_connection_binding"
    },
    "task_intake": {
      "$ref": "#/$defs/task_intake"
    },
    "preflight_gates": {
      "$ref": "#/$defs/preflight_gates"
    },
    "authority_denials": {
      "$ref": "#/$defs/authority_denials"
    },
    "validators": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/validator_ref"
      }
    },
    "next_action": {
      "type": "string",
      "minLength": 1
    },
    "report_is_not_terminal_closure": {
      "type": "boolean",
      "const": true
    },
    "terminal_closure_required": {
      "type": "boolean",
      "const": true
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "evidence_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/#$-]*$"
    },
    "evidence_ref_list": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/evidence_ref"
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tenant_id",
        "organization_id",
        "project_id",
        "repository_connection_id",
        "repository_slug",
        "agent_task_id",
        "agent_run_id",
        "foundation_phase",
        "read_only"
      ],
      "properties": {
        "tenant_id": { "$ref": "#/$defs/identifier" },
        "organization_id": { "$ref": "#/$defs/identifier" },
        "project_id": { "$ref": "#/$defs/identifier" },
        "repository_connection_id": { "$ref": "#/$defs/identifier" },
        "repository_slug": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
        },
        "agent_task_id": { "$ref": "#/$defs/identifier" },
        "agent_run_id": { "$ref": "#/$defs/identifier" },
        "foundation_phase": {
          "type": "string",
          "const": "foundation_contract_only"
        },
        "read_only": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "repository_connection_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "repository_connection_id",
        "repository_slug",
        "connection_state",
        "credential_binding_ref",
        "permission_scopes",
        "write_authority_granted",
        "installation_ref_redacted",
        "revocation_state",
        "evidence_refs"
      ],
      "properties": {
        "provider": {
          "type": "string",
          "const": "github"
        },
        "repository_connection_id": { "$ref": "#/$defs/identifier" },
        "repository_slug": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
        },
        "connection_state": {
          "type": "string",
          "const": "verified_read_only"
        },
        "credential_binding_ref": { "$ref": "#/$defs/evidence_ref" },
        "permission_scopes": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "metadata:read",
              "contents:read",
              "pull_requests:read",
              "checks:read"
            ]
          }
        },
        "write_authority_granted": {
          "type": "boolean",
          "const": false
        },
        "installation_ref_redacted": {
          "type": "boolean",
          "const": true
        },
        "revocation_state": {
          "type": "string",
          "enum": [
            "not_revoked",
            "revocation_check_required"
          ]
        },
        "evidence_refs": { "$ref": "#/$defs/evidence_ref_list" }
      }
    },
    "task_intake": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "intake_id",
        "agent_task_id",
        "requested_mode",
        "allowed_action_classes",
        "task_scope_summary_ref",
        "allowed_path_prefixes",
        "forbidden_path_prefixes",
        "requested_commands",
        "code_execution_requested",
        "filesystem_write_requested",
        "external_adapter_requested",
        "approval_request_ref",
        "evidence_refs"
      ],
      "properties": {
        "intake_id": { "$ref": "#/$defs/identifier" },
        "agent_task_id": { "$ref": "#/$defs/identifier" },
        "requested_mode": {
          "type": "string",
          "const": "read_only"
        },
        "allowed_action_classes": {
          "type": "array",
          "prefixItems": [
            {
              "type": "string",
              "const": "read_only"
            }
          ],
          "items": false,
          "minItems": 1,
          "maxItems": 1
        },
        "task_scope_summary_ref": { "$ref": "#/$defs/evidence_ref" },
        "allowed_path_prefixes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^(README\\.md|docs/|schemas/|examples/|scripts/|tests/)[A-Za-z0-9._/-]*$"
          }
        },
        "forbidden_path_prefixes": {
          "type": "array",
          "minItems": 3,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              ".git/",
              ".env",
              ".github/secrets/",
              "deploy/",
              "infra/production/",
              "secrets/"
            ]
          }
        },
        "requested_commands": {
          "type": "array",
          "maxItems": 0
        },
        "code_execution_requested": {
          "type": "boolean",
          "const": false
        },
        "filesystem_write_requested": {
          "type": "boolean",
          "const": false
        },
        "external_adapter_requested": {
          "type": "boolean",
          "const": false
        },
        "approval_request_ref": { "$ref": "#/$defs/evidence_ref" },
        "evidence_refs": { "$ref": "#/$defs/evidence_ref_list" }
      }
    },
    "preflight_gates": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository_connection_verified",
        "repository_slug_matches_scope",
        "agent_task_matches_scope",
        "task_scope_bounded",
        "path_allowlist_present",
        "approval_required_before_effects",
        "execution_authority_granted",
        "branch_workspace_creation_granted",
        "pull_request_creation_granted",
        "terminal_closure_granted"
      ],
      "properties": {
        "repository_connection_verified": { "type": "boolean", "const": true },
        "repository_slug_matches_scope": { "type": "boolean", "const": true },
        "agent_task_matches_scope": { "type": "boolean", "const": true },
        "task_scope_bounded": { "type": "boolean", "const": true },
        "path_allowlist_present": { "type": "boolean", "const": true },
        "approval_required_before_effects": { "type": "boolean", "const": true },
        "execution_authority_granted": { "type": "boolean", "const": false },
        "branch_workspace_creation_granted": { "type": "boolean", "const": false },
        "pull_request_creation_granted": { "type": "boolean", "const": false },
        "terminal_closure_granted": { "type": "boolean", "const": false }
      }
    },
    "authority_denials": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mutation_endpoint_admitted",
        "live_adapter_execution",
        "filesystem_write",
        "branch_creation",
        "pull_request_creation",
        "deployment",
        "dns_mutation",
        "secret_serialization",
        "destructive_operation",
        "terminal_closure"
      ],
      "properties": {
        "mutation_endpoint_admitted": { "type": "boolean", "const": false },
        "live_adapter_execution": { "type": "boolean", "const": false },
        "filesystem_write": { "type": "boolean", "const": false },
        "branch_creation": { "type": "boolean", "const": false },
        "pull_request_creation": { "type": "boolean", "const": false },
        "deployment": { "type": "boolean", "const": false },
        "dns_mutation": { "type": "boolean", "const": false },
        "secret_serialization": { "type": "boolean", "const": false },
        "destructive_operation": { "type": "boolean", "const": false },
        "terminal_closure": { "type": "boolean", "const": false }
      }
    },
    "validator_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "path"
      ],
      "properties": {
        "name": { "$ref": "#/$defs/identifier" },
        "path": { "$ref": "#/$defs/evidence_ref" }
      }
    }
  }
}
