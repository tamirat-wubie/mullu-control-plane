{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:read-only-worker-runtime-enablement-submitted-evidence-refs:1",
  "title": "Mullu Read-Only Worker Runtime Enablement Submitted Evidence Refs",
  "description": "Foundation Mode submitted-for-review evidence reference ledger for read-only worker runtime enablement. Submitted references are not evidence acceptance, authority, dispatch, receipt append, worker invocation, or terminal closure.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "submission_id",
    "submission_version",
    "source_status_ledger_ref",
    "source_operator_input_request_ref",
    "selected_worker_path",
    "solver_outcome",
    "proof_state",
    "submission_state",
    "review_state",
    "evidence_submitted",
    "evidence_accepted",
    "evidence_rejected",
    "authority_granted",
    "runtime_enablement_allowed",
    "runtime_enablement_executed",
    "runtime_dispatch_admitted",
    "runtime_dispatch_performed",
    "worker_invocation_performed",
    "runtime_receipt_emitted",
    "receipt_append_performed",
    "terminal_closure_performed",
    "success_claim_allowed",
    "secret_values_serialized",
    "connector_authority_allowed",
    "filesystem_write_allowed",
    "external_network_allowed",
    "submitted_refs_are_not_acceptance",
    "submitted_refs_are_not_rejection",
    "submitted_refs_are_not_authorization",
    "submitted_refs_are_not_runtime_enablement",
    "submitted_refs_are_not_dispatch",
    "submitted_refs_are_not_worker_invocation",
    "submitted_refs_are_not_receipt_emission",
    "submitted_refs_are_not_receipt_append",
    "submitted_refs_are_not_terminal_closure",
    "submitted_refs_are_not_success_claim",
    "submitted_records",
    "submitted_record_refs",
    "submitted_evidence_refs",
    "accepted_evidence_refs",
    "rejected_evidence_refs",
    "authority_grant_refs",
    "blocked_actions",
    "summary",
    "validators",
    "next_action"
  ],
  "properties": {
    "submission_id": { "$ref": "#/$defs/identifier" },
    "submission_version": { "const": "read_only_worker_runtime_enablement_submitted_evidence_refs.v1" },
    "source_status_ledger_ref": { "const": "examples/read_only_worker_runtime_enablement_evidence_request_status_ledger.foundation.json" },
    "source_operator_input_request_ref": { "const": "generated://read-only-worker-runtime-enablement-operator-input-request/default" },
    "selected_worker_path": { "const": "read_only_repo_inspection" },
    "solver_outcome": { "const": "AwaitingEvidence" },
    "proof_state": { "const": "Unknown" },
    "submission_state": { "const": "partial_repo_refs_submitted_for_review" },
    "review_state": { "const": "not_evaluated" },
    "evidence_submitted": { "const": true },
    "evidence_accepted": { "const": false },
    "evidence_rejected": { "const": false },
    "authority_granted": { "const": false },
    "runtime_enablement_allowed": { "const": false },
    "runtime_enablement_executed": { "const": false },
    "runtime_dispatch_admitted": { "const": false },
    "runtime_dispatch_performed": { "const": false },
    "worker_invocation_performed": { "const": false },
    "runtime_receipt_emitted": { "const": false },
    "receipt_append_performed": { "const": false },
    "terminal_closure_performed": { "const": false },
    "success_claim_allowed": { "const": false },
    "secret_values_serialized": { "const": false },
    "connector_authority_allowed": { "const": false },
    "filesystem_write_allowed": { "const": false },
    "external_network_allowed": { "const": false },
    "submitted_refs_are_not_acceptance": { "const": true },
    "submitted_refs_are_not_rejection": { "const": true },
    "submitted_refs_are_not_authorization": { "const": true },
    "submitted_refs_are_not_runtime_enablement": { "const": true },
    "submitted_refs_are_not_dispatch": { "const": true },
    "submitted_refs_are_not_worker_invocation": { "const": true },
    "submitted_refs_are_not_receipt_emission": { "const": true },
    "submitted_refs_are_not_receipt_append": { "const": true },
    "submitted_refs_are_not_terminal_closure": { "const": true },
    "submitted_refs_are_not_success_claim": { "const": true },
    "submitted_records": {
      "type": "array",
      "minItems": 12,
      "maxItems": 12,
      "items": { "$ref": "#/$defs/submitted_record" }
    },
    "submitted_record_refs": {
      "type": "array",
      "minItems": 12,
      "maxItems": 12,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/identifier" }
    },
    "submitted_evidence_refs": {
      "type": "array",
      "minItems": 11,
      "maxItems": 11,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/repo_ref" }
    },
    "accepted_evidence_refs": { "$ref": "#/$defs/empty_refs" },
    "rejected_evidence_refs": { "$ref": "#/$defs/empty_refs" },
    "authority_grant_refs": { "$ref": "#/$defs/empty_refs" },
    "blocked_actions": {
      "type": "array",
      "minItems": 7,
      "maxItems": 7,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/identifier" }
    },
    "summary": { "$ref": "#/$defs/summary" },
    "validators": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/repo_ref" }
    },
    "next_action": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "repo_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9._~:/@+ -]+$"
    },
    "empty_refs": {
      "type": "array",
      "maxItems": 0,
      "items": { "$ref": "#/$defs/repo_ref" }
    },
    "submitted_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "submitted_record_id",
        "source_status_record_id",
        "source_input_id",
        "input_kind",
        "required_names",
        "submission_state",
        "review_state",
        "proof_state",
        "submitted_for_review",
        "accepted",
        "rejected",
        "authority_granted",
        "runtime_enablement_allowed",
        "runtime_dispatch_allowed",
        "worker_invocation_allowed",
        "runtime_receipt_emission_allowed",
        "receipt_append_allowed",
        "terminal_closure_allowed",
        "submitted_evidence_refs",
        "missing_evidence_names",
        "candidate_ref_kind",
        "candidate_ref_satisfies_required_name",
        "record_is_not_acceptance",
        "record_is_not_authorization",
        "record_is_not_runtime_enablement",
        "record_is_not_dispatch",
        "record_is_not_worker_invocation",
        "record_is_not_receipt_emission",
        "record_is_not_receipt_append",
        "record_is_not_terminal_closure",
        "blocked_action_refs",
        "review_note",
        "next_action"
      ],
      "properties": {
        "submitted_record_id": { "$ref": "#/$defs/identifier" },
        "source_status_record_id": { "$ref": "#/$defs/identifier" },
        "source_input_id": { "$ref": "#/$defs/identifier" },
        "input_kind": { "$ref": "#/$defs/identifier" },
        "required_names": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/identifier" } },
        "submission_state": { "enum": ["submitted_for_review", "awaiting_operator_evidence"] },
        "review_state": { "const": "not_evaluated" },
        "proof_state": { "const": "Unknown" },
        "submitted_for_review": { "type": "boolean" },
        "accepted": { "const": false },
        "rejected": { "const": false },
        "authority_granted": { "const": false },
        "runtime_enablement_allowed": { "const": false },
        "runtime_dispatch_allowed": { "const": false },
        "worker_invocation_allowed": { "const": false },
        "runtime_receipt_emission_allowed": { "const": false },
        "receipt_append_allowed": { "const": false },
        "terminal_closure_allowed": { "const": false },
        "submitted_evidence_refs": { "type": "array", "maxItems": 1, "items": { "$ref": "#/$defs/repo_ref" } },
        "missing_evidence_names": { "type": "array", "items": { "$ref": "#/$defs/identifier" } },
        "candidate_ref_kind": { "enum": ["foundation_witness_ref", "missing_operator_input"] },
        "candidate_ref_satisfies_required_name": { "const": false },
        "record_is_not_acceptance": { "const": true },
        "record_is_not_authorization": { "const": true },
        "record_is_not_runtime_enablement": { "const": true },
        "record_is_not_dispatch": { "const": true },
        "record_is_not_worker_invocation": { "const": true },
        "record_is_not_receipt_emission": { "const": true },
        "record_is_not_receipt_append": { "const": true },
        "record_is_not_terminal_closure": { "const": true },
        "blocked_action_refs": { "type": "array", "minItems": 7, "maxItems": 7, "items": { "$ref": "#/$defs/identifier" } },
        "review_note": { "type": "string", "minLength": 1 },
        "next_action": { "type": "string", "minLength": 1 }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source_required_input_count": { "const": 12 },
        "submitted_record_count": { "const": 12 },
        "records_with_repo_ref_count": { "const": 11 },
        "records_awaiting_operator_evidence_count": { "const": 1 },
        "submitted_evidence_ref_count": { "const": 11 },
        "accepted_evidence_count": { "const": 0 },
        "rejected_evidence_count": { "const": 0 },
        "authority_grant_count": { "const": 0 },
        "runtime_enablement_count": { "const": 0 },
        "dispatch_count": { "const": 0 },
        "worker_invocation_count": { "const": 0 },
        "receipt_emission_count": { "const": 0 },
        "receipt_append_count": { "const": 0 },
        "terminal_closure_count": { "const": 0 },
        "unknown_proof_state_count": { "const": 12 },
        "blocked_action_count": { "const": 7 }
      },
      "required": [
        "source_required_input_count",
        "submitted_record_count",
        "records_with_repo_ref_count",
        "records_awaiting_operator_evidence_count",
        "submitted_evidence_ref_count",
        "accepted_evidence_count",
        "rejected_evidence_count",
        "authority_grant_count",
        "runtime_enablement_count",
        "dispatch_count",
        "worker_invocation_count",
        "receipt_emission_count",
        "receipt_append_count",
        "terminal_closure_count",
        "unknown_proof_state_count",
        "blocked_action_count"
      ]
    }
  }
}
