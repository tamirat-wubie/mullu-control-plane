{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:model-response:1",
  "title": "Model Response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "response_id",
    "invocation_id",
    "status",
    "output_digest",
    "completed_at",
    "validation_status"
  ],
  "properties": {
    "response_id": {
      "type": "string",
      "minLength": 1
    },
    "invocation_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "succeeded",
        "failed",
        "timeout"
      ]
    },
    "output_digest": {
      "type": "string",
      "minLength": 1
    },
    "output_tokens": {
      "type": "integer",
      "minimum": 0
    },
    "actual_cost": {
      "type": "number",
      "minimum": 0
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    },
    "validation_status": {
      "type": "string",
      "enum": [
        "passed",
        "failed",
        "pending"
      ]
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
