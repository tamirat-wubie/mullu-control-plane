{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:spatial-map:1",
  "title": "Spatial Governance Map",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "frame",
    "entities",
    "regions",
    "boundaries",
    "paths",
    "metrics",
    "judgments",
    "blockers",
    "witness"
  ],
  "properties": {
    "frame": {
      "type": "string",
      "minLength": 1
    },
    "entities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/entity"
      }
    },
    "regions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/region"
      }
    },
    "boundaries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/boundary"
      }
    },
    "paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/path"
      }
    },
    "metrics": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/metric"
      }
    },
    "judgments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/judgment"
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "witness": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "entity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "region"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "region": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "region": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "trust"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "trust": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "separates",
        "rule"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "separates": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "rule": {
          "enum": [
            "allow",
            "block",
            "requires_evidence"
          ]
        }
      }
    },
    "path": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "source",
        "target",
        "crosses"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "crosses": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "metric": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "value"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "judgment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path_id",
        "status",
        "reasons",
        "witness"
      ],
      "properties": {
        "path_id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": [
            "allowed",
            "blocked",
            "unknown"
          ]
        },
        "reasons": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "witness": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
