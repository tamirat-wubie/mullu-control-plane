{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:agentic-service-harness-github-pr-branch-write-authority-binding:1",
  "title": "Agentic Service Harness GitHub PR Branch Write Authority Binding",
  "description": "Foundation Mode witness request for GitHub pull-request branch-write authority after command-preview-bound operator response evidence. This schema records the authority binding requirement only and does not execute commands, create branches, open pull requests, write repositories, call connectors, admit mutation routes, append receipt stores, deploy, mutate DNS, serialize secrets, perform destructive operations, or provide terminal closure.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "binding_id",
    "schema_version",
    "generated_at",
    "solver_outcome",
    "source_response_command_preview_binding_ref",
    "witness_kind",
    "requested_evidence_ref",
    "binding_status",
    "authority_binding_collected",
    "authority_granted",
    "planning_only",
    "read_only",
    "report_is_not_terminal_closure",
    "terminal_closure",
    "scope",
    "branch_write_binding",
    "command_preview_operator_response_evidence",
    "remaining_witnesses",
    "authority_denials",
    "effect_boundary",
    "receipt_refs",
    "validators",
    "next_action"
  ],
  "properties": {
    "binding_id": {
      "type": "string",
      "const": "agentic_service_harness_github_pr_branch_write_authority_binding"
    },
    "schema_version": { "type": "integer", "const": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "solver_outcome": { "type": "string", "const": "AwaitingEvidence" },
    "source_response_command_preview_binding_ref": {
      "type": "string",
      "const": "examples/agentic_service_harness_github_pr_operator_response_command_preview_binding.foundation.json"
    },
    "witness_kind": { "type": "string", "const": "branch_write_authority_binding" },
    "requested_evidence_ref": { "$ref": "#/$defs/evidence_ref" },
    "binding_status": {
      "type": "string",
      "const": "AwaitingEvidence"
    },
    "authority_binding_collected": { "type": "boolean", "const": false },
    "authority_granted": { "type": "boolean", "const": false },
    "planning_only": { "type": "boolean", "const": true },
    "read_only": { "type": "boolean", "const": true },
    "report_is_not_terminal_closure": { "type": "boolean", "const": true },
    "terminal_closure": { "type": "boolean", "const": false },
    "scope": { "$ref": "#/$defs/scope" },
    "branch_write_binding": { "$ref": "#/$defs/branch_write_binding" },
    "command_preview_operator_response_evidence": {
      "$ref": "#/$defs/command_preview_operator_response_evidence"
    },
    "remaining_witnesses": {
      "type": "array",
      "minItems": 7,
      "maxItems": 7,
      "items": { "$ref": "#/$defs/remaining_witness" },
      "uniqueItems": true
    },
    "authority_denials": { "$ref": "#/$defs/authority_denials" },
    "effect_boundary": { "$ref": "#/$defs/effect_boundary" },
    "receipt_refs": { "$ref": "#/$defs/receipt_refs" },
    "validators": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/validator_ref" }
    },
    "next_action": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "evidence_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/#$<>-]*$"
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tenant_id",
        "organization_id",
        "project_id",
        "repository_connection_id",
        "repository_slug",
        "task_service_id",
        "foundation_phase",
        "read_only"
      ],
      "properties": {
        "tenant_id": { "$ref": "#/$defs/identifier" },
        "organization_id": { "$ref": "#/$defs/identifier" },
        "project_id": { "$ref": "#/$defs/identifier" },
        "repository_connection_id": { "$ref": "#/$defs/identifier" },
        "repository_slug": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
        },
        "task_service_id": {
          "type": "string",
          "const": "github-repo-task-service-read-only-foundation"
        },
        "foundation_phase": {
          "type": "string",
          "const": "foundation_pr_branch_write_command_preview_response_bound"
        },
        "read_only": { "type": "boolean", "const": true }
      }
    },
    "branch_write_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "authority_request_id",
        "source_approval_request_id",
        "source_response_record_ref",
        "requires_command_preview_operator_response_witness",
        "command_preview_operator_response_binding_ref",
        "operator_response_witness_ref",
        "operator_approval_request_command_preview_binding_ref",
        "actual_diff_operator_response_witness_ref",
        "actual_diff_approval_request_binding_ref",
        "actual_non_empty_diff_receipt_ref",
        "changed_file_refs",
        "diff_refs",
        "redacted_diff_bundle_ref",
        "redacted_output_ref",
        "command_preview_ref",
        "redacted_command_preview",
        "argument_vector_template",
        "placeholder_refs",
        "required_authority_kind",
        "required_evidence_ref",
        "response_witness_required",
        "response_witness_satisfied",
        "command_preview_bound",
        "operator_response_bound",
        "branch_write_authority_required",
        "branch_write_authority_collected",
        "branch_write_authority_effect",
        "pr_creation_authorized_after_binding",
        "required_before_execution_refs"
      ],
      "properties": {
        "authority_request_id": {
          "type": "string",
          "const": "authority-binding.github-pr-branch-write"
        },
        "source_approval_request_id": {
          "type": "string",
          "const": "approval-request.github-pr-admission"
        },
        "source_response_record_ref": { "$ref": "#/$defs/evidence_ref" },
        "requires_command_preview_operator_response_witness": { "type": "boolean", "const": true },
        "command_preview_operator_response_binding_ref": {
          "type": "string",
          "const": "examples/agentic_service_harness_github_pr_operator_response_command_preview_binding.foundation.json"
        },
        "operator_response_witness_ref": {
          "type": "string",
          "const": "examples/agentic_service_harness_github_pr_operator_response_witness.foundation.json"
        },
        "operator_approval_request_command_preview_binding_ref": {
          "type": "string",
          "const": "examples/agentic_service_harness_github_pr_operator_approval_request_command_preview_binding.foundation.json"
        },
        "actual_diff_operator_response_witness_ref": {
          "type": "string",
