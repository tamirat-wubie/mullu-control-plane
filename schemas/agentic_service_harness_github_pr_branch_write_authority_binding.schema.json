        "source_response_command_preview_binding_ref": {
          "type": "string",
          "const": "examples/agentic_service_harness_github_pr_operator_response_command_preview_binding.foundation.json"
        },
        "source_binding_id": {
          "type": "string",
          "const": "agentic_service_harness_github_pr_operator_response_command_preview_binding"
        },
