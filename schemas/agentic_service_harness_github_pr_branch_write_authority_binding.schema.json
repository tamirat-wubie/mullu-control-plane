          "type": "array",
          "minItems": 10,
          "items": { "$ref": "#/$defs/evidence_ref" },
          "uniqueItems": true
        },
        "source_blocked_reason_refs": {
          "type": "array",
          "minItems": 9,
          "items": { "$ref": "#/$defs/evidence_ref" },
          "uniqueItems": true
