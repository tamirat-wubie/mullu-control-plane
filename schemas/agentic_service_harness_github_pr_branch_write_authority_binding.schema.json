        "redacted_output_ref": {
          "type": "string",
          "const": "witness://filesystem-write-output-redacted"
        },
        "command_preview_ref": {
          "type": "string",
          "const": "examples/agentic_service_harness_github_pr_creation_command_preview.foundation.json"
        },
        "redacted_command_preview": {
          "type": "string",
          "const": "gh pr create --base main --head <branch-ref> --title <redacted-title-ref> --body-file <redacted-body-file-ref>"
        },
        "argument_vector_template": {
          "type": "array",
          "prefixItems": [
            { "type": "string", "const": "gh" },
            { "type": "string", "const": "pr" },
            { "type": "string", "const": "create" },
            { "type": "string", "const": "--base" },
            { "type": "string", "const": "main" },
            { "type": "string", "const": "--head" },
            { "type": "string", "const": "<branch-ref>" },
            { "type": "string", "const": "--title" },
            { "type": "string", "const": "<redacted-title-ref>" },
            { "type": "string", "const": "--body-file" },
            { "type": "string", "const": "<redacted-body-file-ref>" }
          ],
          "minItems": 11,
          "maxItems": 11
        },
        "placeholder_refs": {
          "type": "array",
          "prefixItems": [
            { "type": "string", "const": "placeholder://branch-ref" },
            { "type": "string", "const": "placeholder://redacted-title-ref" },
            { "type": "string", "const": "placeholder://redacted-body-file-ref" }
          ],
          "minItems": 3,
          "maxItems": 3
        },
        "required_authority_kind": {
          "type": "string",
          "const": "branch_write_authority"
        },
        "required_evidence_ref": { "$ref": "#/$defs/evidence_ref" },
        "response_witness_required": { "type": "boolean", "const": true },
        "response_witness_satisfied": { "type": "boolean", "const": false },
        "command_preview_bound": { "type": "boolean", "const": true },
        "operator_response_bound": { "type": "boolean", "const": true },
        "branch_write_authority_required": { "type": "boolean", "const": true },
        "branch_write_authority_collected": { "type": "boolean", "const": false },
        "branch_write_authority_effect": {
          "type": "string",
          "const": "permits_branch_workspace_request_only_after_separate_uao"
        },
        "pr_creation_authorized_after_binding": { "type": "boolean", "const": false },
        "required_before_execution_refs": {
          "type": "array",
          "minItems": 10,
          "items": { "$ref": "#/$defs/evidence_ref" },
          "uniqueItems": true
        }
      }
    },
    "remaining_witness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "witness_kind",
        "status",
        "evidence_ref",
        "blocks_pr_admission",
        "authority_granted"
      ],
      "properties": {
        "witness_kind": {
          "type": "string",
