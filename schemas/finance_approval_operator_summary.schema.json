{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:finance-approval-operator-summary:1",
  "title": "Finance Approval Operator Summary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "summary_id",
    "checked_at",
    "packet_id",
    "packet_ok",
    "packet_ready",
    "packet_status",
    "chain_ok",
    "chain_ready",
    "promotion_mode",
    "strict_promotion_command",
    "readiness_blockers",
    "next_actions",
    "artifact_statuses",
    "must_not_claim"
  ],
  "properties": {
    "summary_id": {
      "type": "string",
      "pattern": "^finance-operator-summary-[0-9a-f]{16}$"
    },
    "checked_at": {
      "type": "string",
      "format": "date-time"
    },
    "packet_id": {
      "type": "string",
      "pattern": "^finance-handoff-packet-[0-9a-f]{16}$"
    },
    "packet_ok": {
      "type": "boolean"
    },
    "packet_ready": {
      "type": "boolean"
    },
    "packet_status": {
      "type": "string",
      "enum": [
        "ready",
        "blocked"
      ]
    },
    "chain_ok": {
      "type": "boolean"
    },
    "chain_ready": {
      "type": "boolean"
    },
    "promotion_mode": {
      "type": "string",
      "enum": [
        "proof-pilot-blocked",
        "live-email-handoff"
      ]
    },
    "strict_promotion_command": {
      "type": "string",
      "minLength": 1
    },
    "readiness_blockers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "next_actions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "artifact_statuses": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "must_not_claim": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
