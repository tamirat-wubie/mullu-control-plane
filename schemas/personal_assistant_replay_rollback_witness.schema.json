{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:personal-assistant-replay-rollback-witness:1",
  "title": "Personal Assistant Replay Rollback Witness",
  "description": "Foundation Mode no-effect witness that records replay plan refs, rollback plan refs, and idempotency refs after worker/replay preflight without authorizing execution.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "witness_set_id",
    "generated_at",
    "governed",
    "source_projection",
    "source_preflight_set_id",
    "witness_count",
    "witness_ids",
    "preflight_ids",
    "receipt_ids",
    "witnesses",
    "effect_boundary",
    "private_payload_policy",
    "assurance",
    "metadata"
  ],
  "properties": {
    "witness_set_id": {"type": "string", "pattern": "^pa_replay_rollback_witness_[a-z0-9][a-z0-9_:-]*$"},
    "generated_at": {"type": "string", "minLength": 1},
    "governed": {"const": true},
    "source_projection": {"const": "worker_replay_preflight"},
    "source_preflight_set_id": {"type": "string", "pattern": "^pa_worker_replay_preflight_[a-z0-9][a-z0-9_:-]*$"},
    "witness_count": {"type": "integer", "minimum": 1},
    "witness_ids": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "pattern": "^pa_replay_rollback_witness_item_[a-z0-9][a-z0-9_:-]*$"},
      "uniqueItems": true
    },
    "preflight_ids": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "pattern": "^pa_worker_replay_preflight_item_[a-z0-9][a-z0-9_:-]*$"},
      "uniqueItems": true
    },
    "receipt_ids": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "pattern": "^pa_receipt_[a-z0-9][a-z0-9_:-]*$"},
      "uniqueItems": true
    },
    "witnesses": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/witness_item"}
    },
    "effect_boundary": {"$ref": "#/$defs/effect_boundary"},
    "private_payload_policy": {"$ref": "#/$defs/private_payload_policy"},
    "assurance": {"$ref": "#/$defs/assurance"},
    "metadata": {"$ref": "#/$defs/metadata"}
  },
  "$defs": {
    "digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "witness_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "witness_id",
        "preflight_id",
        "approval_id",
        "request_id",
        "plan_id",
        "skill_id",
        "risk_level",
        "worker_replay_preflight_ref",
        "replay_plan_witness",
        "rollback_plan_witness",
        "idempotency_witness",
        "dispatch_blockers",
        "receipt"
      ],
      "properties": {
        "witness_id": {"type": "string", "pattern": "^pa_replay_rollback_witness_item_[a-z0-9][a-z0-9_:-]*$"},
        "preflight_id": {"type": "string", "pattern": "^pa_worker_replay_preflight_item_[a-z0-9][a-z0-9_:-]*$"},
        "approval_id": {"type": "string", "pattern": "^pa_approval_[a-z0-9][a-z0-9_:-]*$"},
        "request_id": {"type": "string", "pattern": "^pa_request_[a-z0-9][a-z0-9_:-]*$"},
        "plan_id": {"type": "string", "pattern": "^pa_plan_[a-z0-9][a-z0-9_:-]*$"},
        "skill_id": {"type": "string", "pattern": "^[a-z][a-z0-9_]*(\\.[a-z0-9_]+)+$"},
        "risk_level": {"enum": ["P3", "P4", "P5"]},
        "worker_replay_preflight_ref": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "source_preflight_set_id",
            "preflight_receipt_id",
            "preflight_receipt_state",
            "worker_binding_allowed",
            "replay_execution_allowed",
            "payload_digest_only"
          ],
          "properties": {
            "source_preflight_set_id": {"type": "string", "minLength": 1},
            "preflight_receipt_id": {"type": "string", "pattern": "^pa_receipt_[a-z0-9][a-z0-9_:-]*$"},
            "preflight_receipt_state": {"const": "deferred"},
            "worker_binding_allowed": {"const": false},
            "replay_execution_allowed": {"const": false},
            "payload_digest_only": {"const": true}
          }
        },
        "replay_plan_witness": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "replay_plan_required",
            "replay_plan_ref",
            "replay_plan_digest",
            "replay_plan_state",
            "replay_plan_validated",
            "replay_scope",
            "replay_payload_projection",
            "replay_execution_allowed"
          ],
          "properties": {
            "replay_plan_required": {"const": true},
            "replay_plan_ref": {"type": "string", "pattern": "^proof://personal-assistant/replay-plan/pa_approval_[a-z0-9][a-z0-9_:-]*$"},
            "replay_plan_digest": {"$ref": "#/$defs/digest"},
            "replay_plan_state": {"const": "recorded_validated"},
            "replay_plan_validated": {"const": true},
            "replay_scope": {"const": "single_approval_projection"},
            "replay_payload_projection": {"const": "digest_only"},
            "replay_execution_allowed": {"const": false}
          }
        },
        "rollback_plan_witness": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "rollback_plan_required",
            "rollback_plan_ref",
            "rollback_plan_digest",
            "rollback_plan_state",
            "rollback_plan_validated",
            "rollback_scope",
            "compensation_required_after_execution",
            "rollback_execution_allowed"
          ],
          "properties": {
            "rollback_plan_required": {"const": true},
            "rollback_plan_ref": {"type": "string", "pattern": "^proof://personal-assistant/rollback-plan/pa_approval_[a-z0-9][a-z0-9_:-]*$"},
            "rollback_plan_digest": {"$ref": "#/$defs/digest"},
            "rollback_plan_state": {"const": "recorded_validated"},
            "rollback_plan_validated": {"const": true},
            "rollback_scope": {"const": "no_effect_before_execution"},
            "compensation_required_after_execution": {"const": true},
            "rollback_execution_allowed": {"const": false}
          }
        },
        "idempotency_witness": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "idempotency_key_required",
            "idempotency_key_ref",
            "idempotency_key_digest",
            "idempotency_key_present",
            "idempotency_key_serialized",
            "idempotency_window_ref",
            "idempotency_window_validated"
          ],
          "properties": {
            "idempotency_key_required": {"const": true},
            "idempotency_key_ref": {"type": "string", "pattern": "^idempotency://personal-assistant/pa_approval_[a-z0-9][a-z0-9_:-]*$"},
            "idempotency_key_digest": {"$ref": "#/$defs/digest"},
            "idempotency_key_present": {"const": true},
            "idempotency_key_serialized": {"const": false},
            "idempotency_window_ref": {"type": "string", "pattern": "^temporal://personal-assistant/idempotency-window/pa_approval_[a-z0-9][a-z0-9_:-]*$"},
            "idempotency_window_validated": {"const": true}
          }
        },
        "dispatch_blockers": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "execution_worker_bound",
            "worker_binding_state",
            "live_connector_witness_present",
            "dispatch_lease_present",
            "operator_reapproval_required",
            "execution_allowed"
          ],
          "properties": {
            "execution_worker_bound": {"const": false},
            "worker_binding_state": {"const": "unbound"},
            "live_connector_witness_present": {"const": false},
            "dispatch_lease_present": {"const": false},
            "operator_reapproval_required": {"const": true},
            "execution_allowed": {"const": false}
          }
        },
        "receipt": {"type": "object", "additionalProperties": true}
      }
    },
    "effect_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "replay_rollback_witness_allowed",
        "replay_plan_binding_allowed",
        "rollback_plan_binding_allowed",
        "idempotency_ref_binding_allowed",
        "worker_binding_allowed",
        "dispatch_lease_binding_allowed",
        "replay_execution_allowed",
        "rollback_execution_allowed",
        "execution_allowed",
        "live_connector_execution_allowed",
        "external_send_allowed",
        "calendar_write_allowed",
        "task_write_allowed",
        "memory_write_allowed",
        "connector_mutation_allowed",
        "system_of_record_write_allowed",
        "deployment_mutation_allowed",
        "nested_mind_live_activation_allowed",
        "public_readiness_claim_allowed"
      ],
      "properties": {
        "replay_rollback_witness_allowed": {"const": true},
        "replay_plan_binding_allowed": {"const": true},
        "rollback_plan_binding_allowed": {"const": true},
        "idempotency_ref_binding_allowed": {"const": true},
        "worker_binding_allowed": {"const": false},
        "dispatch_lease_binding_allowed": {"const": false},
        "replay_execution_allowed": {"const": false},
        "rollback_execution_allowed": {"const": false},
        "execution_allowed": {"const": false},
        "live_connector_execution_allowed": {"const": false},
        "external_send_allowed": {"const": false},
        "calendar_write_allowed": {"const": false},
        "task_write_allowed": {"const": false},
        "memory_write_allowed": {"const": false},
        "connector_mutation_allowed": {"const": false},
        "system_of_record_write_allowed": {"const": false},
        "deployment_mutation_allowed": {"const": false},
        "nested_mind_live_activation_allowed": {"const": false},
        "public_readiness_claim_allowed": {"const": false}
      }
    },
    "private_payload_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raw_private_payload_serialized",
        "secret_values_serialized",
        "connector_payload_projection",
        "plan_payload_projection",
        "idempotency_key_projection"
      ],
      "properties": {
        "raw_private_payload_serialized": {"const": false},
        "secret_values_serialized": {"const": false},
        "connector_payload_projection": {"const": "ref_only"},
        "plan_payload_projection": {"const": "digest_only"},
        "idempotency_key_projection": {"const": "digest_only"}
      }
    },
    "assurance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "assurance_id",
        "outcome",
        "foundation_only",
        "ready_for_live_execution",
        "ready_for_customer_readiness_claim",
        "authority_drift_detected",
        "checked_controls",
        "blocking_reasons",
        "next_action"
      ],
      "properties": {
        "assurance_id": {"const": "personal_assistant_replay_rollback_witness_no_effect_assurance"},
        "outcome": {"enum": ["SolvedVerified", "GovernanceBlocked"]},
        "foundation_only": {"const": true},
        "ready_for_live_execution": {"const": false},
        "ready_for_customer_readiness_claim": {"const": false},
        "authority_drift_detected": {"type": "boolean"},
        "checked_controls": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "blocking_reasons": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "next_action": {"type": "string", "minLength": 1}
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "foundation_only",
        "projection_contract",
        "runtime_boundary",
        "live_connector_execution_allowed",
        "connector_mutation_allowed",
        "external_send_allowed",
        "system_of_record_write_allowed",
        "memory_write_allowed"
      ],
      "properties": {
        "foundation_only": {"const": true},
        "projection_contract": {"const": "replay_rollback_witness_evidence_only"},
        "runtime_boundary": {"const": "witness_records_replay_rollback_refs_without_execution"},
        "live_connector_execution_allowed": {"const": false},
        "connector_mutation_allowed": {"const": false},
        "external_send_allowed": {"const": false},
        "system_of_record_write_allowed": {"const": false},
        "memory_write_allowed": {"const": false}
      }
    }
  }
}
