{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:agentic-service-harness-loopstatus-projection:1",
  "title": "Agentic Service Harness LoopStatus Projection",
  "description": "Read-only LoopStatus projection for the Mullusi Agentic Service Harness. This contract binds harness project LoopStatus refs to the holistic loop read model without registering loops, executing transitions, granting authority, admitting dashboard UI, creating tasks, or claiming terminal closure.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "report_id",
    "schema_version",
    "generated_at",
    "scope",
    "source_contract_refs",
    "loop_status_projection",
    "readiness_gates",
    "authority_denials",
    "validators",
    "next_action",
    "report_is_not_terminal_closure",
    "terminal_closure_required"
  ],
  "properties": {
    "report_id": { "type": "string", "const": "agentic_service_harness_loopstatus_projection" },
    "schema_version": { "type": "integer", "const": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "scope": { "$ref": "#/$defs/scope" },
    "source_contract_refs": {
      "type": "array",
      "minItems": 6,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/ref" }
    },
    "loop_status_projection": { "$ref": "#/$defs/loop_status_projection" },
    "readiness_gates": { "$ref": "#/$defs/readiness_gates" },
    "authority_denials": { "$ref": "#/$defs/authority_denials" },
    "validators": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/validator_ref" }
    },
    "next_action": { "type": "string", "minLength": 1 },
    "report_is_not_terminal_closure": { "type": "boolean", "const": true },
    "terminal_closure_required": { "type": "boolean", "const": true }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/#$-]*$"
    },
    "ref_list": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/ref" }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tenant_id",
        "project_id",
        "loop_status_ref",
        "read_only",
        "projection_only",
        "loop_registration_admitted",
        "status_transition_admitted",
        "runtime_execution_admitted",
        "secret_values_serialized",
        "terminal_closure_granted"
      ],
      "properties": {
        "tenant_id": { "$ref": "#/$defs/identifier" },
        "project_id": { "$ref": "#/$defs/identifier" },
        "loop_status_ref": { "$ref": "#/$defs/ref" },
        "read_only": { "type": "boolean", "const": true },
        "projection_only": { "type": "boolean", "const": true },
        "loop_registration_admitted": { "type": "boolean", "const": false },
        "status_transition_admitted": { "type": "boolean", "const": false },
        "runtime_execution_admitted": { "type": "boolean", "const": false },
        "secret_values_serialized": { "type": "boolean", "const": false },
        "terminal_closure_granted": { "type": "boolean", "const": false }
      }
    },
    "loop_status_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project_id",
        "loop_status_ref",
        "source_report_id",
        "source_report_status",
        "source_report_ref",
        "source_loop_count",
        "source_returned_count",
        "projected_outcome",
        "projected_status",
        "proof_state",
        "blocker_refs",
        "evidence_refs",
        "authority_gap_refs",
        "read_only",
        "projection_only",
        "status_transition",
        "loop_registration",
        "runtime_execution",
        "terminal_closure"
      ],
      "properties": {
        "project_id": { "$ref": "#/$defs/identifier" },
        "loop_status_ref": { "$ref": "#/$defs/ref" },
        "source_report_id": { "type": "string", "const": "holistic_loop_read_model" },
        "source_report_status": { "type": "string", "enum": ["blocked", "verified"] },
        "source_report_ref": { "$ref": "#/$defs/ref" },
        "source_loop_count": { "type": "integer", "minimum": 0 },
        "source_returned_count": { "type": "integer", "minimum": 0 },
        "projected_outcome": { "type": "string", "enum": ["AwaitingEvidence", "SolvedUnverified"] },
        "projected_status": { "type": "string", "enum": ["blocked", "verified"] },
        "proof_state": { "type": "string", "enum": ["Unknown", "Pass"] },
        "blocker_refs": { "$ref": "#/$defs/ref_list" },
        "evidence_refs": { "$ref": "#/$defs/ref_list" },
        "authority_gap_refs": { "$ref": "#/$defs/ref_list" },
        "read_only": { "type": "boolean", "const": true },
        "projection_only": { "type": "boolean", "const": true },
        "status_transition": { "type": "boolean", "const": false },
        "loop_registration": { "type": "boolean", "const": false },
        "runtime_execution": { "type": "boolean", "const": false },
        "terminal_closure": { "type": "boolean", "const": false }
      }
    },
    "readiness_gates": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dashboard_data_contract_closed",
        "receipt_evidence_read_models_closed",
        "dashboard_ui_admitted",
        "task_creation_route_admitted",
        "loop_registration_admitted",
        "terminal_closure_granted",
        "missing_evidence_policy",
        "required_before_task_creation_refs",
        "blocked_reason_refs"
      ],
      "properties": {
        "dashboard_data_contract_closed": { "type": "boolean", "const": true },
        "receipt_evidence_read_models_closed": { "type": "boolean", "const": true },
        "dashboard_ui_admitted": { "type": "boolean", "const": false },
        "task_creation_route_admitted": { "type": "boolean", "const": false },
        "loop_registration_admitted": { "type": "boolean", "const": false },
        "terminal_closure_granted": { "type": "boolean", "const": false },
        "missing_evidence_policy": { "type": "string", "const": "AwaitingEvidence" },
        "required_before_task_creation_refs": { "$ref": "#/$defs/ref_list" },
        "blocked_reason_refs": { "$ref": "#/$defs/ref_list" }
      }
    },
    "authority_denials": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "loop_registration",
        "status_transition",
        "runtime_execution",
        "dashboard_ui",
        "task_creation_route",
        "mutation_endpoint",
        "receipt_store_append",
        "external_adapter_execution",
        "secret_serialization",
        "terminal_closure"
      ],
      "properties": {
        "loop_registration": { "type": "boolean", "const": false },
        "status_transition": { "type": "boolean", "const": false },
        "runtime_execution": { "type": "boolean", "const": false },
        "dashboard_ui": { "type": "boolean", "const": false },
        "task_creation_route": { "type": "boolean", "const": false },
        "mutation_endpoint": { "type": "boolean", "const": false },
        "receipt_store_append": { "type": "boolean", "const": false },
        "external_adapter_execution": { "type": "boolean", "const": false },
        "secret_serialization": { "type": "boolean", "const": false },
        "terminal_closure": { "type": "boolean", "const": false }
      }
    },
    "validator_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["validator_id", "command", "required_for_closure"],
      "properties": {
        "validator_id": { "$ref": "#/$defs/identifier" },
        "command": { "type": "string", "minLength": 1 },
        "required_for_closure": { "type": "boolean", "const": true }
      }
    }
  }
}
