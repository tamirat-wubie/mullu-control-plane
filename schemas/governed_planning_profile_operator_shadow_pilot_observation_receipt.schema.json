{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:governed-planning-profile-operator-shadow-pilot-observation-receipt:1",
  "title": "Governed Planning Profile Operator Shadow-Pilot Observation Receipt",
  "description": "Read-only local receipt for collected GovernedPlanningProfile shadow-pilot observations that does not grant runtime promotion.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receipt_id",
    "schema_version",
    "profile_id",
    "observed_at",
    "solver_outcome",
    "operator_observation_status",
    "operator_observation_collected",
    "local_observation_only",
    "read_only",
    "mutation_route",
    "runtime_behavior_change",
    "runtime_promotion_authorized",
    "execution_allowed",
    "dispatch_allowed",
    "runtime_replanning_enabled",
    "success_claim_allowed",
    "terminal_closure",
    "source_evidence_request",
    "source_dossier",
    "expected_plan_classes",
    "scenario_observations",
    "observation_summary",
    "remaining_promotion_gates",
    "authority_denials",
    "evidence_refs",
    "validators",
    "next_action",
    "receipt_hash"
  ],
  "properties": {
    "receipt_id": {
      "type": "string",
      "pattern": "^governed-planning-profile-operator-shadow-pilot-observation-receipt-[a-f0-9]{16}$"
    },
    "schema_version": {
      "type": "string",
      "const": "governed_planning_profile_operator_shadow_pilot_observation_receipt.v1"
    },
    "profile_id": {
      "type": "string",
      "const": "governed-planning-profile-foundation-v1"
    },
    "observed_at": {
      "type": "string",
      "const": "2026-06-19T00:00:00Z"
    },
    "solver_outcome": {
      "type": "string",
      "const": "AwaitingEvidence"
    },
    "operator_observation_status": {
      "type": "string",
      "const": "Collected"
    },
    "operator_observation_collected": { "type": "boolean", "const": true },
    "local_observation_only": { "type": "boolean", "const": true },
    "read_only": { "type": "boolean", "const": true },
    "mutation_route": { "type": "boolean", "const": false },
    "runtime_behavior_change": { "type": "boolean", "const": false },
    "runtime_promotion_authorized": { "type": "boolean", "const": false },
    "execution_allowed": { "type": "boolean", "const": false },
    "dispatch_allowed": { "type": "boolean", "const": false },
    "runtime_replanning_enabled": { "type": "boolean", "const": false },
    "success_claim_allowed": { "type": "boolean", "const": false },
    "terminal_closure": { "type": "boolean", "const": false },
    "source_evidence_request": { "$ref": "#/$defs/source_evidence_request" },
    "source_dossier": { "$ref": "#/$defs/source_dossier" },
    "expected_plan_classes": {
      "type": "array",
      "prefixItems": [
        { "const": "uncompiled_conversation" },
        { "const": "read_only_search" },
        { "const": "compound_search_notification" },
        { "const": "high_risk_payment" },
        { "const": "world_contradiction_search" }
      ],
      "minItems": 5,
      "maxItems": 5
    },
    "scenario_observations": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": { "$ref": "#/$defs/scenario_observation" }
    },
    "observation_summary": { "$ref": "#/$defs/observation_summary" },
    "remaining_promotion_gates": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": { "$ref": "#/$defs/remaining_promotion_gate" }
    },
    "authority_denials": { "$ref": "#/$defs/authority_denials" },
    "evidence_refs": { "$ref": "#/$defs/non_empty_string_array" },
    "validators": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/validator_ref" }
    },
    "next_action": {
      "type": "string",
      "const": "obtain runtime promotion approval, replay/recovery witness, and terminal closure certificate before runtime promotion"
    },
    "receipt_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  },
  "$defs": {
    "source_evidence_request": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_id",
        "evidence_hash",
        "operator_evidence_status",
        "operator_observation_collected"
      ],
      "properties": {
        "evidence_id": {
          "type": "string",
          "pattern": "^governed-planning-profile-operator-shadow-pilot-evidence-[a-f0-9]{16}$"
        },
        "evidence_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "operator_evidence_status": {
          "type": "string",
          "const": "AwaitingEvidence"
        },
        "operator_observation_collected": { "type": "boolean", "const": false }
      }
    },
    "source_dossier": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dossier_id",
        "dossier_hash",
        "scenario_count",
        "report_count",
        "promotion_blocker_count",
        "shadow_mismatch_count",
        "status"
      ],
      "properties": {
        "dossier_id": {
          "type": "string",
          "pattern": "^governed-planning-profile-shadow-dossier-[a-f0-9]{16}$"
        },
        "dossier_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "scenario_count": { "type": "integer", "const": 5 },
        "report_count": { "type": "integer", "const": 5 },
        "promotion_blocker_count": { "type": "integer", "minimum": 1 },
        "shadow_mismatch_count": { "type": "integer", "const": 0 },
        "status": { "type": "string", "const": "verified" }
      }
    },
    "scenario_observation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scenario_id",
        "plan_class",
        "source_plan_id",
        "admission_report_id",
        "admission_decision",
        "shadow_parity_status",
        "solver_outcome",
        "risk_tier",
        "promotion_blocker_count",
        "shadow_mismatch_count",
        "operator_observation_status",
        "operator_observation_ref",
        "parity_confirmed",
        "observed_behavior_matches_projection",
        "runtime_promotion_ready"
      ],
      "properties": {
        "scenario_id": { "type": "string", "pattern": "^scenario-[a-z0-9-]+$" },
        "plan_class": {
          "type": "string",
          "enum": [
            "uncompiled_conversation",
            "read_only_search",
            "compound_search_notification",
            "high_risk_payment",
            "world_contradiction_search"
          ]
        },
        "source_plan_id": { "type": "string", "minLength": 1 },
        "admission_report_id": {
          "type": "string",
          "pattern": "^governed-planning-profile-admission-[a-f0-9]{16}$"
        },
        "admission_decision": {
          "type": "string",
          "enum": ["blocked", "shadow_parity_ready"]
        },
        "shadow_parity_status": {
          "type": "string",
          "enum": ["matched", "blocked"]
        },
        "solver_outcome": {
          "type": "string",
          "const": "AwaitingEvidence"
        },
        "risk_tier": { "type": "string", "minLength": 1 },
        "promotion_blocker_count": { "type": "integer", "minimum": 0 },
        "shadow_mismatch_count": { "type": "integer", "const": 0 },
        "operator_observation_status": {
          "type": "string",
          "const": "Collected"
        },
        "operator_observation_ref": {
          "type": "string",
          "pattern": "^receipt://governed-planning-profile/operator-shadow-pilot/[a-z0-9_]+$"
        },
        "parity_confirmed": { "type": "boolean", "const": true },
        "observed_behavior_matches_projection": { "type": "boolean", "const": true },
        "runtime_promotion_ready": { "type": "boolean", "const": false }
      }
    },
    "observation_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scenario_observation_count",
        "parity_confirmed_count",
        "projection_match_count",
        "runtime_promotion_ready_count",
        "remaining_promotion_gate_count"
      ],
      "properties": {
        "scenario_observation_count": { "type": "integer", "const": 5 },
        "parity_confirmed_count": { "type": "integer", "const": 5 },
        "projection_match_count": { "type": "integer", "const": 5 },
        "runtime_promotion_ready_count": { "type": "integer", "const": 0 },
        "remaining_promotion_gate_count": { "type": "integer", "const": 3 }
      }
    },
    "remaining_promotion_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gate_id",
        "status",
        "required_evidence_ref",
        "blocks_runtime_promotion"
      ],
      "properties": {
        "gate_id": {
          "type": "string",
          "enum": [
            "runtime_promotion_approval",
            "replay_recovery_witness",
            "terminal_closure_certificate"
          ]
        },
        "status": { "type": "string", "const": "AwaitingEvidence" },
        "required_evidence_ref": {
          "type": "string",
          "pattern": "^unknown://governed-planning-profile/[A-Za-z0-9._:/#-]+$"
        },
        "blocks_runtime_promotion": { "type": "boolean", "const": true }
      }
    },
    "authority_denials": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime_promotion_authorized",
        "execution_allowed",
        "dispatch_allowed",
        "runtime_replanning_enabled",
        "success_claim_allowed",
        "terminal_closure"
      ],
      "properties": {
        "runtime_promotion_authorized": { "type": "boolean", "const": false },
        "execution_allowed": { "type": "boolean", "const": false },
        "dispatch_allowed": { "type": "boolean", "const": false },
        "runtime_replanning_enabled": { "type": "boolean", "const": false },
        "success_claim_allowed": { "type": "boolean", "const": false },
        "terminal_closure": { "type": "boolean", "const": false }
      }
    },
    "validator_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["validator_id", "command"],
      "properties": {
        "validator_id": { "type": "string", "minLength": 1 },
        "command": { "type": "string", "minLength": 1 }
      }
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    }
  }
}
