{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:mullu-name-clearance-draft:1",
  "title": "Mullu Name Clearance Draft",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "packet_id",
    "candidate_name",
    "company_brand",
    "first_reference",
    "prepared_date",
    "timezone",
    "review_status",
    "final_decision",
    "public_paid_launch_allowed",
    "summary",
    "known_public_uses",
    "official_searches",
    "domain_candidates",
    "stop_conditions",
    "required_next_actions"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1"
    },
    "packet_id": {
      "type": "string",
      "minLength": 1
    },
    "candidate_name": {
      "type": "string",
      "const": "Mullu"
    },
    "company_brand": {
      "type": "string",
      "const": "Mullusi"
    },
    "first_reference": {
      "type": "string",
      "const": "Mullu, by Mullusi"
    },
    "prepared_date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "timezone": {
      "type": "string",
      "minLength": 1
    },
    "review_status": {
      "type": "string",
      "enum": [
        "draft",
        "in_review",
        "closed"
      ]
    },
    "final_decision": {
      "type": "string",
      "enum": [
        "pending",
        "proceed",
        "proceed_with_risk_controls",
        "hold",
        "rename"
      ]
    },
    "public_paid_launch_allowed": {
      "type": "boolean"
    },
    "summary": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "known_public_uses": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "surface",
          "relevance",
          "risk",
          "decision"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "surface": {
            "type": "string",
            "minLength": 1
          },
          "relevance": {
            "type": "string",
            "minLength": 1
          },
          "risk": {
            "type": "string",
            "minLength": 1
          },
          "decision": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "official_searches": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source",
          "url",
          "status",
          "required_queries"
        ],
        "properties": {
          "source": {
            "type": "string",
            "minLength": 1
          },
          "url": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "open",
              "complete",
              "blocked"
            ]
          },
          "required_queries": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "required_classes": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "domain_candidates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "domain",
          "priority",
          "role",
          "status"
        ],
        "properties": {
          "domain": {
            "type": "string",
            "minLength": 1
          },
          "priority": {
            "type": "integer",
            "minimum": 1
          },
          "role": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "stop_conditions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "required_next_actions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
