{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:governed-symbolic-loop-contract:1",
  "title": "Governed Symbolic Loop Contract",
  "description": "Read-only contract for a platform-wide governed symbolic loop after read-model registry admission and before runtime registration.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_id",
    "contract_version",
    "surface",
    "loop_name",
    "solver_outcome",
    "action_classes",
    "canonical_phases",
    "required_authority",
    "required_evidence",
    "deterministic_kernel_boundaries",
    "effect_bearing_guards",
    "non_runtime_guards",
    "receipt_envelope",
    "rollback_plan",
    "next_action",
    "evidence_refs"
  ],
  "properties": {
    "contract_id": { "type": "string", "minLength": 1 },
    "contract_version": { "type": "string", "const": "governed_symbolic_loop_contract.v1" },
    "surface": { "type": "string", "const": "foundation_governed_symbolic_loop_contract" },
    "loop_name": { "type": "string", "minLength": 1 },
    "solver_outcome": { "type": "string", "enum": ["AwaitingEvidence"] },
    "action_classes": {
      "type": "array",
      "minItems": 3,
      "items": { "type": "string", "enum": ["epistemic", "effect_bearing", "hybrid"] },
      "uniqueItems": true
    },
    "canonical_phases": {
      "type": "array",
      "minItems": 9,
      "items": {
        "type": "string",
        "enum": [
          "problem_compile",
          "action_classification",
          "governance_preflight",
          "capability_routing",
          "execution_or_observation",
          "verification",
          "receipt_emission",
          "rollback_or_recovery",
          "learning_admission"
        ]
      },
      "uniqueItems": true
    },
    "required_authority": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "required_evidence": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "deterministic_kernel_boundaries": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "effect_bearing_guards": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "uao_required",
        "phi_gov_required",
        "life_meaning_judgment_required",
        "rollback_or_recovery_required",
        "rejected_deltas_logged",
        "raw_reasoning_rejected",
        "learning_after_verification_only",
        "mfidel_atomicity_preserved"
      ],
      "properties": {
        "uao_required": { "type": "boolean", "const": true },
        "phi_gov_required": { "type": "boolean", "const": true },
        "life_meaning_judgment_required": { "type": "boolean", "const": true },
        "rollback_or_recovery_required": { "type": "boolean", "const": true },
        "rejected_deltas_logged": { "type": "boolean", "const": true },
        "raw_reasoning_rejected": { "type": "boolean", "const": true },
        "learning_after_verification_only": { "type": "boolean", "const": true },
        "mfidel_atomicity_preserved": { "type": "boolean", "const": true }
      }
    },
    "non_runtime_guards": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "read_only",
        "read_model_registry_admission_claimed",
        "runtime_registration_claimed",
        "execution_authority_granted",
        "connector_authority_granted",
        "deployment_claimed",
        "terminal_closure"
      ],
      "properties": {
        "read_only": { "type": "boolean", "const": true },
        "read_model_registry_admission_claimed": { "type": "boolean", "const": true },
        "runtime_registration_claimed": { "type": "boolean", "const": false },
        "execution_authority_granted": { "type": "boolean", "const": false },
        "connector_authority_granted": { "type": "boolean", "const": false },
        "deployment_claimed": { "type": "boolean", "const": false },
        "terminal_closure": { "type": "boolean", "const": false }
      }
    },
    "receipt_envelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "uao_ref",
        "causal_decision_trace_ref",
        "receipt_ref"
      ],
      "properties": {
        "uao_ref": { "type": "string", "minLength": 1 },
        "causal_decision_trace_ref": { "type": "string", "minLength": 1 },
        "receipt_ref": { "type": "string", "minLength": 1 }
      }
    },
    "rollback_plan": { "type": "string", "minLength": 1 },
    "next_action": { "type": "string", "minLength": 1 },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    }
  }
}
