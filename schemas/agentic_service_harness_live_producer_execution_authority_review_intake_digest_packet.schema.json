{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:agentic-service-harness-live-producer-execution-authority-review-intake-digest-packet:1",
  "title": "Agentic Service Harness Live Producer Execution Authority Review Intake Evidence Digest Packet",
  "description": "No-effect packet for future redacted live authority review intake evidence digests.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "packet_id",
    "schema_version",
    "generated_at",
    "solver_outcome",
    "packet_status",
    "source_review_intake_preflight_ref",
    "source_review_intake_preflight_status",
    "planning_only",
    "read_only",
    "digest_packet_ready",
    "digest_collection_started",
    "digest_collection_complete",
    "review_route_admitted",
    "input_collection_started",
    "input_collection_complete",
    "review_submitted",
    "live_producer_implemented",
    "live_execution_authorized",
    "authority_granted",
    "terminal_closure",
    "source_review_intake_preflight_binding",
    "digest_requirements",
    "missing_digest_requirements",
    "digest_policy",
    "authority_denials",
    "effect_boundary",
    "validators",
    "next_action"
  ],
  "properties": {
    "packet_id": {
      "type": "string",
      "const": "agentic-service-harness-live-producer-execution-authority-review-intake-digest-packet"
    },
    "schema_version": { "type": "integer", "const": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "solver_outcome": { "type": "string", "const": "AwaitingEvidence" },
    "packet_status": {
      "type": "string",
      "const": "blocked_awaiting_redacted_review_intake_evidence_digests"
    },
    "source_review_intake_preflight_ref": { "type": "string" },
    "source_review_intake_preflight_status": {
      "type": "string",
      "const": "blocked_awaiting_redacted_live_authority_review_intake"
    },
    "planning_only": { "type": "boolean", "const": true },
    "read_only": { "type": "boolean", "const": true },
    "digest_packet_ready": { "type": "boolean", "const": true },
    "digest_collection_started": { "type": "boolean", "const": false },
    "digest_collection_complete": { "type": "boolean", "const": false },
    "review_route_admitted": { "type": "boolean", "const": false },
    "input_collection_started": { "type": "boolean", "const": false },
    "input_collection_complete": { "type": "boolean", "const": false },
    "review_submitted": { "type": "boolean", "const": false },
    "live_producer_implemented": { "type": "boolean", "const": false },
    "live_execution_authorized": { "type": "boolean", "const": false },
    "authority_granted": { "type": "boolean", "const": false },
    "terminal_closure": { "type": "boolean", "const": false },
    "source_review_intake_preflight_binding": { "type": "object" },
    "digest_requirements": { "type": "array", "minItems": 9, "maxItems": 9 },
    "missing_digest_requirements": { "type": "array", "minItems": 9, "maxItems": 9 },
    "digest_policy": { "type": "object" },
    "authority_denials": { "type": "object" },
    "effect_boundary": { "type": "object" },
    "validators": { "type": "array", "minItems": 1, "maxItems": 1 },
    "next_action": { "type": "string", "minLength": 1 }
  }
}
