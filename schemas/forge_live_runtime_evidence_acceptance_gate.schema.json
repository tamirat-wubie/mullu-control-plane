{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:forge-live-runtime-evidence-acceptance-gate:1",
  "title": "Forge Live Runtime Evidence Acceptance Gate",
  "description": "Foundation Mode gate that blocks Forge live-runtime promotion until signed live evidence replaces local design artifacts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "gate_id",
    "schema_ref",
    "schema_version",
    "bridge_ref",
    "source_local_evidence_bundle_ref",
    "source_local_evidence_bundle_hash",
    "acceptance_mode",
    "acceptance_status",
    "solver_outcome",
    "admission_decision",
    "acceptance_items",
    "blocked_reasons",
    "required_controls",
    "disallowed_authority",
    "next_allowed_action",
    "validators",
    "gate_hash"
  ],
  "properties": {
    "gate_id": { "type": "string", "const": "forge-live-runtime-evidence-acceptance-gate.v1" },
    "schema_ref": { "type": "string", "const": "urn:mullusi:schema:forge-live-runtime-evidence-acceptance-gate:1" },
    "schema_version": { "type": "integer", "const": 1 },
    "bridge_ref": { "type": "string", "const": "forge_write_spine_bridge.v1" },
    "source_local_evidence_bundle_ref": {
      "type": "string",
      "const": "examples/forge_live_runtime_local_evidence_bundle.foundation.json"
    },
    "source_local_evidence_bundle_hash": { "$ref": "#/$defs/hash" },
    "acceptance_mode": { "type": "string", "const": "signed_live_evidence_required" },
    "acceptance_status": { "type": "string", "const": "blocked_awaiting_signed_live_evidence" },
    "solver_outcome": { "type": "string", "const": "AwaitingEvidence" },
    "admission_decision": { "type": "string", "const": "block_live_runtime_promotion" },
    "acceptance_items": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "items": { "$ref": "#/$defs/acceptance_item" }
    },
    "blocked_reasons": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9_]+_signed_live_evidence_missing$"
      }
    },
    "required_controls": {
      "type": "array",
      "minItems": 11,
      "maxItems": 11,
      "items": { "type": "string" }
    },
    "disallowed_authority": { "$ref": "#/$defs/disallowed_authority" },
    "next_allowed_action": {
      "type": "string",
      "const": "collect_signed_live_evidence_under_operator_approval"
    },
    "validators": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": { "$ref": "#/$defs/validator" }
    },
    "gate_hash": { "$ref": "#/$defs/hash" }
  },
  "$defs": {
    "hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "acceptance_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_id",
        "source_local_artifact_ref",
        "required_live_evidence_ref",
        "required_witnesses",
        "live_evidence_status",
        "acceptance_status",
        "blocker_reason",
        "local_artifact_sufficient",
        "authority_effect"
      ],
      "properties": {
        "evidence_id": { "type": "string" },
        "source_local_artifact_ref": {
          "type": "string",
          "pattern": "^artifact://forge/live-runtime/local-design/[a-z0-9-]+$"
        },
        "required_live_evidence_ref": {
          "type": "string",
          "pattern": "^evidence://forge/live-runtime/[a-z0-9-]+$"
        },
        "required_witnesses": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "prefixItems": [
            { "const": "signed_live_receipt" },
            { "const": "dependency_or_credential_probe" },
            { "const": "recovery_or_revocation_path" }
          ]
        },
        "live_evidence_status": { "type": "string", "const": "missing" },
        "acceptance_status": { "type": "string", "const": "blocked" },
        "blocker_reason": {
          "type": "string",
          "pattern": "^[a-z0-9_]+_signed_live_evidence_missing$"
        },
        "local_artifact_sufficient": { "type": "boolean", "const": false },
        "authority_effect": { "type": "boolean", "const": false }
      }
    },
    "disallowed_authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "live_runtime_authorized",
        "state_write_runtime_registered",
        "production_authorized",
        "external_effects_allowed",
        "commit_allowed",
        "terminal_closure"
      ],
      "properties": {
        "live_runtime_authorized": { "type": "boolean", "const": false },
        "state_write_runtime_registered": { "type": "boolean", "const": false },
        "production_authorized": { "type": "boolean", "const": false },
        "external_effects_allowed": { "type": "boolean", "const": false },
        "commit_allowed": { "type": "boolean", "const": false },
        "terminal_closure": { "type": "boolean", "const": false }
      }
    },
    "validator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["validator_id", "command", "required_for_closure"],
      "properties": {
        "validator_id": {
          "type": "string",
          "const": "forge-live-runtime-evidence-acceptance-gate"
        },
        "command": {
          "type": "string",
          "const": "python scripts/validate_forge_live_runtime_evidence_acceptance_gate.py"
        },
        "required_for_closure": { "type": "boolean", "const": true }
      }
    }
  }
}
