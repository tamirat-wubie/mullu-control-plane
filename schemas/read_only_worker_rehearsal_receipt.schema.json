{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:read-only-worker-rehearsal-receipt:1",
  "title": "Read-Only Worker Rehearsal Receipt",
  "description": "Foundation Mode receipt contract for local rehearsal-only read_only_repo_inspection evidence without runtime dispatch, writes, network, connectors, raw output retention, or terminal closure.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receipt_id",
    "receipt_version",
    "binding_ref",
    "lease_preflight_ref",
    "selected_worker_path",
    "tenant_id",
    "actor_id",
    "created_at",
    "solver_outcome",
    "authority_scope",
    "rehearsal_contract",
    "rehearsal_result",
    "receipt_refs",
    "contract_summary",
    "governance_refs",
    "receipt_envelope",
    "evidence_refs"
  ],
  "properties": {
    "receipt_id": { "type": "string", "pattern": "^read-only-worker-rehearsal-receipt-[a-z0-9-]+$" },
    "receipt_version": { "type": "string", "const": "read_only_worker_rehearsal_receipt.v1" },
    "binding_ref": { "type": "string", "const": "examples/read_only_worker_binding.foundation.json" },
    "lease_preflight_ref": { "type": "string", "const": "examples/read_only_worker_lease_preflight.foundation.json" },
    "selected_worker_path": { "type": "string", "const": "read_only_repo_inspection" },
    "tenant_id": { "type": "string", "minLength": 1 },
    "actor_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "solver_outcome": {
      "type": "string",
      "enum": ["SolvedVerified", "AwaitingEvidence", "GovernanceBlocked"]
    },
    "authority_scope": { "$ref": "#/$defs/authority_scope" },
    "rehearsal_contract": { "$ref": "#/$defs/rehearsal_contract" },
    "rehearsal_result": { "$ref": "#/$defs/rehearsal_result" },
    "receipt_refs": { "$ref": "#/$defs/receipt_refs" },
    "contract_summary": { "$ref": "#/$defs/contract_summary" },
    "governance_refs": { "$ref": "#/$defs/non_empty_string_array" },
    "receipt_envelope": { "$ref": "#/$defs/receipt_envelope" },
    "evidence_refs": { "$ref": "#/$defs/non_empty_string_array" },
    "metadata": { "type": "object", "additionalProperties": true }
  },
  "$defs": {
    "authority_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "read_only",
        "local_rehearsal_only",
        "runtime_dispatch_allowed",
        "lease_preflight_required",
        "external_network_allowed",
        "secret_access_allowed",
        "filesystem_write_allowed",
        "connector_authority_allowed",
        "terminal_closure_allowed",
        "raw_output_retention_allowed",
        "mfidel_atomicity_preserved"
      ],
      "properties": {
        "read_only": { "type": "boolean", "const": true },
        "local_rehearsal_only": { "type": "boolean", "const": true },
        "runtime_dispatch_allowed": { "type": "boolean", "const": false },
        "lease_preflight_required": { "type": "boolean", "const": true },
        "external_network_allowed": { "type": "boolean", "const": false },
        "secret_access_allowed": { "type": "boolean", "const": false },
        "filesystem_write_allowed": { "type": "boolean", "const": false },
        "connector_authority_allowed": { "type": "boolean", "const": false },
        "terminal_closure_allowed": { "type": "boolean", "const": false },
        "raw_output_retention_allowed": { "type": "boolean", "const": false },
        "mfidel_atomicity_preserved": { "type": "boolean", "const": true }
      }
    },
    "rehearsal_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "worker_id",
        "capability",
        "operation_family",
        "rehearsal_mode",
        "dispatch_admitted",
        "filesystem_snapshot_required",
        "allowed_resource_refs",
        "forbidden_effect_refs",
        "required_preflight_refs",
        "verification_refs"
      ],
      "properties": {
        "worker_id": { "type": "string", "const": "worker_local_read_only_repo_inspection" },
        "capability": { "type": "string", "const": "read_only_repo_inspection" },
        "operation_family": { "type": "string", "const": "local_repo_inspection" },
        "rehearsal_mode": { "type": "string", "const": "LOCAL_DRY_RUN" },
        "dispatch_admitted": { "type": "boolean", "const": false },
        "filesystem_snapshot_required": { "type": "boolean", "const": true },
        "allowed_resource_refs": { "$ref": "#/$defs/non_empty_string_array" },
        "forbidden_effect_refs": { "$ref": "#/$defs/non_empty_string_array" },
        "required_preflight_refs": { "$ref": "#/$defs/non_empty_string_array" },
        "verification_refs": { "$ref": "#/$defs/non_empty_string_array" }
      }
    },
    "rehearsal_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "result_state",
        "inspected_resource_refs",
        "observed_evidence_refs",
        "output_digest",
        "raw_output_included",
        "raw_secret_material_included",
        "external_effects_observed",
        "filesystem_writes_observed",
        "connector_calls_observed",
        "terminal_closure",
        "success_claim_allowed"
      ],
      "properties": {
        "result_state": {
          "type": "string",
          "enum": ["REHEARSAL_RECORDED", "REHEARSAL_BLOCKED", "REHEARSAL_INVALIDATED"]
        },
        "inspected_resource_refs": { "$ref": "#/$defs/non_empty_string_array" },
        "observed_evidence_refs": { "$ref": "#/$defs/non_empty_string_array" },
        "output_digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "raw_output_included": { "type": "boolean", "const": false },
        "raw_secret_material_included": { "type": "boolean", "const": false },
        "external_effects_observed": { "type": "boolean", "const": false },
        "filesystem_writes_observed": { "type": "boolean", "const": false },
        "connector_calls_observed": { "type": "boolean", "const": false },
        "terminal_closure": { "type": "boolean", "const": false },
        "success_claim_allowed": { "type": "boolean", "const": false }
      }
    },
    "receipt_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "read_only_worker_binding_schema",
        "read_only_worker_lease_preflight_schema",
        "read_only_worker_rehearsal_receipt_schema",
        "temporal_lease_window_receipt_schema",
        "worker_failure_receipt_schema",
        "worker_mesh_schema"
      ],
      "properties": {
        "read_only_worker_binding_schema": { "type": "string", "const": "schemas/read_only_worker_binding.schema.json" },
        "read_only_worker_lease_preflight_schema": { "type": "string", "const": "schemas/read_only_worker_lease_preflight.schema.json" },
        "read_only_worker_rehearsal_receipt_schema": { "type": "string", "const": "schemas/read_only_worker_rehearsal_receipt.schema.json" },
        "temporal_lease_window_receipt_schema": { "type": "string", "const": "schemas/temporal_lease_window_receipt.schema.json" },
        "worker_failure_receipt_schema": { "type": "string", "const": "schemas/worker_failure_receipt.schema.json" },
        "worker_mesh_schema": { "type": "string", "const": "schemas/worker_mesh.schema.json" }
      }
    },
    "contract_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowed_resource_ref_count",
        "forbidden_effect_ref_count",
        "required_preflight_ref_count",
        "verification_ref_count",
        "inspected_resource_ref_count",
        "observed_evidence_ref_count",
        "receipt_ref_count",
        "evidence_ref_count"
      ],
      "properties": {
        "allowed_resource_ref_count": { "type": "integer", "minimum": 1 },
        "forbidden_effect_ref_count": { "type": "integer", "minimum": 1 },
        "required_preflight_ref_count": { "type": "integer", "minimum": 2 },
        "verification_ref_count": { "type": "integer", "minimum": 1 },
        "inspected_resource_ref_count": { "type": "integer", "minimum": 1 },
        "observed_evidence_ref_count": { "type": "integer", "minimum": 1 },
        "receipt_ref_count": { "type": "integer", "const": 6 },
        "evidence_ref_count": { "type": "integer", "minimum": 1 }
      }
    },
    "receipt_envelope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["uao_ref", "causal_decision_trace_ref", "receipt_ref"],
      "properties": {
        "uao_ref": { "type": "string", "pattern": "^uao://.+$" },
        "causal_decision_trace_ref": { "type": "string", "pattern": "^trace://.+$" },
        "receipt_ref": { "type": "string", "pattern": "^receipt://.+$" }
      }
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
