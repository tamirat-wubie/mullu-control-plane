{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:deployment-publication-evidence-packet:1",
  "title": "Deployment Publication Evidence Packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "packet_id",
    "output_dir",
    "gateway_host",
    "gateway_url",
    "expected_environment",
    "ready",
    "blockers",
    "artifacts",
    "validation_status",
    "dispatch_command"
  ],
  "properties": {
    "packet_id": {
      "type": "string",
      "pattern": "^deployment-publication-evidence-packet-[0-9a-f]{16}$"
    },
    "output_dir": {
      "type": "string",
      "minLength": 1
    },
    "gateway_host": {
      "type": "string",
      "pattern": "^[a-z0-9](?:[a-z0-9.-]{0,251}[a-z0-9])$"
    },
    "gateway_url": {
      "type": "string",
      "pattern": "^https://[a-z0-9](?:[a-z0-9.-]{0,251}[a-z0-9])$"
    },
    "expected_environment": {
      "type": "string",
      "enum": [
        "pilot",
        "production"
      ]
    },
    "ready": {
      "type": "boolean"
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "deployment_publication_closure_plan",
        "deployment_publication_closure_plan_schema_validation",
        "deployment_publication_evidence_packet",
        "deployment_publication_evidence_packet_validation",
        "deployment_upstream_blocker_receipt",
        "deployment_upstream_blocker_validation",
        "gateway_dns_resolution_receipt",
        "gateway_dns_resolution_validation",
        "gateway_dns_target_binding_receipt",
        "gateway_dns_target_binding_validation",
        "gateway_publication_dispatch_plan",
        "gateway_publication_readiness"
      ],
      "properties": {
        "deployment_publication_closure_plan": {
          "type": "string",
          "minLength": 1
        },
        "deployment_publication_closure_plan_schema_validation": {
          "type": "string",
          "minLength": 1
        },
        "deployment_publication_evidence_packet": {
          "type": "string",
          "minLength": 1
        },
        "deployment_publication_evidence_packet_validation": {
          "type": "string",
          "minLength": 1
        },
        "deployment_upstream_blocker_receipt": {
          "type": "string",
          "minLength": 1
        },
        "deployment_upstream_blocker_validation": {
          "type": "string",
          "minLength": 1
        },
        "gateway_dns_resolution_receipt": {
          "type": "string",
          "minLength": 1
        },
        "gateway_dns_resolution_validation": {
          "type": "string",
          "minLength": 1
        },
        "gateway_dns_target_binding_receipt": {
          "type": "string",
          "minLength": 1
        },
        "gateway_dns_target_binding_validation": {
          "type": "string",
          "minLength": 1
        },
        "gateway_publication_dispatch_plan": {
          "type": "string",
          "minLength": 1
        },
        "gateway_publication_readiness": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "validation_status": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "deployment_publication_closure_plan_schema",
        "deployment_upstream_blocker",
        "gateway_dns_resolution",
        "gateway_dns_target_binding"
      ],
      "properties": {
        "deployment_publication_closure_plan_schema": {
          "type": "boolean"
        },
        "deployment_upstream_blocker": {
          "type": "boolean"
        },
        "gateway_dns_resolution": {
          "type": "boolean"
        },
        "gateway_dns_target_binding": {
          "type": "boolean"
        }
      }
    },
    "dispatch_command": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
