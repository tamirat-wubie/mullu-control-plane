{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:connector-result:1",
  "title": "Connector Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "result_id",
    "connector_id",
    "status",
    "response_digest",
    "started_at",
    "finished_at"
  ],
  "properties": {
    "result_id": {
      "type": "string",
      "minLength": 1
    },
    "connector_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "succeeded",
        "failed",
        "timeout"
      ]
    },
    "response_digest": {
      "type": "string",
      "minLength": 1
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "finished_at": {
      "type": "string",
      "format": "date-time"
    },
    "error_code": {
      "type": "string",
      "minLength": 1
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
