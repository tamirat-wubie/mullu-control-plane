{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:collaboration-case:1",
  "title": "Governed Collaboration Case",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "case_id",
    "tenant_id",
    "requester_id",
    "subject",
    "approval_decider_id",
    "decider_authority_ref",
    "controls",
    "evidence_refs",
    "status",
    "closure_is_terminal",
    "case_hash",
    "metadata"
  ],
  "properties": {
    "case_id": {
      "type": "string",
      "minLength": 1
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "requester_id": {
      "type": "string",
      "minLength": 1
    },
    "subject": {
      "type": "string",
      "minLength": 1
    },
    "approval_decider_id": {
      "type": "string",
      "minLength": 1
    },
    "decider_authority_ref": {
      "type": "string",
      "minLength": 1
    },
    "controls": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/collaboration_control"
      }
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "blocked",
        "closed",
        "requires_review"
      ]
    },
    "closure_is_terminal": {
      "type": "boolean",
      "const": false
    },
    "case_hash": {
      "type": "string",
      "minLength": 1
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "approval_separation_required",
        "pending_controls_block_case_closure",
        "decider_authority_required",
        "closure_is_not_terminal_command_closure"
      ],
      "properties": {
        "approval_separation_required": {
          "type": "boolean",
          "const": true
        },
        "pending_controls_block_case_closure": {
          "type": "boolean",
          "const": true
        },
        "decider_authority_required": {
          "type": "boolean",
          "const": true
        },
        "closure_is_not_terminal_command_closure": {
          "type": "boolean",
          "const": true
        }
      }
    }
  },
  "$defs": {
    "collaboration_control": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "control_id",
        "control_type",
        "owner_id",
        "status",
        "evidence_refs"
      ],
      "properties": {
        "control_id": {
          "type": "string",
          "minLength": 1
        },
        "control_type": {
          "type": "string",
          "minLength": 1
        },
        "owner_id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "resolved",
            "waived"
          ]
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
