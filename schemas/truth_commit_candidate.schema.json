{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:mullu-truth-kernel:truth-commit-candidate:1",
  "title": "Mullu Truth Kernel Truth Commit Candidate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "commit_candidate_id",
    "tenant_id",
    "candidate_id",
    "delta_kind",
    "parent_kernel_signature",
    "new_kernel_signature",
    "proof_ref",
    "governance_ref",
    "trace_ref",
    "rollback_ref",
    "truth_admission",
    "journal",
    "status",
    "commit_hash"
  ],
  "properties": {
    "commit_candidate_id": {"type": "string", "minLength": 1},
    "tenant_id": {"type": "string", "minLength": 1},
    "candidate_id": {"type": "string", "minLength": 1},
    "delta_kind": {"$ref": "#/$defs/delta_kind"},
    "parent_kernel_signature": {"type": "string", "minLength": 1},
    "new_kernel_signature": {"type": "string", "minLength": 1},
    "proof_ref": {"$ref": "#/$defs/proof_ref"},
    "governance_ref": {"type": "string", "minLength": 1},
    "trace_ref": {"type": "string", "minLength": 1},
    "rollback_ref": {"type": "string", "minLength": 1},
    "truth_admission": {"$ref": "#/$defs/truth_admission"},
    "journal": {"$ref": "#/$defs/journal_binding"},
    "status": {
      "type": "string",
      "enum": ["proposed", "validated", "approved", "committed", "rejected", "rolled_back"]
    },
    "commit_hash": {"type": "string", "minLength": 1},
    "metadata": {"type": "object", "additionalProperties": true}
  },
  "$defs": {
    "delta_kind": {
      "type": "string",
      "enum": [
        "domain_addition",
        "constraint_addition",
        "constraint_status_change",
        "proof_attachment"
      ]
    },
    "proof_state": {
      "type": "string",
      "enum": ["Pass", "Fail", "Unknown", "BudgetUnknown"]
    },
    "result_kind": {
      "type": "string",
      "enum": [
        "ExactResult",
        "BoundedResult",
        "ApproximateResult",
        "UnknownResult",
        "ContradictionResult",
        "BudgetExceededResult"
      ]
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "proof_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof_id",
        "proof_hash",
        "proof_schema_ref"
      ],
      "properties": {
        "proof_id": {"type": "string", "minLength": 1},
        "proof_hash": {"type": "string", "minLength": 1},
        "proof_schema_ref": {"type": "string", "const": "schemas/kernel_proof.schema.json"}
      }
    },
    "truth_admission": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof_state",
        "result_kind",
        "mutation_allowed",
        "admission_reason_refs"
      ],
      "properties": {
        "proof_state": {"$ref": "#/$defs/proof_state"},
        "result_kind": {"$ref": "#/$defs/result_kind"},
        "mutation_allowed": {"type": "boolean"},
        "admission_reason_refs": {"$ref": "#/$defs/non_empty_string_array"}
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "mutation_allowed": {"const": true}
            },
            "required": ["mutation_allowed"]
          },
          "then": {
            "properties": {
              "proof_state": {"const": "Pass"},
              "result_kind": {"const": "ExactResult"}
            }
          }
        }
      ]
    },
    "journal_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "journal_event_ref",
        "replay_required",
        "replay_mode",
        "expected_replay_hash"
      ],
      "properties": {
        "journal_event_ref": {"type": "string", "minLength": 1},
        "replay_required": {"type": "boolean"},
        "replay_mode": {
          "type": "string",
          "enum": ["observation_only", "effect_bearing"]
        },
        "expected_replay_hash": {"type": "string", "minLength": 1}
      }
    }
  }
}
