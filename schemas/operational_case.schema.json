{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:operational-case:1",
  "title": "Operational Governance Case",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "case_id",
    "case_type",
    "tenant_id",
    "severity",
    "status",
    "owner",
    "approver",
    "requested_by",
    "action",
    "deadline",
    "evidence_refs",
    "decision_history",
    "obligations",
    "escalation_path",
    "closure_condition",
    "source_refs",
    "case_hash",
    "metadata"
  ],
  "properties": {
    "case_id": {"type": "string", "minLength": 1},
    "case_type": {
      "type": "string",
      "enum": [
        "approval_case",
        "risk_review_case",
        "payment_exception_case",
        "policy_exception_case",
        "incident_case",
        "accepted_risk_case",
        "requires_review_closure_case",
        "data_deletion_case",
        "capability_certification_case"
      ]
    },
    "tenant_id": {"type": "string", "minLength": 1},
    "severity": {"type": "string", "enum": ["low", "medium", "high", "critical"]},
    "status": {
      "type": "string",
      "enum": ["awaiting_approval", "open", "escalated", "closed", "denied", "expired", "cancelled"]
    },
    "owner": {"type": "string", "minLength": 1},
    "approver": {"type": "string"},
    "requested_by": {"type": "string", "minLength": 1},
    "action": {"type": "string", "minLength": 1},
    "deadline": {"type": "string"},
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "decision_history": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["decision", "actor", "source_ref"],
        "properties": {
          "decision": {"type": "string", "minLength": 1},
          "actor": {"type": "string", "minLength": 1},
          "source_ref": {"type": "string", "minLength": 1}
        }
      }
    },
    "obligations": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "escalation_path": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "closure_condition": {"type": "string", "minLength": 1},
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "case_hash": {"type": "string", "minLength": 1},
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "read_model_only",
        "operator_case_projection",
        "does_not_grant_execution_authority"
      ],
      "properties": {
        "read_model_only": {"type": "boolean", "const": true},
        "operator_case_projection": {"type": "boolean", "const": true},
        "does_not_grant_execution_authority": {"type": "boolean", "const": true}
      }
    }
  }
}
