{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:personal-assistant-approval-decision:1",
  "title": "Personal Assistant Approval Decision Evidence",
  "description": "Evidence envelope for personal-assistant approval decisions that records approve, reject, revise, and expire outcomes without executing effect-bearing actions.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "decision_set_id",
    "generated_at",
    "governed",
    "source_projection",
    "decision_count",
    "decision_ids",
    "approval_ids",
    "receipt_ids",
    "decisions",
    "effect_boundary",
    "private_payload_policy",
    "assurance",
    "metadata"
  ],
  "properties": {
    "decision_set_id": {
      "type": "string",
      "pattern": "^pa_approval_decision_set_[a-z0-9][a-z0-9_:-]*$"
    },
    "generated_at": {"type": "string", "minLength": 1},
    "governed": {"const": true},
    "source_projection": {"const": "operator_supplied_decision_evidence"},
    "decision_count": {"type": "integer", "minimum": 1},
    "decision_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^pa_approval_decision_[a-z0-9][a-z0-9_:-]*$"
      },
      "uniqueItems": true
    },
    "approval_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^pa_approval_[a-z0-9][a-z0-9_:-]*$"
      },
      "uniqueItems": true
    },
    "receipt_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^pa_receipt_[a-z0-9][a-z0-9_:-]*$"
      },
      "uniqueItems": true
    },
    "decisions": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/decision_evidence"}
    },
    "effect_boundary": {"$ref": "#/$defs/effect_boundary"},
    "private_payload_policy": {"$ref": "#/$defs/private_payload_policy"},
    "assurance": {"$ref": "#/$defs/assurance"},
    "metadata": {"$ref": "#/$defs/metadata"}
  },
  "$defs": {
    "decision_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision_id",
        "approval_id",
        "request_id",
        "plan_id",
        "decision",
        "decided_at",
        "reason_codes",
        "queue_precondition_ref",
        "packet",
        "receipt"
      ],
      "properties": {
        "decision_id": {
          "type": "string",
          "pattern": "^pa_approval_decision_[a-z0-9][a-z0-9_:-]*$"
        },
        "approval_id": {
          "type": "string",
          "pattern": "^pa_approval_[a-z0-9][a-z0-9_:-]*$"
        },
        "request_id": {
          "type": "string",
          "pattern": "^pa_request_[a-z0-9][a-z0-9_:-]*$"
        },
        "plan_id": {
          "type": "string",
          "pattern": "^pa_plan_[a-z0-9][a-z0-9_:-]*$"
        },
        "decision": {"enum": ["approved", "rejected", "revised", "expired"]},
        "decided_at": {"type": "string", "minLength": 1},
        "reason_codes": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "queue_precondition_ref": {"$ref": "#/$defs/queue_precondition_ref"},
        "packet": {
          "type": "object",
          "additionalProperties": true
        },
        "receipt": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "queue_precondition_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_projection",
        "approval_id",
        "request_id",
        "plan_id",
        "source_queue_state",
        "source_receipt_id",
        "source_review_packet_id",
        "source_review_packet_sha256",
        "payload_digest_only",
        "decision_precondition_met",
        "execution_allowed",
        "approval_is_execution",
        "external_send_allowed",
        "connector_mutation_allowed",
        "system_of_record_write_allowed",
        "queue_precondition_sha256"
      ],
      "properties": {
        "source_projection": {"const": "personal_assistant_approval_queue_read_model"},
        "approval_id": {
          "type": "string",
          "pattern": "^pa_approval_[a-z0-9][a-z0-9_:-]*$"
        },
        "request_id": {
          "type": "string",
          "pattern": "^pa_request_[a-z0-9][a-z0-9_:-]*$"
        },
        "plan_id": {
          "type": "string",
          "pattern": "^pa_plan_[a-z0-9][a-z0-9_:-]*$"
        },
        "source_queue_state": {"const": "requested"},
        "source_receipt_id": {
          "type": "string",
          "pattern": "^pa_receipt_[a-z0-9][a-z0-9_:-]*_request$"
        },
        "source_review_packet_id": {"const": "pa_approval_review_approval_review_packet_001"},
        "source_review_packet_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "payload_digest_only": {"const": true},
        "decision_precondition_met": {"const": true},
        "execution_allowed": {"const": false},
        "approval_is_execution": {"const": false},
        "external_send_allowed": {"const": false},
        "connector_mutation_allowed": {"const": false},
        "system_of_record_write_allowed": {"const": false},
        "queue_precondition_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "effect_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "approval_decision_records_allowed",
        "execution_allowed",
        "approval_is_execution",
        "live_connector_execution_allowed",
        "external_send_allowed",
        "calendar_write_allowed",
        "task_write_allowed",
        "memory_write_allowed",
        "connector_mutation_allowed",
        "system_of_record_write_allowed",
        "deployment_mutation_allowed",
        "nested_mind_live_activation_allowed",
        "public_readiness_claim_allowed"
      ],
      "properties": {
        "approval_decision_records_allowed": {"const": true},
        "execution_allowed": {"const": false},
        "approval_is_execution": {"const": false},
        "live_connector_execution_allowed": {"const": false},
        "external_send_allowed": {"const": false},
        "calendar_write_allowed": {"const": false},
        "task_write_allowed": {"const": false},
        "memory_write_allowed": {"const": false},
        "connector_mutation_allowed": {"const": false},
        "system_of_record_write_allowed": {"const": false},
        "deployment_mutation_allowed": {"const": false},
        "nested_mind_live_activation_allowed": {"const": false},
        "public_readiness_claim_allowed": {"const": false}
      }
    },
    "private_payload_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raw_private_payload_serialized",
        "secret_values_serialized",
        "connector_payload_projection",
        "decision_payload_projection"
      ],
      "properties": {
        "raw_private_payload_serialized": {"const": false},
        "secret_values_serialized": {"const": false},
        "connector_payload_projection": {"const": "ref_only"},
        "decision_payload_projection": {"const": "bounded_operator_decision_record"}
      }
    },
    "assurance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "assurance_id",
        "outcome",
        "foundation_only",
        "ready_for_live_execution",
        "ready_for_customer_readiness_claim",
        "authority_drift_detected",
        "checked_controls",
        "blocking_reasons",
        "next_action"
      ],
      "properties": {
        "assurance_id": {"const": "personal_assistant_approval_decision_no_effect_assurance"},
        "outcome": {"enum": ["SolvedVerified", "GovernanceBlocked"]},
        "foundation_only": {"const": true},
        "ready_for_live_execution": {"const": false},
        "ready_for_customer_readiness_claim": {"const": false},
        "authority_drift_detected": {"type": "boolean"},
        "checked_controls": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "blocking_reasons": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "next_action": {"type": "string", "minLength": 1}
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "foundation_only",
        "projection_contract",
        "runtime_boundary",
        "live_connector_execution_allowed",
        "connector_mutation_allowed",
        "external_send_allowed",
        "system_of_record_write_allowed",
        "memory_write_allowed"
      ],
      "properties": {
        "foundation_only": {"const": true},
        "projection_contract": {"const": "approval_decision_evidence_only"},
        "runtime_boundary": {"const": "decision_does_not_execute"},
        "live_connector_execution_allowed": {"const": false},
        "connector_mutation_allowed": {"const": false},
        "external_send_allowed": {"const": false},
        "system_of_record_write_allowed": {"const": false},
        "memory_write_allowed": {"const": false}
      }
    }
  }
}
