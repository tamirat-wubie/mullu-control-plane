{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:read-only-search-worker-path:1",
  "title": "Read-Only Search Worker Path",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_ref",
    "selection_id",
    "selected_capability_id",
    "status",
    "mode",
    "decision_rationale",
    "mutation_allowed",
    "external_network_allowed",
    "secrets_required",
    "spend_required",
    "retrieval_authority",
    "search_decision_receipt_required",
    "source_scope",
    "allowed_inputs",
    "blocked_inputs",
    "allowed_outputs",
    "required_receipts",
    "proof_obligations",
    "acceptance_tests",
    "rollback_plan",
    "next_action"
  ],
  "properties": {
    "schema_ref": {"const": "urn:mullusi:schema:read-only-search-worker-path:1"},
    "selection_id": {"type": "string", "pattern": "^read-only-search-worker-path-[0-9]{8}$"},
    "selected_capability_id": {"const": "enterprise.knowledge_search"},
    "status": {"const": "selected_for_foundation_mode"},
    "mode": {"const": "read_only"},
    "decision_rationale": {"type": "string", "minLength": 1},
    "mutation_allowed": {"const": false},
    "external_network_allowed": {"const": false},
    "secrets_required": {"const": false},
    "spend_required": {"const": false},
    "retrieval_authority": {"const": "evidence_only"},
    "search_decision_receipt_required": {"const": true},
    "source_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["local_text_like_sources_only", "web_search_allowed", "supported_extensions"],
      "properties": {
        "local_text_like_sources_only": {"const": true},
        "web_search_allowed": {"const": false},
        "supported_extensions": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "pattern": "^\\.[a-z0-9]+$"},
          "uniqueItems": true
        }
      }
    },
    "allowed_inputs": {"$ref": "#/$defs/allowed_inputs"},
    "blocked_inputs": {"$ref": "#/$defs/blocked_inputs"},
    "allowed_outputs": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "required_receipts": {
      "type": "array",
      "minItems": 6,
      "items": {
        "type": "string",
        "enum": [
          "search_decision_receipt",
          "worker_lease_receipt",
          "input_hash_receipt",
          "source_boundary_witness",
          "evidence_only_retrieval_witness",
          "read_only_result_receipt",
          "redaction_witness",
          "terminal_closure_or_blocker_receipt"
        ]
      },
      "uniqueItems": true
    },
    "proof_obligations": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "string",
        "enum": [
          "no_write_operation",
          "no_external_network",
          "source_path_boundary",
          "search_decision_receipt_required",
          "evidence_only_retrieval",
          "scan_bounds",
          "secret_redaction",
          "deterministic_traversal"
        ]
      },
      "uniqueItems": true
    },
    "acceptance_tests": {
      "type": "array",
      "minItems": 2,
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "rollback_plan": {"type": "string", "minLength": 1},
    "next_action": {"type": "string", "minLength": 1}
  },
  "$defs": {
    "allowed_inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_relative_paths",
        "query_text",
        "search_decision_receipt",
        "max_sources",
        "max_bytes_per_source",
        "max_result_count"
      ],
      "properties": {
        "source_relative_paths": {"const": true},
        "query_text": {"const": true},
        "search_decision_receipt": {"const": true},
        "max_sources": {"type": "integer", "minimum": 1},
        "max_bytes_per_source": {"type": "integer", "minimum": 1},
        "max_result_count": {"type": "integer", "minimum": 1}
      }
    },
    "blocked_inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "absolute_paths_outside_knowledge_root",
        "raw_secret_values",
        "write_requests",
        "network_targets",
        "tenant_external_resources",
        "web_search_requests",
        "retrieved_instruction_authority"
      ],
      "properties": {
        "absolute_paths_outside_knowledge_root": {"const": true},
        "raw_secret_values": {"const": true},
        "write_requests": {"const": true},
        "network_targets": {"const": true},
        "tenant_external_resources": {"const": true},
        "web_search_requests": {"const": true},
        "retrieved_instruction_authority": {"const": true}
      }
    }
  }
}
