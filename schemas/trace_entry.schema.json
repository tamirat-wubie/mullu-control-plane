{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:trace-entry:1",
  "title": "Trace Entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "trace_id",
    "parent_trace_id",
    "event_type",
    "subject_id",
    "goal_id",
    "state_hash",
    "registry_hash",
    "timestamp"
  ],
  "properties": {
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "parent_trace_id": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "null"
        }
      ]
    },
    "event_type": {
      "type": "string",
      "minLength": 1
    },
    "subject_id": {
      "type": "string",
      "minLength": 1
    },
    "goal_id": {
      "type": "string",
      "minLength": 1
    },
    "state_hash": {
      "type": "string",
      "minLength": 1
    },
    "registry_hash": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
