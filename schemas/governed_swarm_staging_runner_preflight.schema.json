{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:governed-swarm-staging-runner-preflight:1",
  "title": "Governed Swarm Staging Runner Preflight",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receipt_id",
    "checked_at",
    "staging_url",
    "control_plane_commit",
    "runtime_path",
    "audit_store_path",
    "ready",
    "outcome",
    "checks"
  ],
  "properties": {
    "receipt_id": {
      "type": "string",
      "pattern": "^governed-swarm-runner-preflight-[0-9a-f]{16}$"
    },
    "checked_at": {
      "type": "string",
      "format": "date-time"
    },
    "staging_url": {
      "type": "string",
      "pattern": "^https?://.+"
    },
    "control_plane_commit": {
      "type": "string",
      "minLength": 7
    },
    "runtime_path": {
      "type": "string",
      "pattern": "mcoi$"
    },
    "audit_store_path": {
      "type": "string",
      "minLength": 1
    },
    "ready": {
      "type": "boolean"
    },
    "outcome": {
      "type": "string",
      "enum": ["SolvedVerified", "AwaitingEvidence"]
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/check"
      }
    }
  },
  "$defs": {
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "passed", "detail"],
      "properties": {
        "name": {
          "type": "string",
          "enum": [
            "staging_url",
            "control_plane_commit",
            "runtime_bridge",
            "audit_store_exists",
            "audit_store_readable"
          ]
        },
        "passed": {
          "type": "boolean"
        },
        "detail": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
