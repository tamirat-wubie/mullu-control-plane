{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:sdlc-change-request:1",
  "title": "SDLC Change Request",
  "description": "Governed intake artifact for a software change request.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_id",
    "source",
    "actor_id",
    "tenant_id",
    "title",
    "summary",
    "change_type",
    "risk_hint",
    "target_surfaces",
    "created_at",
    "evidence_refs",
    "uao_ref",
    "causal_decision_trace_ref",
    "receipt_ref"
  ],
  "properties": {
    "request_id": { "type": "string", "minLength": 1 },
    "source": { "type": "string", "minLength": 1 },
    "actor_id": { "type": "string", "minLength": 1 },
    "tenant_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "change_type": {
      "type": "string",
      "enum": [
        "feature",
        "bugfix",
        "security_fix",
        "test_fix",
        "docs",
        "refactor",
        "deployment",
        "governance",
        "compliance",
        "incident",
        "research"
      ]
    },
    "risk_hint": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
    "target_surfaces": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "created_at": { "type": "string", "format": "date-time" },
    "evidence_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "uao_ref": { "type": "string", "minLength": 1 },
    "causal_decision_trace_ref": { "type": "string", "minLength": 1 },
    "receipt_ref": { "type": "string", "minLength": 1 }
  }
}
