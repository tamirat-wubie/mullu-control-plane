{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:multimodal-operation-receipt:1",
  "title": "Multimodal Operation Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receipt_id",
    "request_id",
    "tenant_id",
    "actor_id",
    "worker_id",
    "capability",
    "modality",
    "operation",
    "command_id",
    "status",
    "blocked_reasons",
    "review_reasons",
    "required_controls",
    "source_ref",
    "source_hash",
    "input_hash",
    "evidence_refs",
    "policy_refs",
    "requested_at",
    "evaluated_at",
    "receipt_schema_ref",
    "source_reference_preserved",
    "worker_receipt_required",
    "terminal_closure_required",
    "receipt_hash",
    "metadata"
  ],
  "properties": {
    "receipt_id": {
      "type": "string",
      "pattern": "^multimodal-receipt-[0-9a-f]{16}$"
    },
    "request_id": {"type": "string", "minLength": 1},
    "tenant_id": {"type": "string", "minLength": 1},
    "actor_id": {"type": "string", "minLength": 1},
    "worker_id": {"type": "string", "minLength": 1},
    "capability": {"type": "string", "minLength": 1},
    "modality": {
      "type": "string",
      "enum": [
        "text",
        "pdf",
        "spreadsheet",
        "image",
        "voice",
        "screen",
        "browser",
        "email",
        "calendar",
        "forms",
        "video_frame",
        "unknown"
      ]
    },
    "operation": {"type": "string", "minLength": 1},
    "command_id": {"type": "string", "minLength": 1},
    "status": {
      "type": "string",
      "enum": ["allowed", "blocked", "requires_review"]
    },
    "blocked_reasons": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "review_reasons": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "required_controls": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "source_ref": {"type": "string", "minLength": 1},
    "source_hash": {"type": "string", "minLength": 1},
    "input_hash": {"type": "string", "minLength": 1},
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "policy_refs": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "requested_at": {"type": "string"},
    "evaluated_at": {"type": "string"},
    "receipt_schema_ref": {
      "type": "string",
      "const": "urn:mullusi:schema:multimodal-operation-receipt:1"
    },
    "source_reference_preserved": {"type": "boolean", "const": true},
    "worker_receipt_required": {"type": "boolean", "const": true},
    "terminal_closure_required": {"type": "boolean", "const": true},
    "receipt_hash": {"type": "string", "minLength": 1},
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "receipt_is_not_terminal_closure",
        "dispatch_allowed",
        "external_effect",
        "original_modality",
        "sensitivity_level",
        "policy_maturity_level",
        "production_certified"
      ],
      "properties": {
        "receipt_is_not_terminal_closure": {"type": "boolean", "const": true},
        "dispatch_allowed": {"type": "boolean"},
        "external_effect": {"type": "boolean"},
        "original_modality": {"type": "string", "minLength": 1},
        "sensitivity_level": {
          "type": "string",
          "enum": ["public", "internal", "confidential", "restricted"]
        },
        "policy_maturity_level": {
          "type": "string",
          "enum": ["", "C0", "C1", "C2", "C3", "C4", "C5", "C6", "C7"]
        },
        "production_certified": {"type": "boolean"}
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {"status": {"const": "blocked"}},
        "required": ["status"]
      },
      "then": {
        "properties": {
          "blocked_reasons": {"minItems": 1},
          "metadata": {
            "properties": {
              "dispatch_allowed": {"const": false}
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {"status": {"const": "requires_review"}},
        "required": ["status"]
      },
      "then": {
        "properties": {
          "blocked_reasons": {"maxItems": 0},
          "review_reasons": {"minItems": 1},
          "metadata": {
            "properties": {
              "dispatch_allowed": {"const": false}
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {"status": {"const": "allowed"}},
        "required": ["status"]
      },
      "then": {
        "properties": {
          "blocked_reasons": {"maxItems": 0},
          "review_reasons": {"maxItems": 0},
          "metadata": {
            "properties": {
              "dispatch_allowed": {"const": true}
            }
          }
        }
      }
    }
  ]
}
