{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:multimodal-operation-receipt:1",
  "title": "Multimodal Operation Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receipt_id",
    "request_id",
    "tenant_id",
    "command_id",
    "capability_id",
    "modality",
    "operation",
    "sensitivity",
    "status",
    "reason",
    "worker_plane",
    "policy_id",
    "source_ref",
    "source_hash",
    "evidence_refs",
    "required_controls",
    "blocked_reasons",
    "review_reasons",
    "policy_refs",
    "receipt_schema_ref",
    "worker_receipt_required",
    "source_reference_preserved",
    "sandbox_required",
    "terminal_closure_required",
    "receipt_hash",
    "metadata"
  ],
  "properties": {
    "receipt_id": {"type": "string", "pattern": "^multimodal-receipt-[0-9a-f]{16}$"},
    "request_id": {"type": "string", "minLength": 1},
    "tenant_id": {"type": "string", "minLength": 1},
    "command_id": {"type": "string", "minLength": 1},
    "capability_id": {"type": "string", "minLength": 1},
    "modality": {"type": "string"},
    "operation": {"type": "string", "minLength": 1},
    "sensitivity": {"type": "string"},
    "status": {"type": "string", "enum": ["allowed", "blocked", "requires_review"]},
    "reason": {"type": "string", "minLength": 1},
    "worker_plane": {"type": "string"},
    "policy_id": {"type": "string"},
    "source_ref": {"type": "string"},
    "source_hash": {"type": "string"},
    "evidence_refs": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "required_controls": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "blocked_reasons": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "review_reasons": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "policy_refs": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "receipt_schema_ref": {"type": "string", "const": "urn:mullusi:schema:multimodal-operation-receipt:1"},
    "worker_receipt_required": {"type": "boolean", "const": true},
    "source_reference_preserved": {"type": "boolean", "const": true},
    "sandbox_required": {"type": "boolean"},
    "terminal_closure_required": {"type": "boolean", "const": true},
    "receipt_hash": {"type": "string", "minLength": 1},
    "metadata": {"type": "object", "additionalProperties": true}
  }
}
