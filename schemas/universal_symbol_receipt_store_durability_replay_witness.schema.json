{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:universal-symbol-receipt-store-durability-replay-witness:1",
  "title": "Universal Symbol Receipt Store Durability Replay Witness",
  "description": "Foundation Mode witness for a future UniversalSymbol receipt-store durability replay boundary. This witness defines replay obligations while denying durability replay binding, write-path registration, receipt append, replay execution, raw payload storage, raw secret storage, runtime dispatch, connector calls, state mutation, terminal closure, and production readiness.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "witness_id",
    "schema_version",
    "generated_at",
    "witness_scope",
    "solver_outcome",
    "foundation_mode",
    "durability_replay_decision",
    "durability_replay_witness_is_not_append_authority",
    "durability_replay_requirements",
    "authority_denials",
    "durability_replay_constraints",
    "rejection_policy",
    "blocked_reasons",
    "next_actions",
    "evidence_refs",
    "contract_summary"
  ],
  "properties": {
    "witness_id": { "type": "string", "const": "universal-symbol-receipt-store-durability-replay-witness-foundation" },
    "schema_version": { "type": "integer", "const": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "witness_scope": { "type": "string", "const": "foundation-mode-universal-symbol-receipt-store-durability-replay" },
    "solver_outcome": { "type": "string", "const": "AwaitingEvidence" },
    "foundation_mode": { "type": "boolean", "const": true },
    "durability_replay_decision": { "type": "string", "const": "blocked_pending_ordered_replay_digest_crash_window_and_audit_evidence" },
    "durability_replay_witness_is_not_append_authority": { "type": "boolean", "const": true },
    "durability_replay_requirements": {
      "type": "array",
      "minItems": 8,
      "items": { "$ref": "#/$defs/durability_replay_requirement" },
      "uniqueItems": true
    },
    "authority_denials": { "$ref": "#/$defs/authority_denials" },
    "durability_replay_constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ordered_replay_required",
        "append_sequence_required",
        "digest_chain_required",
        "idempotency_key_reuse_required",
        "crash_window_required",
        "durability_receipt_required",
        "rollback_handoff_required",
        "audit_receipt_required"
      ],
      "properties": {
        "ordered_replay_required": { "type": "boolean", "const": true },
        "append_sequence_required": { "type": "boolean", "const": true },
        "digest_chain_required": { "type": "boolean", "const": true },
        "idempotency_key_reuse_required": { "type": "boolean", "const": true },
        "crash_window_required": { "type": "boolean", "const": true },
        "durability_receipt_required": { "type": "boolean", "const": true },
        "rollback_handoff_required": { "type": "boolean", "const": true },
        "audit_receipt_required": { "type": "boolean", "const": true }
      }
    },
    "rejection_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "missing_ordered_replay_blocks_durability",
        "missing_digest_chain_blocks_durability",
        "missing_idempotency_reuse_blocks_durability",
        "missing_crash_window_blocks_durability",
        "unknown_hard_constraint_blocks_durability",
        "failed_precondition_logs_delta_reject"
      ],
      "properties": {
        "missing_ordered_replay_blocks_durability": { "type": "boolean", "const": true },
        "missing_digest_chain_blocks_durability": { "type": "boolean", "const": true },
        "missing_idempotency_reuse_blocks_durability": { "type": "boolean", "const": true },
        "missing_crash_window_blocks_durability": { "type": "boolean", "const": true },
        "unknown_hard_constraint_blocks_durability": { "type": "boolean", "const": true },
        "failed_precondition_logs_delta_reject": { "type": "boolean", "const": true }
      }
    },
    "blocked_reasons": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "string",
        "enum": [
          "ordered_replay_missing",
          "append_sequence_missing",
          "digest_chain_missing",
          "idempotency_reuse_missing",
          "crash_window_missing",
          "durability_receipt_missing",
          "rollback_handoff_missing",
          "audit_receipt_missing",
          "receipt_store_durability_replay_forbidden",
          "terminal_closure_not_allowed"
        ]
      },
      "uniqueItems": true
    },
    "next_actions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/ref" },
      "uniqueItems": true
    },
    "contract_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "durability_replay_requirement_count",
        "authority_denial_count",
        "durability_replay_constraint_count",
        "rejection_check_count",
        "blocked_reason_count",
        "evidence_ref_count"
      ],
      "properties": {
        "durability_replay_requirement_count": { "type": "integer", "minimum": 8 },
        "authority_denial_count": { "type": "integer", "const": 11 },
        "durability_replay_constraint_count": { "type": "integer", "const": 8 },
        "rejection_check_count": { "type": "integer", "const": 6 },
        "blocked_reason_count": { "type": "integer", "minimum": 8 },
        "evidence_ref_count": { "type": "integer", "minimum": 1 }
      }
    }
  },
  "$defs": {
    "ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/#-]*$"
    },
    "durability_replay_requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requirement_id",
        "proof_state",
        "required_evidence_ref",
        "current_decision",
        "delta_reject_ref"
      ],
      "properties": {
        "requirement_id": { "$ref": "#/$defs/ref" },
        "proof_state": { "type": "string", "enum": ["Unknown", "BudgetUnknown", "Fail"] },
        "required_evidence_ref": { "$ref": "#/$defs/ref" },
        "current_decision": { "type": "string", "const": "durability_replay_blocked" },
        "delta_reject_ref": { "$ref": "#/$defs/ref" }
      }
    },
    "authority_denials": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_store_durability_replay_bound",
        "receipt_store_write_path_registered",
        "receipt_store_append_performed",
        "receipt_store_replay_performed",
        "duplicate_effect_allowed",
        "raw_payload_stored",
        "raw_secret_stored",
        "runtime_dispatch_performed",
        "connector_call_performed",
        "state_mutation_performed",
        "terminal_closure_allowed"
      ],
      "properties": {
        "receipt_store_durability_replay_bound": { "type": "boolean", "const": false },
        "receipt_store_write_path_registered": { "type": "boolean", "const": false },
        "receipt_store_append_performed": { "type": "boolean", "const": false },
        "receipt_store_replay_performed": { "type": "boolean", "const": false },
        "duplicate_effect_allowed": { "type": "boolean", "const": false },
        "raw_payload_stored": { "type": "boolean", "const": false },
        "raw_secret_stored": { "type": "boolean", "const": false },
        "runtime_dispatch_performed": { "type": "boolean", "const": false },
        "connector_call_performed": { "type": "boolean", "const": false },
        "state_mutation_performed": { "type": "boolean", "const": false },
        "terminal_closure_allowed": { "type": "boolean", "const": false }
      }
    }
  }
}
