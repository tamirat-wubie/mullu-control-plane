{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:universal-symbol-receipt-store-path-custody-witness:1",
  "title": "Universal Symbol Receipt Store Path Custody Witness",
  "description": "Foundation Mode witness for a future UniversalSymbol receipt-store path custody boundary. This witness defines custody evidence obligations while denying custody registration, write-path registration, receipt append, raw payload storage, raw secret storage, runtime dispatch, connector calls, state mutation, terminal closure, and production readiness.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "witness_id",
    "schema_version",
    "generated_at",
    "witness_scope",
    "solver_outcome",
    "foundation_mode",
    "path_custody_decision",
    "path_custody_witness_is_not_write_path_authority",
    "custody_requirements",
    "authority_denials",
    "custody_constraints",
    "rejection_policy",
    "blocked_reasons",
    "next_actions",
    "evidence_refs",
    "contract_summary"
  ],
  "properties": {
    "witness_id": { "type": "string", "const": "universal-symbol-receipt-store-path-custody-witness-foundation" },
    "schema_version": { "type": "integer", "const": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "witness_scope": { "type": "string", "const": "foundation-mode-universal-symbol-receipt-store-path-custody" },
    "solver_outcome": { "type": "string", "const": "AwaitingEvidence" },
    "foundation_mode": { "type": "boolean", "const": true },
    "path_custody_decision": { "type": "string", "const": "blocked_pending_confinement_idempotency_replay_and_recovery_evidence" },
    "path_custody_witness_is_not_write_path_authority": { "type": "boolean", "const": true },
    "custody_requirements": {
      "type": "array",
      "minItems": 8,
      "items": { "$ref": "#/$defs/custody_requirement" },
      "uniqueItems": true
    },
    "authority_denials": { "$ref": "#/$defs/authority_denials" },
    "custody_constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canonical_path_identity_required",
        "repository_relative_path_required",
        "path_confinement_required",
        "append_only_boundary_required",
        "digest_only_boundary_required",
        "tenant_actor_partition_required",
        "idempotency_binding_required",
        "rollback_recovery_required"
      ],
      "properties": {
        "canonical_path_identity_required": { "type": "boolean", "const": true },
        "repository_relative_path_required": { "type": "boolean", "const": true },
        "path_confinement_required": { "type": "boolean", "const": true },
        "append_only_boundary_required": { "type": "boolean", "const": true },
        "digest_only_boundary_required": { "type": "boolean", "const": true },
        "tenant_actor_partition_required": { "type": "boolean", "const": true },
        "idempotency_binding_required": { "type": "boolean", "const": true },
        "rollback_recovery_required": { "type": "boolean", "const": true }
      }
    },
    "rejection_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "missing_canonical_path_blocks_custody",
        "missing_confinement_blocks_custody",
        "missing_append_only_boundary_blocks_custody",
        "missing_idempotency_blocks_custody",
        "unknown_hard_constraint_blocks_custody",
        "failed_precondition_logs_delta_reject"
      ],
      "properties": {
        "missing_canonical_path_blocks_custody": { "type": "boolean", "const": true },
        "missing_confinement_blocks_custody": { "type": "boolean", "const": true },
        "missing_append_only_boundary_blocks_custody": { "type": "boolean", "const": true },
        "missing_idempotency_blocks_custody": { "type": "boolean", "const": true },
        "unknown_hard_constraint_blocks_custody": { "type": "boolean", "const": true },
        "failed_precondition_logs_delta_reject": { "type": "boolean", "const": true }
      }
    },
    "blocked_reasons": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "string",
        "enum": [
          "canonical_path_identity_missing",
          "repository_relative_path_missing",
          "path_confinement_witness_missing",
          "append_only_boundary_missing",
          "digest_only_boundary_missing",
          "tenant_actor_partition_missing",
          "idempotency_binding_missing",
          "rollback_recovery_witness_missing",
          "receipt_store_path_custody_registration_forbidden",
          "terminal_closure_not_allowed"
        ]
      },
      "uniqueItems": true
    },
    "next_actions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/ref" },
      "uniqueItems": true
    },
    "contract_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "custody_requirement_count",
        "authority_denial_count",
        "custody_constraint_count",
        "rejection_check_count",
        "blocked_reason_count",
        "evidence_ref_count"
      ],
      "properties": {
        "custody_requirement_count": { "type": "integer", "minimum": 8 },
        "authority_denial_count": { "type": "integer", "const": 10 },
        "custody_constraint_count": { "type": "integer", "const": 8 },
        "rejection_check_count": { "type": "integer", "const": 6 },
        "blocked_reason_count": { "type": "integer", "minimum": 8 },
        "evidence_ref_count": { "type": "integer", "minimum": 1 }
      }
    }
  },
  "$defs": {
    "ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/#-]*$"
    },
    "custody_requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requirement_id",
        "proof_state",
        "required_evidence_ref",
        "current_decision",
        "delta_reject_ref"
      ],
      "properties": {
        "requirement_id": { "$ref": "#/$defs/ref" },
        "proof_state": { "type": "string", "enum": ["Unknown", "BudgetUnknown", "Fail"] },
        "required_evidence_ref": { "$ref": "#/$defs/ref" },
        "current_decision": { "type": "string", "const": "path_custody_blocked" },
        "delta_reject_ref": { "$ref": "#/$defs/ref" }
      }
    },
    "authority_denials": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_store_path_custody_registered",
        "receipt_store_writer_registered",
        "receipt_store_write_path_registered",
        "receipt_store_append_performed",
        "raw_payload_stored",
        "raw_secret_stored",
        "runtime_dispatch_performed",
        "connector_call_performed",
        "state_mutation_performed",
        "terminal_closure_allowed"
      ],
      "properties": {
        "receipt_store_path_custody_registered": { "type": "boolean", "const": false },
        "receipt_store_writer_registered": { "type": "boolean", "const": false },
        "receipt_store_write_path_registered": { "type": "boolean", "const": false },
        "receipt_store_append_performed": { "type": "boolean", "const": false },
        "raw_payload_stored": { "type": "boolean", "const": false },
        "raw_secret_stored": { "type": "boolean", "const": false },
        "runtime_dispatch_performed": { "type": "boolean", "const": false },
        "connector_call_performed": { "type": "boolean", "const": false },
        "state_mutation_performed": { "type": "boolean", "const": false },
        "terminal_closure_allowed": { "type": "boolean", "const": false }
      }
    }
  }
}
