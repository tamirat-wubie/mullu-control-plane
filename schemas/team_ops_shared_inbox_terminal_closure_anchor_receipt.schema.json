{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:team-ops-shared-inbox-terminal-closure-anchor-receipt:1",
  "title": "TeamOps Shared Inbox Terminal Closure Anchor Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "receipt_id",
    "created_at",
    "ready",
    "solver_outcome",
    "proof_state",
    "preflight_path",
    "source_preflight_receipt_id",
    "bundle_path",
    "bundle_id",
    "command_id",
    "terminal_certificate_id",
    "bundle_hash",
    "anchor_target",
    "external_anchor_status",
    "external_anchor_ref",
    "operator_authority_ref",
    "anchor_receipt_id",
    "anchor_receipt_hash",
    "artifact_root_hash",
    "artifact_count",
    "required_artifact_types",
    "anchor_receipt",
    "artifacts",
    "step_count",
    "steps",
    "blockers",
    "metadata"
  ],
  "properties": {
    "schema_version": {"type": "integer", "const": 1},
    "receipt_id": {
      "type": "string",
      "pattern": "^teamops-shared-inbox-terminal-anchor-receipt-[0-9a-f]{16}$"
    },
    "created_at": {"type": "string", "format": "date-time"},
    "ready": {"type": "boolean"},
    "solver_outcome": {
      "type": "string",
      "enum": ["SolvedVerified", "AwaitingEvidence", "GovernanceBlocked"]
    },
    "proof_state": {
      "type": "string",
      "enum": ["Pass", "Unknown", "Fail"]
    },
    "preflight_path": {"type": "string", "minLength": 1},
    "source_preflight_receipt_id": {
      "type": "string",
      "pattern": "^teamops-shared-inbox-terminal-anchor-preflight-[0-9a-f]{16}$"
    },
    "bundle_path": {"type": "string", "minLength": 1},
    "bundle_id": {"type": "string", "pattern": "^trust-bundle-[0-9a-f]{16}$"},
    "command_id": {"type": "string", "const": "team_ops.shared_inbox_triage"},
    "terminal_certificate_id": {"type": "string", "minLength": 1},
    "bundle_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "anchor_target": {
      "type": "string",
      "enum": ["audit_chain", "transparency_log", "external_ledger", "regulatory_archive"]
    },
    "external_anchor_status": {"type": "string", "const": "pending"},
    "external_anchor_ref": {"type": "string", "const": ""},
    "operator_authority_ref": {"type": "string", "pattern": "^proof://.+"},
    "anchor_receipt_id": {
      "type": "string",
      "pattern": "^trust-anchor-receipt-[0-9a-f]{16}$"
    },
    "anchor_receipt_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "artifact_root_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "artifact_count": {"type": "integer", "minimum": 4},
    "required_artifact_types": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "string",
        "enum": [
          "command",
          "execution_receipt",
          "verification_result",
          "terminal_certificate"
        ]
      },
      "uniqueItems": true
    },
    "anchor_receipt": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "anchor_receipt_id",
        "bundle_id",
        "tenant_id",
        "command_id",
        "terminal_certificate_id",
        "anchor_target",
        "external_anchor_ref",
        "external_anchor_status",
        "bundle_hash",
        "artifact_root_hash",
        "hash_chain_root",
        "artifact_count",
        "required_artifact_types",
        "anchored_at",
        "signature_key_id",
        "signature",
        "anchor_receipt_hash",
        "metadata"
      ],
      "properties": {
        "anchor_receipt_id": {
          "type": "string",
          "pattern": "^trust-anchor-receipt-[0-9a-f]{16}$"
        },
        "bundle_id": {"type": "string", "pattern": "^trust-bundle-[0-9a-f]{16}$"},
        "tenant_id": {"type": "string", "minLength": 1},
        "command_id": {"type": "string", "const": "team_ops.shared_inbox_triage"},
        "terminal_certificate_id": {"type": "string", "minLength": 1},
        "anchor_target": {
          "type": "string",
          "enum": ["audit_chain", "transparency_log", "external_ledger", "regulatory_archive"]
        },
        "external_anchor_ref": {"type": "string", "const": ""},
        "external_anchor_status": {"type": "string", "const": "pending"},
        "bundle_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "artifact_root_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "hash_chain_root": {"type": "string", "minLength": 1},
        "artifact_count": {"type": "integer", "minimum": 4},
        "required_artifact_types": {
          "type": "array",
          "minItems": 4,
          "items": {
            "type": "string",
            "enum": [
              "command",
              "approval",
              "execution_receipt",
              "verification_result",
              "effect_reconciliation",
              "terminal_certificate",
              "learning_decision",
              "deployment_witness"
            ]
          }
        },
        "anchored_at": {"type": "string", "format": "date-time"},
        "signature_key_id": {"type": "string", "minLength": 1},
        "signature": {"type": "string", "pattern": "^hmac-sha256:.+"},
        "anchor_receipt_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "metadata": {
          "type": "object",
          "additionalProperties": true,
          "required": ["anchor_receipt_is_not_terminal_closure"],
          "properties": {
            "anchor_receipt_is_not_terminal_closure": {"type": "boolean", "const": true},
            "bundle_signature_key_id": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 4,
      "items": {"$ref": "#/$defs/evidence_artifact"}
    },
    "step_count": {"type": "integer", "minimum": 7, "maximum": 7},
    "steps": {
      "type": "array",
      "minItems": 7,
      "maxItems": 7,
      "items": {"$ref": "#/$defs/anchor_receipt_step"}
    },
    "blockers": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "preflight_ready_required",
        "anchor_receipt_created",
        "anchor_bundle_called",
        "remote_submit_executed",
        "ledger_append_executed",
        "provider_call_performed",
        "external_mailbox_write_performed",
        "external_message_sent",
        "raw_message_content_serialized",
        "raw_provider_payload_serialized",
        "no_secret_values_serialized",
        "production_ready_claimed",
        "requires_separate_remote_submission_preflight"
      ],
      "properties": {
        "source": {
          "type": "string",
          "const": "team_ops_shared_inbox_terminal_closure_anchor_receipt"
        },
        "preflight_ready_required": {"type": "boolean", "const": true},
        "anchor_receipt_created": {"type": "boolean", "const": true},
        "anchor_bundle_called": {"type": "boolean", "const": true},
        "remote_submit_executed": {"type": "boolean", "const": false},
        "ledger_append_executed": {"type": "boolean", "const": false},
        "provider_call_performed": {"type": "boolean", "const": false},
        "external_mailbox_write_performed": {"type": "boolean", "const": false},
        "external_message_sent": {"type": "boolean", "const": false},
        "raw_message_content_serialized": {"type": "boolean", "const": false},
        "raw_provider_payload_serialized": {"type": "boolean", "const": false},
        "no_secret_values_serialized": {"type": "boolean", "const": true},
        "production_ready_claimed": {"type": "boolean", "const": false},
        "requires_separate_remote_submission_preflight": {"type": "boolean", "const": true}
      }
    }
  },
  "$defs": {
    "evidence_artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_type",
        "artifact_id",
        "artifact_hash",
        "evidence_ref",
        "required",
        "metadata"
      ],
      "properties": {
        "artifact_type": {
          "type": "string",
          "enum": [
            "command",
            "approval",
            "execution_receipt",
            "verification_result",
            "effect_reconciliation",
            "terminal_certificate",
            "learning_decision",
            "deployment_witness",
            "orgos_event_receipt"
          ]
        },
        "artifact_id": {"type": "string", "minLength": 1},
        "artifact_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "evidence_ref": {"type": "string", "pattern": "^proof://.+"},
        "required": {"type": "boolean"},
        "metadata": {"type": "object", "additionalProperties": true}
      }
    },
    "anchor_receipt_step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "passed", "detail"],
      "properties": {
        "name": {
          "type": "string",
          "enum": [
            "preflight_validation",
            "preflight_ready",
            "source_binding",
            "artifact_projection",
            "anchor_receipt_signature",
            "pending_boundary",
            "effect_boundary"
          ]
        },
        "passed": {"type": "boolean"},
        "detail": {"type": "string", "minLength": 1}
      }
    }
  }
}
