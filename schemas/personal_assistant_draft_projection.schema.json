{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:personal-assistant-draft-projection:1",
  "title": "Personal Assistant Draft Projection",
  "description": "Evidence envelope for email, calendar, and task drafts produced without sends, invites, connector mutation, memory writes, or system-of-record writes.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "draft_set_id",
    "generated_at",
    "governed",
    "source_projection",
    "draft_count",
    "draft_ids",
    "receipt_ids",
    "connectors_used",
    "drafts",
    "effect_boundary",
    "private_payload_policy",
    "approval_boundary",
    "assurance",
    "metadata"
  ],
  "properties": {
    "draft_set_id": {
      "type": "string",
      "pattern": "^pa_draft_projection_[a-z0-9][a-z0-9_:-]*$"
    },
    "generated_at": {"type": "string", "minLength": 1},
    "governed": {"const": true},
    "source_projection": {"const": "operator_supplied_redacted_projection"},
    "draft_count": {"type": "integer", "minimum": 1},
    "draft_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^pa_draft_projection_item_[a-z0-9][a-z0-9_:-]*$"
      },
      "uniqueItems": true
    },
    "receipt_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^pa_receipt_[a-z0-9][a-z0-9_:-]*$"
      },
      "uniqueItems": true
    },
    "connectors_used": {
      "type": "array",
      "items": {"enum": ["gmail", "google_calendar"]},
      "uniqueItems": true
    },
    "drafts": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/draft_projection"}
    },
    "effect_boundary": {"$ref": "#/$defs/effect_boundary"},
    "private_payload_policy": {"$ref": "#/$defs/private_payload_policy"},
    "approval_boundary": {"$ref": "#/$defs/approval_boundary"},
    "assurance": {"$ref": "#/$defs/assurance"},
    "metadata": {"$ref": "#/$defs/metadata"}
  },
  "$defs": {
    "draft_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "draft_id",
        "request_id",
        "skill_id",
        "draft_type",
        "draft",
        "receipt"
      ],
      "properties": {
        "draft_id": {
          "type": "string",
          "pattern": "^pa_draft_projection_item_[a-z0-9][a-z0-9_:-]*$"
        },
        "request_id": {
          "type": "string",
          "pattern": "^pa_request_[a-z0-9][a-z0-9_:-]*$"
        },
        "skill_id": {
          "enum": ["email.response.draft", "calendar.event.draft", "task.create_draft"]
        },
        "draft_type": {
          "enum": ["email_response", "calendar_event", "task"]
        },
        "draft": {
          "type": "object",
          "additionalProperties": true,
          "required": ["draft_type", "effect_boundary"],
          "properties": {
            "draft_type": {
              "enum": ["email_response", "calendar_event", "task"]
            },
            "effect_boundary": {
              "enum": [
                "draft_only_email_not_sent",
                "draft_only_event_not_created",
                "draft_only_task_not_written"
              ]
            },
            "approval_required_before_send": {"type": "boolean"},
            "approval_required_before_create_or_invite": {"type": "boolean"},
            "approval_required_before_task_write": {"type": "boolean"}
          }
        },
        "receipt": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "effect_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "draft_preparation_allowed",
        "execution_allowed",
        "live_connector_execution_allowed",
        "mailbox_mutation_allowed",
        "external_send_allowed",
        "calendar_write_allowed",
        "task_write_allowed",
        "memory_write_allowed",
        "connector_mutation_allowed",
        "system_of_record_write_allowed",
        "deployment_mutation_allowed",
        "public_readiness_claim_allowed"
      ],
      "properties": {
        "draft_preparation_allowed": {"const": true},
        "execution_allowed": {"const": false},
        "live_connector_execution_allowed": {"const": false},
        "mailbox_mutation_allowed": {"const": false},
        "external_send_allowed": {"const": false},
        "calendar_write_allowed": {"const": false},
        "task_write_allowed": {"const": false},
        "memory_write_allowed": {"const": false},
        "connector_mutation_allowed": {"const": false},
        "system_of_record_write_allowed": {"const": false},
        "deployment_mutation_allowed": {"const": false},
        "public_readiness_claim_allowed": {"const": false}
      }
    },
    "private_payload_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raw_private_payload_serialized",
        "secret_values_serialized",
        "connector_payload_projection",
        "body_projection"
      ],
      "properties": {
        "raw_private_payload_serialized": {"const": false},
        "secret_values_serialized": {"const": false},
        "connector_payload_projection": {"enum": ["mixed_redacted_or_no_connector", "redacted_summary"]},
        "body_projection": {"const": "operator_visible_draft"}
      }
    },
    "approval_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "risk_level",
        "approval_required_before_external_action",
        "approval_required_before_system_write",
        "approval_required_before_connector_mutation"
      ],
      "properties": {
        "risk_level": {"const": "P2"},
        "approval_required_before_external_action": {"const": true},
        "approval_required_before_system_write": {"const": true},
        "approval_required_before_connector_mutation": {"const": true}
      }
    },
    "assurance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "assurance_id",
        "outcome",
        "foundation_only",
        "ready_for_live_execution",
        "ready_for_customer_readiness_claim",
        "authority_drift_detected",
        "checked_controls",
        "blocking_reasons",
        "next_action"
      ],
      "properties": {
        "assurance_id": {"const": "personal_assistant_draft_projection_no_effect_assurance"},
        "outcome": {"enum": ["SolvedVerified", "GovernanceBlocked"]},
        "foundation_only": {"const": true},
        "ready_for_live_execution": {"const": false},
        "ready_for_customer_readiness_claim": {"const": false},
        "authority_drift_detected": {"type": "boolean"},
        "checked_controls": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "blocking_reasons": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "next_action": {"type": "string", "minLength": 1}
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "foundation_only",
        "projection_contract",
        "runtime_boundary",
        "live_connector_execution_allowed",
        "connector_mutation_allowed",
        "external_send_allowed",
        "system_of_record_write_allowed",
        "memory_write_allowed"
      ],
      "properties": {
        "foundation_only": {"const": true},
        "projection_contract": {"const": "draft_only_redacted_evidence"},
        "runtime_boundary": {"const": "no_live_connector_calls"},
        "live_connector_execution_allowed": {"const": false},
        "connector_mutation_allowed": {"const": false},
        "external_send_allowed": {"const": false},
        "system_of_record_write_allowed": {"const": false},
        "memory_write_allowed": {"const": false}
      }
    }
  }
}
