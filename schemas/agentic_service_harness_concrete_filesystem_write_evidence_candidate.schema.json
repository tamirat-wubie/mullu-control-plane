{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:agentic-service-harness-concrete-filesystem-write-evidence-candidate:1",
  "title": "Agentic Service Harness Concrete Filesystem Write Evidence Candidate",
  "description": "Foundation Mode candidate receipt for future concrete filesystem write evidence. This candidate binds a non-empty redacted changed-file/diff summary to the blocked filesystem-write admission preflight and blocked non-empty diff file summary receipt while keeping live filesystem writes, branch/workspace writes, raw outputs, receipt append, PR creation, connector calls, mutation routes, secret serialization, and terminal closure blocked.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receipt_id",
    "schema_version",
    "generated_at",
    "solver_outcome",
    "candidate_status",
    "source_filesystem_write_admission_preflight_ref",
    "source_non_empty_diff_file_summary_receipt_ref",
    "scope",
    "source_receipts",
    "candidate_evidence",
    "admission_gates",
    "authority_denials",
    "redaction_policy",
    "receipt_refs",
    "validators",
    "next_action",
    "receipt_is_not_terminal_closure",
    "terminal_closure_required"
  ],
  "properties": {
    "receipt_id": {
      "type": "string",
      "const": "agentic_service_harness_concrete_filesystem_write_evidence_candidate"
    },
    "schema_version": { "type": "integer", "const": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "solver_outcome": { "type": "string", "const": "AwaitingEvidence" },
    "candidate_status": {
      "type": "string",
      "const": "candidate_recorded_without_live_write_authority"
    },
    "source_filesystem_write_admission_preflight_ref": {
      "type": "string",
      "const": "examples/agentic_service_harness_filesystem_write_admission_preflight.foundation.json"
    },
    "source_non_empty_diff_file_summary_receipt_ref": {
      "type": "string",
      "const": "examples/agentic_service_harness_non_empty_diff_file_summary_receipt.foundation.json"
    },
    "scope": { "$ref": "#/$defs/scope" },
    "source_receipts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "filesystem_write_admission_preflight_ref",
        "non_empty_diff_file_summary_receipt_ref",
        "filesystem_write_admission_preflight_verified",
        "non_empty_diff_file_summary_receipt_verified",
        "source_filesystem_write_admitted",
        "source_non_empty_file_summary_emitted",
        "source_changed_file_count"
      ],
      "properties": {
        "filesystem_write_admission_preflight_ref": {
          "type": "string",
          "const": "examples/agentic_service_harness_filesystem_write_admission_preflight.foundation.json"
        },
        "non_empty_diff_file_summary_receipt_ref": {
          "type": "string",
          "const": "examples/agentic_service_harness_non_empty_diff_file_summary_receipt.foundation.json"
        },
        "filesystem_write_admission_preflight_verified": { "type": "boolean", "const": true },
        "non_empty_diff_file_summary_receipt_verified": { "type": "boolean", "const": true },
        "source_filesystem_write_admitted": { "type": "boolean", "const": false },
        "source_non_empty_file_summary_emitted": { "type": "boolean", "const": false },
        "source_changed_file_count": { "type": "integer", "const": 0 }
      }
    },
    "candidate_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_kind",
        "candidate_changed_file_count",
        "changed_file_refs",
        "diff_refs",
        "redacted_diff_bundle_ref",
        "cleanup_receipt_ref",
        "rollback_plan_ref",
        "receipt_append_ref",
        "raw_diff_body_serialized",
        "raw_file_content_serialized",
        "absolute_paths_allowed",
        "parent_traversal_allowed",
        "secret_paths_allowed",
        "production_paths_allowed"
      ],
      "properties": {
        "candidate_kind": {
          "type": "string",
          "const": "redacted_non_empty_filesystem_write_evidence_candidate"
        },
        "candidate_changed_file_count": { "type": "integer", "minimum": 1 },
        "changed_file_refs": { "$ref": "#/$defs/evidence_ref_list" },
        "diff_refs": { "$ref": "#/$defs/evidence_ref_list" },
        "redacted_diff_bundle_ref": {
          "type": "string",
          "const": "digest://redacted-filesystem-write-diff-bundle-candidate"
        },
        "cleanup_receipt_ref": {
          "type": "string",
          "const": "evidence://cleanup-receipt-after-workspace-use"
        },
        "rollback_plan_ref": {
          "type": "string",
          "const": "evidence://filesystem-write-rollback-plan"
        },
        "receipt_append_ref": {
          "type": "string",
          "const": "blocked://receipt-store-write-path/not-verified"
        },
        "raw_diff_body_serialized": { "type": "boolean", "const": false },
        "raw_file_content_serialized": { "type": "boolean", "const": false },
        "absolute_paths_allowed": { "type": "boolean", "const": false },
        "parent_traversal_allowed": { "type": "boolean", "const": false },
        "secret_paths_allowed": { "type": "boolean", "const": false },
        "production_paths_allowed": { "type": "boolean", "const": false }
      }
    },
    "admission_gates": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "filesystem_write_evidence_candidate_recorded",
        "non_empty_diff_candidate_present",
        "filesystem_write_executed",
        "branch_write_authority_verified",
        "workspace_write_authority_verified",
        "operator_approval_collected",
        "cleanup_receipt_verified",
        "redaction_evidence_verified",
        "uao_filesystem_write_verified",
        "receipt_store_write_path_verified",
        "required_before_live_write_refs",
        "blocked_reason_refs",
        "next_required_evidence_refs"
      ],
      "properties": {
        "filesystem_write_evidence_candidate_recorded": { "type": "boolean", "const": true },
        "non_empty_diff_candidate_present": { "type": "boolean", "const": true },
        "filesystem_write_executed": { "type": "boolean", "const": false },
        "branch_write_authority_verified": { "type": "boolean", "const": false },
        "workspace_write_authority_verified": { "type": "boolean", "const": false },
        "operator_approval_collected": { "type": "boolean", "const": false },
        "cleanup_receipt_verified": { "type": "boolean", "const": false },
        "redaction_evidence_verified": { "type": "boolean", "const": false },
        "uao_filesystem_write_verified": { "type": "boolean", "const": false },
        "receipt_store_write_path_verified": { "type": "boolean", "const": false },
        "required_before_live_write_refs": { "$ref": "#/$defs/evidence_ref_list" },
        "blocked_reason_refs": { "$ref": "#/$defs/evidence_ref_list" },
        "next_required_evidence_refs": { "$ref": "#/$defs/evidence_ref_list" }
      }
    },
    "authority_denials": { "$ref": "#/$defs/authority_denials" },
    "redaction_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "secret_redaction_required",
        "diff_redaction_required",
        "redaction_evidence_ref",
        "raw_secret_value_storage_allowed",
        "raw_output_storage_allowed"
      ],
      "properties": {
        "secret_redaction_required": { "type": "boolean", "const": true },
        "diff_redaction_required": { "type": "boolean", "const": true },
        "redaction_evidence_ref": {
          "type": "string",
          "const": "evidence://redaction-policy-for-file-change-collection"
        },
        "raw_secret_value_storage_allowed": { "type": "boolean", "const": false },
        "raw_output_storage_allowed": { "type": "boolean", "const": false }
      }
    },
    "receipt_refs": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/evidence_ref" },
      "required": [
        "concrete_filesystem_write_evidence_candidate_schema",
        "filesystem_write_admission_preflight_example",
        "non_empty_diff_file_summary_receipt_example",
        "redacted_diff_bundle_ref",
        "cleanup_receipt_ref",
        "rollback_plan_ref",
        "receipt_store_write_path_ref",
        "uao_filesystem_write_ref"
      ]
    },
    "validators": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["validator_id", "command", "required_for_closure"],
        "properties": {
          "validator_id": { "$ref": "#/$defs/identifier" },
          "command": { "type": "string", "minLength": 1 },
          "required_for_closure": { "type": "boolean", "const": true }
        }
      }
    },
    "next_action": { "type": "string", "minLength": 1 },
    "receipt_is_not_terminal_closure": { "type": "boolean", "const": true },
    "terminal_closure_required": { "type": "boolean", "const": true }
  },
  "$defs": {
    "authority_denials": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "branch_write_enabled",
        "workspace_write_enabled",
        "filesystem_write_enabled",
        "raw_diff_body_stored",
        "raw_file_content_stored",
        "receipt_store_append_enabled",
        "runtime_state_write_enabled",
        "connector_calls_enabled",
        "mutation_route_enabled",
        "pr_creation_enabled",
        "secret_values_serialized",
        "terminal_closure"
      ],
      "properties": {
        "branch_write_enabled": { "type": "boolean", "const": false },
        "workspace_write_enabled": { "type": "boolean", "const": false },
        "filesystem_write_enabled": { "type": "boolean", "const": false },
        "raw_diff_body_stored": { "type": "boolean", "const": false },
        "raw_file_content_stored": { "type": "boolean", "const": false },
        "receipt_store_append_enabled": { "type": "boolean", "const": false },
        "runtime_state_write_enabled": { "type": "boolean", "const": false },
        "connector_calls_enabled": { "type": "boolean", "const": false },
        "mutation_route_enabled": { "type": "boolean", "const": false },
        "pr_creation_enabled": { "type": "boolean", "const": false },
        "secret_values_serialized": { "type": "boolean", "const": false },
        "terminal_closure": { "type": "boolean", "const": false }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project_id",
        "task_id",
        "run_id",
        "sandbox_id",
        "repository_connection_id",
        "repository_slug",
        "mode",
        "foundation_phase"
      ],
      "properties": {
        "project_id": { "$ref": "#/$defs/identifier" },
        "task_id": { "$ref": "#/$defs/identifier" },
        "run_id": { "$ref": "#/$defs/identifier" },
        "sandbox_id": { "$ref": "#/$defs/identifier" },
        "repository_connection_id": { "$ref": "#/$defs/identifier" },
        "repository_slug": { "type": "string", "const": "tamirat-wubie/mullu-control-plane" },
        "mode": { "type": "string", "const": "branch_write" },
        "foundation_phase": {
          "type": "string",
          "const": "foundation_concrete_filesystem_write_evidence_candidate"
        }
      }
    },
    "evidence_ref": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(approval|blocked|digest|evidence|examples|receipt|schemas|scripts|witness)://|^(examples|schemas|scripts)/|^MULLUSI_"
    },
    "evidence_ref_list": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/evidence_ref" }
    },
    "identifier": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9][a-z0-9_.-]*$"
    }
  }
}
