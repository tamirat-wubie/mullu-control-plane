{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:world-state:1",
  "title": "World State",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "tenant_id",
    "state_id",
    "entities",
    "relations",
    "events",
    "claims",
    "contradictions",
    "projected_at",
    "state_hash"
  ],
  "properties": {
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "state_id": {
      "type": "string",
      "minLength": 1
    },
    "entities": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/world_entity"
      }
    },
    "relations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/world_relation"
      }
    },
    "events": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/world_event"
      }
    },
    "claims": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/world_claim"
      }
    },
    "contradictions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/contradiction"
      }
    },
    "projected_at": {
      "type": "string",
      "format": "date-time"
    },
    "state_hash": {
      "type": "string",
      "minLength": 1
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "evidence_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_id",
        "evidence_type",
        "source",
        "observed_at"
      ],
      "properties": {
        "evidence_id": {
          "type": "string",
          "minLength": 1
        },
        "evidence_type": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "observed_at": {
          "type": "string",
          "format": "date-time"
        },
        "uri": {
          "type": "string"
        },
        "content_hash": {
          "type": "string"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "validity_window": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "valid_from"
      ],
      "properties": {
        "valid_from": {
          "type": "string",
          "format": "date-time"
        },
        "valid_until": {
          "type": "string"
        },
        "requires_refresh": {
          "type": "boolean"
        }
      }
    },
    "world_entity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entity_id",
        "tenant_id",
        "entity_type",
        "display_name",
        "evidence_refs",
        "source",
        "observed_at",
        "validity",
        "trust_class",
        "allowed_for_planning",
        "allowed_for_execution"
      ],
      "properties": {
        "entity_id": {
          "type": "string",
          "minLength": 1
        },
        "tenant_id": {
          "type": "string",
          "minLength": 1
        },
        "entity_type": {
          "type": "string",
          "minLength": 1
        },
        "display_name": {
          "type": "string",
          "minLength": 1
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/evidence_ref"
          }
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "observed_at": {
          "type": "string",
          "format": "date-time"
        },
        "validity": {
          "$ref": "#/$defs/validity_window"
        },
        "attributes": {
          "type": "object",
          "additionalProperties": true
        },
        "trust_class": {
          "type": "string",
          "minLength": 1
        },
        "supersedes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "contradicts": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "allowed_for_planning": {
          "type": "boolean"
        },
        "allowed_for_execution": {
          "type": "boolean"
        },
        "created_at": {
          "type": "string"
        },
        "state_hash": {
          "type": "string"
        }
      }
    },
    "world_relation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "relation_id",
        "tenant_id",
        "relation_type",
        "source_entity_id",
        "target_entity_id",
        "evidence_refs",
        "source",
        "observed_at",
        "validity",
        "trust_class",
        "allowed_for_planning",
        "allowed_for_execution"
      ],
      "properties": {
        "relation_id": {
          "type": "string",
          "minLength": 1
        },
        "tenant_id": {
          "type": "string",
          "minLength": 1
        },
        "relation_type": {
          "type": "string",
          "minLength": 1
        },
        "source_entity_id": {
          "type": "string",
          "minLength": 1
        },
        "target_entity_id": {
          "type": "string",
          "minLength": 1
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/evidence_ref"
          }
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "observed_at": {
          "type": "string",
          "format": "date-time"
        },
        "validity": {
          "$ref": "#/$defs/validity_window"
        },
        "attributes": {
          "type": "object",
          "additionalProperties": true
        },
        "trust_class": {
          "type": "string",
          "minLength": 1
        },
        "supersedes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "contradicts": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "allowed_for_planning": {
          "type": "boolean"
        },
        "allowed_for_execution": {
          "type": "boolean"
        },
        "created_at": {
          "type": "string"
        },
        "state_hash": {
          "type": "string"
        }
      }
    },
    "world_event": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_id",
        "tenant_id",
        "event_type",
        "occurred_at",
        "evidence_refs",
        "source"
      ],
      "properties": {
        "event_id": {
          "type": "string",
          "minLength": 1
        },
        "tenant_id": {
          "type": "string",
          "minLength": 1
        },
        "event_type": {
          "type": "string",
          "minLength": 1
        },
        "occurred_at": {
          "type": "string",
          "format": "date-time"
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/evidence_ref"
          }
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "entity_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "relation_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "claim_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "attributes": {
          "type": "object",
          "additionalProperties": true
        },
        "created_at": {
          "type": "string"
        },
        "event_hash": {
          "type": "string"
        }
      }
    },
    "world_claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim_id",
        "tenant_id",
        "subject_ref",
        "predicate",
        "object_value",
        "evidence_refs",
        "source",
        "observed_at",
        "validity",
        "confidence",
        "trust_class",
        "freshness_window_days",
        "domain_risk",
        "allowed_for_planning",
        "allowed_for_execution"
      ],
      "properties": {
        "claim_id": {
          "type": "string",
          "minLength": 1
        },
        "tenant_id": {
          "type": "string",
          "minLength": 1
        },
        "subject_ref": {
          "type": "string",
          "minLength": 1
        },
        "predicate": {
          "type": "string",
          "minLength": 1
        },
        "object_value": {
          "type": "string"
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/evidence_ref"
          }
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "observed_at": {
          "type": "string",
          "format": "date-time"
        },
        "validity": {
          "$ref": "#/$defs/validity_window"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "trust_class": {
          "type": "string",
          "minLength": 1
        },
        "freshness_window_days": {
          "type": "integer",
          "minimum": 0
        },
        "domain_risk": {
          "type": "string",
          "minLength": 1
        },
        "supersedes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "contradicts": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "allowed_for_planning": {
          "type": "boolean"
        },
        "allowed_for_execution": {
          "type": "boolean"
        },
        "created_at": {
          "type": "string"
        },
        "claim_hash": {
          "type": "string"
        }
      }
    },
    "contradiction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contradiction_id",
        "tenant_id",
        "refs",
        "reason",
        "evidence_refs",
        "source",
        "observed_at",
        "severity",
        "status"
      ],
      "properties": {
        "contradiction_id": {
          "type": "string",
          "minLength": 1
        },
        "tenant_id": {
          "type": "string",
          "minLength": 1
        },
        "refs": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/evidence_ref"
          }
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "observed_at": {
          "type": "string",
          "format": "date-time"
        },
        "severity": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "open",
            "resolved",
            "accepted_risk"
          ]
        },
        "resolution_ref": {
          "type": "string"
        },
        "created_at": {
          "type": "string"
        },
        "contradiction_hash": {
          "type": "string"
        }
      }
    }
  }
}
