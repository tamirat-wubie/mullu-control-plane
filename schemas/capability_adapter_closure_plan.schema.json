{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:capability-adapter-closure-plan:1",
  "title": "Capability Adapter Closure Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "plan_id",
    "source_evidence_path",
    "source_ready",
    "action_count",
    "blockers",
    "actions"
  ],
  "properties": {
    "plan_id": {
      "type": "string",
      "pattern": "^capability-adapter-closure-plan-[0-9a-f]{16}$"
    },
    "source_evidence_path": {
      "type": "string",
      "minLength": 1
    },
    "source_ready": {
      "type": "boolean"
    },
    "action_count": {
      "type": "integer",
      "minimum": 0
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/adapter_closure_action"
      }
    }
  },
  "$defs": {
    "adapter_closure_action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_id",
        "adapter_id",
        "blocker",
        "action_type",
        "command",
        "verification_command",
        "receipt_validator",
        "evidence_required",
        "risk_level",
        "approval_required"
      ],
      "properties": {
        "action_id": {
          "type": "string",
          "minLength": 1
        },
        "adapter_id": {
          "type": "string",
          "minLength": 1
        },
        "blocker": {
          "type": "string",
          "minLength": 1
        },
        "action_type": {
          "type": "string",
          "enum": [
            "credential",
            "dependency",
            "live-receipt",
            "manual-review"
          ]
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "verification_command": {
          "type": "string",
          "minLength": 1
        },
        "receipt_validator": {
          "type": "string",
          "minLength": 1
        },
        "evidence_required": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "risk_level": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "approval_required": {
          "type": "boolean"
        }
      }
    }
  }
}
