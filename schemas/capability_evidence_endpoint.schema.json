{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:capability-evidence-endpoint:1",
  "title": "Capability Evidence Endpoint",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "runtime_env",
    "commit_sha",
    "deployment_id",
    "enabled",
    "capability_count",
    "capability_evidence",
    "live_capabilities",
    "sandbox_only_capabilities",
    "checks"
  ],
  "properties": {
    "runtime_env": {
      "type": "string",
      "minLength": 1
    },
    "commit_sha": {
      "type": "string",
      "minLength": 1
    },
    "deployment_id": {
      "type": "string",
      "minLength": 1
    },
    "enabled": {
      "type": "boolean"
    },
    "capability_count": {
      "type": "integer",
      "minimum": 0
    },
    "capsule_count": {
      "type": "integer",
      "minimum": 0
    },
    "require_certified": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "capability_evidence": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "enum": [
          "described_only",
          "tested",
          "sandbox",
          "pilot",
          "production"
        ]
      }
    },
    "live_capabilities": {
      "$ref": "#/$defs/capability_ids"
    },
    "sandbox_only_capabilities": {
      "$ref": "#/$defs/capability_ids"
    },
    "checks": {
      "$ref": "#/$defs/checks"
    }
  },
  "$defs": {
    "capability_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "check_id",
          "passed",
          "detail"
        ],
        "properties": {
          "check_id": {
            "type": "string",
            "minLength": 1
          },
          "passed": {
            "type": "boolean"
          },
          "detail": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
