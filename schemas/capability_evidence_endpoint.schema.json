{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:capability-evidence-endpoint:1",
  "title": "Capability Evidence Endpoint",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "runtime_env",
    "commit_sha",
    "deployment_id",
    "enabled",
    "capability_count",
    "capability_evidence",
    "live_capabilities",
    "sandbox_only_capabilities",
    "checks"
  ],
  "properties": {
    "runtime_env": {
      "type": "string",
      "minLength": 1
    },
    "commit_sha": {
      "type": "string",
      "minLength": 1
    },
    "deployment_id": {
      "type": "string",
      "minLength": 1
    },
    "enabled": {
      "type": "boolean"
    },
    "capability_count": {
      "type": "integer",
      "minimum": 0
    },
    "capsule_count": {
      "type": "integer",
      "minimum": 0
    },
    "require_certified": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "capability_evidence": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/capability_evidence_value"
      }
    },
    "live_capabilities": {
      "$ref": "#/$defs/capability_ids"
    },
    "sandbox_only_capabilities": {
      "$ref": "#/$defs/capability_ids"
    },
    "checks": {
      "$ref": "#/$defs/checks"
    }
  },
  "$defs": {
    "capability_evidence_value": {
      "oneOf": [
        {
          "$ref": "#/$defs/maturity_status"
        },
        {
          "$ref": "#/$defs/physical_live_safety_evidence"
        }
      ]
    },
    "maturity_status": {
      "type": "string",
      "enum": [
        "described_only",
        "tested",
        "sandbox",
        "pilot",
        "production"
      ]
    },
    "physical_live_safety_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "maturity",
        "effect_mode",
        "production_admissible",
        "physical_action_receipt_schema_ref",
        "physical_action_receipt_ref",
        "simulation_ref",
        "operator_approval_ref",
        "manual_override_ref",
        "emergency_stop_ref",
        "sensor_confirmation_ref",
        "deployment_witness_ref"
      ],
      "properties": {
        "maturity": {
          "type": "string",
          "const": "production"
        },
        "effect_mode": {
          "type": "string",
          "const": "live"
        },
        "production_admissible": {
          "type": "boolean",
          "const": true
        },
        "physical_action_receipt_schema_ref": {
          "type": "string",
          "const": "urn:mullusi:schema:physical-action-receipt:1"
        },
        "physical_action_receipt_ref": {
          "type": "string",
          "minLength": 1
        },
        "simulation_ref": {
          "type": "string",
          "minLength": 1
        },
        "operator_approval_ref": {
          "type": "string",
          "minLength": 1
        },
        "manual_override_ref": {
          "type": "string",
          "minLength": 1
        },
        "emergency_stop_ref": {
          "type": "string",
          "minLength": 1
        },
        "sensor_confirmation_ref": {
          "type": "string",
          "minLength": 1
        },
        "deployment_witness_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "capability_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "check_id",
          "passed",
          "detail"
        ],
        "properties": {
          "check_id": {
            "type": "string",
            "minLength": 1
          },
          "passed": {
            "type": "boolean"
          },
          "detail": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
