{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:temporal-credential-expiry-receipt:1",
  "title": "Temporal Credential Expiry Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receipt_id",
    "request_id",
    "tenant_id",
    "actor_id",
    "command_id",
    "action_type",
    "risk_level",
    "policy_id",
    "status",
    "credential_state",
    "runtime_now_utc",
    "credential_check_required",
    "credential_id",
    "provider_id",
    "credential_scope_id",
    "source_kind",
    "disposition",
    "issued_at",
    "observed_at",
    "expires_at",
    "rotation_due_at",
    "seconds_until_expiry",
    "seconds_until_rotation_due",
    "credential_age_seconds",
    "owner_id",
    "allowed_provider_ids",
    "allowed_credential_scope_ids",
    "blocked_reasons",
    "warning_reasons",
    "required_controls",
    "evidence_refs",
    "credential_evidence_refs",
    "source_binding_receipt_id",
    "source_temporal_receipt_id",
    "source_reapproval_receipt_id",
    "receipt_schema_ref",
    "terminal_closure_required",
    "receipt_hash",
    "metadata"
  ],
  "properties": {
    "receipt_id": {
      "type": "string",
      "pattern": "^temporal-credential-expiry-receipt-[0-9a-f]{16}$"
    },
    "request_id": {"type": "string", "minLength": 1},
    "tenant_id": {"type": "string", "minLength": 1},
    "actor_id": {"type": "string", "minLength": 1},
    "command_id": {"type": "string", "minLength": 1},
    "action_type": {"type": "string", "minLength": 1},
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "policy_id": {"type": "string", "minLength": 1},
    "status": {
      "type": "string",
      "enum": ["credential_valid", "rotation_pending", "expired", "blocked", "not_required"]
    },
    "credential_state": {
      "type": "string",
      "enum": ["active", "rotation_pending", "expired", "revoked", "future", "wrong_scope", "invalid", "not_required"]
    },
    "runtime_now_utc": {"type": "string", "format": "date-time"},
    "credential_check_required": {"type": "boolean"},
    "credential_id": {"type": "string"},
    "provider_id": {"type": "string", "minLength": 1},
    "credential_scope_id": {"type": "string", "minLength": 1},
    "source_kind": {
      "type": "string",
      "enum": ["", "environment", "file", "vault", "operator_input"]
    },
    "disposition": {
      "type": "string",
      "enum": ["", "active", "rotation_pending", "expired", "revoked"]
    },
    "issued_at": {"type": "string"},
    "observed_at": {"type": "string"},
    "expires_at": {"type": "string"},
    "rotation_due_at": {"type": "string"},
    "seconds_until_expiry": {"type": "integer", "minimum": 0},
    "seconds_until_rotation_due": {"type": "integer", "minimum": 0},
    "credential_age_seconds": {"type": "integer", "minimum": 0},
    "owner_id": {"type": "string"},
    "allowed_provider_ids": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "allowed_credential_scope_ids": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "blocked_reasons": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "warning_reasons": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "required_controls": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "evidence_refs": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "credential_evidence_refs": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "source_binding_receipt_id": {"type": "string"},
    "source_temporal_receipt_id": {"type": "string"},
    "source_reapproval_receipt_id": {"type": "string"},
    "receipt_schema_ref": {
      "type": "string",
      "const": "urn:mullusi:schema:temporal-credential-expiry-receipt:1"
    },
    "terminal_closure_required": {"type": "boolean", "const": true},
    "receipt_hash": {"type": "string", "minLength": 1},
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "receipt_is_not_terminal_closure",
        "runtime_owns_time_truth",
        "dispatch_allowed",
        "credential_checked",
        "expiry_checked",
        "provider_scope_checked",
        "rotation_warning_checked",
        "secret_value_absent",
        "high_risk_source_receipts_checked"
      ],
      "properties": {
        "receipt_is_not_terminal_closure": {"type": "boolean", "const": true},
        "runtime_owns_time_truth": {"type": "boolean", "const": true},
        "dispatch_allowed": {"type": "boolean"},
        "credential_checked": {"type": "boolean"},
        "expiry_checked": {"type": "boolean"},
        "provider_scope_checked": {"type": "boolean"},
        "rotation_warning_checked": {"type": "boolean"},
        "secret_value_absent": {"type": "boolean", "const": true},
        "high_risk_source_receipts_checked": {"type": "boolean"}
      },
      "not": {
        "anyOf": [
          {"required": ["api_key"]},
          {"required": ["credential_value"]},
          {"required": ["password"]},
          {"required": ["raw_secret"]},
          {"required": ["raw_value"]},
          {"required": ["secret"]},
          {"required": ["secret_value"]},
          {"required": ["token"]}
        ]
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {"status": {"const": "credential_valid"}},
        "required": ["status"]
      },
      "then": {
        "properties": {
          "credential_check_required": {"const": true},
          "credential_state": {"const": "active"},
          "blocked_reasons": {"maxItems": 0},
          "warning_reasons": {"maxItems": 0},
          "credential_id": {"minLength": 1},
          "source_kind": {"minLength": 1},
          "disposition": {"const": "active"},
          "seconds_until_expiry": {"exclusiveMinimum": 0},
          "metadata": {
            "properties": {
              "dispatch_allowed": {"const": true},
              "credential_checked": {"const": true},
              "expiry_checked": {"const": true},
              "provider_scope_checked": {"const": true},
              "rotation_warning_checked": {"const": true}
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {"status": {"const": "rotation_pending"}},
        "required": ["status"]
      },
      "then": {
        "properties": {
          "credential_check_required": {"const": true},
          "credential_state": {"const": "rotation_pending"},
          "blocked_reasons": {"maxItems": 0},
          "warning_reasons": {"minItems": 1},
          "credential_id": {"minLength": 1},
          "seconds_until_expiry": {"exclusiveMinimum": 0},
          "metadata": {
            "properties": {
              "dispatch_allowed": {"const": true},
              "credential_checked": {"const": true},
              "expiry_checked": {"const": true},
              "rotation_warning_checked": {"const": true}
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {"status": {"const": "expired"}},
        "required": ["status"]
      },
      "then": {
        "properties": {
          "credential_state": {"const": "expired"},
          "seconds_until_expiry": {"const": 0},
          "blocked_reasons": {"minItems": 1},
          "metadata": {
            "properties": {
              "dispatch_allowed": {"const": false},
              "credential_checked": {"const": true},
              "expiry_checked": {"const": true}
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {"status": {"const": "blocked"}},
        "required": ["status"]
      },
      "then": {
        "properties": {
          "blocked_reasons": {"minItems": 1},
          "metadata": {
            "properties": {
              "dispatch_allowed": {"const": false}
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {"status": {"const": "not_required"}},
        "required": ["status"]
      },
      "then": {
        "properties": {
          "credential_check_required": {"const": false},
          "credential_state": {"const": "not_required"},
          "credential_id": {"maxLength": 0},
          "source_kind": {"maxLength": 0},
          "disposition": {"maxLength": 0},
          "issued_at": {"maxLength": 0},
          "observed_at": {"maxLength": 0},
          "expires_at": {"maxLength": 0},
          "rotation_due_at": {"maxLength": 0},
          "seconds_until_expiry": {"const": 0},
          "seconds_until_rotation_due": {"const": 0},
          "credential_age_seconds": {"const": 0},
          "owner_id": {"maxLength": 0},
          "blocked_reasons": {"maxItems": 0},
          "warning_reasons": {"maxItems": 0},
          "credential_evidence_refs": {"maxItems": 0},
          "source_binding_receipt_id": {"maxLength": 0},
          "metadata": {
            "properties": {
              "dispatch_allowed": {"const": true},
              "credential_checked": {"const": false},
              "expiry_checked": {"const": false},
              "provider_scope_checked": {"const": false},
              "rotation_warning_checked": {"const": false},
              "high_risk_source_receipts_checked": {"const": false}
            }
          }
        }
      }
    }
  ]
}
