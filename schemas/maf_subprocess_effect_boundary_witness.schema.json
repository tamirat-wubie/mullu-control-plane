{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:maf-subprocess-effect-boundary-witness:1",
  "title": "MAF Subprocess Effect Boundary Witness",
  "description": "Foundation Mode witness that closes the static subprocess effect-boundary envelope for future MAF CLI binding while denying subprocess execution, shell invocation, runtime dispatch, raw output retention, secrets, writes, terminal closure, and success authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "witness_id",
    "witness_version",
    "generated_at",
    "solver_outcome",
    "boundary_scope",
    "source_artifacts",
    "effect_controls",
    "authority_boundary",
    "receipt_refs",
    "contract_summary",
    "evidence_refs"
  ],
  "properties": {
    "witness_id": {"type": "string", "minLength": 1},
    "witness_version": {"const": "maf_subprocess_effect_boundary_witness.v1"},
    "generated_at": {"type": "string", "format": "date-time"},
    "solver_outcome": {"const": "AwaitingEvidence"},
    "boundary_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_family",
        "foundation_mode",
        "boundary_mode",
        "subprocess_effect_boundary_closed",
        "runtime_binding_claimed",
        "subprocess_execution_claimed",
        "abi_cli_contract_ref",
        "parity_witness_ref",
        "uao_ref",
        "life_meaning_judgment_ref",
        "required_future_witnesses"
      ],
      "properties": {
        "source_family": {"const": "maf/rust"},
        "foundation_mode": {"type": "boolean"},
        "boundary_mode": {"const": "denied_by_default_subprocess_effect_boundary"},
        "subprocess_effect_boundary_closed": {"type": "boolean"},
        "runtime_binding_claimed": {"type": "boolean"},
        "subprocess_execution_claimed": {"type": "boolean"},
        "abi_cli_contract_ref": {"const": "witness://maf/abi-cli-contract"},
        "parity_witness_ref": {"const": "witness://maf/receipt-parity"},
        "uao_ref": {"type": "string", "minLength": 1},
        "life_meaning_judgment_ref": {"type": "string", "minLength": 1},
        "required_future_witnesses": {"$ref": "#/$defs/non_empty_string_array"}
      }
    },
    "source_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/source_artifact"}
    },
    "effect_controls": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/effect_control"}
    },
    "authority_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "static_boundary_read_allowed",
        "cli_execution_allowed",
        "subprocess_execution_allowed",
        "runtime_binding_allowed",
        "pyo3_binding_allowed",
        "rust_crate_execution_allowed",
        "python_imports_rust_allowed",
        "shell_invocation_allowed",
        "child_process_spawn_allowed",
        "network_call_allowed",
        "secret_access_allowed",
        "environment_secret_allowed",
        "stdin_secret_allowed",
        "raw_stdout_retention_allowed",
        "raw_stderr_retention_allowed",
        "filesystem_write_allowed",
        "runtime_dispatch_allowed",
        "canonical_state_mutation_allowed",
        "terminal_closure_allowed",
        "success_claim_allowed"
      ],
      "properties": {
        "static_boundary_read_allowed": {"type": "boolean"},
        "cli_execution_allowed": {"type": "boolean"},
        "subprocess_execution_allowed": {"type": "boolean"},
        "runtime_binding_allowed": {"type": "boolean"},
        "pyo3_binding_allowed": {"type": "boolean"},
        "rust_crate_execution_allowed": {"type": "boolean"},
        "python_imports_rust_allowed": {"type": "boolean"},
        "shell_invocation_allowed": {"type": "boolean"},
        "child_process_spawn_allowed": {"type": "boolean"},
        "network_call_allowed": {"type": "boolean"},
        "secret_access_allowed": {"type": "boolean"},
        "environment_secret_allowed": {"type": "boolean"},
        "stdin_secret_allowed": {"type": "boolean"},
        "raw_stdout_retention_allowed": {"type": "boolean"},
        "raw_stderr_retention_allowed": {"type": "boolean"},
        "filesystem_write_allowed": {"type": "boolean"},
        "runtime_dispatch_allowed": {"type": "boolean"},
        "canonical_state_mutation_allowed": {"type": "boolean"},
        "terminal_closure_allowed": {"type": "boolean"},
        "success_claim_allowed": {"type": "boolean"}
      }
    },
    "receipt_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "maf_subprocess_effect_boundary_witness_schema",
        "maf_subprocess_effect_boundary_witness_example",
        "maf_subprocess_effect_boundary_witness_validator",
        "maf_subprocess_effect_boundary_witness_tests",
        "maf_subprocess_effect_boundary_witness_doc",
        "maf_abi_cli_contract_witness_schema",
        "maf_abi_cli_contract_witness_example",
        "maf_abi_cli_contract_witness_validator",
        "maf_abi_cli_contract_witness_tests",
        "maf_receipt_parity_witness_schema",
        "maf_receipt_parity_witness_example",
        "maf_boundary_doc",
        "rust_workspace_manifest",
        "rust_cli_manifest",
        "rust_cli_entry",
        "universal_action_orchestration_schema",
        "life_meaning_judgment_schema",
        "worker_failure_receipt_schema"
      ],
      "properties": {
        "maf_subprocess_effect_boundary_witness_schema": {"type": "string", "minLength": 1},
        "maf_subprocess_effect_boundary_witness_example": {"type": "string", "minLength": 1},
        "maf_subprocess_effect_boundary_witness_validator": {"type": "string", "minLength": 1},
        "maf_subprocess_effect_boundary_witness_tests": {"type": "string", "minLength": 1},
        "maf_subprocess_effect_boundary_witness_doc": {"type": "string", "minLength": 1},
        "maf_abi_cli_contract_witness_schema": {"type": "string", "minLength": 1},
        "maf_abi_cli_contract_witness_example": {"type": "string", "minLength": 1},
        "maf_abi_cli_contract_witness_validator": {"type": "string", "minLength": 1},
        "maf_abi_cli_contract_witness_tests": {"type": "string", "minLength": 1},
        "maf_receipt_parity_witness_schema": {"type": "string", "minLength": 1},
        "maf_receipt_parity_witness_example": {"type": "string", "minLength": 1},
        "maf_boundary_doc": {"type": "string", "minLength": 1},
        "rust_workspace_manifest": {"type": "string", "minLength": 1},
        "rust_cli_manifest": {"type": "string", "minLength": 1},
        "rust_cli_entry": {"type": "string", "minLength": 1},
        "universal_action_orchestration_schema": {"type": "string", "minLength": 1},
        "life_meaning_judgment_schema": {"type": "string", "minLength": 1},
        "worker_failure_receipt_schema": {"type": "string", "minLength": 1}
      }
    },
    "contract_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_artifact_count",
        "effect_control_count",
        "authority_denial_count",
        "open_gap_count",
        "evidence_ref_count"
      ],
      "properties": {
        "source_artifact_count": {"type": "integer", "minimum": 0},
        "effect_control_count": {"type": "integer", "minimum": 0},
        "authority_denial_count": {"type": "integer", "minimum": 0},
        "open_gap_count": {"type": "integer", "minimum": 0},
        "evidence_ref_count": {"type": "integer", "minimum": 0}
      }
    },
    "evidence_refs": {"$ref": "#/$defs/non_empty_string_array"}
  },
  "$defs": {
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "source_artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "artifact_ref",
        "artifact_digest_sha256",
        "artifact_role",
        "execution_authority_denied"
      ],
      "properties": {
        "artifact_id": {"type": "string", "minLength": 1},
        "artifact_ref": {"type": "string", "minLength": 1},
        "artifact_digest_sha256": {"$ref": "#/$defs/sha256"},
        "artifact_role": {
          "type": "string",
          "enum": [
            "abi_cli_contract",
            "abi_cli_example",
            "abi_cli_validator",
            "abi_cli_tests",
            "workspace_manifest",
            "cli_manifest",
            "cli_entry"
          ]
        },
        "execution_authority_denied": {"type": "boolean"}
      }
    },
    "effect_control": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "control_id",
        "control_family",
        "boundary_status",
        "execution_allowed",
        "raw_retention_allowed",
        "policy_ref",
        "gap_refs"
      ],
      "properties": {
        "control_id": {"type": "string", "minLength": 1},
        "control_family": {
          "type": "string",
          "enum": [
            "command_resolution",
            "argv",
            "cwd",
            "environment",
            "stdin",
            "stdout",
            "stderr",
            "timeout",
            "exit_code",
            "filesystem",
            "process_network",
            "receipt_failure"
          ]
        },
        "boundary_status": {"const": "denied_until_witnessed"},
        "execution_allowed": {"type": "boolean"},
        "raw_retention_allowed": {"type": "boolean"},
        "policy_ref": {"type": "string", "minLength": 1},
        "gap_refs": {"$ref": "#/$defs/non_empty_string_array"}
      }
    }
  }
}
