{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:governed-swarm-staging-evidence-bundle:1",
  "title": "Governed Swarm Staging Evidence Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bundle_id",
    "validated_at",
    "environment",
    "runner_preflight_ref",
    "activation_witness_ref",
    "control_plane_commit",
    "runtime_path",
    "audit_store_path",
    "staging_url",
    "extension_health",
    "runner_ready",
    "activation_outcome",
    "cross_checks",
    "outcome",
    "errors"
  ],
  "properties": {
    "bundle_id": {
      "type": "string",
      "pattern": "^governed-swarm-staging-bundle-[0-9a-f]{16}$"
    },
    "validated_at": {
      "type": "string",
      "format": "date-time"
    },
    "environment": {
      "type": "string",
      "enum": ["staging", "pilot"]
    },
    "runner_preflight_ref": {
      "type": "string",
      "minLength": 1
    },
    "activation_witness_ref": {
      "type": "string",
      "minLength": 1
    },
    "control_plane_commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "runtime_path": {
      "type": "string",
      "pattern": "mcoi$"
    },
    "audit_store_path": {
      "type": "string",
      "minLength": 1
    },
    "staging_url": {
      "type": "string",
      "pattern": "^https?://.+"
    },
    "extension_health": {
      "$ref": "#/$defs/extension_health"
    },
    "runner_ready": {
      "type": "boolean"
    },
    "activation_outcome": {
      "type": "string",
      "enum": ["SolvedVerified", "AwaitingEvidence", "GovernanceBlocked"]
    },
    "cross_checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/cross_check"
      }
    },
    "outcome": {
      "type": "string",
      "enum": ["SolvedVerified", "AwaitingEvidence"]
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "extension_health": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "http_status",
        "governed",
        "governed_swarm",
        "note_memory"
      ],
      "properties": {
        "http_status": {
          "type": "integer",
          "const": 200
        },
        "governed": {
          "type": "boolean",
          "const": true
        },
        "governed_swarm": {
          "$ref": "#/$defs/governed_swarm_extension"
        },
        "note_memory": {
          "$ref": "#/$defs/note_memory_extension"
        }
      }
    },
    "governed_swarm_extension": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "registered",
        "enabled",
        "mounted",
        "state",
        "reason",
        "audit_store_configured"
      ],
      "properties": {
        "registered": {
          "type": "boolean"
        },
        "enabled": {
          "type": "boolean"
        },
        "mounted": {
          "type": "boolean"
        },
        "state": {
          "type": "string",
          "enum": ["unregistered", "disabled", "enabled_unmounted", "mounted"]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "audit_store_configured": {
          "type": "boolean"
        }
      }
    },
    "note_memory_extension": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "registered",
        "enabled",
        "mounted",
        "state",
        "reason",
        "store_configured"
      ],
      "properties": {
        "registered": {
          "type": "boolean"
        },
        "enabled": {
          "type": "boolean"
        },
        "mounted": {
          "type": "boolean"
        },
        "state": {
          "type": "string",
          "enum": ["unregistered", "disabled", "enabled_unmounted", "mounted"]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "store_configured": {
          "type": "boolean"
        }
      }
    },
    "cross_check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "passed", "detail"],
      "properties": {
        "name": {
          "type": "string",
          "enum": [
            "runner_preflight_valid",
            "activation_witness_valid",
            "control_plane_commit_match",
            "runtime_path_match",
            "audit_store_path_match",
            "runner_ready",
            "activation_solved",
            "extension_health_bound",
            "environment_bound",
            "staging_url_bound"
          ]
        },
        "passed": {
          "type": "boolean"
        },
        "detail": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
