{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:governed-swarm-promotion-readiness:1",
  "title": "Governed Swarm Promotion Readiness",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "readiness_id",
    "checked_at",
    "target_environment",
    "staging_evidence_bundle_ref",
    "control_plane_commit",
    "runtime_path",
    "audit_store_path",
    "staging_url",
    "extension_health",
    "ready",
    "readiness_level",
    "outcome",
    "checks",
    "blockers"
  ],
  "properties": {
    "readiness_id": {
      "type": "string",
      "pattern": "^governed-swarm-promotion-[0-9a-f]{16}$"
    },
    "checked_at": {
      "type": "string",
      "format": "date-time"
    },
    "target_environment": {
      "type": "string",
      "enum": ["pilot", "production"]
    },
    "staging_evidence_bundle_ref": {
      "type": "string",
      "minLength": 1
    },
    "control_plane_commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "runtime_path": {
      "type": "string",
      "pattern": "mcoi$"
    },
    "audit_store_path": {
      "type": "string",
      "minLength": 1
    },
    "staging_url": {
      "type": "string",
      "pattern": "^https?://.+"
    },
    "extension_health": {
      "$ref": "#/$defs/extension_health"
    },
    "ready": {
      "type": "boolean"
    },
    "readiness_level": {
      "type": "string",
      "enum": ["pilot-ready", "promotion-blocked"]
    },
    "outcome": {
      "type": "string",
      "enum": ["SolvedVerified", "AwaitingEvidence", "GovernanceBlocked"]
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/check"
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "passed", "detail"],
      "properties": {
        "name": {
          "type": "string",
          "enum": [
            "staging_evidence_bundle_valid",
            "staging_evidence_solved",
            "runner_ready_bound",
            "activation_outcome_solved",
            "extension_health_bound",
            "target_environment_allowed",
            "production_witness_required"
          ]
        },
        "passed": {
          "type": "boolean"
        },
        "detail": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "extension_health": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "http_status",
        "governed",
        "governed_swarm",
        "note_memory"
      ],
      "properties": {
        "http_status": {
          "type": "integer",
          "const": 200
        },
        "governed": {
          "type": "boolean",
          "const": true
        },
        "governed_swarm": {
          "$ref": "#/$defs/governed_swarm_extension"
        },
        "note_memory": {
          "$ref": "#/$defs/note_memory_extension"
        }
      }
    },
    "governed_swarm_extension": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "registered",
        "enabled",
        "mounted",
        "state",
        "reason",
        "audit_store_configured"
      ],
      "properties": {
        "registered": {
          "type": "boolean"
        },
        "enabled": {
          "type": "boolean"
        },
        "mounted": {
          "type": "boolean"
        },
        "state": {
          "type": "string",
          "enum": ["unregistered", "disabled", "enabled_unmounted", "mounted"]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "audit_store_configured": {
          "type": "boolean"
        }
      }
    },
    "note_memory_extension": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "registered",
        "enabled",
        "mounted",
        "state",
        "reason",
        "store_configured"
      ],
      "properties": {
        "registered": {
          "type": "boolean"
        },
        "enabled": {
          "type": "boolean"
        },
        "mounted": {
          "type": "boolean"
        },
        "state": {
          "type": "string",
          "enum": ["unregistered", "disabled", "enabled_unmounted", "mounted"]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "store_configured": {
          "type": "boolean"
        }
      }
    }
  }
}
