{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:agentic-service-harness-live-producer-execution-authority-evidence-packet:1",
  "title": "Agentic Service Harness Live Producer Execution Authority Evidence Packet",
  "description": "No-effect evidence packet for live producer execution authority. The packet binds the execution authority admission surface while keeping all live execution, connector calls, receipt append, runtime writes, credential access, mutation routes, and terminal closure denied.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "packet_id",
    "schema_version",
    "generated_at",
    "solver_outcome",
    "packet_status",
    "source_admission_ref",
    "source_admission_status",
    "planning_only",
    "read_only",
    "live_producer_implemented",
    "live_execution_authorized",
    "authority_granted",
    "terminal_closure",
    "source_admission_binding",
    "required_evidence",
    "missing_evidence",
    "authority_denials",
    "effect_boundary",
    "validators",
    "next_action"
  ],
  "properties": {
    "packet_id": {
      "type": "string",
      "const": "agentic-service-harness-live-producer-execution-authority-evidence-packet"
    },
    "schema_version": { "type": "integer", "const": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "solver_outcome": { "type": "string", "const": "AwaitingEvidence" },
    "packet_status": {
      "type": "string",
      "const": "blocked_awaiting_live_execution_authority_evidence"
    },
    "source_admission_ref": {
      "type": "string",
      "const": "examples/agentic_service_harness_live_producer_execution_authority_admission.awaiting_evidence.json"
    },
    "source_admission_status": {
      "type": "string",
      "const": "blocked_awaiting_live_execution_authority_components"
    },
    "planning_only": { "type": "boolean", "const": true },
    "read_only": { "type": "boolean", "const": true },
    "live_producer_implemented": { "type": "boolean", "const": false },
    "live_execution_authorized": { "type": "boolean", "const": false },
    "authority_granted": { "type": "boolean", "const": false },
    "terminal_closure": { "type": "boolean", "const": false },
    "source_admission_binding": { "$ref": "#/$defs/source_admission_binding" },
    "required_evidence": {
      "type": "array",
      "minItems": 9,
      "maxItems": 9,
      "items": { "$ref": "#/$defs/evidence_item" },
      "uniqueItems": true
    },
    "missing_evidence": {
      "type": "array",
      "minItems": 9,
      "maxItems": 9,
      "items": { "$ref": "#/$defs/missing_evidence_item" },
      "uniqueItems": true
    },
    "authority_denials": { "$ref": "#/$defs/authority_denials" },
    "effect_boundary": { "$ref": "#/$defs/effect_boundary" },
    "validators": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": { "$ref": "#/$defs/validator_ref" }
    },
    "next_action": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "evidence_id": {
      "type": "string",
      "enum": [
        "admission_gate_ref",
        "operator_approval_ref",
        "effect_receipt_packet_ref",
        "external_adapter_evidence_packet_ref",
        "secret_handoff_packet_ref",
        "rollback_proof_packet_ref",
        "uao_admission_ref",
        "life_meaning_judgment_ref",
        "temporal_lease_ref"
      ]
    },
    "source_admission_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_admission_id",
        "source_admission_ref",
        "source_validator_command",
        "source_status",
        "source_blocks_live_execution",
        "source_authority_granted"
      ],
      "properties": {
        "source_admission_id": {
          "type": "string",
          "const": "agentic-service-harness-live-producer-execution-authority-admission"
        },
        "source_admission_ref": {
          "type": "string",
          "const": "examples/agentic_service_harness_live_producer_execution_authority_admission.awaiting_evidence.json"
        },
        "source_validator_command": {
          "type": "string",
          "const": "python scripts/validate_agentic_service_harness_live_producer_execution_authority_admission.py"
        },
        "source_status": {
          "type": "string",
          "const": "blocked_awaiting_live_execution_authority_components"
        },
        "source_blocks_live_execution": { "type": "boolean", "const": true },
        "source_authority_granted": { "type": "boolean", "const": false }
      }
    },
    "evidence_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence_id", "required_ref", "status", "blocks_live_execution"],
      "properties": {
        "evidence_id": { "$ref": "#/$defs/evidence_id" },
        "required_ref": {
          "type": "string",
          "minLength": 1,
          "pattern": "^future://agentic-service-harness/live-producer/[A-Za-z0-9._:/#-]+$"
        },
        "status": { "type": "string", "const": "AwaitingEvidence" },
        "blocks_live_execution": { "type": "boolean", "const": true }
      }
    },
    "missing_evidence_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence_id", "status", "blocks_live_execution"],
      "properties": {
        "evidence_id": { "$ref": "#/$defs/evidence_id" },
        "status": { "type": "string", "const": "AwaitingEvidence" },
        "blocks_live_execution": { "type": "boolean", "const": true }
      }
    },
    "authority_denials": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ui_created",
        "mutation_endpoints_admitted",
        "external_adapter_integrated",
        "connector_call_enabled",
        "branch_write_enabled",
        "pull_request_creation_enabled",
        "deployment_enabled",
        "dns_mutation_enabled",
        "secret_mutation_enabled",
        "destructive_operation_enabled",
        "runtime_state_written",
        "receipt_store_append_enabled",
        "live_execution_authorized"
      ],
      "properties": {
        "ui_created": { "type": "boolean", "const": false },
        "mutation_endpoints_admitted": { "type": "boolean", "const": false },
        "external_adapter_integrated": { "type": "boolean", "const": false },
        "connector_call_enabled": { "type": "boolean", "const": false },
        "branch_write_enabled": { "type": "boolean", "const": false },
        "pull_request_creation_enabled": { "type": "boolean", "const": false },
        "deployment_enabled": { "type": "boolean", "const": false },
        "dns_mutation_enabled": { "type": "boolean", "const": false },
        "secret_mutation_enabled": { "type": "boolean", "const": false },
        "destructive_operation_enabled": { "type": "boolean", "const": false },
        "runtime_state_written": { "type": "boolean", "const": false },
        "receipt_store_append_enabled": { "type": "boolean", "const": false },
        "live_execution_authorized": { "type": "boolean", "const": false }
      }
    },
    "effect_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "network_policy",
        "provider_calls_allowed",
        "mutation_routes_admitted",
        "external_state_writes_allowed",
        "runtime_state_writes_allowed",
        "receipt_store_append_allowed",
        "secret_values_allowed",
        "raw_payload_retention_allowed"
      ],
      "properties": {
        "network_policy": { "type": "string", "const": "none" },
        "provider_calls_allowed": { "type": "boolean", "const": false },
        "mutation_routes_admitted": { "type": "boolean", "const": false },
        "external_state_writes_allowed": { "type": "boolean", "const": false },
        "runtime_state_writes_allowed": { "type": "boolean", "const": false },
        "receipt_store_append_allowed": { "type": "boolean", "const": false },
        "secret_values_allowed": { "type": "boolean", "const": false },
        "raw_payload_retention_allowed": { "type": "boolean", "const": false }
      }
    },
    "validator_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["validator_id", "command", "required_for_closure"],
      "properties": {
        "validator_id": {
          "type": "string",
          "const": "agentic-service-harness-live-producer-execution-authority-evidence-packet"
        },
        "command": {
          "type": "string",
          "const": "python scripts/validate_agentic_service_harness_live_producer_execution_authority_evidence_packet.py"
        },
        "required_for_closure": { "type": "boolean", "const": true }
      }
    }
  }
}
