{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:mullu-clearance-capture-requirements:1",
  "title": "Mullu Govern Clearance Capture Requirements",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "requirements_id",
    "product_name",
    "suite_family",
    "company_brand",
    "evidence_root",
    "public_paid_launch_allowed",
    "gates",
    "mutation_rule"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1"
    },
    "requirements_id": {
      "type": "string",
      "minLength": 1
    },
    "product_name": {
      "type": "string",
      "const": "Mullu Govern"
    },
    "suite_family": {
      "type": "string",
      "const": "Mullu"
    },
    "company_brand": {
      "type": "string",
      "const": "Mullusi"
    },
    "evidence_root": {
      "type": "string",
      "const": "docs/clearance-evidence/mullu/2026-05-15/"
    },
    "public_paid_launch_allowed": {
      "type": "boolean",
      "const": false
    },
    "gates": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": {
        "$ref": "#/$defs/gate_requirement"
      }
    },
    "mutation_rule": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "gate_requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gate",
        "directory",
        "authority",
        "required_files",
        "decision_fields",
        "status"
      ],
      "properties": {
        "gate": {
          "type": "string",
          "enum": [
            "uspto_search",
            "wipo_search",
            "euipo_tmview_search",
            "close_variant_review",
            "domain_ownership",
            "legal_review"
          ]
        },
        "directory": {
          "type": "string",
          "minLength": 1
        },
        "authority": {
          "type": "string",
          "minLength": 1
        },
        "required_files": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "decision_fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "status": {
          "type": "string",
          "const": "pending"
        }
      }
    }
  }
}
