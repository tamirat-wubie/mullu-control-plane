{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:distributed-lease-adapter-registry-receipt:1",
  "title": "Distributed Lease Adapter Registry Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receipt_id",
    "registry_id",
    "request_id",
    "tenant_id",
    "actor_id",
    "command_id",
    "backend_kind",
    "adapter_mode",
    "adapter_status",
    "production_ready",
    "fencing_tokens_supported",
    "compare_and_swap_supported",
    "required_environment",
    "registry_hash",
    "capability_hash",
    "claim_receipt",
    "claim_receipt_hash",
    "claim_receipt_status",
    "claim_outcome",
    "adapter_claim_admissible",
    "external_gateway_delegated",
    "blocked_reasons",
    "required_actions",
    "required_controls",
    "evidence_refs",
    "evaluated_at",
    "receipt_schema_ref",
    "terminal_closure_required",
    "lease_service_call_performed",
    "adapter_backend_call_performed",
    "request_authentication_performed",
    "raw_secret_stored",
    "receipt_hash",
    "metadata"
  ],
  "properties": {
    "receipt_id": {
      "type": "string",
      "pattern": "^distributed-lease-adapter-registry-receipt-[0-9a-f]{16}$"
    },
    "registry_id": {"type": "string", "minLength": 1},
    "request_id": {"type": "string", "minLength": 1},
    "tenant_id": {"type": "string", "minLength": 1},
    "actor_id": {"type": "string", "minLength": 1},
    "command_id": {"type": "string", "minLength": 1},
    "backend_kind": {"$ref": "#/$defs/backend_kind"},
    "adapter_mode": {
      "type": "string",
      "enum": ["local_compare_and_swap", "native_client", "external_gateway", "disabled"]
    },
    "adapter_status": {
      "type": "string",
      "enum": ["adapter_ready", "adapter_delegated", "adapter_blocked"]
    },
    "production_ready": {"type": "boolean"},
    "fencing_tokens_supported": {"type": "boolean"},
    "compare_and_swap_supported": {"type": "boolean"},
    "required_environment": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "registry_hash": {"$ref": "#/$defs/sha256_hex"},
    "capability_hash": {"$ref": "#/$defs/sha256_hex"},
    "claim_receipt": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "receipt_id",
        "request_id",
        "status",
        "backend_kind",
        "job_id",
        "worker_id",
        "claim_outcome",
        "receipt_hash"
      ],
      "properties": {
        "receipt_id": {
          "type": "string",
          "pattern": "^distributed-lease-claim-receipt-[0-9a-f]{16}$"
        },
        "request_id": {"type": "string", "minLength": 1},
        "status": {
          "type": "string",
          "enum": ["planned", "dry_run_accepted", "claim_receipt_bound", "blocked"]
        },
        "backend_kind": {"$ref": "#/$defs/backend_kind"},
        "job_id": {"type": "string", "minLength": 1},
        "worker_id": {"type": "string", "minLength": 1},
        "claim_outcome": {
          "type": "string",
          "enum": ["not_observed", "granted", "rejected", "conflict", "deferred"]
        },
        "receipt_hash": {"$ref": "#/$defs/sha256_hex"}
      }
    },
    "claim_receipt_hash": {"$ref": "#/$defs/sha256_hex"},
    "claim_receipt_status": {
      "type": "string",
      "enum": ["planned", "dry_run_accepted", "claim_receipt_bound", "blocked"]
    },
    "claim_outcome": {
      "type": "string",
      "enum": ["not_observed", "granted", "rejected", "conflict", "deferred"]
    },
    "adapter_claim_admissible": {"type": "boolean"},
    "external_gateway_delegated": {"type": "boolean"},
    "blocked_reasons": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "required_actions": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "required_controls": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "evidence_refs": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "evaluated_at": {"type": "string", "format": "date-time"},
    "receipt_schema_ref": {
      "type": "string",
      "const": "urn:mullusi:schema:distributed-lease-adapter-registry-receipt:1"
    },
    "terminal_closure_required": {"type": "boolean", "const": true},
    "lease_service_call_performed": {"type": "boolean", "const": false},
    "adapter_backend_call_performed": {"type": "boolean", "const": false},
    "request_authentication_performed": {"type": "boolean", "const": false},
    "raw_secret_stored": {"type": "boolean", "const": false},
    "receipt_hash": {"$ref": "#/$defs/sha256_hex"},
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "receipt_is_not_terminal_closure",
        "registry_hash_bound",
        "capability_hash_bound",
        "claim_receipt_hash_bound",
        "lease_service_not_called",
        "adapter_backend_not_called",
        "request_authentication_not_performed",
        "raw_secret_not_stored",
        "external_gateway_delegated",
        "adapter_claim_admissible",
        "secret_absence_verified"
      ],
      "properties": {
        "receipt_is_not_terminal_closure": {"type": "boolean", "const": true},
        "registry_hash_bound": {"type": "boolean", "const": true},
        "capability_hash_bound": {"type": "boolean", "const": true},
        "claim_receipt_hash_bound": {"type": "boolean", "const": true},
        "lease_service_not_called": {"type": "boolean", "const": true},
        "adapter_backend_not_called": {"type": "boolean", "const": true},
        "request_authentication_not_performed": {"type": "boolean", "const": true},
        "raw_secret_not_stored": {"type": "boolean", "const": true},
        "external_gateway_delegated": {"type": "boolean"},
        "adapter_claim_admissible": {"type": "boolean"},
        "secret_absence_verified": {"type": "boolean"}
      }
    }
  },
  "$defs": {
    "sha256_hex": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "backend_kind": {
      "type": "string",
      "enum": [
        "sqlite_compare_and_swap",
        "postgres_advisory_lock",
        "redis_redlock",
        "etcd_lease",
        "consul_session",
        "external_http_gateway"
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {"adapter_status": {"const": "adapter_blocked"}},
        "required": ["adapter_status"]
      },
      "then": {
        "properties": {
          "adapter_claim_admissible": {"const": false},
          "external_gateway_delegated": {"const": false},
          "blocked_reasons": {"minItems": 1},
          "metadata": {
            "properties": {
              "adapter_claim_admissible": {"const": false},
              "external_gateway_delegated": {"const": false}
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {"adapter_status": {"const": "adapter_ready"}},
        "required": ["adapter_status"]
      },
      "then": {
        "properties": {
          "adapter_mode": {"const": "local_compare_and_swap"},
          "production_ready": {"const": true},
          "adapter_claim_admissible": {"const": true},
          "external_gateway_delegated": {"const": false},
          "blocked_reasons": {"maxItems": 0}
        }
      }
    },
    {
      "if": {
        "properties": {"adapter_status": {"const": "adapter_delegated"}},
        "required": ["adapter_status"]
      },
      "then": {
        "properties": {
          "adapter_mode": {"const": "external_gateway"},
          "adapter_claim_admissible": {"const": true},
          "external_gateway_delegated": {"const": true},
          "blocked_reasons": {"maxItems": 0},
          "metadata": {
            "properties": {
              "adapter_claim_admissible": {"const": true},
              "external_gateway_delegated": {"const": true}
            }
          }
        }
      }
    }
  ]
}
