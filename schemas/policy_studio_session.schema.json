{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:policy-studio-session:1",
  "title": "PolicyStudioSession",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "session_id",
    "policy_id",
    "rules",
    "simulations",
    "probe_report",
    "session_hash",
    "metadata"
  ],
  "properties": {
    "session_id": {"type": "string", "minLength": 1},
    "policy_id": {"type": "string", "minLength": 1},
    "rules": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/rule"}},
    "simulations": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/simulation"}},
    "probe_report": {"$ref": "#/$defs/probe_report"},
    "session_hash": {"type": "string", "minLength": 32},
    "metadata": {
      "type": "object",
      "required": ["policy_studio_is_read_only"],
      "properties": {
        "policy_studio_is_read_only": {"type": "boolean", "const": true}
      }
    }
  },
  "$defs": {
    "verdict": {
      "type": "string",
      "enum": ["allow", "deny", "escalate"]
    },
    "rule_effect": {
      "type": "string",
      "enum": ["deny", "escalate", "require_approval"]
    },
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "description",
        "effect",
        "action",
        "min_amount",
        "max_amount",
        "required_role",
        "required_approval_role",
        "requires_fresh_evidence",
        "business_hours_only",
        "tenant_match_required",
        "self_approval_forbidden",
        "rule_hash",
        "metadata"
      ],
      "properties": {
        "rule_id": {"type": "string", "minLength": 1},
        "description": {"type": "string", "minLength": 1},
        "effect": {"$ref": "#/$defs/rule_effect"},
        "action": {"type": "string"},
        "min_amount": {"type": "number", "minimum": 0},
        "max_amount": {"type": "number", "minimum": 0},
        "required_role": {"type": "string"},
        "required_approval_role": {"type": "string"},
        "requires_fresh_evidence": {"type": "boolean"},
        "business_hours_only": {"type": "boolean"},
        "tenant_match_required": {"type": "boolean", "const": true},
        "self_approval_forbidden": {"type": "boolean", "const": true},
        "rule_hash": {"type": "string", "minLength": 32},
        "metadata": {"type": "object"}
      }
    },
    "simulation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "simulation_id",
        "policy_id",
        "scenario_id",
        "verdict",
        "reasons",
        "matched_rule_ids",
        "required_approvals",
        "side_effects_allowed",
        "evidence_refs",
        "simulation_hash",
        "metadata"
      ],
      "properties": {
        "simulation_id": {"type": "string", "minLength": 1},
        "policy_id": {"type": "string", "minLength": 1},
        "scenario_id": {"type": "string", "minLength": 1},
        "verdict": {"$ref": "#/$defs/verdict"},
        "reasons": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "matched_rule_ids": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "required_approvals": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "side_effects_allowed": {"type": "boolean"},
        "evidence_refs": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "simulation_hash": {"type": "string", "minLength": 32},
        "metadata": {
          "type": "object",
          "required": ["simulation_is_read_only", "live_policy_mutated"],
          "properties": {
            "simulation_is_read_only": {"type": "boolean", "const": true},
            "live_policy_mutated": {"type": "boolean", "const": false}
          }
        }
      }
    },
    "counterexample": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "probe_id",
        "scenario_id",
        "reason",
        "simulation_id",
        "evidence_refs"
      ],
      "properties": {
        "probe_id": {"type": "string", "minLength": 1},
        "scenario_id": {"type": "string", "minLength": 1},
        "reason": {"type": "string", "minLength": 1},
        "simulation_id": {"type": "string", "minLength": 1},
        "evidence_refs": {"type": "array", "items": {"type": "string", "minLength": 1}}
      }
    },
    "probe_report": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "report_id",
        "policy_id",
        "status",
        "probe_count",
        "counterexample_count",
        "counterexamples",
        "report_hash",
        "metadata"
      ],
      "properties": {
        "report_id": {"type": "string", "minLength": 1},
        "policy_id": {"type": "string", "minLength": 1},
        "status": {"type": "string", "enum": ["proved", "counterexample_found"]},
        "probe_count": {"type": "integer", "minimum": 1},
        "counterexample_count": {"type": "integer", "minimum": 0},
        "counterexamples": {"type": "array", "items": {"$ref": "#/$defs/counterexample"}},
        "report_hash": {"type": "string", "minLength": 32},
        "metadata": {
          "type": "object",
          "required": ["proof_is_bounded", "policy_weakening_allowed"],
          "properties": {
            "proof_is_bounded": {"type": "boolean", "const": true},
            "policy_weakening_allowed": {"type": "boolean", "const": false}
          }
        }
      }
    }
  }
}
