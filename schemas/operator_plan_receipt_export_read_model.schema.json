{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:operator-plan-receipt-export-read-model:1",
  "title": "Operator Plan Receipt Export Read Model",
  "description": "Operator-gated, read-only export binding Plan Review evidence to step command receipt groups.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_ref",
    "plan_id",
    "status",
    "plan_review",
    "plan_evidence_bundle",
    "evidence_bundle_available",
    "step_command_count",
    "missing_step_command_ids",
    "receipt_group_count",
    "receipt_count",
    "step_receipt_groups",
    "raw_message_exposed",
    "execution_allowed",
    "write_allowed",
    "governed"
  ],
  "properties": {
    "schema_ref": {
      "type": "string",
      "const": "urn:mullusi:schema:operator-plan-receipt-export-read-model:1"
    },
    "plan_id": {"type": "string", "pattern": "^plan-[a-f0-9]{16}$"},
    "status": {
      "type": "string",
      "enum": ["certified", "awaiting_certificate", "not_found"]
    },
    "plan_review": {"$ref": "urn:mullusi:schema:operator-plan-review-read-model:1"},
    "plan_evidence_bundle": {
      "anyOf": [
        {"type": "null"},
        {"$ref": "#/$defs/plan_evidence_bundle"}
      ]
    },
    "evidence_bundle_available": {"type": "boolean"},
    "step_command_count": {"type": "integer", "minimum": 0},
    "missing_step_command_ids": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "receipt_group_count": {"type": "integer", "minimum": 0},
    "receipt_count": {"type": "integer", "minimum": 0},
    "step_receipt_groups": {
      "type": "array",
      "items": {"$ref": "#/$defs/receipt_group"}
    },
    "raw_message_exposed": {"type": "boolean", "const": false},
    "execution_allowed": {"type": "boolean", "const": false},
    "write_allowed": {"type": "boolean", "const": false},
    "governed": {"type": "boolean", "const": true}
  },
  "$defs": {
    "plan_evidence_bundle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bundle_id",
        "bundle_hash",
        "plan_id",
        "certificate_id",
        "disposition",
        "step_count",
        "step_command_ids",
        "step_terminal_certificate_ids",
        "plan_evidence_hash",
        "witness_ids",
        "recovery_attempt_ids",
        "evidence_refs",
        "exported_at"
      ],
      "properties": {
        "bundle_id": {"type": "string", "pattern": "^plan-evidence-bundle-[a-f0-9]{16}$"},
        "bundle_hash": {"type": "string", "minLength": 32},
        "plan_id": {"type": "string", "pattern": "^plan-[a-f0-9]{16}$"},
        "certificate_id": {"type": "string", "minLength": 1},
        "disposition": {"type": "string", "minLength": 1},
        "step_count": {"type": "integer", "minimum": 0},
        "step_command_ids": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "step_terminal_certificate_ids": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "plan_evidence_hash": {"type": "string", "minLength": 32},
        "witness_ids": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "recovery_attempt_ids": {
          "type": "array",
          "items": {"type": "string"}
        },
        "evidence_refs": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "exported_at": {"type": "string"}
      }
    },
    "receipt_group": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command_id",
        "tenant_id",
        "actor_id",
        "source",
        "intent",
        "command_state",
        "task_status",
        "payload_hash",
        "trace_id",
        "created_at",
        "latest_event_hash",
        "event_count",
        "receipt_types",
        "receipt_count",
        "receipts"
      ],
      "properties": {
        "command_id": {"type": "string", "minLength": 1},
        "tenant_id": {"type": "string"},
        "actor_id": {"type": "string"},
        "source": {"type": "string"},
        "intent": {"type": "string"},
        "command_state": {"type": "string"},
        "task_status": {"type": "string"},
        "payload_hash": {"type": "string"},
        "trace_id": {"type": "string"},
        "created_at": {"type": "string"},
        "latest_event_hash": {"type": "string"},
        "event_count": {"type": "integer", "minimum": 0},
        "receipt_types": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "receipt_count": {"type": "integer", "minimum": 0},
        "receipts": {
          "type": "array",
          "items": {"type": "object", "additionalProperties": true}
        }
      }
    }
  }
}
