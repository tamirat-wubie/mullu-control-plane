{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:universal-symbol-receipt-store-path-confinement-witness:1",
  "title": "Universal Symbol Receipt Store Path Confinement Witness",
  "description": "Foundation Mode witness for a future UniversalSymbol receipt-store path confinement boundary. This witness defines path confinement obligations while denying confinement binding, path custody registration, write-path registration, receipt append, raw payload storage, raw secret storage, runtime dispatch, connector calls, state mutation, terminal closure, and production readiness.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "witness_id",
    "schema_version",
    "generated_at",
    "witness_scope",
    "solver_outcome",
    "foundation_mode",
    "path_confinement_decision",
    "path_confinement_witness_is_not_path_authority",
    "confinement_requirements",
    "authority_denials",
    "path_confinement_constraints",
    "rejection_policy",
    "blocked_reasons",
    "next_actions",
    "evidence_refs",
    "contract_summary"
  ],
  "properties": {
    "witness_id": { "type": "string", "const": "universal-symbol-receipt-store-path-confinement-witness-foundation" },
    "schema_version": { "type": "integer", "const": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "witness_scope": { "type": "string", "const": "foundation-mode-universal-symbol-receipt-store-path-confinement" },
    "solver_outcome": { "type": "string", "const": "AwaitingEvidence" },
    "foundation_mode": { "type": "boolean", "const": true },
    "path_confinement_decision": { "type": "string", "const": "blocked_pending_root_namespace_traversal_symlink_partition_and_audit_evidence" },
    "path_confinement_witness_is_not_path_authority": { "type": "boolean", "const": true },
    "confinement_requirements": {
      "type": "array",
      "minItems": 8,
      "items": { "$ref": "#/$defs/confinement_requirement" },
      "uniqueItems": true
    },
    "authority_denials": { "$ref": "#/$defs/authority_denials" },
    "path_confinement_constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canonical_root_required",
        "allowed_namespace_required",
        "path_traversal_denial_required",
        "symlink_resolution_required",
        "reserved_path_denial_required",
        "tenant_partition_required",
        "append_only_custody_required",
        "audit_receipt_required"
      ],
      "properties": {
        "canonical_root_required": { "type": "boolean", "const": true },
        "allowed_namespace_required": { "type": "boolean", "const": true },
        "path_traversal_denial_required": { "type": "boolean", "const": true },
        "symlink_resolution_required": { "type": "boolean", "const": true },
        "reserved_path_denial_required": { "type": "boolean", "const": true },
        "tenant_partition_required": { "type": "boolean", "const": true },
        "append_only_custody_required": { "type": "boolean", "const": true },
        "audit_receipt_required": { "type": "boolean", "const": true }
      }
    },
    "rejection_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "missing_canonical_root_blocks_confinement",
        "missing_allowed_namespace_blocks_confinement",
        "missing_traversal_denial_blocks_confinement",
        "missing_partition_blocks_confinement",
        "unknown_hard_constraint_blocks_confinement",
        "failed_precondition_logs_delta_reject"
      ],
      "properties": {
        "missing_canonical_root_blocks_confinement": { "type": "boolean", "const": true },
        "missing_allowed_namespace_blocks_confinement": { "type": "boolean", "const": true },
        "missing_traversal_denial_blocks_confinement": { "type": "boolean", "const": true },
        "missing_partition_blocks_confinement": { "type": "boolean", "const": true },
        "unknown_hard_constraint_blocks_confinement": { "type": "boolean", "const": true },
        "failed_precondition_logs_delta_reject": { "type": "boolean", "const": true }
      }
    },
    "blocked_reasons": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "string",
        "enum": [
          "canonical_root_missing",
          "allowed_namespace_missing",
          "path_traversal_denial_missing",
          "symlink_resolution_missing",
          "reserved_path_denial_missing",
          "tenant_partition_missing",
          "append_only_custody_missing",
          "audit_receipt_missing",
          "receipt_store_path_confinement_forbidden",
          "terminal_closure_not_allowed"
        ]
      },
      "uniqueItems": true
    },
    "next_actions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/ref" },
      "uniqueItems": true
    },
    "contract_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "confinement_requirement_count",
        "authority_denial_count",
        "path_confinement_constraint_count",
        "rejection_check_count",
        "blocked_reason_count",
        "evidence_ref_count"
      ],
      "properties": {
        "confinement_requirement_count": { "type": "integer", "minimum": 8 },
        "authority_denial_count": { "type": "integer", "const": 11 },
        "path_confinement_constraint_count": { "type": "integer", "const": 8 },
        "rejection_check_count": { "type": "integer", "const": 6 },
        "blocked_reason_count": { "type": "integer", "minimum": 8 },
        "evidence_ref_count": { "type": "integer", "minimum": 1 }
      }
    }
  },
  "$defs": {
    "ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/#-]*$"
    },
    "confinement_requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requirement_id",
        "proof_state",
        "required_evidence_ref",
        "current_decision",
        "delta_reject_ref"
      ],
      "properties": {
        "requirement_id": { "$ref": "#/$defs/ref" },
        "proof_state": { "type": "string", "enum": ["Unknown", "BudgetUnknown", "Fail"] },
        "required_evidence_ref": { "$ref": "#/$defs/ref" },
        "current_decision": { "type": "string", "const": "path_confinement_blocked" },
        "delta_reject_ref": { "$ref": "#/$defs/ref" }
      }
    },
    "authority_denials": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_store_path_confinement_bound",
        "receipt_store_path_custody_registered",
        "receipt_store_write_path_registered",
        "receipt_store_append_performed",
        "raw_payload_stored",
        "raw_secret_stored",
        "runtime_dispatch_performed",
        "connector_call_performed",
        "filesystem_escape_allowed",
        "state_mutation_performed",
        "terminal_closure_allowed"
      ],
      "properties": {
        "receipt_store_path_confinement_bound": { "type": "boolean", "const": false },
        "receipt_store_path_custody_registered": { "type": "boolean", "const": false },
        "receipt_store_write_path_registered": { "type": "boolean", "const": false },
        "receipt_store_append_performed": { "type": "boolean", "const": false },
        "raw_payload_stored": { "type": "boolean", "const": false },
        "raw_secret_stored": { "type": "boolean", "const": false },
        "runtime_dispatch_performed": { "type": "boolean", "const": false },
        "connector_call_performed": { "type": "boolean", "const": false },
        "filesystem_escape_allowed": { "type": "boolean", "const": false },
        "state_mutation_performed": { "type": "boolean", "const": false },
        "terminal_closure_allowed": { "type": "boolean", "const": false }
      }
    }
  }
}
