{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:personal-assistant-connector-lease-witness:1",
  "title": "Personal Assistant Connector Lease Witness",
  "description": "Foundation Mode no-effect witness that records connector witness refs and inactive dispatch lease refs after replay/rollback witness without authorizing live connector execution.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "witness_set_id",
    "generated_at",
    "governed",
    "source_projection",
    "source_replay_rollback_witness_set_id",
    "witness_count",
    "witness_ids",
    "source_witness_ids",
    "receipt_ids",
    "witnesses",
    "effect_boundary",
    "private_payload_policy",
    "assurance",
    "metadata"
  ],
  "properties": {
    "witness_set_id": {"type": "string", "pattern": "^pa_connector_lease_witness_[a-z0-9][a-z0-9_:-]*$"},
    "generated_at": {"type": "string", "minLength": 1},
    "governed": {"const": true},
    "source_projection": {"const": "replay_rollback_witness"},
    "source_replay_rollback_witness_set_id": {"type": "string", "pattern": "^pa_replay_rollback_witness_[a-z0-9][a-z0-9_:-]*$"},
    "witness_count": {"type": "integer", "minimum": 1},
    "witness_ids": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "pattern": "^pa_connector_lease_witness_item_[a-z0-9][a-z0-9_:-]*$"},
      "uniqueItems": true
    },
    "source_witness_ids": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "pattern": "^pa_replay_rollback_witness_item_[a-z0-9][a-z0-9_:-]*$"},
      "uniqueItems": true
    },
    "receipt_ids": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "pattern": "^pa_receipt_[a-z0-9][a-z0-9_:-]*$"},
      "uniqueItems": true
    },
    "witnesses": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/witness_item"}
    },
    "effect_boundary": {"$ref": "#/$defs/effect_boundary"},
    "private_payload_policy": {"$ref": "#/$defs/private_payload_policy"},
    "assurance": {"$ref": "#/$defs/assurance"},
    "metadata": {"$ref": "#/$defs/metadata"}
  },
  "$defs": {
    "digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "witness_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "witness_id",
        "source_witness_id",
        "approval_id",
        "request_id",
        "plan_id",
        "skill_id",
        "risk_level",
        "replay_rollback_witness_ref",
        "connector_witness",
        "dispatch_lease_witness",
        "operator_reapproval_gate",
        "receipt"
      ],
      "properties": {
        "witness_id": {"type": "string", "pattern": "^pa_connector_lease_witness_item_[a-z0-9][a-z0-9_:-]*$"},
        "source_witness_id": {"type": "string", "pattern": "^pa_replay_rollback_witness_item_[a-z0-9][a-z0-9_:-]*$"},
        "approval_id": {"type": "string", "pattern": "^pa_approval_[a-z0-9][a-z0-9_:-]*$"},
        "request_id": {"type": "string", "pattern": "^pa_request_[a-z0-9][a-z0-9_:-]*$"},
        "plan_id": {"type": "string", "pattern": "^pa_plan_[a-z0-9][a-z0-9_:-]*$"},
        "skill_id": {"type": "string", "pattern": "^[a-z][a-z0-9_]*(\\.[a-z0-9_]+)+$"},
        "risk_level": {"enum": ["P3", "P4", "P5"]},
        "replay_rollback_witness_ref": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "source_witness_set_id",
            "source_receipt_id",
            "source_receipt_state",
            "replay_plan_bound",
            "rollback_plan_bound",
            "idempotency_ref_bound",
            "payload_digest_only"
          ],
          "properties": {
            "source_witness_set_id": {"type": "string", "minLength": 1},
            "source_receipt_id": {"type": "string", "pattern": "^pa_receipt_[a-z0-9][a-z0-9_:-]*$"},
            "source_receipt_state": {"const": "deferred"},
            "replay_plan_bound": {"const": true},
            "rollback_plan_bound": {"const": true},
            "idempotency_ref_bound": {"const": true},
            "payload_digest_only": {"const": true}
          }
        },
        "connector_witness": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "connector_family",
            "connector_required",
            "connector_ref",
            "connector_ref_digest",
            "connector_scope_ref",
            "connector_tenant_ref",
            "connector_tenant_bound",
            "connector_revocation_path_ref",
            "connector_revocation_path_recorded",
            "live_connector_witness_required",
            "live_connector_witness_ref_bound",
            "live_connector_witness_state",
            "live_connector_receipt_present",
            "live_connector_execution_allowed",
            "connector_mutation_allowed"
          ],
          "properties": {
            "connector_family": {"enum": ["gmail", "none"]},
            "connector_required": {"type": "boolean"},
            "connector_ref": {"type": "string", "pattern": "^connector://personal-assistant/(gmail|none)/pa_approval_[a-z0-9][a-z0-9_:-]*$"},
            "connector_ref_digest": {"$ref": "#/$defs/digest"},
            "connector_scope_ref": {"type": "string", "pattern": "^scope://personal-assistant/connector/(gmail|none)/approval-bound/pa_approval_[a-z0-9][a-z0-9_:-]*$"},
            "connector_tenant_ref": {"type": "string", "pattern": "^tenant://personal-assistant/operator-local/pa_approval_[a-z0-9][a-z0-9_:-]*$"},
            "connector_tenant_bound": {"const": true},
            "connector_revocation_path_ref": {"type": "string", "pattern": "^recovery://personal-assistant/connector-revocation/pa_approval_[a-z0-9][a-z0-9_:-]*$"},
            "connector_revocation_path_recorded": {"const": true},
            "live_connector_witness_required": {"type": "boolean"},
            "live_connector_witness_ref_bound": {"const": true},
            "live_connector_witness_state": {"const": "ref_bound_live_receipt_awaiting_evidence"},
            "live_connector_receipt_present": {"const": false},
            "live_connector_execution_allowed": {"const": false},
            "connector_mutation_allowed": {"const": false}
          }
        },
        "dispatch_lease_witness": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "dispatch_lease_required",
            "dispatch_lease_ref",
            "dispatch_lease_digest",
            "dispatch_lease_ref_bound",
            "dispatch_lease_state",
            "dispatch_lease_active",
            "dispatch_lease_scope",
            "dispatch_lease_expiry_ref",
            "dispatch_allowed",
            "execution_worker_admission_allowed"
          ],
          "properties": {
            "dispatch_lease_required": {"const": true},
            "dispatch_lease_ref": {"type": "string", "pattern": "^lease://personal-assistant/dispatch/pa_approval_[a-z0-9][a-z0-9_:-]*$"},
            "dispatch_lease_digest": {"$ref": "#/$defs/digest"},
            "dispatch_lease_ref_bound": {"const": true},
            "dispatch_lease_state": {"const": "candidate_inactive"},
            "dispatch_lease_active": {"const": false},
            "dispatch_lease_scope": {"const": "single_approval_projection"},
            "dispatch_lease_expiry_ref": {"type": "string", "pattern": "^temporal://personal-assistant/dispatch-lease-expiry/pa_approval_[a-z0-9][a-z0-9_:-]*$"},
            "dispatch_allowed": {"const": false},
            "execution_worker_admission_allowed": {"const": false}
          }
        },
        "operator_reapproval_gate": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "operator_reapproval_required",
            "operator_reapproval_present",
            "approval_ref",
            "approval_state",
            "execution_allowed_after_reapproval_only",
            "execution_worker_admission_allowed"
          ],
          "properties": {
            "operator_reapproval_required": {"const": true},
            "operator_reapproval_present": {"const": false},
            "approval_ref": {"type": "string", "pattern": "^pa_approval_[a-z0-9][a-z0-9_:-]*$"},
            "approval_state": {"const": "required_after_connector_lease_binding"},
            "execution_allowed_after_reapproval_only": {"const": true},
            "execution_worker_admission_allowed": {"const": false}
          }
        },
        "receipt": {"type": "object", "additionalProperties": true}
      }
    },
    "effect_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "connector_lease_witness_allowed",
        "connector_witness_ref_binding_allowed",
        "dispatch_lease_ref_binding_allowed",
        "execution_worker_admission_allowed",
        "dispatch_allowed",
        "dispatch_lease_active",
        "live_connector_receipt_present",
        "live_connector_execution_allowed",
        "external_send_allowed",
        "calendar_write_allowed",
        "task_write_allowed",
        "memory_write_allowed",
        "connector_mutation_allowed",
        "system_of_record_write_allowed",
        "deployment_mutation_allowed",
        "nested_mind_live_activation_allowed",
        "public_readiness_claim_allowed"
      ],
      "properties": {
        "connector_lease_witness_allowed": {"const": true},
        "connector_witness_ref_binding_allowed": {"const": true},
        "dispatch_lease_ref_binding_allowed": {"const": true},
        "execution_worker_admission_allowed": {"const": false},
        "dispatch_allowed": {"const": false},
        "dispatch_lease_active": {"const": false},
        "live_connector_receipt_present": {"const": false},
        "live_connector_execution_allowed": {"const": false},
        "external_send_allowed": {"const": false},
        "calendar_write_allowed": {"const": false},
        "task_write_allowed": {"const": false},
        "memory_write_allowed": {"const": false},
        "connector_mutation_allowed": {"const": false},
        "system_of_record_write_allowed": {"const": false},
        "deployment_mutation_allowed": {"const": false},
        "nested_mind_live_activation_allowed": {"const": false},
        "public_readiness_claim_allowed": {"const": false}
      }
    },
    "private_payload_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raw_private_payload_serialized",
        "secret_values_serialized",
        "connector_payload_projection",
        "lease_payload_projection",
        "tenant_payload_projection"
      ],
      "properties": {
        "raw_private_payload_serialized": {"const": false},
        "secret_values_serialized": {"const": false},
        "connector_payload_projection": {"const": "ref_only"},
        "lease_payload_projection": {"const": "digest_only"},
        "tenant_payload_projection": {"const": "ref_only"}
      }
    },
    "assurance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "assurance_id",
        "outcome",
        "foundation_only",
        "ready_for_live_execution",
        "ready_for_customer_readiness_claim",
        "authority_drift_detected",
        "checked_controls",
        "blocking_reasons",
        "next_action"
      ],
      "properties": {
        "assurance_id": {"const": "personal_assistant_connector_lease_witness_no_effect_assurance"},
        "outcome": {"enum": ["AwaitingEvidence", "GovernanceBlocked"]},
        "foundation_only": {"const": true},
        "ready_for_live_execution": {"const": false},
        "ready_for_customer_readiness_claim": {"const": false},
        "authority_drift_detected": {"type": "boolean"},
        "checked_controls": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "blocking_reasons": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "next_action": {"type": "string", "minLength": 1}
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "foundation_only",
        "projection_contract",
        "runtime_boundary",
        "live_connector_execution_allowed",
        "connector_mutation_allowed",
        "external_send_allowed",
        "system_of_record_write_allowed",
        "memory_write_allowed"
      ],
      "properties": {
        "foundation_only": {"const": true},
        "projection_contract": {"const": "connector_lease_witness_evidence_only"},
        "runtime_boundary": {"const": "witness_records_connector_and_inactive_lease_refs_without_dispatch"},
        "live_connector_execution_allowed": {"const": false},
        "connector_mutation_allowed": {"const": false},
        "external_send_allowed": {"const": false},
        "system_of_record_write_allowed": {"const": false},
        "memory_write_allowed": {"const": false}
      }
    }
  }
}
