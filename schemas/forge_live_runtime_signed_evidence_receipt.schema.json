{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:forge-live-runtime-signed-evidence-receipt:1",
  "title": "Forge Live Runtime Signed Evidence Receipt",
  "description": "Receipt shape for future signed Forge live-runtime evidence, with Foundation Mode fixture requiring all live evidence to remain absent.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receipt_id",
    "schema_ref",
    "schema_version",
    "bridge_ref",
    "source_acceptance_gate_ref",
    "source_acceptance_gate_hash",
    "receipt_mode",
    "receipt_status",
    "solver_outcome",
    "evidence_receipts",
    "blocked_reasons",
    "required_controls",
    "disallowed_authority",
    "next_allowed_action",
    "validators",
    "receipt_hash"
  ],
  "properties": {
    "receipt_id": { "type": "string", "const": "forge-live-runtime-signed-evidence-receipt.v1" },
    "schema_ref": { "type": "string", "const": "urn:mullusi:schema:forge-live-runtime-signed-evidence-receipt:1" },
    "schema_version": { "type": "integer", "const": 1 },
    "bridge_ref": { "type": "string", "const": "forge_write_spine_bridge.v1" },
    "source_acceptance_gate_ref": {
      "type": "string",
      "const": "examples/forge_live_runtime_evidence_acceptance_gate.foundation.json"
    },
    "source_acceptance_gate_hash": { "$ref": "#/$defs/hash" },
    "receipt_mode": { "type": "string", "const": "signed_live_evidence_shape" },
    "receipt_status": { "type": "string", "enum": ["awaiting_signed_live_evidence", "signed_live_evidence_present"] },
    "solver_outcome": { "type": "string", "enum": ["AwaitingEvidence", "SolvedVerified"] },
    "evidence_receipts": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "items": { "$ref": "#/$defs/evidence_receipt" }
    },
    "blocked_reasons": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9_]+_signed_live_evidence_missing$"
      }
    },
    "required_controls": {
      "type": "array",
      "minItems": 11,
      "maxItems": 11,
      "items": { "type": "string" }
    },
    "disallowed_authority": { "$ref": "#/$defs/disallowed_authority" },
    "next_allowed_action": {
      "type": "string",
      "const": "populate_signed_live_receipt_refs_after_operator_approved_probe"
    },
    "validators": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": { "$ref": "#/$defs/validator" }
    },
    "receipt_hash": { "$ref": "#/$defs/hash" }
  },
  "$defs": {
    "hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "optional_hash": {
      "type": "string",
      "pattern": "^$|^[0-9a-f]{64}$"
    },
    "evidence_receipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_id",
        "required_live_evidence_ref",
        "acceptance_blocker_reason",
        "signed_live_receipt_status",
        "signed_live_receipt_ref",
        "signed_live_receipt_hash",
        "dependency_or_credential_probe_ref",
        "recovery_or_revocation_ref",
        "signing_key_id",
        "trust_epoch",
        "signature",
        "verification_status",
        "authority_effect",
        "promotion_effect"
      ],
      "properties": {
        "evidence_id": { "type": "string" },
        "required_live_evidence_ref": {
          "type": "string",
          "pattern": "^evidence://forge/live-runtime/[a-z0-9-]+$"
        },
        "acceptance_blocker_reason": {
          "type": "string",
          "pattern": "^[a-z0-9_]+_signed_live_evidence_missing$"
        },
        "signed_live_receipt_status": {
          "type": "string",
          "enum": ["not_present", "present"]
        },
        "signed_live_receipt_ref": {
          "type": "string",
          "pattern": "^$|^receipt://forge/live-runtime/[a-z0-9-]+$"
        },
        "signed_live_receipt_hash": { "$ref": "#/$defs/optional_hash" },
        "dependency_or_credential_probe_ref": {
          "type": "string",
          "pattern": "^$|^evidence://forge/live-runtime/[a-z0-9-]+/(dependency|credential)-probe$"
        },
        "recovery_or_revocation_ref": {
          "type": "string",
          "pattern": "^$|^evidence://forge/live-runtime/[a-z0-9-]+/(recovery|revocation)-path$"
        },
        "signing_key_id": { "type": "string" },
        "trust_epoch": { "type": "string" },
        "signature": {
          "type": "string",
          "pattern": "^$|^ed25519:[A-Za-z0-9_-]+$"
        },
        "verification_status": {
          "type": "string",
          "enum": ["not_verified", "verified"]
        },
        "authority_effect": { "type": "boolean" },
        "promotion_effect": { "type": "boolean" }
      }
    },
    "disallowed_authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "live_runtime_authorized",
        "state_write_runtime_registered",
        "production_authorized",
        "external_effects_allowed",
        "commit_allowed",
        "terminal_closure"
      ],
      "properties": {
        "live_runtime_authorized": { "type": "boolean", "const": false },
        "state_write_runtime_registered": { "type": "boolean", "const": false },
        "production_authorized": { "type": "boolean", "const": false },
        "external_effects_allowed": { "type": "boolean", "const": false },
        "commit_allowed": { "type": "boolean", "const": false },
        "terminal_closure": { "type": "boolean", "const": false }
      }
    },
    "validator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["validator_id", "command", "required_for_closure"],
      "properties": {
        "validator_id": { "type": "string", "const": "forge-live-runtime-signed-evidence-receipt" },
        "command": {
          "type": "string",
          "const": "python scripts/validate_forge_live_runtime_signed_evidence_receipt.py"
        },
        "required_for_closure": { "type": "boolean", "const": true }
      }
    }
  }
}
