{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:snet-episode:1",
  "title": "SNet Episode",
  "description": "Deterministic local replay contract for one bounded SNet recursive WH symbolic mesh episode.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "episode_id",
    "snet_version",
    "semantics_hash",
    "surface",
    "replay_mode",
    "tick_scope",
    "input_digest",
    "seed_symbol",
    "budget",
    "perspective",
    "context",
    "confidence",
    "validation_state",
    "answer_bindings",
    "expected_mesh_digest",
    "expected_receipt_id",
    "expected_counts",
    "expected_receipt",
    "raw_answers_bounded",
    "raw_answers_exposed",
    "raw_metadata_values_exposed",
    "execution_authority_granted",
    "connector_authority_granted",
    "route_authority_granted",
    "filesystem_authority_granted",
    "evidence_refs"
  ],
  "properties": {
    "episode_id": {
      "type": "string",
      "pattern": "^snet-episode-[0-9a-f]{16}$"
    },
    "snet_version": {
      "type": "string",
      "const": "0.1.5"
    },
    "semantics_hash": {
      "type": "string",
      "const": "sha256:snet-v0.1.5-answer-and-text-boundary-refined"
    },
    "surface": {
      "type": "string",
      "const": "snet_episode_replay"
    },
    "replay_mode": {
      "type": "string",
      "const": "deterministic_local"
    },
    "tick_scope": {
      "type": "string",
      "const": "root_single_tick"
    },
    "input_digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "seed_symbol": {
      "$ref": "#/$defs/seed_symbol"
    },
    "budget": {
      "$ref": "#/$defs/budget"
    },
    "perspective": {
      "type": "string",
      "minLength": 1
    },
    "context": {
      "type": "string",
      "minLength": 1
    },
    "confidence": {
      "$ref": "#/$defs/unit_number"
    },
    "validation_state": {
      "$ref": "#/$defs/validation_state"
    },
    "answer_bindings": {
      "$ref": "#/$defs/answer_bindings"
    },
    "expected_mesh_digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "expected_receipt_id": {
      "type": "string",
      "pattern": "^snet-mesh-[0-9a-f]{16}$"
    },
    "expected_counts": {
      "$ref": "#/$defs/expected_counts"
    },
    "expected_receipt": {
      "$ref": "#/$defs/snet_mesh_receipt"
    },
    "raw_answers_bounded": {
      "type": "boolean",
      "const": true
    },
    "raw_answers_exposed": {
      "type": "boolean",
      "const": false
    },
    "raw_metadata_values_exposed": {
      "type": "boolean",
      "const": false
    },
    "execution_authority_granted": {
      "type": "boolean",
      "const": false
    },
    "connector_authority_granted": {
      "type": "boolean",
      "const": false
    },
    "route_authority_granted": {
      "type": "boolean",
      "const": false
    },
    "filesystem_authority_granted": {
      "type": "boolean",
      "const": false
    },
    "evidence_refs": {
      "$ref": "#/$defs/non_empty_string_array"
    }
  },
  "$defs": {
    "unit_number": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "non_negative_integer": {
      "type": "integer",
      "minimum": 0
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "validation_state": {
      "type": "string",
      "enum": [
        "unverified",
        "weakly_supported",
        "supported",
        "strongly_supported",
        "contradicted",
        "not_applicable"
      ]
    },
    "seed_symbol": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "symbol_type",
        "sense_id",
        "definition",
        "ontology_status"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "symbol_type": {
          "type": "string",
          "minLength": 1
        },
        "sense_id": {
          "type": "string"
        },
        "definition": {
          "type": "string"
        },
        "ontology_status": {
          "type": "string",
          "enum": [
            "physical_real",
            "fictional",
            "mythological",
            "hypothetical",
            "mathematical",
            "simulated",
            "unknown_status"
          ]
        }
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_depth",
        "max_questions_per_symbol",
        "promotion_threshold",
        "unknown_gravity_threshold"
      ],
      "properties": {
        "max_depth": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "max_questions_per_symbol": {
          "type": "integer",
          "minimum": 1,
          "maximum": 14
        },
        "promotion_threshold": {
          "$ref": "#/$defs/unit_number"
        },
        "unknown_gravity_threshold": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "answer_bindings": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "maxProperties": 14,
      "properties": {
        "what": {
          "$ref": "#/$defs/non_empty_text"
        },
        "why": {
          "$ref": "#/$defs/non_empty_text"
        },
        "how": {
          "$ref": "#/$defs/non_empty_text"
        },
        "when": {
          "$ref": "#/$defs/non_empty_text"
        },
        "where": {
          "$ref": "#/$defs/non_empty_text"
        },
        "which": {
          "$ref": "#/$defs/non_empty_text"
        },
        "who": {
          "$ref": "#/$defs/non_empty_text"
        },
        "whose": {
          "$ref": "#/$defs/non_empty_text"
        },
        "what_if": {
          "$ref": "#/$defs/non_empty_text"
        },
        "what_not": {
          "$ref": "#/$defs/non_empty_text"
        },
        "why_not": {
          "$ref": "#/$defs/non_empty_text"
        },
        "how_not": {
          "$ref": "#/$defs/non_empty_text"
        },
        "depends_on": {
          "$ref": "#/$defs/non_empty_text"
        },
        "depends_on_me": {
          "$ref": "#/$defs/non_empty_text"
        }
      }
    },
    "non_empty_text": {
      "type": "string",
      "minLength": 1
    },
    "expected_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "symbol_count",
        "question_count",
        "answer_count",
        "metadata_count",
        "relation_count",
        "unknown_count",
        "contradiction_count"
      ],
      "properties": {
        "symbol_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "question_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "answer_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "metadata_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "relation_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "unknown_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "contradiction_count": {
          "$ref": "#/$defs/non_negative_integer"
        }
      }
    },
    "settlement_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "active",
        "expanding",
        "settled",
        "dormant",
        "contradictory",
        "unknown_heavy",
        "deprecated"
      ],
      "properties": {
        "active": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "expanding": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "settled": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "dormant": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "contradictory": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "unknown_heavy": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "deprecated": {
          "$ref": "#/$defs/non_negative_integer"
        }
      }
    },
    "snet_mesh_receipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_id",
        "snet_version",
        "semantics_hash",
        "mesh_digest",
        "surface",
        "symbol_count",
        "question_count",
        "answer_count",
        "metadata_count",
        "relation_count",
        "unknown_count",
        "contradiction_count",
        "max_depth",
        "promotion_threshold",
        "settlement_counts",
        "terminal_closure_required",
        "receipt_is_not_terminal_closure",
        "raw_answers_exposed",
        "raw_metadata_values_exposed",
        "execution_authority_granted",
        "connector_authority_granted",
        "route_authority_granted",
        "filesystem_authority_granted",
        "evidence_refs"
      ],
      "properties": {
        "receipt_id": {
          "type": "string",
          "pattern": "^snet-mesh-[0-9a-f]{16}$"
        },
        "snet_version": {
          "type": "string",
          "const": "0.1.5"
        },
        "semantics_hash": {
          "type": "string",
          "const": "sha256:snet-v0.1.5-answer-and-text-boundary-refined"
        },
        "mesh_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "surface": {
          "type": "string",
          "const": "read_only_snet_recursive_mesh"
        },
        "symbol_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "question_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "answer_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "metadata_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "relation_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "unknown_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "contradiction_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "max_depth": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "promotion_threshold": {
          "$ref": "#/$defs/unit_number"
        },
        "settlement_counts": {
          "$ref": "#/$defs/settlement_counts"
        },
        "terminal_closure_required": {
          "type": "boolean",
          "const": true
        },
        "receipt_is_not_terminal_closure": {
          "type": "boolean",
          "const": true
        },
        "raw_answers_exposed": {
          "type": "boolean",
          "const": false
        },
        "raw_metadata_values_exposed": {
          "type": "boolean",
          "const": false
        },
        "execution_authority_granted": {
          "type": "boolean",
          "const": false
        },
        "connector_authority_granted": {
          "type": "boolean",
          "const": false
        },
        "route_authority_granted": {
          "type": "boolean",
          "const": false
        },
        "filesystem_authority_granted": {
          "type": "boolean",
          "const": false
        },
        "evidence_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        }
      }
    }
  }
}
