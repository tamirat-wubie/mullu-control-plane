{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:temporal-evidence-freshness-receipt:1",
  "title": "Temporal Evidence Freshness Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receipt_id",
    "request_id",
    "tenant_id",
    "actor_id",
    "command_id",
    "action_type",
    "risk_level",
    "status",
    "required_evidence_types",
    "evidence_refs",
    "accepted_evidence_refs",
    "stale_evidence_refs",
    "expiring_soon_evidence_refs",
    "blocked_evidence_refs",
    "missing_evidence_types",
    "stale_evidence_types",
    "blocked_reasons",
    "evidence_warnings",
    "required_controls",
    "evidence_states",
    "runtime_now_utc",
    "earliest_fresh_until",
    "recheck_due_at",
    "refresh_due_at",
    "refresh_window_seconds",
    "expiry_warning_seconds",
    "source_temporal_receipt_id",
    "receipt_schema_ref",
    "terminal_closure_required",
    "receipt_hash",
    "metadata"
  ],
  "properties": {
    "receipt_id": {
      "type": "string",
      "pattern": "^temporal-evidence-freshness-receipt-[0-9a-f]{16}$"
    },
    "request_id": {"type": "string", "minLength": 1},
    "tenant_id": {"type": "string", "minLength": 1},
    "actor_id": {"type": "string", "minLength": 1},
    "command_id": {"type": "string", "minLength": 1},
    "action_type": {"type": "string", "minLength": 1},
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "status": {
      "type": "string",
      "enum": ["fresh", "refresh_required", "insufficient_evidence", "blocked"]
    },
    "required_evidence_types": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "evidence_refs": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "accepted_evidence_refs": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "stale_evidence_refs": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "expiring_soon_evidence_refs": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "blocked_evidence_refs": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "missing_evidence_types": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "stale_evidence_types": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "blocked_reasons": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "evidence_warnings": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "required_controls": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "evidence_states": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "evidence_ref",
          "evidence_type",
          "status",
          "observed_at",
          "fresh_until",
          "age_seconds",
          "freshness_seconds",
          "remaining_fresh_seconds",
          "reasons"
        ],
        "properties": {
          "evidence_ref": {"type": "string", "minLength": 1},
          "evidence_type": {"type": "string", "minLength": 1},
          "status": {
            "type": "string",
            "enum": ["fresh", "expiring_soon", "stale", "blocked"]
          },
          "observed_at": {"type": "string"},
          "fresh_until": {"type": "string"},
          "age_seconds": {"type": "integer", "minimum": 0},
          "freshness_seconds": {"type": "integer", "minimum": 0},
          "remaining_fresh_seconds": {"type": "integer", "minimum": 0},
          "reasons": {
            "type": "array",
            "items": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "runtime_now_utc": {"type": "string", "format": "date-time"},
    "earliest_fresh_until": {"type": "string"},
    "recheck_due_at": {"type": "string"},
    "refresh_due_at": {"type": "string"},
    "refresh_window_seconds": {"type": "integer", "minimum": 0},
    "expiry_warning_seconds": {"type": "integer", "minimum": 0},
    "source_temporal_receipt_id": {"type": "string"},
    "receipt_schema_ref": {
      "type": "string",
      "const": "urn:mullusi:schema:temporal-evidence-freshness-receipt:1"
    },
    "terminal_closure_required": {"type": "boolean", "const": true},
    "receipt_hash": {"type": "string", "minLength": 1},
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "receipt_is_not_terminal_closure",
        "runtime_owns_time_truth",
        "evidence_fresh_for_dispatch",
        "refresh_required",
        "recheck_required_before_dispatch",
        "high_risk_requires_verified_evidence",
        "evidence_state_count"
      ],
      "properties": {
        "receipt_is_not_terminal_closure": {"type": "boolean", "const": true},
        "runtime_owns_time_truth": {"type": "boolean", "const": true},
        "evidence_fresh_for_dispatch": {"type": "boolean"},
        "refresh_required": {"type": "boolean"},
        "recheck_required_before_dispatch": {"type": "boolean"},
        "high_risk_requires_verified_evidence": {"type": "boolean"},
        "evidence_state_count": {"type": "integer", "minimum": 0}
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {"status": {"const": "fresh"}},
        "required": ["status"]
      },
      "then": {
        "properties": {
          "accepted_evidence_refs": {"minItems": 1},
          "stale_evidence_refs": {"maxItems": 0},
          "blocked_evidence_refs": {"maxItems": 0},
          "missing_evidence_types": {"maxItems": 0},
          "stale_evidence_types": {"maxItems": 0},
          "blocked_reasons": {"maxItems": 0},
          "earliest_fresh_until": {"minLength": 1},
          "recheck_due_at": {"minLength": 1},
          "refresh_due_at": {"maxLength": 0},
          "metadata": {
            "properties": {
              "evidence_fresh_for_dispatch": {"const": true},
              "refresh_required": {"const": false},
              "recheck_required_before_dispatch": {"const": false}
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {"status": {"const": "refresh_required"}},
        "required": ["status"]
      },
      "then": {
        "properties": {
          "stale_evidence_refs": {"minItems": 1},
          "stale_evidence_types": {"minItems": 1},
          "blocked_evidence_refs": {"maxItems": 0},
          "missing_evidence_types": {"maxItems": 0},
          "blocked_reasons": {"maxItems": 0},
          "refresh_due_at": {"minLength": 1},
          "metadata": {
            "properties": {
              "evidence_fresh_for_dispatch": {"const": false},
              "refresh_required": {"const": true},
              "recheck_required_before_dispatch": {"const": true}
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {"status": {"const": "insufficient_evidence"}},
        "required": ["status"]
      },
      "then": {
        "properties": {
          "missing_evidence_types": {"minItems": 1},
          "blocked_reasons": {"maxItems": 0},
          "metadata": {
            "properties": {
              "evidence_fresh_for_dispatch": {"const": false},
              "refresh_required": {"const": false},
              "recheck_required_before_dispatch": {"const": true}
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {"status": {"const": "blocked"}},
        "required": ["status"]
      },
      "then": {
        "properties": {
          "blocked_reasons": {"minItems": 1},
          "recheck_due_at": {"maxLength": 0},
          "refresh_due_at": {"maxLength": 0},
          "metadata": {
            "properties": {
              "evidence_fresh_for_dispatch": {"const": false},
              "recheck_required_before_dispatch": {"const": true}
            }
          }
        }
      }
    }
  ]
}
