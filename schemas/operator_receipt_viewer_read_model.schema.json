{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:operator-receipt-viewer-read-model:1",
  "title": "Operator Receipt Viewer Read Model",
  "description": "Operator-gated, bounded command receipt groups for read-only evidence review.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_ref",
    "tenant_id_filter",
    "command_id_filter",
    "receipt_type_filter",
    "receipt_status_filter",
    "task_status_filter",
    "search_filter",
    "limit",
    "offset",
    "next_offset",
    "total",
    "count",
    "total_receipts",
    "receipt_groups",
    "raw_message_exposed",
    "execution_allowed",
    "write_allowed",
    "governed"
  ],
  "properties": {
    "schema_ref": {
      "type": "string",
      "const": "urn:mullusi:schema:operator-receipt-viewer-read-model:1"
    },
    "tenant_id_filter": {"type": "string"},
    "command_id_filter": {"type": "string"},
    "receipt_type_filter": {
      "anyOf": [
        {"$ref": "#/$defs/receipt_type"},
        {"type": "string", "const": ""}
      ]
    },
    "receipt_status_filter": {"type": "string", "maxLength": 128},
    "task_status_filter": {
      "anyOf": [
        {"$ref": "#/$defs/task_status"},
        {"type": "string", "const": ""}
      ]
    },
    "search_filter": {"type": "string", "maxLength": 128},
    "limit": {"type": "integer", "minimum": 1, "maximum": 500},
    "offset": {"type": "integer", "minimum": 0},
    "next_offset": {
      "anyOf": [
        {"type": "integer", "minimum": 0},
        {"type": "null"}
      ]
    },
    "total": {"type": "integer", "minimum": 0},
    "count": {"type": "integer", "minimum": 0},
    "total_receipts": {"type": "integer", "minimum": 0},
    "receipt_groups": {
      "type": "array",
      "items": {"$ref": "#/$defs/receipt_group"}
    },
    "raw_message_exposed": {"type": "boolean", "const": false},
    "execution_allowed": {"type": "boolean", "const": false},
    "write_allowed": {"type": "boolean", "const": false},
    "governed": {"type": "boolean", "const": true}
  },
  "$defs": {
    "receipt_group": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command_id",
        "tenant_id",
        "actor_id",
        "source",
        "intent",
        "command_state",
        "task_status",
        "payload_hash",
        "trace_id",
        "created_at",
        "latest_event_hash",
        "event_count",
        "receipt_types",
        "receipt_count",
        "receipts"
      ],
      "properties": {
        "command_id": {"type": "string", "minLength": 1},
        "tenant_id": {"type": "string", "minLength": 1},
        "actor_id": {"type": "string", "minLength": 1},
        "source": {"type": "string", "minLength": 1},
        "intent": {"type": "string", "minLength": 1},
        "command_state": {"type": "string", "minLength": 1},
        "task_status": {"$ref": "#/$defs/task_status"},
        "payload_hash": {"type": "string", "minLength": 1},
        "trace_id": {"type": "string", "minLength": 1},
        "created_at": {"type": "string", "minLength": 1},
        "latest_event_hash": {"type": "string"},
        "event_count": {"type": "integer", "minimum": 0},
        "receipt_types": {
          "type": "array",
          "items": {"$ref": "#/$defs/receipt_type"},
          "uniqueItems": true
        },
        "receipt_count": {"type": "integer", "minimum": 0},
        "receipts": {
          "type": "array",
          "items": {"$ref": "#/$defs/receipt"}
        }
      }
    },
    "receipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_type",
        "receipt_id",
        "receipt_hash",
        "status",
        "details",
        "evidence_refs"
      ],
      "properties": {
        "receipt_type": {"$ref": "#/$defs/receipt_type"},
        "receipt_id": {"type": "string"},
        "receipt_hash": {"type": "string"},
        "status": {"type": "string"},
        "details": {"type": "object", "additionalProperties": true},
        "evidence_refs": {"type": "object", "additionalProperties": true}
      }
    },
    "receipt_type": {
      "type": "string",
      "enum": [
        "interpretation_receipt",
        "llm_interpretation_proposal_receipt",
        "search_decision_receipt",
        "search_receipt",
        "plan_step_receipt",
        "approval_receipt",
        "denial_receipt",
        "worker_receipt",
        "worker_failure_receipt",
        "delivery_receipt",
        "command_event",
        "universal_action_proof",
        "terminal_closure_certificate"
      ]
    },
    "task_status": {
      "type": "string",
      "enum": [
        "received",
        "active",
        "waiting_for_approval",
        "requires_review",
        "blocked",
        "completed"
      ]
    }
  }
}
