{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:runtime-conformance-collection:1",
  "title": "Runtime Conformance Collection",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "collection_id",
    "collected_at",
    "gateway_url",
    "endpoint_status",
    "certificate_status",
    "signature_status",
    "certificate",
    "steps",
    "errors"
  ],
  "properties": {
    "collection_id": {
      "type": "string",
      "pattern": "^runtime-conformance-collection-[0-9a-f]{16}$"
    },
    "collected_at": {
      "type": "string",
      "minLength": 1
    },
    "gateway_url": {
      "type": "string",
      "minLength": 1
    },
    "endpoint_status": {
      "type": "integer",
      "minimum": 0
    },
    "certificate_status": {
      "type": "string"
    },
    "signature_status": {
      "type": "string",
      "minLength": 1
    },
    "certificate": {
      "type": "object",
      "additionalProperties": true
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/collection_step"
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 1024
      }
    }
  },
  "$defs": {
    "collection_step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "passed",
        "detail"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "passed": {
          "type": "boolean"
        },
        "detail": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2048
        }
      }
    }
  }
}
