{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:temporal-memory-receipt:1",
  "title": "Temporal Memory Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receipt_id",
    "request_id",
    "memory_id",
    "tenant_id",
    "owner_id",
    "scope",
    "subject",
    "action_type",
    "risk_level",
    "use_context",
    "status",
    "temporal_violations",
    "temporal_warnings",
    "supersession_reasons",
    "required_controls",
    "runtime_now_utc",
    "observed_at",
    "learned_at",
    "last_confirmed_at",
    "valid_from",
    "valid_until",
    "age_seconds",
    "freshness_seconds",
    "stale_seconds",
    "confidence",
    "decayed_confidence",
    "min_confidence",
    "confidence_decay_per_day",
    "supersedes",
    "superseded_by",
    "source_event_id",
    "evidence_refs",
    "allowed_use",
    "forbidden_use",
    "receipt_schema_ref",
    "terminal_closure_required",
    "receipt_hash",
    "metadata"
  ],
  "properties": {
    "receipt_id": {
      "type": "string",
      "pattern": "^temporal-memory-receipt-[0-9a-f]{16}$"
    },
    "request_id": {"type": "string", "minLength": 1},
    "memory_id": {"type": "string", "minLength": 1},
    "tenant_id": {"type": "string", "minLength": 1},
    "owner_id": {"type": "string", "minLength": 1},
    "scope": {"type": "string", "minLength": 1},
    "subject": {"type": "string", "minLength": 1},
    "action_type": {"type": "string", "minLength": 1},
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "use_context": {"type": "string", "minLength": 1},
    "status": {
      "type": "string",
      "enum": ["usable", "refresh_required", "blocked", "superseded"]
    },
    "temporal_violations": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "temporal_warnings": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "supersession_reasons": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "required_controls": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "runtime_now_utc": {"type": "string", "format": "date-time"},
    "observed_at": {"type": "string"},
    "learned_at": {"type": "string"},
    "last_confirmed_at": {"type": "string"},
    "valid_from": {"type": "string"},
    "valid_until": {"type": "string"},
    "age_seconds": {"type": "integer", "minimum": 0},
    "freshness_seconds": {"type": "integer", "minimum": 0},
    "stale_seconds": {"type": "integer", "minimum": 0},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "decayed_confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "min_confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "confidence_decay_per_day": {"type": "number", "minimum": 0},
    "supersedes": {"type": "string"},
    "superseded_by": {"type": "string"},
    "source_event_id": {"type": "string", "minLength": 1},
    "evidence_refs": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "allowed_use": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "forbidden_use": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "receipt_schema_ref": {
      "type": "string",
      "const": "urn:mullusi:schema:temporal-memory-receipt:1"
    },
    "terminal_closure_required": {"type": "boolean", "const": true},
    "receipt_hash": {"type": "string", "minLength": 1},
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "receipt_is_not_terminal_closure",
        "memory_usable",
        "runtime_owns_time_truth",
        "evidence_refresh_required",
        "supersession_checked",
        "confidence_decay_applied"
      ],
      "properties": {
        "receipt_is_not_terminal_closure": {"type": "boolean", "const": true},
        "memory_usable": {"type": "boolean"},
        "runtime_owns_time_truth": {"type": "boolean", "const": true},
        "evidence_refresh_required": {"type": "boolean"},
        "supersession_checked": {"type": "boolean", "const": true},
        "confidence_decay_applied": {"type": "boolean"}
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {"status": {"const": "usable"}},
        "required": ["status"]
      },
      "then": {
        "properties": {
          "temporal_violations": {"maxItems": 0},
          "temporal_warnings": {"maxItems": 0},
          "supersession_reasons": {"maxItems": 0},
          "metadata": {
            "properties": {
              "memory_usable": {"const": true},
              "evidence_refresh_required": {"const": false}
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {"status": {"const": "refresh_required"}},
        "required": ["status"]
      },
      "then": {
        "properties": {
          "temporal_violations": {"maxItems": 0},
          "temporal_warnings": {"minItems": 1},
          "supersession_reasons": {"maxItems": 0},
          "metadata": {
            "properties": {
              "memory_usable": {"const": false},
              "evidence_refresh_required": {"const": true}
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {"status": {"const": "blocked"}},
        "required": ["status"]
      },
      "then": {
        "properties": {
          "temporal_violations": {"minItems": 1},
          "metadata": {
            "properties": {
              "memory_usable": {"const": false}
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {"status": {"const": "superseded"}},
        "required": ["status"]
      },
      "then": {
        "properties": {
          "temporal_violations": {"maxItems": 0},
          "supersession_reasons": {"minItems": 1},
          "metadata": {
            "properties": {
              "memory_usable": {"const": false}
            }
          }
        }
      }
    }
  ]
}
