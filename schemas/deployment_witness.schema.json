{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:deployment-witness:1",
  "title": "Deployment Witness",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "witness_id",
    "collected_at",
    "gateway_url",
    "public_health_endpoint",
    "health_http_status",
    "health_response_digest",
    "deployment_claim",
    "health_status",
    "runtime_witness_status",
    "signature_status",
    "conformance_status",
    "conformance_signature_status",
    "latest_conformance_certificate_id",
    "latest_terminal_certificate_id",
    "latest_command_event_hash",
    "runtime_witness_id",
    "runtime_environment",
    "runtime_signature_key_id",
    "authority_responsibility_debt_clear",
    "authority_pending_approval_chain_count",
    "authority_overdue_approval_chain_count",
    "authority_open_obligation_count",
    "authority_overdue_obligation_count",
    "authority_escalated_obligation_count",
    "authority_unowned_high_risk_capability_count",
    "steps",
    "errors"
  ],
  "properties": {
    "witness_id": {
      "type": "string",
      "pattern": "^deployment-witness-[0-9a-f]{16}$"
    },
    "collected_at": {
      "type": "string",
      "format": "date-time"
    },
    "gateway_url": {
      "type": "string",
      "minLength": 1
    },
    "public_health_endpoint": {
      "type": "string",
      "minLength": 1
    },
    "health_http_status": {
      "type": "integer",
      "minimum": 0
    },
    "health_response_digest": {
      "type": "string",
      "pattern": "^(sha256:[0-9a-f]{64})?$"
    },
    "deployment_claim": {
      "type": "string",
      "enum": [
        "published",
        "not-published"
      ]
    },
    "health_status": {
      "type": "string"
    },
    "runtime_witness_status": {
      "type": "string"
    },
    "signature_status": {
      "type": "string",
      "minLength": 1
    },
    "conformance_status": {
      "type": "string"
    },
    "conformance_signature_status": {
      "type": "string",
      "minLength": 1
    },
    "latest_conformance_certificate_id": {
      "type": "string"
    },
    "latest_terminal_certificate_id": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "null"
        }
      ]
    },
    "latest_command_event_hash": {
      "type": "string"
    },
    "runtime_witness_id": {
      "type": "string"
    },
    "runtime_environment": {
      "type": "string"
    },
    "runtime_signature_key_id": {
      "type": "string"
    },
    "authority_responsibility_debt_clear": {
      "type": "boolean"
    },
    "authority_pending_approval_chain_count": {
      "type": "integer",
      "minimum": 0
    },
    "authority_overdue_approval_chain_count": {
      "type": "integer",
      "minimum": 0
    },
    "authority_open_obligation_count": {
      "type": "integer",
      "minimum": 0
    },
    "authority_overdue_obligation_count": {
      "type": "integer",
      "minimum": 0
    },
    "authority_escalated_obligation_count": {
      "type": "integer",
      "minimum": 0
    },
    "authority_unowned_high_risk_capability_count": {
      "type": "integer",
      "minimum": 0
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/probe_step"
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "probe_step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "passed",
        "detail"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "passed": {
          "type": "boolean"
        },
        "detail": {
          "type": "string"
        }
      }
    }
  }
}
