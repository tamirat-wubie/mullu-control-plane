{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:trust-ledger-export-package:1",
  "title": "Trust Ledger Export Package",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "package_id",
    "schema_version",
    "bundle_id",
    "anchor_receipt_id",
    "tenant_id",
    "command_id",
    "terminal_certificate_id",
    "bundle_hash",
    "anchor_receipt_hash",
    "artifact_root_hash",
    "artifact_count",
    "files",
    "package_hash",
    "created_at",
    "metadata"
  ],
  "properties": {
    "package_id": {"type": "string", "pattern": "^trust-export-[0-9a-f]{16}$"},
    "schema_version": {"type": "integer", "const": 1},
    "bundle_id": {"type": "string", "pattern": "^trust-bundle-[0-9a-f]{16}$"},
    "anchor_receipt_id": {"type": "string", "pattern": "^trust-anchor-receipt-[0-9a-f]{16}$"},
    "tenant_id": {"type": "string", "minLength": 1},
    "command_id": {"type": "string", "minLength": 1},
    "terminal_certificate_id": {"type": "string", "minLength": 1},
    "bundle_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "anchor_receipt_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "artifact_root_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "artifact_count": {"type": "integer", "minimum": 1},
    "files": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bundle", "anchor_receipt", "artifacts"],
      "properties": {
        "bundle": {"$ref": "#/$defs/export_file"},
        "anchor_receipt": {"$ref": "#/$defs/export_file"},
        "artifacts": {"$ref": "#/$defs/export_file"}
      }
    },
    "package_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "created_at": {"type": "string", "format": "date-time"},
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["package_is_not_terminal_closure"],
      "properties": {
        "package_is_not_terminal_closure": {"type": "boolean", "const": true}
      }
    }
  },
  "$defs": {
    "export_file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    }
  }
}
