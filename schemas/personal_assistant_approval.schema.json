{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:personal-assistant-approval:1",
  "title": "Personal Assistant Approval",
  "description": "Approval packet for effect-bearing personal-assistant actions.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "approval_id",
    "request_id",
    "plan_id",
    "created_at",
    "risk_level",
    "approval_state",
    "explicit_approval_required",
    "approver_ref",
    "approval_scope",
    "proposed_actions",
    "forbidden_without_approval",
    "decision_record",
    "receipt_ref",
    "evidence_refs",
    "metadata"
  ],
  "properties": {
    "approval_id": { "type": "string", "pattern": "^pa_approval_[a-z0-9][a-z0-9_:-]*$" },
    "request_id": { "type": "string", "pattern": "^pa_request_[a-z0-9][a-z0-9_:-]*$" },
    "plan_id": { "type": "string", "pattern": "^pa_plan_[a-z0-9][a-z0-9_:-]*$" },
    "created_at": { "type": "string", "format": "date-time" },
    "risk_level": { "type": "string", "enum": ["P0", "P1", "P2", "P3", "P4", "P5"] },
    "approval_state": { "type": "string", "enum": ["not_required", "requested", "approved", "rejected", "revised", "expired", "blocked"] },
    "explicit_approval_required": { "type": "boolean" },
    "approver_ref": { "type": "string" },
    "approval_scope": { "type": "string", "enum": ["none", "per_request", "per_plan", "per_skill", "per_action", "per_recipient"] },
    "proposed_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["action_id", "skill_id", "risk_level", "effect_boundary", "summary"],
        "properties": {
          "action_id": { "type": "string", "minLength": 1 },
          "skill_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*(\\.[a-z0-9_]+)+$" },
          "risk_level": { "type": "string", "enum": ["P0", "P1", "P2", "P3", "P4", "P5"] },
          "effect_boundary": { "type": "string", "minLength": 1 },
          "summary": { "type": "string", "minLength": 1 }
        }
      }
    },
    "forbidden_without_approval": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "decision_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision", "reason_codes", "decided_at"],
      "properties": {
        "decision": { "type": "string", "enum": ["pending", "approved", "rejected", "revised", "blocked"] },
        "reason_codes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "decided_at": { "type": "string" }
      }
    },
    "receipt_ref": { "type": "string", "minLength": 1 },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "metadata": { "type": "object", "additionalProperties": true }
  }
}
