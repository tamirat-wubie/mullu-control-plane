{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:maf-abi-cli-contract-witness:1",
  "title": "MAF ABI CLI Contract Witness",
  "description": "Foundation Mode witness for the MAF ABI/CLI contract boundary before any Python-to-Rust runtime binding can be considered.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "witness_id",
    "witness_version",
    "generated_at",
    "solver_outcome",
    "contract_scope",
    "source_digests",
    "cli_contract",
    "authority_boundary",
    "receipt_refs",
    "contract_summary",
    "evidence_refs"
  ],
  "properties": {
    "witness_id": {"type": "string", "minLength": 1},
    "witness_version": {"const": "maf_abi_cli_contract_witness.v1"},
    "generated_at": {"type": "string", "format": "date-time"},
    "solver_outcome": {"const": "AwaitingEvidence"},
    "contract_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_family",
        "foundation_mode",
        "runtime_binding_claimed",
        "cli_execution_performed",
        "abi_stability_claimed",
        "preceding_witness_ref",
        "uao_ref",
        "life_meaning_judgment_ref",
        "required_future_witnesses"
      ],
      "properties": {
        "source_family": {"const": "maf/rust/maf-cli"},
        "foundation_mode": {"type": "boolean"},
        "runtime_binding_claimed": {"type": "boolean"},
        "cli_execution_performed": {"type": "boolean"},
        "abi_stability_claimed": {"type": "boolean"},
        "preceding_witness_ref": {"type": "string", "minLength": 1},
        "uao_ref": {"type": "string", "minLength": 1},
        "life_meaning_judgment_ref": {"type": "string", "minLength": 1},
        "required_future_witnesses": {"$ref": "#/$defs/non_empty_string_array"}
      }
    },
    "source_digests": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source_ref", "digest_sha256", "source_role"],
        "properties": {
          "source_ref": {"type": "string", "minLength": 1},
          "digest_sha256": {"$ref": "#/$defs/sha256"},
          "source_role": {"type": "string", "minLength": 1}
        }
      }
    },
    "cli_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "binary_crate",
        "manifest_ref",
        "entry_ref",
        "declared_contract_state",
        "accepted_argument_schema_ref",
        "output_receipt_schema_ref",
        "failure_receipt_schema_ref",
        "deterministic_fixture_parity_ref",
        "subprocess_effect_boundary_ref"
      ],
      "properties": {
        "binary_crate": {"const": "maf-cli"},
        "manifest_ref": {"const": "maf/rust/crates/maf-cli/Cargo.toml"},
        "entry_ref": {"const": "maf/rust/crates/maf-cli/src/main.rs"},
        "declared_contract_state": {"const": "ABI_CLI_CONTRACT_AWAITING_EVIDENCE"},
        "accepted_argument_schema_ref": {"type": "string", "minLength": 1},
        "output_receipt_schema_ref": {"type": "string", "minLength": 1},
        "failure_receipt_schema_ref": {"type": "string", "minLength": 1},
        "deterministic_fixture_parity_ref": {"type": "string", "minLength": 1},
        "subprocess_effect_boundary_ref": {"type": "string", "minLength": 1}
      }
    },
    "authority_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cli_execution_allowed",
        "subprocess_execution_allowed",
        "rust_crate_execution_allowed",
        "python_to_rust_binding_allowed",
        "abi_stability_claim_allowed",
        "external_connector_call_allowed",
        "network_call_allowed",
        "secret_access_allowed",
        "filesystem_write_allowed",
        "runtime_dispatch_allowed",
        "terminal_closure_allowed",
        "success_claim_allowed"
      ],
      "properties": {
        "cli_execution_allowed": {"type": "boolean"},
        "subprocess_execution_allowed": {"type": "boolean"},
        "rust_crate_execution_allowed": {"type": "boolean"},
        "python_to_rust_binding_allowed": {"type": "boolean"},
        "abi_stability_claim_allowed": {"type": "boolean"},
        "external_connector_call_allowed": {"type": "boolean"},
        "network_call_allowed": {"type": "boolean"},
        "secret_access_allowed": {"type": "boolean"},
        "filesystem_write_allowed": {"type": "boolean"},
        "runtime_dispatch_allowed": {"type": "boolean"},
        "terminal_closure_allowed": {"type": "boolean"},
        "success_claim_allowed": {"type": "boolean"}
      }
    },
    "receipt_refs": {"type": "object", "additionalProperties": {"type": "string", "minLength": 1}},
    "contract_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_digest_count", "authority_denial_count", "future_witness_count", "evidence_ref_count"],
      "properties": {
        "source_digest_count": {"type": "integer", "minimum": 0},
        "authority_denial_count": {"type": "integer", "minimum": 0},
        "future_witness_count": {"type": "integer", "minimum": 0},
        "evidence_ref_count": {"type": "integer", "minimum": 0}
      }
    },
    "evidence_refs": {"$ref": "#/$defs/non_empty_string_array"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    }
  }
}
