{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:local-developer-workflow-pr-command-preview-packet:1",
  "title": "Local Developer Workflow PR Command Preview Packet",
  "description": "Projection-only local review packet for Local Developer Workflow v1 PR command text before any branch push or pull-request creation authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "packet_id",
    "workflow_id",
    "workflow_run_id",
    "status",
    "solver_outcome",
    "projection_only",
    "packet_is_not_execution_authority",
    "command_preview_is_review_only",
    "execution_performed",
    "external_effects_allowed",
    "live_execution_enabled",
    "commands_rendered",
    "command_count",
    "approval",
    "command_preview",
    "required_before_execution",
    "blocked_effects",
    "effect_boundary",
    "source_refs",
    "validators",
    "causal_trace",
    "packet_hash"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "packet_id": {
      "type": "string",
      "const": "local_developer_workflow_v1.pr_command_preview_packet.foundation.v1"
    },
    "workflow_id": {
      "type": "string",
      "const": "mullu.local_developer_workflow.v1"
    },
    "workflow_run_id": { "$ref": "#/$defs/text" },
    "status": { "type": "string", "const": "AwaitingEvidence" },
    "solver_outcome": { "type": "string", "const": "AwaitingEvidence" },
    "projection_only": { "type": "boolean", "const": true },
    "packet_is_not_execution_authority": { "type": "boolean", "const": true },
    "command_preview_is_review_only": { "type": "boolean", "const": true },
    "execution_performed": { "type": "boolean", "const": false },
    "external_effects_allowed": { "type": "boolean", "const": false },
    "live_execution_enabled": { "type": "boolean", "const": false },
    "commands_rendered": { "type": "boolean", "const": true },
    "command_count": { "type": "integer", "const": 2 },
    "approval": { "$ref": "#/$defs/approval" },
    "command_preview": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": { "$ref": "#/$defs/command_preview" }
    },
    "required_before_execution": {
      "type": "array",
      "minItems": 5,
      "items": { "$ref": "#/$defs/text" }
    },
    "blocked_effects": {
      "type": "array",
      "minItems": 7,
      "maxItems": 7,
      "items": {
        "type": "string",
        "enum": [
          "branch_push",
          "pull_request_create",
          "merge",
          "deploy",
          "connector_call",
          "external_write",
          "live_execution"
        ]
      }
    },
    "effect_boundary": { "$ref": "#/$defs/effect_boundary" },
    "source_refs": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "validators": {
      "type": "array",
      "minItems": 2,
      "items": { "$ref": "#/$defs/text" }
    },
    "causal_trace": {
      "type": "array",
      "minItems": 4,
      "items": { "$ref": "#/$defs/text" }
    },
    "packet_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  },
  "$defs": {
    "text": { "type": "string", "minLength": 1, "maxLength": 2000 },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "approval_request_id",
        "approval_required",
        "approval_status",
        "approval_performed",
        "approval_does_not_authorize_execution",
        "allowed_decisions"
      ],
      "properties": {
        "approval_request_id": { "$ref": "#/$defs/text" },
        "approval_required": { "type": "boolean", "const": true },
        "approval_status": { "type": "string", "const": "pending" },
        "approval_performed": { "type": "boolean", "const": false },
        "approval_does_not_authorize_execution": { "type": "boolean", "const": true },
        "allowed_decisions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/text" }
        }
      }
    },
    "command_preview": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command_id", "effect", "command", "review_only", "execution_allowed"],
      "properties": {
        "command_id": { "$ref": "#/$defs/text" },
        "effect": { "type": "string", "enum": ["push_branch", "open_external_pr"] },
        "command": { "$ref": "#/$defs/text" },
        "review_only": { "type": "boolean", "const": true },
        "execution_allowed": { "type": "boolean", "const": false }
      }
    },
    "effect_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "file_write_performed",
        "source_mutation_performed",
        "test_process_executed",
        "branch_created",
        "branch_push_performed",
        "pull_request_created",
        "merge_performed",
        "deployment_performed",
        "connector_call_performed",
        "external_write_performed",
        "live_execution_enabled"
      ],
      "properties": {
        "file_write_performed": { "type": "boolean", "const": false },
        "source_mutation_performed": { "type": "boolean", "const": false },
        "test_process_executed": { "type": "boolean", "const": false },
        "branch_created": { "type": "boolean", "const": false },
        "branch_push_performed": { "type": "boolean", "const": false },
        "pull_request_created": { "type": "boolean", "const": false },
        "merge_performed": { "type": "boolean", "const": false },
        "deployment_performed": { "type": "boolean", "const": false },
        "connector_call_performed": { "type": "boolean", "const": false },
        "external_write_performed": { "type": "boolean", "const": false },
        "live_execution_enabled": { "type": "boolean", "const": false }
      }
    }
  }
}
