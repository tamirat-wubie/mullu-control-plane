{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:physical-action-receipt:1",
  "title": "Physical Action Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receipt_id",
    "request_id",
    "tenant_id",
    "command_id",
    "actuator_id",
    "action",
    "effect_mode",
    "risk_level",
    "status",
    "reason",
    "policy_id",
    "safety_envelope_ref",
    "environment_ref",
    "simulation_passed",
    "operator_approval_ref",
    "manual_override_ref",
    "emergency_stop_ref",
    "sensor_confirmation_ref",
    "evidence_refs",
    "required_controls",
    "blocked_reasons",
    "review_reasons",
    "policy_refs",
    "receipt_schema_ref",
    "physical_worker_receipt_required",
    "operator_approval_required",
    "manual_override_required",
    "emergency_stop_required",
    "sensor_confirmation_required",
    "terminal_closure_required",
    "no_physical_effect_applied",
    "receipt_hash",
    "metadata"
  ],
  "properties": {
    "receipt_id": {"type": "string", "pattern": "^physical-action-receipt-[0-9a-f]{16}$"},
    "request_id": {"type": "string", "minLength": 1},
    "tenant_id": {"type": "string", "minLength": 1},
    "command_id": {"type": "string", "minLength": 1},
    "actuator_id": {"type": "string", "minLength": 1},
    "action": {"type": "string", "minLength": 1},
    "effect_mode": {"type": "string", "enum": ["sandbox", "live"]},
    "risk_level": {"type": "string", "enum": ["low", "medium", "high", "critical"]},
    "status": {"type": "string", "enum": ["allowed", "blocked", "requires_review"]},
    "reason": {"type": "string", "minLength": 1},
    "policy_id": {"type": "string", "minLength": 1},
    "safety_envelope_ref": {"type": "string", "minLength": 1},
    "environment_ref": {"type": "string", "minLength": 1},
    "simulation_passed": {"type": "boolean"},
    "operator_approval_ref": {"type": "string"},
    "manual_override_ref": {"type": "string"},
    "emergency_stop_ref": {"type": "string"},
    "sensor_confirmation_ref": {"type": "string"},
    "evidence_refs": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "required_controls": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "blocked_reasons": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "review_reasons": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "policy_refs": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "receipt_schema_ref": {"type": "string", "const": "urn:mullusi:schema:physical-action-receipt:1"},
    "physical_worker_receipt_required": {"type": "boolean", "const": true},
    "operator_approval_required": {"type": "boolean", "const": true},
    "manual_override_required": {"type": "boolean", "const": true},
    "emergency_stop_required": {"type": "boolean", "const": true},
    "sensor_confirmation_required": {"type": "boolean", "const": true},
    "terminal_closure_required": {"type": "boolean", "const": true},
    "no_physical_effect_applied": {"type": "boolean"},
    "receipt_hash": {"type": "string", "minLength": 1},
    "metadata": {"type": "object", "additionalProperties": true}
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "effect_mode": {"const": "sandbox"}
        }
      },
      "then": {
        "properties": {
          "no_physical_effect_applied": {"const": true}
        }
      }
    }
  ]
}
