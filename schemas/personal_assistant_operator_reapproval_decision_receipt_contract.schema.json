{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:personal-assistant-operator-reapproval-decision-receipt-contract:1",
  "title": "Personal Assistant Operator Reapproval Decision Receipt Contract",
  "description": "Foundation Mode no-effect contract for the future receipt required to bind a fresh operator reapproval decision.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_set_id",
    "generated_at",
    "governed",
    "source_projection",
    "source_operator_reapproval_decision_intake_set_id",
    "contract_count",
    "contract_ids",
    "source_intake_ids",
    "receipt_ids",
    "contracts",
    "effect_boundary",
    "private_payload_policy",
    "assurance",
    "metadata"
  ],
  "properties": {
    "contract_set_id": {"type": "string", "pattern": "^pa_operator_reapproval_decision_receipt_contract_[a-z0-9][a-z0-9_:-]*$"},
    "generated_at": {"type": "string", "minLength": 1},
    "governed": {"const": true},
    "source_projection": {"const": "operator_reapproval_decision_intake"},
    "source_operator_reapproval_decision_intake_set_id": {"type": "string", "pattern": "^pa_operator_reapproval_decision_intake_[a-z0-9][a-z0-9_:-]*$"},
    "contract_count": {"type": "integer", "minimum": 1},
    "contract_ids": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "pattern": "^pa_operator_reapproval_decision_receipt_contract_item_[a-z0-9][a-z0-9_:-]*$"},
      "uniqueItems": true
    },
    "source_intake_ids": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "pattern": "^pa_operator_reapproval_decision_intake_item_[a-z0-9][a-z0-9_:-]*$"},
      "uniqueItems": true
    },
    "receipt_ids": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "pattern": "^pa_receipt_[a-z0-9][a-z0-9_:-]*$"},
      "uniqueItems": true
    },
    "contracts": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/contract_item"}
    },
    "effect_boundary": {"$ref": "#/$defs/effect_boundary"},
    "private_payload_policy": {"$ref": "#/$defs/private_payload_policy"},
    "assurance": {"$ref": "#/$defs/assurance"},
    "metadata": {"$ref": "#/$defs/metadata"}
  },
  "$defs": {
    "digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "contract_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract_id",
        "source_intake_id",
        "approval_id",
        "request_id",
        "plan_id",
        "skill_id",
        "risk_level",
        "decision_intake_ref",
        "required_receipt_contract",
        "execution_admission_block",
        "receipt"
      ],
      "properties": {
        "contract_id": {"type": "string", "pattern": "^pa_operator_reapproval_decision_receipt_contract_item_[a-z0-9][a-z0-9_:-]*$"},
        "source_intake_id": {"type": "string", "pattern": "^pa_operator_reapproval_decision_intake_item_[a-z0-9][a-z0-9_:-]*$"},
        "approval_id": {"type": "string", "pattern": "^pa_approval_[a-z0-9][a-z0-9_:-]*$"},
        "request_id": {"type": "string", "pattern": "^pa_request_[a-z0-9][a-z0-9_:-]*$"},
        "plan_id": {"type": "string", "pattern": "^pa_plan_[a-z0-9][a-z0-9_:-]*$"},
        "skill_id": {"type": "string", "pattern": "^[a-z][a-z0-9_]*(\\.[a-z0-9_]+)+$"},
        "risk_level": {"enum": ["P3", "P4", "P5"]},
        "decision_intake_ref": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "source_intake_set_id",
            "source_intake_id",
            "intake_request_ref",
            "intake_request_digest",
            "wait_state",
            "accepted_decision_values",
            "decision_receipt_required",
            "decision_receipt_present",
            "execution_worker_admission_allowed"
          ],
          "properties": {
            "source_intake_set_id": {"type": "string", "minLength": 1},
            "source_intake_id": {"type": "string", "pattern": "^pa_operator_reapproval_decision_intake_item_[a-z0-9][a-z0-9_:-]*$"},
            "intake_request_ref": {"type": "string", "pattern": "^approval://personal-assistant/reapproval-decision-intake/pa_approval_[a-z0-9][a-z0-9_:-]*$"},
            "intake_request_digest": {"$ref": "#/$defs/digest"},
            "wait_state": {"const": "awaiting_operator_reapproval"},
            "accepted_decision_values": {
              "type": "array",
              "minItems": 4,
              "maxItems": 4,
              "items": {"enum": ["approved", "rejected", "revised", "expired"]},
              "uniqueItems": true
            },
            "decision_receipt_required": {"const": true},
            "decision_receipt_present": {"const": false},
            "execution_worker_admission_allowed": {"const": false}
          }
        },
        "required_receipt_contract": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "required_receipt_ref",
            "required_receipt_digest",
            "allowed_decision_values",
            "required_identity_binding",
            "required_signature_binding",
            "required_source_refs",
            "required_receipt_fields",
            "raw_operator_decision_serialized",
            "secret_values_serialized",
            "decision_receipt_present"
          ],
          "properties": {
            "required_receipt_ref": {"type": "string", "pattern": "^receipt://personal-assistant/operator-reapproval-decision/pa_approval_[a-z0-9][a-z0-9_:-]*$"},
            "required_receipt_digest": {"$ref": "#/$defs/digest"},
            "allowed_decision_values": {
              "type": "array",
              "minItems": 4,
              "maxItems": 4,
              "items": {"enum": ["approved", "rejected", "revised", "expired"]},
              "uniqueItems": true
            },
            "required_identity_binding": {"const": "operator_identity_ref"},
            "required_signature_binding": {"const": "operator_signature_ref"},
            "required_source_refs": {
              "type": "array",
              "minItems": 3,
              "items": {"enum": ["operator_reapproval_gate_ref", "operator_reapproval_decision_intake_ref", "approval_ref"]},
              "uniqueItems": true
            },
            "required_receipt_fields": {
              "type": "array",
              "minItems": 8,
              "items": {"type": "string", "minLength": 1},
              "uniqueItems": true
            },
            "raw_operator_decision_serialized": {"const": false},
            "secret_values_serialized": {"const": false},
            "decision_receipt_present": {"const": false}
          }
        },
        "execution_admission_block": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "execution_worker_admission_state",
            "execution_worker_admission_allowed",
            "dispatch_allowed",
            "live_connector_execution_allowed",
            "connector_mutation_allowed",
            "external_send_allowed",
            "system_of_record_write_allowed",
            "memory_write_allowed"
          ],
          "properties": {
            "execution_worker_admission_state": {"const": "blocked_pending_operator_reapproval_decision_receipt"},
            "execution_worker_admission_allowed": {"const": false},
            "dispatch_allowed": {"const": false},
            "live_connector_execution_allowed": {"const": false},
            "connector_mutation_allowed": {"const": false},
            "external_send_allowed": {"const": false},
            "system_of_record_write_allowed": {"const": false},
            "memory_write_allowed": {"const": false}
          }
        },
        "receipt": {"type": "object", "additionalProperties": true}
      }
    },
    "effect_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operator_reapproval_decision_receipt_contract_allowed",
        "decision_intake_ref_binding_allowed",
        "fresh_operator_decision_required",
        "operator_identity_ref_required",
        "operator_signature_ref_required",
        "decision_receipt_required",
        "fresh_operator_decision_present",
        "operator_identity_ref_present",
        "operator_signature_ref_present",
        "operator_reapproval_receipt_present",
        "decision_receipt_present",
        "execution_worker_admission_allowed",
        "dispatch_allowed",
        "dispatch_lease_active",
        "live_connector_receipt_present",
        "live_connector_execution_allowed",
        "external_send_allowed",
        "calendar_write_allowed",
        "task_write_allowed",
        "memory_write_allowed",
        "connector_mutation_allowed",
        "system_of_record_write_allowed",
        "deployment_mutation_allowed",
        "nested_mind_live_activation_allowed",
        "public_readiness_claim_allowed"
      ],
      "properties": {
        "operator_reapproval_decision_receipt_contract_allowed": {"const": true},
        "decision_intake_ref_binding_allowed": {"const": true},
        "fresh_operator_decision_required": {"const": true},
        "operator_identity_ref_required": {"const": true},
        "operator_signature_ref_required": {"const": true},
        "decision_receipt_required": {"const": true},
        "fresh_operator_decision_present": {"const": false},
        "operator_identity_ref_present": {"const": false},
        "operator_signature_ref_present": {"const": false},
        "operator_reapproval_receipt_present": {"const": false},
        "decision_receipt_present": {"const": false},
        "execution_worker_admission_allowed": {"const": false},
        "dispatch_allowed": {"const": false},
        "dispatch_lease_active": {"const": false},
        "live_connector_receipt_present": {"const": false},
        "live_connector_execution_allowed": {"const": false},
        "external_send_allowed": {"const": false},
        "calendar_write_allowed": {"const": false},
        "task_write_allowed": {"const": false},
        "memory_write_allowed": {"const": false},
        "connector_mutation_allowed": {"const": false},
        "system_of_record_write_allowed": {"const": false},
        "deployment_mutation_allowed": {"const": false},
        "nested_mind_live_activation_allowed": {"const": false},
        "public_readiness_claim_allowed": {"const": false}
      }
    },
    "private_payload_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raw_private_payload_serialized",
        "secret_values_serialized",
        "intake_payload_projection",
        "receipt_payload_projection"
      ],
      "properties": {
        "raw_private_payload_serialized": {"const": false},
        "secret_values_serialized": {"const": false},
        "intake_payload_projection": {"const": "ref_only"},
        "receipt_payload_projection": {"const": "absent_until_operator_submits_decision"}
      }
    },
    "assurance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "assurance_id",
        "outcome",
        "foundation_only",
        "ready_for_execution_worker_admission",
        "ready_for_live_execution",
        "ready_for_customer_readiness_claim",
        "authority_drift_detected",
        "checked_controls",
        "blocking_reasons",
        "next_action"
      ],
      "properties": {
        "assurance_id": {"const": "personal_assistant_operator_reapproval_decision_receipt_contract_no_effect_assurance"},
        "outcome": {"enum": ["AwaitingEvidence", "GovernanceBlocked"]},
        "foundation_only": {"const": true},
        "ready_for_execution_worker_admission": {"const": false},
        "ready_for_live_execution": {"const": false},
        "ready_for_customer_readiness_claim": {"const": false},
        "authority_drift_detected": {"type": "boolean"},
        "checked_controls": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "blocking_reasons": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "next_action": {"type": "string", "minLength": 1}
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "foundation_only",
        "projection_contract",
        "runtime_boundary",
        "fresh_operator_decision_present",
        "operator_identity_ref_present",
        "operator_signature_ref_present",
        "operator_reapproval_receipt_present",
        "decision_receipt_present",
        "execution_worker_admission_allowed",
        "dispatch_allowed",
        "live_connector_execution_allowed",
        "connector_mutation_allowed",
        "external_send_allowed",
        "system_of_record_write_allowed",
        "memory_write_allowed"
      ],
      "properties": {
        "foundation_only": {"const": true},
        "projection_contract": {"const": "operator_reapproval_decision_receipt_contract_evidence_only"},
        "runtime_boundary": {"const": "receipt_contract_records_requirements_without_collecting_decision"},
        "fresh_operator_decision_present": {"const": false},
        "operator_identity_ref_present": {"const": false},
        "operator_signature_ref_present": {"const": false},
        "operator_reapproval_receipt_present": {"const": false},
        "decision_receipt_present": {"const": false},
        "execution_worker_admission_allowed": {"const": false},
        "dispatch_allowed": {"const": false},
        "live_connector_execution_allowed": {"const": false},
        "connector_mutation_allowed": {"const": false},
        "external_send_allowed": {"const": false},
        "system_of_record_write_allowed": {"const": false},
        "memory_write_allowed": {"const": false}
      }
    }
  }
}
