{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:universal-action-orchestration-validation-receipt:1",
  "title": "Universal Action Orchestration Validation Receipt",
  "description": "Machine-readable non-terminal receipt for one canonical Universal Action Orchestration validation run.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receipt_id",
    "terminal_closure_required",
    "receipt_is_not_terminal_closure",
    "valid",
    "status",
    "schema_path",
    "document_path",
    "example_paths",
    "example_count",
    "checks",
    "check_count",
    "error_count",
    "errors"
  ],
  "properties": {
    "receipt_id": {
      "type": "string",
      "const": "universal_action_orchestration_validation_receipt"
    },
    "terminal_closure_required": {
      "type": "boolean",
      "const": true
    },
    "receipt_is_not_terminal_closure": {
      "type": "boolean",
      "const": true
    },
    "valid": {
      "type": "boolean"
    },
    "status": {
      "type": "string",
      "enum": ["passed", "failed"]
    },
    "schema_path": {
      "type": "string",
      "const": "schemas/universal_action_orchestration.schema.json"
    },
    "document_path": {
      "type": "string",
      "const": "docs/UNIVERSAL_ACTION_ORCHESTRATION.md"
    },
    "example_paths": {
      "type": "array",
      "prefixItems": [
        {
          "type": "string",
          "const": "examples/universal_action_orchestration.allowed_status_publish.json"
        },
        {
          "type": "string",
          "const": "examples/universal_action_orchestration.blocked_invoice_payment.json"
        },
        {
          "type": "string",
          "const": "examples/uao/blocked_missing_approval.json"
        },
        {
          "type": "string",
          "const": "examples/uao/deferred_stale_evidence.json"
        },
        {
          "type": "string",
          "const": "examples/uao/simulated_low_risk_readonly.json"
        }
      ],
      "minItems": 5,
      "maxItems": 5
    },
    "example_count": {
      "type": "integer",
      "minimum": 0
    },
    "checks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/check_result"
      }
    },
    "check_count": {
      "type": "integer",
      "minimum": 0
    },
    "error_count": {
      "type": "integer",
      "minimum": 0
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "safe_path_label": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(^|/)\\.\\.(/|$))[^:\\\\]+$"
    },
    "check_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "passed"],
      "properties": {
        "name": {
          "type": "string",
          "enum": [
            "universal_action_orchestration_schema",
            "universal_action_orchestration_examples",
            "universal_action_orchestration_document",
            "universal_action_orchestration_no_bypass",
            "universal_action_orchestration_receipts",
            "universal_action_orchestration_runtime_bypass_detector"
          ]
        },
        "passed": {
          "type": "boolean"
        }
      }
    }
  }
}
