{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:personal-assistant-intake-chain-read-model:1",
  "title": "Personal Assistant Intake Chain Read Model",
  "description": "Foundation-only read model that binds personal-assistant request intake, symbolic interpretation, WHQR clarification, plan preview, approval boundary, receipt evidence, memory boundary, and no-effect denials without granting execution authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "read_model_id",
    "read_model_version",
    "generated_at",
    "foundation_only",
    "solver_outcome",
    "request",
    "interpretation",
    "clarification",
    "plan_preview",
    "approval_boundary",
    "receipt_boundary",
    "memory_boundary",
    "effect_boundary",
    "private_payload_policy",
    "source_artifacts",
    "evidence_refs",
    "receipt_refs",
    "lineage",
    "contract_summary"
  ],
  "properties": {
    "read_model_id": {
      "type": "string",
      "pattern": "^pa_intake_chain_[a-z0-9][a-z0-9_:-]*$"
    },
    "read_model_version": {
      "type": "string",
      "const": "personal_assistant_intake_chain_read_model.v1"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "foundation_only": {
      "type": "boolean",
      "const": true
    },
    "solver_outcome": {
      "$ref": "#/$defs/solver_outcome"
    },
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "request_id",
        "interface",
        "risk_level",
        "execution_mode",
        "requires_approval",
        "requested_skill_ids",
        "missing_binding_count",
        "source_ref"
      ],
      "properties": {
        "request_id": {
          "type": "string",
          "pattern": "^pa_request_[a-z0-9][a-z0-9_:-]*$"
        },
        "interface": {
          "type": "string",
          "minLength": 1
        },
        "risk_level": {
          "$ref": "#/$defs/risk_level"
        },
        "execution_mode": {
          "$ref": "#/$defs/execution_mode"
        },
        "requires_approval": {
          "type": "boolean"
        },
        "requested_skill_ids": {
          "$ref": "#/$defs/text_array"
        },
        "missing_binding_count": {
          "type": "integer",
          "minimum": 0
        },
        "source_ref": {
          "$ref": "#/$defs/repo_ref"
        }
      }
    },
    "interpretation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proposal_id",
        "personal_assistant_request_id",
        "gateway_request_id",
        "comparison_result",
        "validation_status",
        "authority_level",
        "deterministic_override_allowed",
        "action_authority_granted",
        "execution_allowed",
        "private_payload_included",
        "secret_values_serialized",
        "source_ref"
      ],
      "properties": {
        "proposal_id": {
          "type": "string",
          "pattern": "^symbolic-interpretation-proposal-[a-f0-9]{16}$"
        },
        "personal_assistant_request_id": {
          "type": "string",
          "pattern": "^pa_request_[a-z0-9][a-z0-9_:-]*$"
        },
        "gateway_request_id": {
          "type": "string",
          "pattern": "^interpreted-request-[a-f0-9]{16}$"
        },
        "comparison_result": {
          "type": "string",
          "enum": [
            "matches_deterministic",
            "differs_from_deterministic",
            "rejected_before_comparison"
          ]
        },
        "validation_status": {
          "type": "string",
          "enum": [
            "accepted_as_proposal",
            "rejected"
          ]
        },
        "authority_level": {
          "type": "string",
          "const": "proposal_only"
        },
        "deterministic_override_allowed": {
          "type": "boolean",
          "const": false
        },
        "action_authority_granted": {
          "type": "boolean",
          "const": false
        },
        "execution_allowed": {
          "type": "boolean",
          "const": false
        },
        "private_payload_included": {
          "type": "boolean",
          "const": false
        },
        "secret_values_serialized": {
          "type": "boolean",
          "const": false
        },
        "source_ref": {
          "$ref": "#/$defs/repo_ref"
        }
      }
    },
    "clarification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "missing_binding_count",
        "reason_codes",
        "questions",
        "safe_default",
        "source_ref"
      ],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "missing_binding_count": {
          "type": "integer",
          "minimum": 0
        },
        "reason_codes": {
          "$ref": "#/$defs/text_array"
        },
        "questions": {
          "$ref": "#/$defs/text_array"
        },
        "safe_default": {
          "type": "string",
          "const": "no_execution"
        },
        "source_ref": {
          "$ref": "#/$defs/repo_ref"
        }
      }
    },
    "plan_preview": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "plan",
        "step_count",
        "actions_not_authorized",
        "source_ref"
      ],
      "properties": {
        "plan": {
          "type": "object"
        },
        "step_count": {
          "type": "integer",
          "minimum": 1
        },
        "actions_not_authorized": {
          "$ref": "#/$defs/text_array"
        },
        "source_ref": {
          "$ref": "#/$defs/repo_ref"
        }
      }
    },
    "approval_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "approval_required_for_p4_p5",
        "approval_id",
        "approval_state",
        "approval_is_execution",
        "execution_allowed",
        "external_send_allowed",
        "source_ref"
      ],
      "properties": {
        "approval_required_for_p4_p5": {
          "type": "boolean",
          "const": true
        },
        "approval_id": {
          "type": "string",
          "pattern": "^pa_approval_[a-z0-9][a-z0-9_:-]*$"
        },
        "approval_state": {
          "type": "string",
          "enum": [
            "requested",
            "approved",
            "rejected",
            "expired"
          ]
        },
        "approval_is_execution": {
          "type": "boolean",
          "const": false
        },
        "execution_allowed": {
          "type": "boolean",
          "const": false
        },
        "external_send_allowed": {
          "type": "boolean",
          "const": false
        },
        "source_ref": {
          "$ref": "#/$defs/repo_ref"
        }
      }
    },
    "receipt_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_required",
        "receipt_count",
        "actions_taken_recorded",
        "actions_not_taken_recorded",
        "success_claim_allowed",
        "source_ref"
      ],
      "properties": {
        "receipt_required": {
          "type": "boolean",
          "const": true
        },
        "receipt_count": {
          "type": "integer",
          "minimum": 1
        },
        "actions_taken_recorded": {
          "type": "boolean",
          "const": true
        },
        "actions_not_taken_recorded": {
          "type": "boolean",
          "const": true
        },
        "success_claim_allowed": {
          "type": "boolean",
          "const": false
        },
        "source_ref": {
          "$ref": "#/$defs/repo_ref"
        }
      }
    },
    "memory_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "memory_observation_allowed",
        "memory_write_allowed",
        "nested_mind_live_activation_allowed",
        "raw_chat_log_storage_allowed"
      ],
      "properties": {
        "memory_observation_allowed": {
          "type": "boolean"
        },
        "memory_write_allowed": {
          "type": "boolean",
          "const": false
        },
        "nested_mind_live_activation_allowed": {
          "type": "boolean",
          "const": false
        },
        "raw_chat_log_storage_allowed": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "effect_boundary": {
      "$ref": "#/$defs/effect_boundary"
    },
    "private_payload_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raw_private_payload_serialized",
        "secret_values_serialized",
        "connector_payload_projection",
        "body_projection"
      ],
      "properties": {
        "raw_private_payload_serialized": {
          "type": "boolean",
          "const": false
        },
        "secret_values_serialized": {
          "type": "boolean",
          "const": false
        },
        "connector_payload_projection": {
          "type": "string",
          "enum": [
            "digest_only",
            "ref_only",
            "redacted_summary",
            "public_only",
            "no_connector_payload"
          ]
        },
        "body_projection": {
          "type": "string",
          "enum": [
            "none",
            "digest_only",
            "redacted_summary",
            "operator_visible_draft"
          ]
        }
      }
    },
    "source_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_kind",
          "source_ref",
          "schema_ref",
          "payload_digest_only",
          "solver_outcome"
        ],
        "properties": {
          "source_kind": {
            "type": "string",
            "minLength": 1
          },
          "source_ref": {
            "$ref": "#/$defs/repo_ref"
          },
          "schema_ref": {
            "$ref": "#/$defs/repo_ref"
          },
          "payload_digest_only": {
            "type": "boolean",
            "const": true
          },
          "solver_outcome": {
            "$ref": "#/$defs/solver_outcome"
          }
        }
      }
    },
    "evidence_refs": {
      "$ref": "#/$defs/text_array"
    },
    "receipt_refs": {
      "$ref": "#/$defs/text_array"
    },
    "lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "accepted_deltas",
        "rejected_deltas"
      ],
      "properties": {
        "accepted_deltas": {
          "$ref": "#/$defs/lineage_delta_array"
        },
        "rejected_deltas": {
          "$ref": "#/$defs/lineage_delta_array"
        }
      }
    },
    "contract_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_artifact_count",
        "evidence_ref_count",
        "receipt_ref_count",
        "missing_binding_count",
        "plan_step_count",
        "read_model_projection_closed",
        "customer_readiness_claim_allowed",
        "deployment_mutation_allowed"
      ],
      "properties": {
        "source_artifact_count": {
          "type": "integer",
          "minimum": 1
        },
        "evidence_ref_count": {
          "type": "integer",
          "minimum": 1
        },
        "receipt_ref_count": {
          "type": "integer",
          "minimum": 1
        },
        "missing_binding_count": {
          "type": "integer",
          "minimum": 0
        },
        "plan_step_count": {
          "type": "integer",
          "minimum": 1
        },
        "read_model_projection_closed": {
          "type": "boolean",
          "const": true
        },
        "customer_readiness_claim_allowed": {
          "type": "boolean",
          "const": false
        },
        "deployment_mutation_allowed": {
          "type": "boolean",
          "const": false
        }
      }
    }
  },
  "$defs": {
    "effect_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "execution_allowed",
        "live_connector_execution_allowed",
        "connector_mutation_allowed",
        "mailbox_read_allowed",
        "mailbox_mutation_allowed",
        "external_send_allowed",
        "calendar_write_allowed",
        "task_write_allowed",
        "memory_write_allowed",
        "deployment_mutation_allowed",
        "customer_readiness_claim_allowed",
        "money_legal_public_action_allowed"
      ],
      "properties": {
        "execution_allowed": {
          "type": "boolean",
          "const": false
        },
        "live_connector_execution_allowed": {
          "type": "boolean",
          "const": false
        },
        "connector_mutation_allowed": {
          "type": "boolean",
          "const": false
        },
        "mailbox_read_allowed": {
          "type": "boolean",
          "const": false
        },
        "mailbox_mutation_allowed": {
          "type": "boolean",
          "const": false
        },
        "external_send_allowed": {
          "type": "boolean",
          "const": false
        },
        "calendar_write_allowed": {
          "type": "boolean",
          "const": false
        },
        "task_write_allowed": {
          "type": "boolean",
          "const": false
        },
        "memory_write_allowed": {
          "type": "boolean",
          "const": false
        },
        "deployment_mutation_allowed": {
          "type": "boolean",
          "const": false
        },
        "customer_readiness_claim_allowed": {
          "type": "boolean",
          "const": false
        },
        "money_legal_public_action_allowed": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "execution_mode": {
      "type": "string",
      "enum": [
        "dry_run",
        "preview",
        "draft",
        "execute_with_approval",
        "blocked",
        "read_and_draft_only"
      ]
    },
    "lineage_delta_array": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "delta_id",
          "logged_in_lineage",
          "reason"
        ],
        "properties": {
          "delta_id": {
            "type": "string",
            "minLength": 1
          },
          "logged_in_lineage": {
            "type": "boolean",
            "const": true
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "repo_ref": {
      "type": "string",
      "minLength": 1
    },
    "risk_level": {
      "type": "string",
      "enum": [
        "P0",
        "P1",
        "P2",
        "P3",
        "P4",
        "P5"
      ]
    },
    "solver_outcome": {
      "type": "string",
      "enum": [
        "SolvedVerified",
        "SolvedUnverified",
        "AwaitingEvidence",
        "SafeHalt",
        "GovernanceBlocked",
        "BudgetExhausted",
        "ImpossibleProved",
        "ModelInvalidated"
      ]
    },
    "text_array": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  }
}
