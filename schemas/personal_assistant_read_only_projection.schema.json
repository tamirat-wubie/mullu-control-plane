{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:personal-assistant-read-only-projection:1",
  "title": "Personal Assistant Read-Only Projection",
  "description": "Evidence envelope for redacted inbox and calendar summaries produced without live connector execution or mutation authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "projection_set_id",
    "generated_at",
    "governed",
    "source_projection",
    "projection_count",
    "projection_ids",
    "receipt_ids",
    "connectors_used",
    "projections",
    "effect_boundary",
    "private_payload_policy",
    "assurance",
    "metadata"
  ],
  "properties": {
    "projection_set_id": {
      "type": "string",
      "pattern": "^pa_read_only_projection_[a-z0-9][a-z0-9_:-]*$"
    },
    "generated_at": {"type": "string", "minLength": 1},
    "governed": {"const": true},
    "source_projection": {"const": "operator_supplied_redacted_projection"},
    "projection_count": {"type": "integer", "minimum": 1},
    "projection_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^pa_read_only_projection_item_[a-z0-9][a-z0-9_:-]*$"
      },
      "uniqueItems": true
    },
    "receipt_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^pa_receipt_[a-z0-9][a-z0-9_:-]*$"
      },
      "uniqueItems": true
    },
    "connectors_used": {
      "type": "array",
      "items": {"enum": ["gmail", "google_calendar"]},
      "uniqueItems": true
    },
    "projections": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/projection"}
    },
    "effect_boundary": {"$ref": "#/$defs/effect_boundary"},
    "private_payload_policy": {"$ref": "#/$defs/private_payload_policy"},
    "assurance": {"$ref": "#/$defs/assurance"},
    "metadata": {"$ref": "#/$defs/metadata"}
  },
  "$defs": {
    "projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "projection_id",
        "request_id",
        "skill_id",
        "summary_type",
        "summary",
        "receipt"
      ],
      "properties": {
        "projection_id": {
          "type": "string",
          "pattern": "^pa_read_only_projection_item_[a-z0-9][a-z0-9_:-]*$"
        },
        "request_id": {
          "type": "string",
          "pattern": "^pa_request_[a-z0-9][a-z0-9_:-]*$"
        },
        "skill_id": {
          "enum": ["email.inbox.summarize", "calendar.day.brief"]
        },
        "summary_type": {
          "enum": ["inbox_read_only", "calendar_day_read_only"]
        },
        "summary": {
          "type": "object",
          "additionalProperties": true,
          "required": ["summary_type", "effect_boundary"],
          "properties": {
            "summary_type": {
              "enum": ["inbox_read_only", "calendar_day_read_only"]
            },
            "effect_boundary": {
              "enum": [
                "read_only_no_mailbox_mutation",
                "read_only_no_calendar_mutation"
              ]
            }
          }
        },
        "receipt": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "effect_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "execution_allowed",
        "live_connector_execution_allowed",
        "mailbox_read_allowed",
        "mailbox_mutation_allowed",
        "external_send_allowed",
        "calendar_write_allowed",
        "task_write_allowed",
        "memory_write_allowed",
        "connector_mutation_allowed",
        "deployment_mutation_allowed",
        "public_readiness_claim_allowed"
      ],
      "properties": {
        "execution_allowed": {"const": false},
        "live_connector_execution_allowed": {"const": false},
        "mailbox_read_allowed": {"const": false},
        "mailbox_mutation_allowed": {"const": false},
        "external_send_allowed": {"const": false},
        "calendar_write_allowed": {"const": false},
        "task_write_allowed": {"const": false},
        "memory_write_allowed": {"const": false},
        "connector_mutation_allowed": {"const": false},
        "deployment_mutation_allowed": {"const": false},
        "public_readiness_claim_allowed": {"const": false}
      }
    },
    "private_payload_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raw_private_payload_serialized",
        "secret_values_serialized",
        "connector_payload_projection",
        "body_projection"
      ],
      "properties": {
        "raw_private_payload_serialized": {"const": false},
        "secret_values_serialized": {"const": false},
        "connector_payload_projection": {"const": "redacted_summary"},
        "body_projection": {"const": "redacted_summary"}
      }
    },
    "assurance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "assurance_id",
        "outcome",
        "foundation_only",
        "ready_for_live_execution",
        "ready_for_customer_readiness_claim",
        "authority_drift_detected",
        "checked_controls",
        "blocking_reasons",
        "next_action"
      ],
      "properties": {
        "assurance_id": {"const": "personal_assistant_read_only_projection_no_effect_assurance"},
        "outcome": {"enum": ["SolvedVerified", "GovernanceBlocked"]},
        "foundation_only": {"const": true},
        "ready_for_live_execution": {"const": false},
        "ready_for_customer_readiness_claim": {"const": false},
        "authority_drift_detected": {"type": "boolean"},
        "checked_controls": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "blocking_reasons": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "next_action": {"type": "string", "minLength": 1}
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "foundation_only",
        "projection_contract",
        "runtime_boundary",
        "live_connector_execution_allowed",
        "connector_mutation_allowed",
        "external_send_allowed",
        "system_of_record_write_allowed"
      ],
      "properties": {
        "foundation_only": {"const": true},
        "projection_contract": {"const": "read_only_redacted_evidence"},
        "runtime_boundary": {"const": "no_live_connector_calls"},
        "live_connector_execution_allowed": {"const": false},
        "connector_mutation_allowed": {"const": false},
        "external_send_allowed": {"const": false},
        "system_of_record_write_allowed": {"const": false}
      }
    }
  }
}
