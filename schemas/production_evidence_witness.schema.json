{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:production-evidence-witness:1",
  "title": "Production Evidence Witness",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "deployment_id",
    "commit_sha",
    "runtime_env",
    "version",
    "gateway_health",
    "api_health",
    "db_health",
    "policy_engine",
    "audit_store",
    "proof_store",
    "capability_evidence",
    "live_capabilities",
    "sandbox_only_capabilities",
    "checks",
    "checks_passed",
    "checks_missing",
    "runtime_conformance_certificate_id",
    "signed_at",
    "witness",
    "signature_key_id",
    "claim_hash",
    "signature"
  ],
  "properties": {
    "deployment_id": {
      "type": "string",
      "minLength": 1
    },
    "commit_sha": {
      "type": "string",
      "minLength": 1
    },
    "runtime_env": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "gateway_health": {
      "$ref": "#/$defs/pass_missing_status"
    },
    "api_health": {
      "$ref": "#/$defs/pass_missing_status"
    },
    "db_health": {
      "$ref": "#/$defs/pass_missing_status"
    },
    "policy_engine": {
      "$ref": "#/$defs/pass_missing_status"
    },
    "audit_store": {
      "$ref": "#/$defs/pass_missing_status"
    },
    "proof_store": {
      "$ref": "#/$defs/pass_missing_status"
    },
    "capability_evidence": {
      "$ref": "#/$defs/capability_evidence_map"
    },
    "live_capabilities": {
      "$ref": "#/$defs/capability_ids"
    },
    "sandbox_only_capabilities": {
      "$ref": "#/$defs/capability_ids"
    },
    "checks": {
      "$ref": "#/$defs/checks"
    },
    "checks_passed": {
      "$ref": "#/$defs/check_ids"
    },
    "checks_missing": {
      "$ref": "#/$defs/check_ids"
    },
    "runtime_conformance_certificate_id": {
      "type": "string"
    },
    "signed_at": {
      "type": "string",
      "minLength": 1
    },
    "witness": {
      "type": "string",
      "const": "mullu_gateway_production_evidence_v1"
    },
    "signature_key_id": {
      "type": "string",
      "minLength": 1
    },
    "claim_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "signature": {
      "type": "string",
      "pattern": "^hmac-sha256:[0-9a-f]{64}$"
    }
  },
  "$defs": {
    "pass_missing_status": {
      "type": "string",
      "enum": [
        "pass",
        "missing"
      ]
    },
    "capability_evidence_map": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/capability_evidence_value"
      }
    },
    "capability_evidence_value": {
      "oneOf": [
        {
          "$ref": "#/$defs/maturity_status"
        },
        {
          "$ref": "#/$defs/physical_live_safety_evidence"
        }
      ]
    },
    "maturity_status": {
      "type": "string",
      "enum": [
        "described_only",
        "tested",
        "sandbox",
        "pilot",
        "production"
      ]
    },
    "physical_live_safety_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "maturity",
        "effect_mode",
        "production_admissible",
        "physical_action_receipt_schema_ref",
        "physical_action_receipt_ref",
        "simulation_ref",
        "operator_approval_ref",
        "manual_override_ref",
        "emergency_stop_ref",
        "sensor_confirmation_ref",
        "deployment_witness_ref"
      ],
      "properties": {
        "maturity": {
          "type": "string",
          "const": "production"
        },
        "effect_mode": {
          "type": "string",
          "const": "live"
        },
        "production_admissible": {
          "type": "boolean",
          "const": true
        },
        "physical_action_receipt_schema_ref": {
          "type": "string",
          "const": "urn:mullusi:schema:physical-action-receipt:1"
        },
        "physical_action_receipt_ref": {
          "type": "string",
          "minLength": 1
        },
        "simulation_ref": {
          "type": "string",
          "minLength": 1
        },
        "operator_approval_ref": {
          "type": "string",
          "minLength": 1
        },
        "manual_override_ref": {
          "type": "string",
          "minLength": 1
        },
        "emergency_stop_ref": {
          "type": "string",
          "minLength": 1
        },
        "sensor_confirmation_ref": {
          "type": "string",
          "minLength": 1
        },
        "deployment_witness_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "capability_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "check_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "check_id",
          "passed",
          "detail"
        ],
        "properties": {
          "check_id": {
            "type": "string",
            "minLength": 1
          },
          "passed": {
            "type": "boolean"
          },
          "detail": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
