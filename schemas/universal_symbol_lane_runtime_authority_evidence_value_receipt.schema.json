{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:universal-symbol-lane-runtime-authority-evidence-value-receipt:1",
  "title": "Universal Symbol Lane Runtime Authority Evidence Value Receipt",
  "description": "Foundation Mode reference-value receipt for lane-level runtime authority evidence. This receipt records operator-supplied evidence refs for lane approval, receipt-store authority, recovery, audit, live runtime witness, and blocked-action evidence while denying lane authority, runtime admission, dispatch, connector calls, writes, receipt append, mutation, terminal closure, and production readiness.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receipt_id",
    "schema_version",
    "generated_at",
    "receipt_scope",
    "solver_outcome",
    "foundation_mode",
    "value_receipt_decision",
    "receipt_is_not_lane_authority",
    "value_subject",
    "lane_value_items",
    "evidence_value_constraints",
    "authority_denials",
    "rejection_policy",
    "blocked_reasons",
    "next_actions",
    "evidence_refs",
    "contract_summary"
  ],
  "properties": {
    "receipt_id": {
      "type": "string",
      "const": "universal-symbol-lane-runtime-authority-evidence-value-receipt-foundation"
    },
    "schema_version": { "type": "integer", "const": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "receipt_scope": {
      "type": "string",
      "const": "foundation-mode-universal-symbol-lane-runtime-authority-evidence-values"
    },
    "solver_outcome": { "type": "string", "const": "AwaitingEvidence" },
    "foundation_mode": { "type": "boolean", "const": true },
    "value_receipt_decision": {
      "type": "string",
      "const": "blocked_pending_lane_evidence_value_verification_runtime_authority_and_admission"
    },
    "receipt_is_not_lane_authority": { "type": "boolean", "const": true },
    "value_subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lane_runtime_authority_evidence_receipt_ref",
        "skill_runtime_authority_witness_ref",
        "runtime_live_witness_input_receipt_ref",
        "value_scope"
      ],
      "properties": {
        "lane_runtime_authority_evidence_receipt_ref": { "$ref": "#/$defs/ref" },
        "skill_runtime_authority_witness_ref": { "$ref": "#/$defs/ref" },
        "runtime_live_witness_input_receipt_ref": { "$ref": "#/$defs/ref" },
        "value_scope": { "type": "string", "const": "lane-runtime-authority-evidence-refs-only" }
      }
    },
    "lane_value_items": {
      "type": "array",
      "minItems": 24,
      "maxItems": 24,
      "items": { "$ref": "#/$defs/lane_value_item" }
    },
    "evidence_value_constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ref_only_input_required",
        "raw_evidence_value_storage_forbidden",
        "operator_supplied_refs_are_not_authority",
        "all_lanes_require_all_value_kinds",
        "live_runtime_witness_still_required",
        "receipt_store_authority_still_required",
        "audit_and_recovery_still_required",
        "terminal_closure_denial_required"
      ],
      "properties": {
        "ref_only_input_required": { "type": "boolean", "const": true },
        "raw_evidence_value_storage_forbidden": { "type": "boolean", "const": true },
        "operator_supplied_refs_are_not_authority": { "type": "boolean", "const": true },
        "all_lanes_require_all_value_kinds": { "type": "boolean", "const": true },
        "live_runtime_witness_still_required": { "type": "boolean", "const": true },
        "receipt_store_authority_still_required": { "type": "boolean", "const": true },
        "audit_and_recovery_still_required": { "type": "boolean", "const": true },
        "terminal_closure_denial_required": { "type": "boolean", "const": true }
      }
    },
    "authority_denials": { "$ref": "#/$defs/authority_denials" },
    "rejection_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "missing_lane_value_blocks_lane_authority",
        "unverified_value_ref_blocks_lane_authority",
        "raw_value_payload_blocks_receipt",
        "missing_receipt_store_authority_blocks_lane_authority",
        "missing_recovery_or_audit_blocks_lane_authority",
        "unknown_hard_constraint_blocks_lane_authority",
        "failed_precondition_logs_delta_reject"
      ],
      "properties": {
        "missing_lane_value_blocks_lane_authority": { "type": "boolean", "const": true },
        "unverified_value_ref_blocks_lane_authority": { "type": "boolean", "const": true },
        "raw_value_payload_blocks_receipt": { "type": "boolean", "const": true },
        "missing_receipt_store_authority_blocks_lane_authority": { "type": "boolean", "const": true },
        "missing_recovery_or_audit_blocks_lane_authority": { "type": "boolean", "const": true },
        "unknown_hard_constraint_blocks_lane_authority": { "type": "boolean", "const": true },
        "failed_precondition_logs_delta_reject": { "type": "boolean", "const": true }
      }
    },
    "blocked_reasons": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "string",
        "enum": [
          "lane_evidence_values_unverified",
          "operator_approval_value_not_authority",
          "receipt_store_authority_value_not_authority",
          "recovery_value_not_execution",
          "audit_value_not_closure",
          "live_runtime_witness_value_not_acceptance",
          "blocked_action_refs_not_terminal_closure",
          "lane_runtime_authority_forbidden",
          "runtime_admission_forbidden",
          "terminal_closure_not_allowed"
        ]
      },
      "uniqueItems": true
    },
    "next_actions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/ref" },
      "uniqueItems": true
    },
    "contract_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lane_count",
        "evidence_value_kind_count",
        "evidence_value_item_count",
        "evidence_value_constraint_count",
        "authority_denial_count",
        "rejection_check_count",
        "blocked_reason_count",
        "evidence_ref_count"
      ],
      "properties": {
        "lane_count": { "type": "integer", "const": 4 },
        "evidence_value_kind_count": { "type": "integer", "const": 6 },
        "evidence_value_item_count": { "type": "integer", "const": 24 },
        "evidence_value_constraint_count": { "type": "integer", "const": 8 },
        "authority_denial_count": { "type": "integer", "const": 13 },
        "rejection_check_count": { "type": "integer", "const": 7 },
        "blocked_reason_count": { "type": "integer", "minimum": 8 },
        "evidence_ref_count": { "type": "integer", "minimum": 1 }
      }
    }
  },
  "$defs": {
    "ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/#-]*$"
    },
    "lane_value_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value_id",
        "lane_ref",
        "symbol_kind",
        "evidence_kind",
        "proof_state",
        "supplied_evidence_ref",
        "value_state",
        "current_decision",
        "delta_reject_ref"
      ],
      "properties": {
        "value_id": { "$ref": "#/$defs/ref" },
        "lane_ref": {
          "type": "string",
          "enum": [
            "skill://teamops-shared-inbox",
            "skill://software-dev",
            "component://governance-core",
            "receipt://worker-ledger"
          ]
        },
        "symbol_kind": { "type": "string", "enum": ["skill", "component", "receipt"] },
        "evidence_kind": {
          "type": "string",
          "enum": [
            "operator_approval",
            "receipt_store_authority",
            "recovery_evidence",
            "audit_receipt",
            "live_runtime_witness",
            "blocked_action_refs"
          ]
        },
        "proof_state": { "type": "string", "enum": ["Unknown", "BudgetUnknown", "Fail"] },
        "supplied_evidence_ref": { "$ref": "#/$defs/ref" },
        "value_state": { "type": "string", "const": "operator_reference_recorded_not_verified" },
        "current_decision": { "type": "string", "const": "lane_runtime_authority_blocked" },
        "delta_reject_ref": { "$ref": "#/$defs/ref" }
      }
    },
    "authority_denials": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lane_runtime_authority_granted",
        "runtime_admission_granted",
        "runtime_registration_performed",
        "skill_admission_recorded",
        "live_dispatch_enabled",
        "connector_call_enabled",
        "filesystem_write_enabled",
        "external_write_enabled",
        "receipt_store_append_enabled",
        "raw_payload_stored",
        "raw_secret_stored",
        "state_mutation_performed",
        "terminal_closure_allowed"
      ],
      "properties": {
        "lane_runtime_authority_granted": { "type": "boolean", "const": false },
        "runtime_admission_granted": { "type": "boolean", "const": false },
        "runtime_registration_performed": { "type": "boolean", "const": false },
        "skill_admission_recorded": { "type": "boolean", "const": false },
        "live_dispatch_enabled": { "type": "boolean", "const": false },
        "connector_call_enabled": { "type": "boolean", "const": false },
        "filesystem_write_enabled": { "type": "boolean", "const": false },
        "external_write_enabled": { "type": "boolean", "const": false },
        "receipt_store_append_enabled": { "type": "boolean", "const": false },
        "raw_payload_stored": { "type": "boolean", "const": false },
        "raw_secret_stored": { "type": "boolean", "const": false },
        "state_mutation_performed": { "type": "boolean", "const": false },
        "terminal_closure_allowed": { "type": "boolean", "const": false }
      }
    }
  }
}
