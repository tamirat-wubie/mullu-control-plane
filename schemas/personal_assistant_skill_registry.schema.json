{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:personal-assistant-skill-registry:1",
  "title": "Personal Assistant Skill Registry",
  "description": "Registry wrapper for governed Personal Assistant skills.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "registry_id", "skills"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "personal_assistant.skill_registry.v1"
    },
    "registry_id": {
      "type": "string",
      "pattern": "^personal_assistant_skill_registry\\.[a-z0-9_.-]+$"
    },
    "skills": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["skill_id", "mode", "risk_level", "effect_boundary"],
        "properties": {
          "skill_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*(\\.[a-z0-9_]+)+$"
          },
          "mode": {
            "type": "string",
            "enum": ["read_only", "draft_only", "planning_only", "approval_required", "blocked"]
          },
          "risk_level": {
            "type": "string",
            "enum": ["P0", "P1", "P2", "P3", "P4", "P5"]
          },
          "effect_boundary": {
            "type": "object"
          }
        }
      }
    }
  }
}
