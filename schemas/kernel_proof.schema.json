{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:mullu-truth-kernel:kernel-proof:1",
  "title": "Mullu Truth Kernel Proof",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "proof_id",
    "tenant_id",
    "proof_kind",
    "proof_state",
    "result_kind",
    "kernel_signature",
    "subject_ref",
    "generated_at",
    "premises",
    "derivation_steps",
    "conclusion",
    "witness_refs",
    "replay",
    "budget",
    "limitations",
    "proof_hash"
  ],
  "properties": {
    "proof_id": {"type": "string", "minLength": 1},
    "tenant_id": {"type": "string", "minLength": 1},
    "proof_kind": {"$ref": "#/$defs/proof_kind"},
    "proof_state": {"$ref": "#/$defs/proof_state"},
    "result_kind": {"$ref": "#/$defs/result_kind"},
    "kernel_signature": {"type": "string", "minLength": 1},
    "subject_ref": {"type": "string", "minLength": 1},
    "generated_at": {"type": "string", "format": "date-time"},
    "premises": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/proof_premise"}
    },
    "derivation_steps": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/derivation_step"}
    },
    "conclusion": {"$ref": "#/$defs/proof_conclusion"},
    "witness_refs": {"$ref": "#/$defs/non_empty_string_array"},
    "replay": {"$ref": "#/$defs/replay_binding"},
    "budget": {"$ref": "#/$defs/proof_budget"},
    "limitations": {"$ref": "#/$defs/string_array"},
    "proof_hash": {"type": "string", "minLength": 1},
    "metadata": {"type": "object", "additionalProperties": true}
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "conclusion": {
            "properties": {
              "supports_truth_mutation": {"const": true}
            },
            "required": ["supports_truth_mutation"]
          }
        },
        "required": ["conclusion"]
      },
      "then": {
        "properties": {
          "proof_state": {"const": "Pass"},
          "result_kind": {"const": "ExactResult"}
        }
      }
    }
  ],
  "$defs": {
    "proof_kind": {
      "type": "string",
      "enum": [
        "ValidityProof",
        "InvalidityProof",
        "ProjectionProof",
        "ForcedValueProof",
        "ContradictionProof",
        "RepairProof",
        "CommitProof"
      ]
    },
    "proof_state": {
      "type": "string",
      "enum": ["Pass", "Fail", "Unknown", "BudgetUnknown"]
    },
    "result_kind": {
      "type": "string",
      "enum": [
        "ExactResult",
        "BoundedResult",
        "ApproximateResult",
        "UnknownResult",
        "ContradictionResult",
        "BudgetExceededResult"
      ]
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "string_array": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "proof_premise": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "premise_id",
        "premise_kind",
        "source_ref",
        "statement"
      ],
      "properties": {
        "premise_id": {"type": "string", "minLength": 1},
        "premise_kind": {
          "type": "string",
          "enum": ["domain", "constraint", "closure", "propagation", "witness", "governance"]
        },
        "source_ref": {"type": "string", "minLength": 1},
        "statement": {"type": "string", "minLength": 1}
      }
    },
    "derivation_step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step_id",
        "rule_ref",
        "input_refs",
        "output_statement"
      ],
      "properties": {
        "step_id": {"type": "string", "minLength": 1},
        "rule_ref": {"type": "string", "minLength": 1},
        "input_refs": {"$ref": "#/$defs/non_empty_string_array"},
        "output_statement": {"type": "string", "minLength": 1}
      }
    },
    "proof_conclusion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "statement",
        "supports_truth_mutation",
        "required_next_action"
      ],
      "properties": {
        "statement": {"type": "string", "minLength": 1},
        "supports_truth_mutation": {"type": "boolean"},
        "required_next_action": {
          "type": "string",
          "enum": ["commit_candidate", "block_action", "plan_sensing", "record_only"]
        }
      }
    },
    "replay_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "replay_mode",
        "deterministic",
        "source_hash",
        "expected_hash",
        "reason_codes"
      ],
      "properties": {
        "replay_mode": {
          "type": "string",
          "enum": ["observation_only", "effect_bearing"]
        },
        "deterministic": {"type": "boolean"},
        "source_hash": {"type": "string", "minLength": 1},
        "expected_hash": {"type": "string", "minLength": 1},
        "reason_codes": {"$ref": "#/$defs/string_array"}
      }
    },
    "proof_budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "budget_id",
        "limit",
        "used",
        "unit"
      ],
      "properties": {
        "budget_id": {"type": "string", "minLength": 1},
        "limit": {"type": "integer", "minimum": 0},
        "used": {"type": "integer", "minimum": 0},
        "unit": {
          "type": "string",
          "enum": ["steps", "milliseconds", "nodes", "checks"]
        }
      }
    }
  }
}
