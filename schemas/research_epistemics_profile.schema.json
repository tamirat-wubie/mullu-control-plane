{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:research-epistemics-profile:1",
  "title": "Research Epistemics Profile v1",
  "description": "Foundation Mode, no-effect contract separating factual evaluation from action governance before any research-runtime expansion.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "profile_id",
    "profile_version",
    "generated_at",
    "maturity",
    "operating_mode",
    "canonical_names",
    "mcoi_research_tuple",
    "compatibility",
    "epistemic_contract",
    "authority_boundary",
    "next_gate",
    "evidence_refs"
  ],
  "properties": {
    "profile_id": {"type": "string", "minLength": 1},
    "profile_version": {"const": "research_epistemics_profile.v1"},
    "generated_at": {"type": "string", "format": "date-time"},
    "maturity": {"const": "specified"},
    "operating_mode": {"const": "foundation_no_effect"},
    "canonical_names": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "public_capability",
        "internal_architecture",
        "epistemic_configuration",
        "workflow_runtime",
        "legacy_migration_name",
        "legacy_migration_status"
      ],
      "properties": {
        "public_capability": {"const": "Mullu Govern Research"},
        "internal_architecture": {"const": "MCOI Governed Research Architecture"},
        "epistemic_configuration": {"const": "Research Epistemics Profile v1"},
        "workflow_runtime": {"const": "ResearchRuntimeEngine"},
        "legacy_migration_name": {"const": "WRE-A2"},
        "legacy_migration_status": {"const": "legacy_reference_only"}
      }
    },
    "mcoi_research_tuple": {
      "type": "object",
      "additionalProperties": false,
      "required": ["symbol", "G", "Q", "E", "W", "V", "M", "A", "H"],
      "properties": {
        "symbol": {"const": "R_MCOI"},
        "G": {"const": "governance"},
        "Q": {"const": "question_and_scope"},
        "E": {"const": "epistemics_and_evidence"},
        "W": {"const": "workflow_and_convergence"},
        "V": {"const": "validation"},
        "M": {"const": "memory_and_revision"},
        "A": {"const": "authority_and_effect_boundary"},
        "H": {"const": "provenance_and_causal_history"}
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "whqr_contract_ref",
        "claim_verification_ref",
        "universal_evidence_graph_ref",
        "research_runtime_ref",
        "memory_mesh_ref",
        "source_conflict_map_ref",
        "truth_kernel_ref"
      ],
      "properties": {
        "whqr_contract_ref": {"type": "string", "minLength": 1},
        "claim_verification_ref": {"type": "string", "minLength": 1},
        "universal_evidence_graph_ref": {"type": "string", "minLength": 1},
        "research_runtime_ref": {"type": "string", "minLength": 1},
        "memory_mesh_ref": {"type": "string", "minLength": 1},
        "source_conflict_map_ref": {"type": "string", "minLength": 1},
        "truth_kernel_ref": {"type": "string", "minLength": 1}
      }
    },
    "epistemic_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "truth_action_separation",
        "claim_kind_separation",
        "epistemic_claim_types",
        "confidence_dimensions",
        "scalar_confidence_projection_allowed",
        "scalar_confidence_is_canonical",
        "dispositions",
        "abstention_record_fields",
        "source_lineage_record_fields",
        "source_identity_independence_rule",
        "contradiction_record_fields",
        "contradiction_classes",
        "failed_experiment_is_factual_contradiction",
        "contradiction_preservation",
        "abstention_required",
        "source_lineage_required",
        "truth_kernel_auto_promotion"
      ],
      "properties": {
        "truth_action_separation": {"const": true},
        "claim_kind_separation": {"const": true},
        "epistemic_claim_types": {
          "type": "array",
          "minItems": 7,
          "uniqueItems": true,
          "items": {
            "enum": [
              "EMPIRICAL",
              "CAUSAL",
              "PREDICTIVE",
              "HISTORICAL",
              "NORMATIVE",
              "ONTOLOGICAL",
              "SYMBOLIC_STRUCTURAL"
            ]
          }
        },
        "confidence_dimensions": {
          "type": "array",
          "minItems": 7,
          "uniqueItems": true,
          "items": {
            "enum": [
              "evidential",
              "logical",
              "provenance",
              "empirical",
              "temporal_applicability",
              "calibration",
              "action_safety"
            ]
          }
        },
        "scalar_confidence_projection_allowed": {"const": true},
        "scalar_confidence_is_canonical": {"const": false},
        "dispositions": {
          "type": "array",
          "minItems": 8,
          "uniqueItems": true,
          "items": {
            "enum": [
              "VALIDATED_CONCLUSION",
              "SUPPORTED_HYPOTHESIS",
              "SPECULATIVE_HYPOTHESIS",
              "COMPETING_MODEL",
              "UNRESOLVED_CONTRADICTION",
              "PARTIAL_RESULT",
              "ABSTENTION",
              "SAFETY_ESCALATION"
            ]
          }
        },
        "abstention_record_fields": {
          "type": "array",
          "minItems": 5,
          "uniqueItems": true,
          "items": {
            "enum": [
              "blocked_claim_ref",
              "reason",
              "missing_requirements",
              "safe_partial_result_refs",
              "required_next_evidence"
            ]
          }
        },
        "source_lineage_record_fields": {
          "type": "array",
          "minItems": 8,
          "uniqueItems": true,
          "items": {
            "enum": [
              "source_id",
              "origin_digest",
              "parent_source_refs",
              "citation_ancestry",
              "derivative_status",
              "independence_group",
              "retrieved_at",
              "integrity_status"
            ]
          }
        },
        "source_identity_independence_rule": {
          "const": "distinct_source_ids_do_not_prove_independent_origin"
        },
        "contradiction_record_fields": {
          "type": "array",
          "minItems": 9,
          "uniqueItems": true,
          "items": {
            "enum": [
              "contradiction_id",
              "claim_refs",
              "contradiction_class",
              "scope_overlap",
              "temporal_overlap",
              "severity",
              "cause_candidates",
              "resolution_attempts",
              "branch_status"
            ]
          }
        },
        "contradiction_classes": {
          "type": "array",
          "minItems": 10,
          "uniqueItems": true,
          "items": {
            "enum": [
              "FACTUAL",
              "DEFINITIONAL",
              "TEMPORAL",
              "SCOPE",
              "METHODOLOGICAL",
              "STATISTICAL",
              "ONTOLOGICAL",
              "NORMATIVE",
              "MODEL_DEPENDENT",
              "EXECUTION_FAILURE"
            ]
          }
        },
        "failed_experiment_is_factual_contradiction": {"const": false},
        "contradiction_preservation": {"const": true},
        "abstention_required": {"const": true},
        "source_lineage_required": {"const": true},
        "truth_kernel_auto_promotion": {"const": false}
      }
    },
    "authority_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime_research_execution_allowed",
        "external_retrieval_allowed",
        "connector_calls_allowed",
        "answer_synthesis_authority",
        "memory_write_allowed",
        "truth_mutation_allowed",
        "publication_allowed",
        "medical_decision_authority",
        "autonomous_self_modification_allowed"
      ],
      "properties": {
        "runtime_research_execution_allowed": {"const": false},
        "external_retrieval_allowed": {"const": false},
        "connector_calls_allowed": {"const": false},
        "answer_synthesis_authority": {"const": false},
        "memory_write_allowed": {"const": false},
        "truth_mutation_allowed": {"const": false},
        "publication_allowed": {"const": false},
        "medical_decision_authority": {"const": false},
        "autonomous_self_modification_allowed": {"const": false}
      }
    },
    "next_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["prerequisite", "runtime_contracts_allowed", "operator_review_required"],
      "properties": {
        "prerequisite": {"const": "cdg_rccm_stable_and_operator_reviewed"},
        "runtime_contracts_allowed": {"const": false},
        "operator_review_required": {"const": true}
      }
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 5,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    }
  }
}
