{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:agentic-service-harness-dry-run-test-runner-plan-receipt:1",
  "title": "Agentic Service Harness Dry Run Test Runner Plan Receipt",
  "description": "Foundation Mode plan-only receipt for selected harness validator and pytest commands. This schema records intended command selection only and does not execute commands, run tests, write files, append receipt stores, call connectors, serialize secrets, claim results, or issue terminal closure.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "report_id",
    "schema_version",
    "generated_at",
    "solver_outcome",
    "plan_status",
    "source_contract_refs",
    "scope",
    "test_plan",
    "authority_denials",
    "required_evidence",
    "receipt_refs",
    "validators",
    "next_action",
    "report_is_not_terminal_closure",
    "terminal_closure_required"
  ],
  "properties": {
    "report_id": {
      "type": "string",
      "const": "agentic_service_harness_dry_run_test_runner_plan_receipt"
    },
    "schema_version": { "type": "integer", "const": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "solver_outcome": { "type": "string", "const": "SolvedVerified" },
    "plan_status": { "type": "string", "const": "AwaitingEvidence" },
    "source_contract_refs": {
      "type": "array",
      "minItems": 4,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/evidence_ref" }
    },
    "scope": { "$ref": "#/$defs/scope" },
    "test_plan": { "$ref": "#/$defs/test_plan" },
    "authority_denials": { "$ref": "#/$defs/authority_denials" },
    "required_evidence": { "$ref": "#/$defs/required_evidence" },
    "receipt_refs": { "$ref": "#/$defs/receipt_refs" },
    "validators": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/validator_ref" }
    },
    "next_action": { "type": "string", "minLength": 1 },
    "report_is_not_terminal_closure": { "type": "boolean", "const": true },
    "terminal_closure_required": { "type": "boolean", "const": true }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "evidence_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/#$-]*$"
    },
    "evidence_ref_list": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/evidence_ref" }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tenant_id",
        "organization_id",
        "project_id",
        "repository_connection_id",
        "repository_slug",
        "approved_branch_workspace_preflight_id",
        "foundation_phase",
        "plan_only",
        "read_only_sources",
        "test_execution_admitted",
        "commands_executed",
        "test_results_claimed",
        "coverage_claimed",
        "secret_values_serialized"
      ],
      "properties": {
        "tenant_id": { "$ref": "#/$defs/identifier" },
        "organization_id": { "$ref": "#/$defs/identifier" },
        "project_id": { "$ref": "#/$defs/identifier" },
        "repository_connection_id": { "$ref": "#/$defs/identifier" },
        "repository_slug": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
        },
        "approved_branch_workspace_preflight_id": { "$ref": "#/$defs/identifier" },
        "foundation_phase": {
          "type": "string",
          "const": "foundation_dry_run_test_runner_plan_receipt"
        },
        "plan_only": { "type": "boolean", "const": true },
        "read_only_sources": { "type": "boolean", "const": true },
        "test_execution_admitted": { "type": "boolean", "const": false },
        "commands_executed": { "type": "boolean", "const": false },
        "test_results_claimed": { "type": "boolean", "const": false },
        "coverage_claimed": { "type": "boolean", "const": false },
        "secret_values_serialized": { "type": "boolean", "const": false }
      }
    },
    "test_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "plan_id",
        "execution_mode",
        "selected_commands",
        "selection_reason_refs",
        "command_execution_enabled",
        "subprocess_execution_enabled",
        "test_result_claim_enabled",
        "coverage_claim_enabled"
      ],
      "properties": {
        "plan_id": {
          "type": "string",
          "const": "dry-run-test-runner-plan-foundation"
        },
        "execution_mode": {
          "type": "string",
          "const": "PLAN_ONLY"
        },
        "selected_commands": {
          "type": "array",
          "minItems": 4,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/selected_command" }
        },
        "selection_reason_refs": { "$ref": "#/$defs/evidence_ref_list" },
        "command_execution_enabled": { "type": "boolean", "const": false },
        "subprocess_execution_enabled": { "type": "boolean", "const": false },
        "test_result_claim_enabled": { "type": "boolean", "const": false },
        "coverage_claim_enabled": { "type": "boolean", "const": false }
      }
    },
    "selected_command": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command_id",
        "command",
        "command_class",
        "path_scope",
        "reason",
        "expected_result"
      ],
      "properties": {
        "command_id": { "$ref": "#/$defs/identifier" },
        "command": { "type": "string", "minLength": 1 },
        "command_class": {
          "type": "string",
          "enum": ["validator", "pytest"]
        },
        "path_scope": {
          "type": "string",
          "enum": ["repository_local", "tests_only"]
        },
        "reason": { "type": "string", "minLength": 1 },
        "expected_result": {
          "type": "string",
          "const": "planned_only_no_result_claim"
        }
      }
    },
    "authority_denials": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "test_execution_enabled",
        "command_execution_enabled",
        "subprocess_execution_enabled",
        "filesystem_write_enabled",
        "branch_write_enabled",
        "pull_request_creation_enabled",
        "adapter_execution_enabled",
        "connector_calls_enabled",
        "receipt_store_append_enabled",
        "runtime_state_write_enabled",
        "mutation_route_enabled",
        "secret_values_serialized",
        "terminal_closure",
        "default_high_risk_authority"
      ],
      "properties": {
        "test_execution_enabled": { "type": "boolean", "const": false },
        "command_execution_enabled": { "type": "boolean", "const": false },
        "subprocess_execution_enabled": { "type": "boolean", "const": false },
        "filesystem_write_enabled": { "type": "boolean", "const": false },
        "branch_write_enabled": { "type": "boolean", "const": false },
        "pull_request_creation_enabled": { "type": "boolean", "const": false },
        "adapter_execution_enabled": { "type": "boolean", "const": false },
        "connector_calls_enabled": { "type": "boolean", "const": false },
        "receipt_store_append_enabled": { "type": "boolean", "const": false },
        "runtime_state_write_enabled": { "type": "boolean", "const": false },
        "mutation_route_enabled": { "type": "boolean", "const": false },
        "secret_values_serialized": { "type": "boolean", "const": false },
        "terminal_closure": { "type": "boolean", "const": false },
        "default_high_risk_authority": { "type": "boolean", "const": false }
      }
    },
    "required_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "must_have_before_command_execution",
        "must_have_before_test_result_claim",
        "must_have_before_receipt_append"
      ],
      "properties": {
        "must_have_before_command_execution": { "$ref": "#/$defs/evidence_ref_list" },
        "must_have_before_test_result_claim": { "$ref": "#/$defs/evidence_ref_list" },
        "must_have_before_receipt_append": { "$ref": "#/$defs/evidence_ref_list" }
      }
    },
    "receipt_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dry_run_test_runner_plan_receipt_schema",
        "dry_run_test_runner_plan_receipt_example",
        "approved_branch_workspace_creation_preflight_schema",
        "approved_branch_workspace_creation_preflight_example",
        "readiness_map"
      ],
      "properties": {
        "dry_run_test_runner_plan_receipt_schema": {
          "type": "string",
          "const": "schemas/agentic_service_harness_dry_run_test_runner_plan_receipt.schema.json"
        },
        "dry_run_test_runner_plan_receipt_example": {
          "type": "string",
          "const": "examples/agentic_service_harness_dry_run_test_runner_plan_receipt.foundation.json"
        },
        "approved_branch_workspace_creation_preflight_schema": {
          "type": "string",
          "const": "schemas/agentic_service_harness_approved_branch_workspace_creation_preflight.schema.json"
        },
        "approved_branch_workspace_creation_preflight_example": {
          "type": "string",
          "const": "examples/agentic_service_harness_approved_branch_workspace_creation_preflight.foundation.json"
        },
        "readiness_map": {
          "type": "string",
          "const": "MULLUSI_AGENTIC_SERVICE_HARNESS_READINESS_MAP.md"
        }
      }
    },
    "validator_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "validator_id",
        "command",
        "required_for_closure"
      ],
      "properties": {
        "validator_id": { "$ref": "#/$defs/identifier" },
        "command": { "type": "string", "minLength": 1 },
        "required_for_closure": { "type": "boolean", "const": true }
      }
    }
  }
}
