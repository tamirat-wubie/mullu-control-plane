{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:universal-symbol-receipt-store-authority-witness:1",
  "title": "Universal Symbol Receipt Store Authority Witness",
  "description": "Foundation Mode witness for UniversalSymbol receipt-store authority. This witness defines the future append authority requirements, including operator identity, approval decision, lifecycle evidence, lifecycle audit, and replacement-decision contracts, while denying writer registration, append, raw payload storage, raw secret storage, runtime dispatch, connector calls, filesystem writes, state mutation, terminal closure, and production readiness.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "witness_id",
    "schema_version",
    "generated_at",
    "witness_scope",
    "solver_outcome",
    "foundation_mode",
    "authority_decision",
    "authority_is_granted",
    "authority_requirements",
    "authority_denials",
    "append_preconditions",
    "rejection_policy",
    "blocked_reasons",
    "next_actions",
    "evidence_refs",
    "contract_summary"
  ],
  "properties": {
    "witness_id": { "type": "string", "const": "universal-symbol-receipt-store-authority-witness-foundation" },
    "schema_version": { "type": "integer", "const": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "witness_scope": { "type": "string", "const": "foundation-mode-universal-symbol-receipt-store-authority" },
    "solver_outcome": { "type": "string", "const": "AwaitingEvidence" },
    "foundation_mode": { "type": "boolean", "const": true },
    "authority_decision": { "type": "string", "const": "blocked_pending_append_audit_and_store_authority" },
    "authority_is_granted": { "type": "boolean", "const": false },
    "authority_requirements": {
      "type": "array",
      "minItems": 14,
      "items": { "$ref": "#/$defs/authority_requirement" },
      "uniqueItems": true
    },
    "authority_denials": { "$ref": "#/$defs/authority_denials" },
    "append_preconditions": {
      "type": "array",
      "minItems": 14,
      "items": { "$ref": "#/$defs/append_precondition" },
      "uniqueItems": true
    },
    "rejection_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "unknown_hard_constraint_blocks_append",
        "budget_unknown_escalates_to_phi_gov",
        "failed_precondition_logs_delta_reject",
        "raw_payload_rejected",
        "raw_secret_rejected",
        "terminal_closure_rejected"
      ],
      "properties": {
        "unknown_hard_constraint_blocks_append": { "type": "boolean", "const": true },
        "budget_unknown_escalates_to_phi_gov": { "type": "boolean", "const": true },
        "failed_precondition_logs_delta_reject": { "type": "boolean", "const": true },
        "raw_payload_rejected": { "type": "boolean", "const": true },
        "raw_secret_rejected": { "type": "boolean", "const": true },
        "terminal_closure_rejected": { "type": "boolean", "const": true }
      }
    },
    "blocked_reasons": {
      "type": "array",
      "minItems": 6,
      "items": {
        "type": "string",
        "enum": [
          "append_audit_witness_not_admitted",
          "receipt_store_writer_registration_missing",
          "receipt_store_write_path_missing",
          "operator_approval_missing",
          "operator_identity_missing",
          "operator_approval_decision_missing",
          "operator_reapproval_expiry_missing",
          "operator_revocation_missing",
          "lifecycle_evidence_receipt_missing",
          "lifecycle_audit_receipt_missing",
          "replacement_decision_receipt_missing",
          "rollback_recovery_witness_missing",
          "idempotency_witness_missing",
          "durability_replay_witness_missing",
          "raw_payload_storage_forbidden",
          "raw_secret_storage_forbidden",
          "terminal_closure_not_allowed"
        ]
      },
      "uniqueItems": true
    },
    "next_actions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/ref" },
      "uniqueItems": true
    },
    "contract_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "authority_requirement_count",
        "authority_denial_count",
        "append_precondition_count",
        "rejection_check_count",
        "blocked_reason_count",
        "evidence_ref_count"
      ],
      "properties": {
        "authority_requirement_count": { "type": "integer", "minimum": 14 },
        "authority_denial_count": { "type": "integer", "const": 10 },
        "append_precondition_count": { "type": "integer", "minimum": 14 },
        "rejection_check_count": { "type": "integer", "const": 6 },
        "blocked_reason_count": { "type": "integer", "minimum": 6 },
        "evidence_ref_count": { "type": "integer", "minimum": 1 }
      }
    }
  },
  "$defs": {
    "ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/#-]*$"
    },
    "authority_requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requirement_id",
        "proof_state",
        "required_evidence_ref",
        "current_decision"
      ],
      "properties": {
        "requirement_id": { "$ref": "#/$defs/ref" },
        "proof_state": { "type": "string", "enum": ["Unknown", "BudgetUnknown", "Fail"] },
        "required_evidence_ref": { "$ref": "#/$defs/ref" },
        "current_decision": { "type": "string", "const": "authority_blocked" }
      }
    },
    "append_precondition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "precondition_id",
        "proof_state",
        "append_decision",
        "delta_reject_ref"
      ],
      "properties": {
        "precondition_id": { "$ref": "#/$defs/ref" },
        "proof_state": { "type": "string", "enum": ["Unknown", "BudgetUnknown", "Fail"] },
        "append_decision": { "type": "string", "const": "block_append" },
        "delta_reject_ref": { "$ref": "#/$defs/ref" }
      }
    },
    "authority_denials": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_store_authority_granted",
        "receipt_store_writer_registered",
        "receipt_store_write_path_registered",
        "receipt_store_append_performed",
        "raw_payload_stored",
        "raw_secret_stored",
        "runtime_dispatch_performed",
        "connector_call_performed",
        "state_mutation_performed",
        "terminal_closure_allowed"
      ],
      "properties": {
        "receipt_store_authority_granted": { "type": "boolean", "const": false },
        "receipt_store_writer_registered": { "type": "boolean", "const": false },
        "receipt_store_write_path_registered": { "type": "boolean", "const": false },
        "receipt_store_append_performed": { "type": "boolean", "const": false },
        "raw_payload_stored": { "type": "boolean", "const": false },
        "raw_secret_stored": { "type": "boolean", "const": false },
        "runtime_dispatch_performed": { "type": "boolean", "const": false },
        "connector_call_performed": { "type": "boolean", "const": false },
        "state_mutation_performed": { "type": "boolean", "const": false },
        "terminal_closure_allowed": { "type": "boolean", "const": false }
      }
    }
  }
}
