{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:autonomous-test-generation-plan:1",
  "title": "Autonomous Test Generation Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "plan_id",
    "tenant_id",
    "source_trace_ids",
    "cases",
    "coverage_requirements",
    "replay_library_refs",
    "operator_review_required",
    "activation_blocked",
    "plan_hash",
    "metadata"
  ],
  "properties": {
    "plan_id": {
      "type": "string",
      "pattern": "^test-generation-plan-[0-9a-f]{16}$"
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "source_trace_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "cases": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/generated_test_case"
      }
    },
    "coverage_requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "approval",
          "budget",
          "channel_variant",
          "governance",
          "operator_review",
          "prompt_injection",
          "replay_fixture",
          "sandbox_scenario",
          "temporal",
          "tenant_boundary",
          "unit"
        ]
      }
    },
    "replay_library_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "operator_review_required": {
      "type": "boolean",
      "const": true
    },
    "activation_blocked": {
      "type": "boolean",
      "const": true
    },
    "plan_hash": {
      "type": "string",
      "minLength": 1
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["plan_is_not_execution"],
      "properties": {
        "plan_is_not_execution": {
          "type": "boolean",
          "const": true
        },
        "trace_count": {
          "type": "integer",
          "minimum": 0
        },
        "case_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  },
  "$defs": {
    "generated_test_case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "trace_id",
        "tenant_id",
        "test_type",
        "title",
        "target",
        "scenario",
        "input_mutations",
        "expected_outcome",
        "required_controls",
        "evidence_refs",
        "replay_required",
        "sandbox_required",
        "operator_review_required",
        "case_hash",
        "metadata"
      ],
      "properties": {
        "case_id": {
          "type": "string",
          "pattern": "^generated-test-[0-9a-f]{16}$"
        },
        "trace_id": {
          "type": "string",
          "minLength": 1
        },
        "tenant_id": {
          "type": "string",
          "minLength": 1
        },
        "test_type": {
          "type": "string",
          "enum": [
            "unit",
            "governance",
            "prompt_injection",
            "tenant_boundary",
            "budget",
            "approval",
            "temporal",
            "replay_fixture",
            "sandbox_scenario",
            "channel_variant"
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "scenario": {
          "type": "string",
          "minLength": 1
        },
        "input_mutations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "expected_outcome": {
          "type": "string",
          "minLength": 1
        },
        "required_controls": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "replay_required": {
          "type": "boolean"
        },
        "sandbox_required": {
          "type": "boolean"
        },
        "operator_review_required": {
          "type": "boolean",
          "const": true
        },
        "case_hash": {
          "type": "string",
          "minLength": 1
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true,
          "required": ["created_from_failure"],
          "properties": {
            "source_failure_type": {
              "type": "string"
            },
            "source_channel": {
              "type": "string"
            },
            "risk_tier": {
              "type": "string",
              "enum": ["low", "medium", "high", "critical"]
            },
            "created_from_failure": {
              "type": "boolean",
              "const": true
            }
          }
        }
      }
    }
  }
}
