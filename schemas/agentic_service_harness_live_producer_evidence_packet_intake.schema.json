{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:agentic-service-harness-live-producer-evidence-packet-intake:1",
  "title": "Agentic Service Harness Live Producer Evidence Packet Intake",
  "description": "Read-only intake packet for the four live producer witness preflights. This schema binds effect receipt, external adapter evidence, secret handoff, and rollback proof references into one governed packet while preserving AwaitingEvidence and denying live producer authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "packet_id",
    "schema_version",
    "generated_at",
    "solver_outcome",
    "packet_status",
    "intake_decision",
    "planning_only",
    "read_only",
    "live_producer_implemented",
    "authority_granted",
    "terminal_closure",
    "operator_response_collection_binding",
    "source_preflights",
    "witness_packet_requirements",
    "missing_evidence",
    "authority_denials",
    "effect_boundary",
    "validators",
    "next_action"
  ],
  "properties": {
    "packet_id": {
      "type": "string",
      "const": "agentic-service-harness-live-producer-evidence-packet-intake"
    },
    "schema_version": { "type": "integer", "const": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "solver_outcome": { "type": "string", "const": "AwaitingEvidence" },
    "packet_status": { "type": "string", "const": "blocked_awaiting_witness_packets" },
    "intake_decision": { "type": "string", "const": "blocked_until_all_required_witness_packets_exist" },
    "planning_only": { "type": "boolean", "const": true },
    "read_only": { "type": "boolean", "const": true },
    "live_producer_implemented": { "type": "boolean", "const": false },
    "authority_granted": { "type": "boolean", "const": false },
    "terminal_closure": { "type": "boolean", "const": false },
    "operator_response_collection_binding": {
      "$ref": "#/$defs/operator_response_collection_binding"
    },
    "source_preflights": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": { "$ref": "#/$defs/source_preflight" },
      "uniqueItems": true
    },
    "witness_packet_requirements": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": { "$ref": "#/$defs/witness_packet_requirement" },
      "uniqueItems": true
    },
    "missing_evidence": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": { "$ref": "#/$defs/missing_evidence_item" },
      "uniqueItems": true
    },
    "authority_denials": { "$ref": "#/$defs/authority_denials" },
    "effect_boundary": { "$ref": "#/$defs/effect_boundary" },
    "validators": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/validator_ref" }
    },
    "next_action": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "evidence_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 320,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/#-]*$"
    },
    "source_preflight": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "witness_kind",
        "preflight_ref",
        "preflight_status",
        "blocks_live_producer",
        "authority_granted"
      ],
      "properties": {
        "witness_kind": {
          "type": "string",
          "enum": ["effect_receipt", "external_adapter_evidence", "secret_handoff", "rollback_proof"]
        },
        "preflight_ref": { "$ref": "#/$defs/evidence_ref" },
        "preflight_status": { "type": "string", "const": "AwaitingEvidence" },
        "blocks_live_producer": { "type": "boolean", "const": true },
        "authority_granted": { "type": "boolean", "const": false }
      }
    },
    "witness_packet_requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "witness_kind",
        "required_packet_ref",
        "required_validator_ref",
        "status",
        "blocks_live_producer",
        "authority_granted"
      ],
      "properties": {
        "witness_kind": {
          "type": "string",
          "enum": ["effect_receipt", "external_adapter_evidence", "secret_handoff", "rollback_proof"]
        },
        "required_packet_ref": { "$ref": "#/$defs/evidence_ref" },
        "required_validator_ref": { "$ref": "#/$defs/evidence_ref" },
        "status": { "type": "string", "const": "AwaitingEvidence" },
        "blocks_live_producer": { "type": "boolean", "const": true },
        "authority_granted": { "type": "boolean", "const": false }
      }
    },
    "missing_evidence_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence_id", "status", "blocks_live_producer"],
      "properties": {
        "evidence_id": {
          "type": "string",
          "enum": [
            "effect_receipt_packet",
            "external_adapter_evidence_packet",
            "secret_handoff_packet",
            "rollback_proof_packet"
          ]
        },
        "status": { "type": "string", "const": "AwaitingEvidence" },
        "blocks_live_producer": { "type": "boolean", "const": true }
      }
    },
    "operator_response_collection_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "binding_id",
        "source_response_witness_id",
        "source_response_witness_ref",
        "source_response_validator_id",
        "source_response_validator_command",
        "source_approval_request_collection_binding_id",
        "source_approval_request_collection_status",
        "source_response_status",
        "source_response_record_collected",
        "source_approval_satisfied",
        "source_authority_granted",
        "source_live_execution_authorized",
        "intake_packet_id",
        "intake_packet_ref",
        "intake_validator_id",
        "intake_validator_command",
        "binding_status",
        "witness_packets_collected",
        "authority_granted",
        "live_execution_authorized",
        "blocks_live_producer"
      ],
      "properties": {
        "binding_id": {
          "type": "string",
          "const": "binding.evidence_packet_intake.operator_response_collection"
        },
        "source_response_witness_id": {
          "type": "string",
          "const": "agentic-service-harness-live-producer-operator-response-witness"
        },
        "source_response_witness_ref": {
          "type": "string",
          "const": "examples/agentic_service_harness_live_producer_operator_response_witness.local.json"
        },
        "source_response_validator_id": {
          "type": "string",
          "const": "agentic-service-harness-live-producer-operator-response-witness"
        },
        "source_response_validator_command": {
          "type": "string",
          "const": "python scripts/validate_agentic_service_harness_live_producer_operator_response_witness.py"
        },
        "source_approval_request_collection_binding_id": {
          "type": "string",
          "const": "binding.operator_response.approval_request_collection"
        },
        "source_approval_request_collection_status": {
          "type": "string",
          "const": "AwaitingEvidence"
        },
        "source_response_status": { "type": "string", "const": "AwaitingEvidence" },
        "source_response_record_collected": { "type": "boolean", "const": false },
        "source_approval_satisfied": { "type": "boolean", "const": false },
        "source_authority_granted": { "type": "boolean", "const": false },
        "source_live_execution_authorized": { "type": "boolean", "const": false },
        "intake_packet_id": {
          "type": "string",
          "const": "agentic-service-harness-live-producer-evidence-packet-intake"
        },
        "intake_packet_ref": {
          "type": "string",
          "const": "examples/agentic_service_harness_live_producer_evidence_packet_intake.local.json"
        },
        "intake_validator_id": {
          "type": "string",
          "const": "agentic-service-harness-live-producer-evidence-packet-intake"
        },
        "intake_validator_command": {
          "type": "string",
          "const": "python scripts/validate_agentic_service_harness_live_producer_evidence_packet_intake.py"
        },
        "binding_status": { "type": "string", "const": "AwaitingEvidence" },
        "witness_packets_collected": { "type": "boolean", "const": false },
        "authority_granted": { "type": "boolean", "const": false },
        "live_execution_authorized": { "type": "boolean", "const": false },
        "blocks_live_producer": { "type": "boolean", "const": true }
      }
    },
    "authority_denials": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ui_created",
        "mutation_endpoints_admitted",
        "external_adapter_integrated",
        "branch_write_enabled",
        "pull_request_creation_enabled",
        "deployment_enabled",
        "dns_mutation_enabled",
        "secret_mutation_enabled",
        "destructive_operation_enabled",
        "runtime_state_written",
        "live_execution_authorized"
      ],
      "properties": {
        "ui_created": { "type": "boolean", "const": false },
        "mutation_endpoints_admitted": { "type": "boolean", "const": false },
        "external_adapter_integrated": { "type": "boolean", "const": false },
        "branch_write_enabled": { "type": "boolean", "const": false },
        "pull_request_creation_enabled": { "type": "boolean", "const": false },
        "deployment_enabled": { "type": "boolean", "const": false },
        "dns_mutation_enabled": { "type": "boolean", "const": false },
        "secret_mutation_enabled": { "type": "boolean", "const": false },
        "destructive_operation_enabled": { "type": "boolean", "const": false },
        "runtime_state_written": { "type": "boolean", "const": false },
        "live_execution_authorized": { "type": "boolean", "const": false }
      }
    },
    "effect_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ui_created",
        "mutation_endpoints_admitted",
        "external_adapter_integrated",
        "branch_write_enabled",
        "pull_request_creation_enabled",
        "deployment_enabled",
        "dns_mutation_enabled",
        "secret_mutation_enabled",
        "destructive_operation_enabled",
        "runtime_state_written",
        "network_policy"
      ],
      "properties": {
        "ui_created": { "type": "boolean", "const": false },
        "mutation_endpoints_admitted": { "type": "boolean", "const": false },
        "external_adapter_integrated": { "type": "boolean", "const": false },
        "branch_write_enabled": { "type": "boolean", "const": false },
        "pull_request_creation_enabled": { "type": "boolean", "const": false },
        "deployment_enabled": { "type": "boolean", "const": false },
        "dns_mutation_enabled": { "type": "boolean", "const": false },
        "secret_mutation_enabled": { "type": "boolean", "const": false },
        "destructive_operation_enabled": { "type": "boolean", "const": false },
        "runtime_state_written": { "type": "boolean", "const": false },
        "network_policy": { "type": "string", "const": "none" }
      }
    },
    "validator_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["validator_id", "command", "required_for_closure"],
      "properties": {
        "validator_id": { "$ref": "#/$defs/identifier" },
        "command": { "type": "string", "minLength": 1 },
        "required_for_closure": { "type": "boolean", "const": true }
      }
    }
  }
}
