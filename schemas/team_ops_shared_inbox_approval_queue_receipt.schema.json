{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:team-ops-shared-inbox-approval-queue-receipt:1",
  "title": "TeamOps Shared Inbox Approval Queue Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receipt_id",
    "schema_version",
    "workflow_id",
    "source_observation_routing_receipt_ref",
    "source_observation_routing_receipt_id",
    "routing_receipt_valid",
    "routing_receipt_ready",
    "status",
    "solver_outcome",
    "proof_state",
    "queued_at",
    "approval_queue_id",
    "approval_request_ref",
    "required_approver_role",
    "approval_state",
    "approval_decision_ref",
    "approval_required_before_external_send",
    "approval_queue_obligation_bound",
    "draft_response_required",
    "external_send_allowed",
    "approval_decision_performed_by_producer",
    "draft_created_by_producer",
    "external_mailbox_write_performed",
    "external_message_sent",
    "provider_mutation_performed",
    "raw_message_content_serialized",
    "no_secret_values_serialized",
    "evidence_refs",
    "blocked_until",
    "recovery_actions",
    "validation_commands"
  ],
  "properties": {
    "receipt_id": {
      "type": "string",
      "pattern": "^teamops-shared-inbox-approval-queue-receipt-[0-9a-f]{16}$"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "workflow_id": {
      "type": "string",
      "const": "team_ops.shared_inbox_triage"
    },
    "source_observation_routing_receipt_ref": {
      "type": "string",
      "minLength": 1
    },
    "source_observation_routing_receipt_id": {
      "type": "string"
    },
    "routing_receipt_valid": {
      "type": "boolean"
    },
    "routing_receipt_ready": {
      "type": "boolean"
    },
    "status": {
      "type": "string",
      "enum": ["blocked", "failed", "passed"]
    },
    "solver_outcome": {
      "type": "string",
      "enum": ["AwaitingEvidence", "GovernanceBlocked", "SolvedVerified"]
    },
    "proof_state": {
      "type": "string",
      "enum": ["Unknown", "Fail", "Pass"]
    },
    "queued_at": {
      "type": "string",
      "format": "date-time"
    },
    "approval_queue_id": {
      "type": "string",
      "enum": ["", "team_ops.external_send_approval"]
    },
    "approval_request_ref": {
      "type": "string"
    },
    "required_approver_role": {
      "type": "string",
      "enum": ["", "team_ops_owner", "team_ops_manager", "security_reviewer", "finance_owner", "operations_owner"]
    },
    "approval_state": {
      "type": "string",
      "enum": ["missing", "pending", "invalid"]
    },
    "approval_decision_ref": {
      "type": "string"
    },
    "approval_required_before_external_send": {
      "type": "boolean",
      "const": true
    },
    "approval_queue_obligation_bound": {
      "type": "boolean"
    },
    "draft_response_required": {
      "type": "boolean"
    },
    "external_send_allowed": {
      "type": "boolean",
      "const": false
    },
    "approval_decision_performed_by_producer": {
      "type": "boolean",
      "const": false
    },
    "draft_created_by_producer": {
      "type": "boolean",
      "const": false
    },
    "external_mailbox_write_performed": {
      "type": "boolean",
      "const": false
    },
    "external_message_sent": {
      "type": "boolean",
      "const": false
    },
    "provider_mutation_performed": {
      "type": "boolean",
      "const": false
    },
    "raw_message_content_serialized": {
      "type": "boolean",
      "const": false
    },
    "no_secret_values_serialized": {
      "type": "boolean",
      "const": true
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "blocked_until": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "recovery_actions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "validation_commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "passed"
          }
        },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "routing_receipt_valid": {
            "const": true
          },
          "routing_receipt_ready": {
            "const": true
          },
          "solver_outcome": {
            "const": "SolvedVerified"
          },
          "proof_state": {
            "const": "Pass"
          },
          "approval_queue_id": {
            "const": "team_ops.external_send_approval"
          },
          "approval_request_ref": {
            "minLength": 1
          },
          "required_approver_role": {
            "enum": ["team_ops_owner", "team_ops_manager", "security_reviewer", "finance_owner", "operations_owner"]
          },
          "approval_state": {
            "const": "pending"
          },
          "approval_decision_ref": {
            "const": ""
          },
          "approval_queue_obligation_bound": {
            "const": true
          },
          "evidence_refs": {
            "minItems": 1
          },
          "blocked_until": {
            "maxItems": 0
          }
        }
      }
    }
  ]
}
