{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:read-only-worker-runtime-enablement-review-packet:1",
  "title": "Mullu Read-Only Worker Runtime Enablement Review Packet",
  "description": "Foundation Mode review packet for submitted read-only worker runtime enablement evidence refs. Review is not evidence acceptance, authority, runtime enablement, dispatch, worker invocation, receipt emission, receipt append, terminal closure, or success claim.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "review_packet_id",
    "review_packet_version",
    "source_submitted_evidence_refs_ref",
    "source_submission_id",
    "source_status_ledger_ref",
    "selected_worker_path",
    "solver_outcome",
    "proof_state",
    "review_packet_state",
    "review_state",
    "review_packet_is_not_acceptance",
    "review_packet_is_not_authorization",
    "review_packet_is_not_runtime_enablement",
    "review_packet_is_not_dispatch",
    "review_packet_is_not_worker_invocation",
    "review_packet_is_not_receipt_emission",
    "review_packet_is_not_receipt_append",
    "review_packet_is_not_terminal_closure",
    "review_packet_is_not_success_claim",
    "evidence_accepted",
    "evidence_rejected",
    "authority_granted",
    "runtime_enablement_allowed",
    "runtime_enablement_executed",
    "runtime_dispatch_admitted",
    "runtime_dispatch_performed",
    "worker_invocation_performed",
    "runtime_receipt_emitted",
    "receipt_append_performed",
    "terminal_closure_performed",
    "success_claim_allowed",
    "secret_values_serialized",
    "connector_authority_allowed",
    "filesystem_write_allowed",
    "external_network_allowed",
    "review_records",
    "review_record_refs",
    "reviewed_evidence_refs",
    "missing_evidence_names",
    "accepted_evidence_refs",
    "rejected_evidence_refs",
    "authority_grant_refs",
    "blocked_actions",
    "summary",
    "validators",
    "next_action"
  ],
  "properties": {
    "review_packet_id": { "$ref": "#/$defs/identifier" },
    "review_packet_version": { "const": "read_only_worker_runtime_enablement_review_packet.v1" },
    "source_submitted_evidence_refs_ref": { "const": "examples/read_only_worker_runtime_enablement_submitted_evidence_refs.foundation.json" },
    "source_submission_id": { "$ref": "#/$defs/identifier" },
    "source_status_ledger_ref": { "const": "examples/read_only_worker_runtime_enablement_evidence_request_status_ledger.foundation.json" },
    "selected_worker_path": { "const": "read_only_repo_inspection" },
    "solver_outcome": { "const": "AwaitingEvidence" },
    "proof_state": { "const": "Unknown" },
    "review_packet_state": { "const": "reviewed_with_missing_inputs" },
    "review_state": { "const": "reviewed_not_accepted" },
    "review_packet_is_not_acceptance": { "const": true },
    "review_packet_is_not_authorization": { "const": true },
    "review_packet_is_not_runtime_enablement": { "const": true },
    "review_packet_is_not_dispatch": { "const": true },
    "review_packet_is_not_worker_invocation": { "const": true },
    "review_packet_is_not_receipt_emission": { "const": true },
    "review_packet_is_not_receipt_append": { "const": true },
    "review_packet_is_not_terminal_closure": { "const": true },
    "review_packet_is_not_success_claim": { "const": true },
    "evidence_accepted": { "const": false },
    "evidence_rejected": { "const": false },
    "authority_granted": { "const": false },
    "runtime_enablement_allowed": { "const": false },
    "runtime_enablement_executed": { "const": false },
    "runtime_dispatch_admitted": { "const": false },
    "runtime_dispatch_performed": { "const": false },
    "worker_invocation_performed": { "const": false },
    "runtime_receipt_emitted": { "const": false },
    "receipt_append_performed": { "const": false },
    "terminal_closure_performed": { "const": false },
    "success_claim_allowed": { "const": false },
    "secret_values_serialized": { "const": false },
    "connector_authority_allowed": { "const": false },
    "filesystem_write_allowed": { "const": false },
    "external_network_allowed": { "const": false },
    "review_records": {
      "type": "array",
      "minItems": 12,
      "maxItems": 12,
      "items": { "$ref": "#/$defs/review_record" }
    },
    "review_record_refs": {
      "type": "array",
      "minItems": 12,
      "maxItems": 12,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/identifier" }
    },
    "reviewed_evidence_refs": {
      "type": "array",
      "minItems": 9,
      "maxItems": 9,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/repo_ref" }
    },
    "missing_evidence_names": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/identifier" }
    },
    "accepted_evidence_refs": { "$ref": "#/$defs/empty_refs" },
    "rejected_evidence_refs": { "$ref": "#/$defs/empty_refs" },
    "authority_grant_refs": { "$ref": "#/$defs/empty_refs" },
    "blocked_actions": {
      "type": "array",
      "minItems": 7,
      "maxItems": 7,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/identifier" }
    },
    "summary": { "$ref": "#/$defs/summary" },
    "validators": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/repo_ref" }
    },
    "next_action": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "repo_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9._~:/@+ -]+$"
    },
    "empty_refs": {
      "type": "array",
      "maxItems": 0,
      "items": { "$ref": "#/$defs/repo_ref" }
    },
    "review_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "review_record_id",
        "source_submitted_record_id",
        "source_status_record_id",
        "source_input_id",
        "input_kind",
        "required_names",
        "review_state",
        "proof_state",
        "reviewed",
        "reviewed_evidence_refs",
        "missing_evidence_names",
        "accepted",
        "rejected",
        "authority_granted",
        "runtime_enablement_allowed",
        "runtime_dispatch_allowed",
        "worker_invocation_allowed",
        "runtime_receipt_emission_allowed",
        "receipt_append_allowed",
        "terminal_closure_allowed",
        "candidate_ref_satisfies_required_name",
        "record_is_not_acceptance",
        "record_is_not_authorization",
        "record_is_not_runtime_enablement",
        "record_is_not_dispatch",
        "record_is_not_worker_invocation",
        "record_is_not_receipt_emission",
        "record_is_not_receipt_append",
        "record_is_not_terminal_closure",
        "review_note",
        "next_action"
      ],
      "properties": {
        "review_record_id": { "$ref": "#/$defs/identifier" },
        "source_submitted_record_id": { "$ref": "#/$defs/identifier" },
        "source_status_record_id": { "$ref": "#/$defs/identifier" },
        "source_input_id": { "$ref": "#/$defs/identifier" },
        "input_kind": { "$ref": "#/$defs/identifier" },
        "required_names": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/identifier" } },
        "review_state": { "enum": ["reviewed_not_accepted", "blocked_missing_external_evidence"] },
        "proof_state": { "const": "Unknown" },
        "reviewed": { "type": "boolean" },
        "reviewed_evidence_refs": { "type": "array", "maxItems": 1, "items": { "$ref": "#/$defs/repo_ref" } },
        "missing_evidence_names": { "type": "array", "items": { "$ref": "#/$defs/identifier" } },
        "accepted": { "const": false },
        "rejected": { "const": false },
        "authority_granted": { "const": false },
        "runtime_enablement_allowed": { "const": false },
        "runtime_dispatch_allowed": { "const": false },
        "worker_invocation_allowed": { "const": false },
        "runtime_receipt_emission_allowed": { "const": false },
        "receipt_append_allowed": { "const": false },
        "terminal_closure_allowed": { "const": false },
        "candidate_ref_satisfies_required_name": { "const": false },
        "record_is_not_acceptance": { "const": true },
        "record_is_not_authorization": { "const": true },
        "record_is_not_runtime_enablement": { "const": true },
        "record_is_not_dispatch": { "const": true },
        "record_is_not_worker_invocation": { "const": true },
        "record_is_not_receipt_emission": { "const": true },
        "record_is_not_receipt_append": { "const": true },
        "record_is_not_terminal_closure": { "const": true },
        "review_note": { "type": "string", "minLength": 1 },
        "next_action": { "type": "string", "minLength": 1 }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_submitted_record_count",
        "review_record_count",
        "reviewed_repo_ref_count",
        "missing_input_count",
        "accepted_evidence_count",
        "rejected_evidence_count",
        "authority_grant_count",
        "runtime_enablement_count",
        "dispatch_count",
        "worker_invocation_count",
        "receipt_emission_count",
        "receipt_append_count",
        "terminal_closure_count",
        "blocked_action_count"
      ],
      "properties": {
        "source_submitted_record_count": { "const": 12 },
        "review_record_count": { "const": 12 },
        "reviewed_repo_ref_count": { "const": 9 },
        "missing_input_count": { "const": 3 },
        "accepted_evidence_count": { "const": 0 },
        "rejected_evidence_count": { "const": 0 },
        "authority_grant_count": { "const": 0 },
        "runtime_enablement_count": { "const": 0 },
        "dispatch_count": { "const": 0 },
        "worker_invocation_count": { "const": 0 },
        "receipt_emission_count": { "const": 0 },
        "receipt_append_count": { "const": 0 },
        "terminal_closure_count": { "const": 0 },
        "blocked_action_count": { "const": 7 }
      }
    }
  }
}
