{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:trust-ledger-anchor-verification-report:1",
  "title": "Trust Ledger Anchor Verification Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "valid",
    "reason",
    "bundle_id",
    "anchor_receipt_id",
    "schema_valid",
    "schema_errors",
    "expected_bundle_hash",
    "observed_bundle_hash",
    "signature_key_id",
    "command_id",
    "terminal_certificate_id",
    "artifact_count",
    "artifact_root_hash",
    "required_artifact_types",
    "package_present",
    "package_valid",
    "package_id",
    "package_hash"
  ],
  "properties": {
    "valid": {
      "type": "boolean"
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "bundle_id": {
      "type": "string"
    },
    "anchor_receipt_id": {
      "type": "string"
    },
    "schema_valid": {
      "type": "boolean"
    },
    "schema_errors": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "expected_bundle_hash": {
      "type": "string"
    },
    "observed_bundle_hash": {
      "type": "string"
    },
    "signature_key_id": {
      "type": "string"
    },
    "command_id": {
      "type": "string"
    },
    "terminal_certificate_id": {
      "type": "string"
    },
    "artifact_count": {
      "type": "integer",
      "minimum": 0
    },
    "artifact_root_hash": {
      "type": "string",
      "pattern": "^$|^[0-9a-f]{64}$"
    },
    "required_artifact_types": {
      "$ref": "#/$defs/required_artifact_types"
    },
    "package_present": {
      "type": "boolean"
    },
    "package_valid": {
      "type": "boolean"
    },
    "package_id": {
      "type": "string"
    },
    "package_hash": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "valid": {
            "const": true
          }
        },
        "required": [
          "valid"
        ]
      },
      "then": {
        "properties": {
          "schema_valid": {
            "const": true
          },
          "reason": {
            "const": "anchor_verified"
          },
          "artifact_count": {
            "minimum": 1
          },
          "artifact_root_hash": {
            "pattern": "^[0-9a-f]{64}$"
          },
          "required_artifact_types": {
            "minItems": 4,
            "contains": {
              "const": "command"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "valid": {
            "const": true
          }
        },
        "required": [
          "valid"
        ]
      },
      "then": {
        "properties": {
          "required_artifact_types": {
            "contains": {
              "const": "execution_receipt"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "valid": {
            "const": true
          }
        },
        "required": [
          "valid"
        ]
      },
      "then": {
        "properties": {
          "required_artifact_types": {
            "contains": {
              "const": "verification_result"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "valid": {
            "const": true
          }
        },
        "required": [
          "valid"
        ]
      },
      "then": {
        "properties": {
          "required_artifact_types": {
            "contains": {
              "const": "terminal_certificate"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "package_present": {
            "const": false
          }
        },
        "required": [
          "package_present"
        ]
      },
      "then": {
        "properties": {
          "package_valid": {
            "const": false
          },
          "package_id": {
            "const": ""
          },
          "package_hash": {
            "const": ""
          }
        }
      }
    }
  ],
  "$defs": {
    "required_artifact_types": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "enum": [
          "command",
          "approval",
          "execution_receipt",
          "provider_observation",
          "verification_result",
          "effect_reconciliation",
          "terminal_certificate",
          "learning_decision",
          "deployment_witness"
        ]
      }
    }
  }
}
