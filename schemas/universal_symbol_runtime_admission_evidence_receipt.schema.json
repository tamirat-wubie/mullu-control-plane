{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:universal-symbol-runtime-admission-evidence-receipt:1",
  "title": "Universal Symbol Runtime Admission Evidence Receipt",
  "description": "Foundation Mode receipt contract for UniversalSymbol runtime-admission live evidence. This receipt records required live runtime, operator, orchestration, receipt-store, skill-lane, rollback, and proof-coverage evidence while denying runtime admission, registration, dispatch, connector calls, external writes, receipt-store append, mutation, terminal closure, and production readiness.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receipt_id",
    "schema_version",
    "generated_at",
    "receipt_scope",
    "solver_outcome",
    "foundation_mode",
    "admission_evidence_decision",
    "receipt_is_not_runtime_authority",
    "runtime_subject",
    "required_live_evidence",
    "evidence_consistency_constraints",
    "authority_denials",
    "rejection_policy",
    "blocked_reasons",
    "next_actions",
    "evidence_refs",
    "contract_summary"
  ],
  "properties": {
    "receipt_id": { "type": "string", "const": "universal-symbol-runtime-admission-evidence-receipt-foundation" },
    "schema_version": { "type": "integer", "const": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "receipt_scope": { "type": "string", "const": "foundation-mode-universal-symbol-runtime-admission-evidence" },
    "solver_outcome": { "type": "string", "const": "AwaitingEvidence" },
    "foundation_mode": { "type": "boolean", "const": true },
    "admission_evidence_decision": {
      "type": "string",
      "const": "blocked_pending_live_runtime_admission_operator_orchestration_receipt_store_skill_recovery_and_proof_evidence"
    },
    "receipt_is_not_runtime_authority": { "type": "boolean", "const": true },
    "runtime_subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime_admission_policy_ref",
        "runtime_authority_witness_ref",
        "runtime_authority_read_model_ref",
        "skill_runtime_authority_witness_ref",
        "authority_scope"
      ],
      "properties": {
        "runtime_admission_policy_ref": { "$ref": "#/$defs/ref" },
        "runtime_authority_witness_ref": { "$ref": "#/$defs/ref" },
        "runtime_authority_read_model_ref": { "$ref": "#/$defs/ref" },
        "skill_runtime_authority_witness_ref": { "$ref": "#/$defs/ref" },
        "authority_scope": { "type": "string", "const": "runtime-admission-evidence-only" }
      }
    },
    "required_live_evidence": {
      "type": "array",
      "minItems": 10,
      "items": { "$ref": "#/$defs/live_evidence_requirement" },
      "uniqueItems": true
    },
    "evidence_consistency_constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime_authority_witness_matches_policy_required",
        "operator_approval_matches_authority_scope_required",
        "uao_decision_matches_effect_boundary_required",
        "phi_gov_decision_matches_state_write_required",
        "life_meaning_judgment_matches_effect_required",
        "receipt_store_authority_denial_respected",
        "skill_lane_witnesses_match_admission_matrix_required",
        "rollback_recovery_handoff_required",
        "proof_coverage_surface_closed_required",
        "all_live_evidence_required_before_runtime_admission"
      ],
      "properties": {
        "runtime_authority_witness_matches_policy_required": { "type": "boolean", "const": true },
        "operator_approval_matches_authority_scope_required": { "type": "boolean", "const": true },
        "uao_decision_matches_effect_boundary_required": { "type": "boolean", "const": true },
        "phi_gov_decision_matches_state_write_required": { "type": "boolean", "const": true },
        "life_meaning_judgment_matches_effect_required": { "type": "boolean", "const": true },
        "receipt_store_authority_denial_respected": { "type": "boolean", "const": true },
        "skill_lane_witnesses_match_admission_matrix_required": { "type": "boolean", "const": true },
        "rollback_recovery_handoff_required": { "type": "boolean", "const": true },
        "proof_coverage_surface_closed_required": { "type": "boolean", "const": true },
        "all_live_evidence_required_before_runtime_admission": { "type": "boolean", "const": true }
      }
    },
    "authority_denials": { "$ref": "#/$defs/authority_denials" },
    "rejection_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "missing_live_runtime_witness_blocks_admission",
        "missing_operator_approval_blocks_admission",
        "missing_orchestration_decision_blocks_admission",
        "missing_receipt_store_authority_blocks_admission",
        "missing_skill_lane_witness_blocks_admission",
        "missing_rollback_recovery_blocks_admission",
        "unknown_hard_constraint_blocks_admission",
        "failed_precondition_logs_delta_reject"
      ],
      "properties": {
        "missing_live_runtime_witness_blocks_admission": { "type": "boolean", "const": true },
        "missing_operator_approval_blocks_admission": { "type": "boolean", "const": true },
        "missing_orchestration_decision_blocks_admission": { "type": "boolean", "const": true },
        "missing_receipt_store_authority_blocks_admission": { "type": "boolean", "const": true },
        "missing_skill_lane_witness_blocks_admission": { "type": "boolean", "const": true },
        "missing_rollback_recovery_blocks_admission": { "type": "boolean", "const": true },
        "unknown_hard_constraint_blocks_admission": { "type": "boolean", "const": true },
        "failed_precondition_logs_delta_reject": { "type": "boolean", "const": true }
      }
    },
    "blocked_reasons": {
      "type": "array",
      "minItems": 9,
      "items": {
        "type": "string",
        "enum": [
          "live_runtime_witness_missing",
          "runtime_authority_witness_missing",
          "operator_approval_missing",
          "uao_decision_missing",
          "phi_gov_decision_missing",
          "life_meaning_judgment_missing",
          "receipt_store_authority_missing",
          "skill_lane_witness_missing",
          "rollback_recovery_handoff_missing",
          "proof_coverage_missing",
          "runtime_admission_forbidden",
          "terminal_closure_not_allowed"
        ]
      },
      "uniqueItems": true
    },
    "next_actions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/ref" },
      "uniqueItems": true
    },
    "contract_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "live_evidence_requirement_count",
        "consistency_constraint_count",
        "authority_denial_count",
        "rejection_check_count",
        "blocked_reason_count",
        "evidence_ref_count"
      ],
      "properties": {
        "live_evidence_requirement_count": { "type": "integer", "const": 10 },
        "consistency_constraint_count": { "type": "integer", "const": 10 },
        "authority_denial_count": { "type": "integer", "const": 12 },
        "rejection_check_count": { "type": "integer", "const": 8 },
        "blocked_reason_count": { "type": "integer", "minimum": 9 },
        "evidence_ref_count": { "type": "integer", "minimum": 1 }
      }
    }
  },
  "$defs": {
    "ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/#-]*$"
    },
    "live_evidence_requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_id",
        "evidence_kind",
        "proof_state",
        "required_evidence_ref",
        "current_decision",
        "delta_reject_ref"
      ],
      "properties": {
        "evidence_id": { "$ref": "#/$defs/ref" },
        "evidence_kind": {
          "type": "string",
          "enum": [
            "live_runtime_witness",
            "runtime_authority_witness",
            "operator_approval",
            "uao_decision",
            "phi_gov_decision",
            "life_meaning_judgment",
            "receipt_store_authority",
            "skill_lane_witness",
            "lane_runtime_authority_evidence",
            "rollback_recovery_handoff"
          ]
        },
        "proof_state": { "type": "string", "enum": ["Unknown", "BudgetUnknown", "Fail"] },
        "required_evidence_ref": { "$ref": "#/$defs/ref" },
        "current_decision": { "type": "string", "const": "runtime_admission_blocked" },
        "delta_reject_ref": { "$ref": "#/$defs/ref" }
      }
    },
    "authority_denials": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime_admission_granted",
        "runtime_registration_performed",
        "live_dispatch_enabled",
        "connector_call_enabled",
        "filesystem_write_enabled",
        "external_write_enabled",
        "receipt_store_append_enabled",
        "raw_payload_stored",
        "raw_secret_stored",
        "state_mutation_performed",
        "terminal_closure_allowed",
        "production_readiness_claimed"
      ],
      "properties": {
        "runtime_admission_granted": { "type": "boolean", "const": false },
        "runtime_registration_performed": { "type": "boolean", "const": false },
        "live_dispatch_enabled": { "type": "boolean", "const": false },
        "connector_call_enabled": { "type": "boolean", "const": false },
        "filesystem_write_enabled": { "type": "boolean", "const": false },
        "external_write_enabled": { "type": "boolean", "const": false },
        "receipt_store_append_enabled": { "type": "boolean", "const": false },
        "raw_payload_stored": { "type": "boolean", "const": false },
        "raw_secret_stored": { "type": "boolean", "const": false },
        "state_mutation_performed": { "type": "boolean", "const": false },
        "terminal_closure_allowed": { "type": "boolean", "const": false },
        "production_readiness_claimed": { "type": "boolean", "const": false }
      }
    }
  }
}
