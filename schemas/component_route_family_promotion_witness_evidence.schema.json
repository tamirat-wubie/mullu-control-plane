{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:component-route-family-promotion-witness-evidence:1",
  "title": "Mullu Component Route-Family Promotion Witness Evidence",
  "description": "Read-only Component Harness report that records concrete denial evidence for blocked route-family promotion gates without granting execution authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "evidence_id",
    "mode",
    "governed",
    "target_surface_id",
    "target_component_id",
    "decision",
    "preflight_outcome",
    "outcome",
    "evidence_decision",
    "witness_evidence_is_not_execution_authority",
    "live_execution_enabled",
    "live_connector_send_enabled",
    "can_execute",
    "can_mutate",
    "can_call_connector",
    "can_claim_terminal_closure",
    "mutates_router_inventory",
    "ready_for_promotion",
    "terminal_closure_required",
    "source_refs",
    "summary",
    "witness_records",
    "witnessed_evidence_keys",
    "remaining_missing_evidence",
    "approval_evidence_required",
    "blocked_actions",
    "expected_receipts",
    "validators",
    "next_action"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "evidence_id": {
      "$ref": "#/$defs/identifier"
    },
    "mode": {
      "type": "string",
      "enum": [
        "foundation",
        "read_only"
      ]
    },
    "governed": {
      "type": "boolean",
      "const": true
    },
    "target_surface_id": {
      "$ref": "#/$defs/identifier"
    },
    "target_component_id": {
      "$ref": "#/$defs/identifier"
    },
    "decision": {
      "type": "string",
      "const": "blocked"
    },
    "preflight_outcome": {
      "type": "string",
      "const": "GovernanceBlocked"
    },
    "outcome": {
      "type": "string",
      "const": "AwaitingEvidence"
    },
    "evidence_decision": {
      "type": "string",
      "const": "denied"
    },
    "witness_evidence_is_not_execution_authority": {
      "type": "boolean",
      "const": true
    },
    "live_execution_enabled": {
      "type": "boolean",
      "const": false
    },
    "live_connector_send_enabled": {
      "type": "boolean",
      "const": false
    },
    "can_execute": {
      "type": "boolean",
      "const": false
    },
    "can_mutate": {
      "type": "boolean",
      "const": false
    },
    "can_call_connector": {
      "type": "boolean",
      "const": false
    },
    "can_claim_terminal_closure": {
      "type": "boolean",
      "const": false
    },
    "mutates_router_inventory": {
      "type": "boolean",
      "const": false
    },
    "ready_for_promotion": {
      "type": "boolean",
      "const": false
    },
    "terminal_closure_required": {
      "type": "boolean",
      "const": true
    },
    "source_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "promotion_witness_requirements",
        "promotion_preflight",
        "router_inventory",
        "component_authority_envelope_witnesses",
        "proof_matrix"
      ],
      "properties": {
        "promotion_witness_requirements": {
          "$ref": "#/$defs/repo_path"
        },
        "promotion_preflight": {
          "$ref": "#/$defs/repo_path"
        },
        "router_inventory": {
          "$ref": "#/$defs/repo_path"
        },
        "component_authority_envelope_witnesses": {
          "$ref": "#/$defs/repo_path"
        },
        "proof_matrix": {
          "$ref": "#/$defs/repo_path"
        }
      }
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "witness_records": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/witness_record"
      }
    },
    "witnessed_evidence_keys": {
      "type": "array",
      "minItems": 4,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/identifier"
      }
    },
    "remaining_missing_evidence": {
      "type": "array",
      "minItems": 0,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/identifier"
      }
    },
    "approval_evidence_required": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/identifier_or_ref"
      }
    },
    "blocked_actions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/identifier"
      }
    },
    "expected_receipts": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/identifier"
      }
    },
    "validators": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/identifier"
      }
    },
    "next_action": {
      "type": "string",
      "minLength": 1,
      "maxLength": 360
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "repo_path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9._~:/{}@+ -]+$"
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "witness_record_count",
        "witnessed_blocker_count",
        "satisfied_requirement_count",
        "unsatisfied_requirement_count",
        "remaining_unwitnessed_blocker_count",
        "original_missing_requirement_count",
        "approval_evidence_required_count"
      ],
      "properties": {
        "witness_record_count": {
          "type": "integer",
          "const": 4
        },
        "witnessed_blocker_count": {
          "type": "integer",
          "const": 4
        },
        "satisfied_requirement_count": {
          "type": "integer",
          "const": 0
        },
        "unsatisfied_requirement_count": {
          "type": "integer",
          "const": 4
        },
        "remaining_unwitnessed_blocker_count": {
          "type": "integer",
          "const": 0
        },
        "original_missing_requirement_count": {
          "type": "integer",
          "const": 4
        },
        "approval_evidence_required_count": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "witness_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "witness_id",
        "requirement_id",
        "gate_id",
        "witness_kind",
        "evidence_key",
        "proof_state",
        "witness_state",
        "satisfies_requirement",
        "blocks_promotion",
        "required_before_promotion",
        "witness_is_not_execution_authority",
        "mutates_router_inventory",
        "grants_execution_authority",
        "grants_connector_authority",
        "grants_terminal_closure",
        "observed_state",
        "denial_reason",
        "source_refs",
        "required_next_artifacts"
      ],
      "properties": {
        "witness_id": {
          "$ref": "#/$defs/identifier"
        },
        "requirement_id": {
          "$ref": "#/$defs/identifier"
        },
        "gate_id": {
          "type": "string",
          "enum": [
            "route_binding_gate",
            "lifecycle_gate",
            "authority_upgrade_gate",
            "product_specific_boundary_gate"
          ]
        },
        "witness_kind": {
          "type": "string",
          "enum": [
            "route_binding",
            "lifecycle_transition",
            "authority_upgrade",
            "product_specific_ownership"
          ]
        },
        "evidence_key": {
          "$ref": "#/$defs/identifier"
        },
        "proof_state": {
          "type": "string",
          "const": "Fail"
        },
        "witness_state": {
          "type": "string",
          "const": "present_denial"
        },
        "satisfies_requirement": {
          "type": "boolean",
          "const": false
        },
        "blocks_promotion": {
          "type": "boolean",
          "const": true
        },
        "required_before_promotion": {
          "type": "boolean",
          "const": true
        },
        "witness_is_not_execution_authority": {
          "type": "boolean",
          "const": true
        },
        "mutates_router_inventory": {
          "type": "boolean",
          "const": false
        },
        "grants_execution_authority": {
          "type": "boolean",
          "const": false
        },
        "grants_connector_authority": {
          "type": "boolean",
          "const": false
        },
        "grants_terminal_closure": {
          "type": "boolean",
          "const": false
        },
        "observed_state": {
          "type": "string",
          "minLength": 1,
          "maxLength": 360
        },
        "denial_reason": {
          "type": "string",
          "minLength": 1,
          "maxLength": 240
        },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/repo_path"
          }
        },
        "required_next_artifacts": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifier_or_ref"
          }
        }
      }
    },
    "identifier_or_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/#{}@+ -]*$"
    }
  }
}
