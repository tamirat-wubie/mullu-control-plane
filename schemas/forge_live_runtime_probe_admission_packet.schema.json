{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:forge-live-runtime-probe-admission-packet:1",
  "title": "Forge Live Runtime Probe Admission Packet",
  "description": "Foundation Mode admission packet for future operator-approved Forge live-runtime evidence probes.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "packet_id",
    "schema_ref",
    "schema_version",
    "bridge_ref",
    "source_signed_evidence_receipt_ref",
    "source_signed_evidence_receipt_hash",
    "admission_mode",
    "admission_status",
    "solver_outcome",
    "probe_items",
    "blocked_reasons",
    "required_controls",
    "disallowed_authority",
    "next_allowed_action",
    "validators",
    "packet_hash"
  ],
  "properties": {
    "packet_id": { "type": "string", "const": "forge-live-runtime-probe-admission-packet.v1" },
    "schema_ref": { "type": "string", "const": "urn:mullusi:schema:forge-live-runtime-probe-admission-packet:1" },
    "schema_version": { "type": "integer", "const": 1 },
    "bridge_ref": { "type": "string", "const": "forge_write_spine_bridge.v1" },
    "source_signed_evidence_receipt_ref": {
      "type": "string",
      "const": "examples/forge_live_runtime_signed_evidence_receipt.foundation.json"
    },
    "source_signed_evidence_receipt_hash": { "$ref": "#/$defs/hash" },
    "admission_mode": { "type": "string", "const": "operator_approved_live_probe_required" },
    "admission_status": { "type": "string", "const": "blocked_awaiting_operator_approval" },
    "solver_outcome": { "type": "string", "const": "AwaitingEvidence" },
    "probe_items": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "items": { "$ref": "#/$defs/probe_item" }
    },
    "blocked_reasons": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "items": { "type": "string", "pattern": "^[a-z0-9_]+_operator_approved_probe_missing$" }
    },
    "required_controls": {
      "type": "array",
      "minItems": 11,
      "maxItems": 11,
      "items": { "type": "string" }
    },
    "disallowed_authority": { "$ref": "#/$defs/disallowed_authority" },
    "next_allowed_action": {
      "type": "string",
      "const": "request_operator_approval_for_bounded_live_probe_inputs"
    },
    "validators": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": { "$ref": "#/$defs/validator" }
    },
    "packet_hash": { "$ref": "#/$defs/hash" }
  },
  "$defs": {
    "hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "probe_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_id",
        "target_signed_evidence_ref",
        "probe_ref",
        "required_inputs",
        "operator_approval_status",
        "probe_admission_status",
        "probe_execution_allowed",
        "external_effects_requested",
        "signed_receipt_population_allowed",
        "blocker_reason",
        "authority_effect"
      ],
      "properties": {
        "evidence_id": { "type": "string" },
        "target_signed_evidence_ref": {
          "type": "string",
          "pattern": "^evidence://forge/live-runtime/[a-z0-9-]+$"
        },
        "probe_ref": {
          "type": "string",
          "pattern": "^probe://forge/live-runtime/[a-z0-9-]+$"
        },
        "required_inputs": {
          "type": "array",
          "minItems": 5,
          "maxItems": 5,
          "prefixItems": [
            { "const": "operator_approval" },
            { "const": "dependency_or_credential_probe" },
            { "const": "recovery_or_revocation_path" },
            { "const": "signed_receipt_writer" },
            { "const": "sandbox_or_isolation_boundary" }
          ]
        },
        "operator_approval_status": { "type": "string", "const": "not_approved" },
        "probe_admission_status": { "type": "string", "const": "blocked" },
        "probe_execution_allowed": { "type": "boolean", "const": false },
        "external_effects_requested": { "type": "boolean", "const": false },
        "signed_receipt_population_allowed": { "type": "boolean", "const": false },
        "blocker_reason": {
          "type": "string",
          "pattern": "^[a-z0-9_]+_operator_approved_probe_missing$"
        },
        "authority_effect": { "type": "boolean", "const": false }
      }
    },
    "disallowed_authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "live_runtime_authorized",
        "state_write_runtime_registered",
        "production_authorized",
        "external_effects_allowed",
        "commit_allowed",
        "terminal_closure"
      ],
      "properties": {
        "live_runtime_authorized": { "type": "boolean", "const": false },
        "state_write_runtime_registered": { "type": "boolean", "const": false },
        "production_authorized": { "type": "boolean", "const": false },
        "external_effects_allowed": { "type": "boolean", "const": false },
        "commit_allowed": { "type": "boolean", "const": false },
        "terminal_closure": { "type": "boolean", "const": false }
      }
    },
    "validator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["validator_id", "command", "required_for_closure"],
      "properties": {
        "validator_id": { "type": "string", "const": "forge-live-runtime-probe-admission-packet" },
        "command": {
          "type": "string",
          "const": "python scripts/validate_forge_live_runtime_probe_admission_packet.py"
        },
        "required_for_closure": { "type": "boolean", "const": true }
      }
    }
  }
}
