{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:universal-symbol:1",
  "title": "Universal Symbol Kernel Record",
  "description": "Foundation Mode symbol-native record for treating platform objects as governed causal symbols before runtime authority is granted.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "symbol_id",
    "symbol_version",
    "generated_at",
    "symbol_identity",
    "symbol_boundary",
    "symbol_metadata",
    "symbol_relations",
    "symbol_causality",
    "symbol_lineage",
    "symbol_governance",
    "symbol_proof",
    "symbol_skill_projection",
    "symbol_authority_boundary",
    "contract_summary",
    "evidence_refs"
  ],
  "properties": {
    "symbol_id": {"type": "string", "pattern": "^universal-symbol-[a-z0-9._:-]+-[0-9a-f]{16}$"},
    "symbol_version": {"const": "universal_symbol.v1"},
    "generated_at": {"type": "string", "format": "date-time"},
    "symbol_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "symbol_kind", "domain", "local_name", "canonical_ref", "ontology_status", "definition"],
      "properties": {
        "label": {"type": "string", "minLength": 1},
        "symbol_kind": {"type": "string", "enum": ["concept", "skill", "component", "receipt", "action", "question", "answer", "metadata", "relation", "trace", "proof", "failure", "unknown", "policy", "boundary", "artifact"]},
        "domain": {"type": "string", "minLength": 1},
        "local_name": {"type": "string", "minLength": 1},
        "canonical_ref": {"type": "string", "minLength": 1},
        "ontology_status": {"type": "string", "enum": ["known", "candidate", "hypothetical", "simulated", "unknown_status", "rejected"]},
        "definition": {"type": "string", "minLength": 1}
      }
    },
    "symbol_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["boundary_scope", "inside_refs", "outside_refs", "protected_refs", "environment_refs", "retention_policy_ref"],
      "properties": {
        "boundary_scope": {"type": "string", "minLength": 1},
        "inside_refs": {"$ref": "#/$defs/string_array"},
        "outside_refs": {"$ref": "#/$defs/string_array"},
        "protected_refs": {"$ref": "#/$defs/string_array"},
        "environment_refs": {"$ref": "#/$defs/string_array"},
        "retention_policy_ref": {"type": "string", "minLength": 1}
      }
    },
    "symbol_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["metadata_refs", "metadata_is_symbolizable", "question_refs", "answer_refs", "unknown_refs", "contradiction_refs"],
      "properties": {
        "metadata_refs": {"$ref": "#/$defs/string_array"},
        "metadata_is_symbolizable": {"type": "boolean", "const": true},
        "question_refs": {"$ref": "#/$defs/string_array"},
        "answer_refs": {"$ref": "#/$defs/string_array"},
        "unknown_refs": {"$ref": "#/$defs/string_array"},
        "contradiction_refs": {"$ref": "#/$defs/string_array"}
      }
    },
    "symbol_relations": {
      "type": "object",
      "additionalProperties": false,
      "required": ["relation_refs", "upstream_refs", "downstream_refs", "peer_refs", "relation_is_symbolizable"],
      "properties": {
        "relation_refs": {"$ref": "#/$defs/string_array"},
        "upstream_refs": {"$ref": "#/$defs/string_array"},
        "downstream_refs": {"$ref": "#/$defs/string_array"},
        "peer_refs": {"$ref": "#/$defs/string_array"},
        "relation_is_symbolizable": {"type": "boolean", "const": true}
      }
    },
    "symbol_causality": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cause_refs", "effect_refs", "pre_state_ref", "post_state_ref", "causal_trace_ref", "unsupported_causal_gap_refs", "causality_is_symbolizable"],
      "properties": {
        "cause_refs": {"$ref": "#/$defs/string_array"},
        "effect_refs": {"$ref": "#/$defs/string_array"},
        "pre_state_ref": {"type": "string"},
        "post_state_ref": {"type": "string"},
        "causal_trace_ref": {"type": "string"},
        "unsupported_causal_gap_refs": {"$ref": "#/$defs/string_array"},
        "causality_is_symbolizable": {"type": "boolean", "const": true}
      }
    },
    "symbol_lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["origin_ref", "parent_symbol_refs", "child_symbol_refs", "promotion_refs", "mutation_refs"],
      "properties": {
        "origin_ref": {"type": "string", "minLength": 1},
        "parent_symbol_refs": {"$ref": "#/$defs/string_array"},
        "child_symbol_refs": {"$ref": "#/$defs/string_array"},
        "promotion_refs": {"$ref": "#/$defs/string_array"},
        "mutation_refs": {"$ref": "#/$defs/string_array"}
      }
    },
    "symbol_governance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["governance_mode", "uao_ref", "policy_refs", "authority_refs", "approval_refs", "blocked_action_refs", "risk_tier"],
      "properties": {
        "governance_mode": {"type": "string", "enum": ["foundation", "read_only", "draft", "live_probe", "approval_required", "blocked"]},
        "uao_ref": {"type": "string", "minLength": 1},
        "policy_refs": {"$ref": "#/$defs/non_empty_string_array"},
        "authority_refs": {"$ref": "#/$defs/string_array"},
        "approval_refs": {"$ref": "#/$defs/string_array"},
        "blocked_action_refs": {"$ref": "#/$defs/non_empty_string_array"},
        "risk_tier": {"type": "string", "enum": ["low", "medium", "high", "critical"]}
      }
    },
    "symbol_proof": {
      "type": "object",
      "additionalProperties": false,
      "required": ["proof_state", "proof_refs", "receipt_refs", "witness_refs", "terminal_closure_ref", "proof_is_symbolizable"],
      "properties": {
        "proof_state": {"type": "string", "enum": ["awaiting_evidence", "witnessed", "proven", "contradicted", "rejected"]},
        "proof_refs": {"$ref": "#/$defs/string_array"},
        "receipt_refs": {"$ref": "#/$defs/string_array"},
        "witness_refs": {"$ref": "#/$defs/string_array"},
        "terminal_closure_ref": {"type": "string"},
        "proof_is_symbolizable": {"type": "boolean", "const": true}
      }
    },
    "symbol_skill_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["projected_skill_refs", "adapter_refs", "skill_transfer_refs", "skill_projection_is_advisory_only"],
      "properties": {
        "projected_skill_refs": {"$ref": "#/$defs/string_array"},
        "adapter_refs": {"$ref": "#/$defs/string_array"},
        "skill_transfer_refs": {"$ref": "#/$defs/string_array"},
        "skill_projection_is_advisory_only": {"type": "boolean", "const": true}
      }
    },
    "symbol_authority_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["raw_private_payload_stored", "raw_secret_value_stored", "connector_call_performed", "external_write_performed", "filesystem_write_performed", "runtime_dispatch_performed", "state_mutation_performed", "terminal_closure_allowed", "success_claim_allowed"],
      "properties": {
        "raw_private_payload_stored": {"type": "boolean", "const": false},
        "raw_secret_value_stored": {"type": "boolean", "const": false},
        "connector_call_performed": {"type": "boolean", "const": false},
        "external_write_performed": {"type": "boolean", "const": false},
        "filesystem_write_performed": {"type": "boolean", "const": false},
        "runtime_dispatch_performed": {"type": "boolean", "const": false},
        "state_mutation_performed": {"type": "boolean", "const": false},
        "terminal_closure_allowed": {"type": "boolean", "const": false},
        "success_claim_allowed": {"type": "boolean", "const": false}
      }
    },
    "contract_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["symbol_native_boundary", "everything_symbolizable", "authority_denial_count", "symbolizable_surface_count", "evidence_ref_count"],
      "properties": {
        "symbol_native_boundary": {"type": "boolean", "const": true},
        "everything_symbolizable": {"type": "boolean", "const": true},
        "authority_denial_count": {"type": "integer", "minimum": 9},
        "symbolizable_surface_count": {"type": "integer", "minimum": 5},
        "evidence_ref_count": {"type": "integer", "minimum": 1}
      }
    },
    "evidence_refs": {"$ref": "#/$defs/non_empty_string_array"}
  },
  "$defs": {
    "string_array": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
    "non_empty_string_array": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
  }
}
