{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:personal-assistant-coherence-ledger-receipt:1",
  "title": "Mullu Personal Assistant Coherence Ledger Receipt",
  "description": "No-effect ledger receipt binding Personal Assistant foundation lanes, evidence references, authority blocks, and next allowed work without granting execution authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "receipt_id",
    "generated_at",
    "proof_state",
    "solver_outcome",
    "governed",
    "receipt_is_not_execution_authority",
    "receipt_is_not_terminal_closure",
    "source_receipts",
    "coherence_summary",
    "lane_ledger_records",
    "authority_block_records",
    "effect_boundary",
    "lineage"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "personal_assistant.coherence_ledger_receipt.v1"
    },
    "receipt_id": {
      "type": "string",
      "pattern": "^personal-assistant-coherence-ledger-[0-9a-f]{16}$"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "proof_state": {
      "type": "string",
      "enum": ["Pass", "Fail"]
    },
    "solver_outcome": {
      "type": "string",
      "enum": ["SolvedVerified", "AwaitingEvidence"]
    },
    "governed": {
      "type": "boolean",
      "const": true
    },
    "receipt_is_not_execution_authority": {
      "type": "boolean",
      "const": true
    },
    "receipt_is_not_terminal_closure": {
      "type": "boolean",
      "const": true
    },
    "source_receipts": {
      "type": "array",
      "minItems": 1,
      "maxItems": 2,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/source_receipt"
      }
    },
    "coherence_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "coherence_ledger_closed",
        "readiness_index_closed",
        "lane_count",
        "dependency_edge_count",
        "blocked_authority_count",
        "next_action_count",
        "all_lanes_bound_to_sources",
        "all_edges_no_effect",
        "no_effect_boundary_verified",
        "production_ready",
        "customer_ready",
        "next_allowed_action"
      ],
      "properties": {
        "coherence_ledger_closed": { "type": "boolean" },
        "readiness_index_closed": { "type": "boolean" },
        "lane_count": { "type": "integer", "minimum": 1 },
        "dependency_edge_count": { "type": "integer", "minimum": 1 },
        "blocked_authority_count": { "type": "integer", "minimum": 1 },
        "next_action_count": { "type": "integer", "minimum": 1 },
        "all_lanes_bound_to_sources": { "type": "boolean" },
        "all_edges_no_effect": { "type": "boolean" },
        "no_effect_boundary_verified": { "type": "boolean" },
        "production_ready": { "type": "boolean", "const": false },
        "customer_ready": { "type": "boolean", "const": false },
        "next_allowed_action": {
          "type": "string",
          "const": "continue_foundation_hardening_only"
        }
      }
    },
    "lane_ledger_records": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/lane_ledger_record"
      }
    },
    "authority_block_records": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/authority_block_record"
      }
    },
    "effect_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "execution_allowed",
        "live_connector_execution_allowed",
        "connector_mutation_allowed",
        "external_effect_allowed",
        "customer_readiness_claim_allowed",
        "nested_mind_live_activation_allowed",
        "production_ready_claim_allowed",
        "secret_values_serialized",
        "raw_private_payloads_serialized"
      ],
      "properties": {
        "execution_allowed": { "type": "boolean", "const": false },
        "live_connector_execution_allowed": { "type": "boolean", "const": false },
        "connector_mutation_allowed": { "type": "boolean", "const": false },
        "external_effect_allowed": { "type": "boolean", "const": false },
        "customer_readiness_claim_allowed": { "type": "boolean", "const": false },
        "nested_mind_live_activation_allowed": { "type": "boolean", "const": false },
        "production_ready_claim_allowed": { "type": "boolean", "const": false },
        "secret_values_serialized": { "type": "boolean", "const": false },
        "raw_private_payloads_serialized": { "type": "boolean", "const": false }
      }
    },
    "lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["accepted_deltas", "rejected_deltas"],
      "properties": {
        "accepted_deltas": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/lineage_delta" }
        },
        "rejected_deltas": {
          "type": "array",
          "items": { "$ref": "#/$defs/lineage_delta" }
        }
      }
    }
  },
  "$defs": {
    "source_receipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "source_ref",
        "receipt_id",
        "proof_state",
        "solver_outcome",
        "closed",
        "no_effect_boundary_verified"
      ],
      "properties": {
        "source_id": { "$ref": "#/$defs/identifier" },
        "source_ref": { "$ref": "#/$defs/repo_path" },
        "receipt_id": { "$ref": "#/$defs/identifier" },
        "proof_state": { "type": "string", "enum": ["Pass", "Fail"] },
        "solver_outcome": { "type": "string", "enum": ["SolvedVerified", "AwaitingEvidence"] },
        "closed": { "type": "boolean" },
        "no_effect_boundary_verified": { "type": "boolean" }
      }
    },
    "lane_ledger_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ledger_record_id",
        "lane_id",
        "stage",
        "state",
        "source_receipt_ids",
        "route_refs",
        "schema_refs",
        "validator_refs",
        "dependency_edge_count",
        "blocked_authority_refs",
        "foundation_only",
        "receipt_required",
        "no_effect_boundary_verified",
        "next_allowed_action"
      ],
      "properties": {
        "ledger_record_id": { "$ref": "#/$defs/identifier" },
        "lane_id": { "$ref": "#/$defs/identifier" },
        "stage": { "$ref": "#/$defs/identifier" },
        "state": { "type": "string", "enum": ["SolvedVerified", "AwaitingEvidence"] },
        "source_receipt_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/identifier" }
        },
        "route_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/repo_path" }
        },
        "schema_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/repo_path" }
        },
        "validator_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/repo_path" }
        },
        "dependency_edge_count": { "type": "integer", "minimum": 1 },
        "blocked_authority_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/identifier" }
        },
        "foundation_only": { "type": "boolean", "const": true },
        "receipt_required": { "type": "boolean", "const": true },
        "no_effect_boundary_verified": { "type": "boolean" },
        "next_allowed_action": {
          "type": "string",
          "const": "continue_foundation_hardening_only"
        }
      }
    },
    "authority_block_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["authority_id", "blocked", "source", "reason"],
      "properties": {
        "authority_id": { "$ref": "#/$defs/identifier" },
        "blocked": { "type": "boolean", "const": true },
        "source": { "$ref": "#/$defs/identifier" },
        "reason": { "type": "string", "minLength": 1, "maxLength": 240 }
      }
    },
    "lineage_delta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["delta_id", "reason", "logged_in_lineage"],
      "properties": {
        "delta_id": { "$ref": "#/$defs/identifier" },
        "reason": { "type": "string", "minLength": 1, "maxLength": 500 },
        "logged_in_lineage": { "type": "boolean", "const": true }
      }
    },
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "repo_path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9._~:/{}@+ -]+$"
    }
  }
}
