{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:governed-planning-profile-runtime-promotion-approval-packet:1",
  "title": "Governed Planning Profile Runtime Promotion Approval Packet",
  "description": "Read-only local approval evidence packet for GovernedPlanningProfile runtime promotion that does not grant runtime authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "packet_id",
    "schema_version",
    "profile_id",
    "approved_at",
    "solver_outcome",
    "runtime_promotion_approval_status",
    "runtime_promotion_approval_collected",
    "runtime_promotion_gate_satisfied",
    "local_approval_only",
    "read_only",
    "mutation_route",
    "runtime_behavior_change",
    "runtime_promotion_authorized",
    "execution_allowed",
    "dispatch_allowed",
    "runtime_replanning_enabled",
    "success_claim_allowed",
    "terminal_closure",
    "source_observation_receipt",
    "expected_plan_classes",
    "approval_criteria",
    "scenario_approvals",
    "promotion_gate_summary",
    "remaining_promotion_gates",
    "authority_denials",
    "evidence_refs",
    "validators",
    "next_action",
    "packet_hash"
  ],
  "properties": {
    "packet_id": {
      "type": "string",
      "pattern": "^governed-planning-profile-runtime-promotion-approval-packet-[a-f0-9]{16}$"
    },
    "schema_version": {
      "type": "string",
      "const": "governed_planning_profile_runtime_promotion_approval_packet.v1"
    },
    "profile_id": {
      "type": "string",
      "const": "governed-planning-profile-foundation-v1"
    },
    "approved_at": {
      "type": "string",
      "const": "2026-06-19T00:00:00Z"
    },
    "solver_outcome": {
      "type": "string",
      "const": "AwaitingEvidence"
    },
    "runtime_promotion_approval_status": {
      "type": "string",
      "const": "ConditionallyApprovedNoEffect"
    },
    "runtime_promotion_approval_collected": { "type": "boolean", "const": true },
    "runtime_promotion_gate_satisfied": { "type": "boolean", "const": true },
    "local_approval_only": { "type": "boolean", "const": true },
    "read_only": { "type": "boolean", "const": true },
    "mutation_route": { "type": "boolean", "const": false },
    "runtime_behavior_change": { "type": "boolean", "const": false },
    "runtime_promotion_authorized": { "type": "boolean", "const": false },
    "execution_allowed": { "type": "boolean", "const": false },
    "dispatch_allowed": { "type": "boolean", "const": false },
    "runtime_replanning_enabled": { "type": "boolean", "const": false },
    "success_claim_allowed": { "type": "boolean", "const": false },
    "terminal_closure": { "type": "boolean", "const": false },
    "source_observation_receipt": { "$ref": "#/$defs/source_observation_receipt" },
    "expected_plan_classes": {
      "type": "array",
      "prefixItems": [
        { "const": "uncompiled_conversation" },
        { "const": "read_only_search" },
        { "const": "compound_search_notification" },
        { "const": "high_risk_payment" },
        { "const": "world_contradiction_search" }
      ],
      "minItems": 5,
      "maxItems": 5
    },
    "approval_criteria": {
      "type": "array",
      "prefixItems": [
        { "$ref": "#/$defs/approval_criterion_source_observation_receipt_valid" },
        { "$ref": "#/$defs/approval_criterion_all_plan_classes_observed" },
        { "$ref": "#/$defs/approval_criterion_shadow_parity_confirmed" },
        { "$ref": "#/$defs/approval_criterion_projection_behavior_matched" },
        { "$ref": "#/$defs/approval_criterion_zero_shadow_mismatches" },
        { "$ref": "#/$defs/approval_criterion_authority_denials_preserved" },
        { "$ref": "#/$defs/approval_criterion_foundation_no_effect_boundary_preserved" }
      ],
      "minItems": 7,
      "maxItems": 7
    },
    "scenario_approvals": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": { "$ref": "#/$defs/scenario_approval" }
    },
    "promotion_gate_summary": { "$ref": "#/$defs/promotion_gate_summary" },
    "remaining_promotion_gates": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": { "$ref": "#/$defs/remaining_promotion_gate" }
    },
    "authority_denials": { "$ref": "#/$defs/authority_denials" },
    "evidence_refs": { "$ref": "#/$defs/non_empty_string_array" },
    "validators": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/validator_ref" }
    },
    "next_action": {
      "type": "string",
      "const": "obtain replay/recovery witness and terminal closure certificate before runtime promotion"
    },
    "packet_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  },
  "$defs": {
    "source_observation_receipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_id",
        "receipt_hash",
        "operator_observation_status",
        "operator_observation_collected",
        "scenario_observation_count",
        "remaining_promotion_gate_count"
      ],
      "properties": {
        "receipt_id": {
          "type": "string",
          "pattern": "^governed-planning-profile-operator-shadow-pilot-observation-receipt-[a-f0-9]{16}$"
        },
        "receipt_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "operator_observation_status": {
          "type": "string",
          "const": "Collected"
        },
        "operator_observation_collected": { "type": "boolean", "const": true },
        "scenario_observation_count": { "type": "integer", "const": 5 },
        "remaining_promotion_gate_count": { "type": "integer", "const": 3 }
      }
    },
    "approval_criterion_base": {
      "type": "object",
      "additionalProperties": false,
      "required": ["criterion_id", "status", "evidence_ref", "blocks_runtime_promotion"],
      "properties": {
        "criterion_id": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "const": "Pass" },
        "evidence_ref": { "type": "string", "minLength": 1 },
        "blocks_runtime_promotion": { "type": "boolean", "const": false }
      }
    },
    "approval_criterion_source_observation_receipt_valid": {
      "allOf": [
        { "$ref": "#/$defs/approval_criterion_base" },
        {
          "type": "object",
          "properties": {
            "criterion_id": { "const": "source_observation_receipt_valid" }
          }
        }
      ]
    },
    "approval_criterion_all_plan_classes_observed": {
      "allOf": [
        { "$ref": "#/$defs/approval_criterion_base" },
        {
          "type": "object",
          "properties": {
            "criterion_id": { "const": "all_plan_classes_observed" }
          }
        }
      ]
    },
    "approval_criterion_shadow_parity_confirmed": {
      "allOf": [
        { "$ref": "#/$defs/approval_criterion_base" },
        {
          "type": "object",
          "properties": {
            "criterion_id": { "const": "shadow_parity_confirmed" }
          }
        }
      ]
    },
    "approval_criterion_projection_behavior_matched": {
      "allOf": [
        { "$ref": "#/$defs/approval_criterion_base" },
        {
          "type": "object",
          "properties": {
            "criterion_id": { "const": "projection_behavior_matched" }
          }
        }
      ]
    },
    "approval_criterion_zero_shadow_mismatches": {
      "allOf": [
        { "$ref": "#/$defs/approval_criterion_base" },
        {
          "type": "object",
          "properties": {
            "criterion_id": { "const": "zero_shadow_mismatches" }
          }
        }
      ]
    },
    "approval_criterion_authority_denials_preserved": {
      "allOf": [
        { "$ref": "#/$defs/approval_criterion_base" },
        {
          "type": "object",
          "properties": {
            "criterion_id": { "const": "authority_denials_preserved" }
          }
        }
      ]
    },
    "approval_criterion_foundation_no_effect_boundary_preserved": {
      "allOf": [
        { "$ref": "#/$defs/approval_criterion_base" },
        {
          "type": "object",
          "properties": {
            "criterion_id": { "const": "foundation_no_effect_boundary_preserved" }
          }
        }
      ]
    },
    "scenario_approval": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scenario_id",
        "plan_class",
        "operator_observation_ref",
        "approval_status",
        "parity_confirmed",
        "observed_behavior_matches_projection",
        "runtime_promotion_ready"
      ],
      "properties": {
        "scenario_id": { "type": "string", "pattern": "^scenario-[a-z0-9-]+$" },
        "plan_class": {
          "type": "string",
          "enum": [
            "uncompiled_conversation",
            "read_only_search",
            "compound_search_notification",
            "high_risk_payment",
            "world_contradiction_search"
          ]
        },
        "operator_observation_ref": {
          "type": "string",
          "pattern": "^receipt://governed-planning-profile/operator-shadow-pilot/[a-z0-9_]+$"
        },
        "approval_status": {
          "type": "string",
          "const": "ConditionallyApprovedNoEffect"
        },
        "parity_confirmed": { "type": "boolean", "const": true },
        "observed_behavior_matches_projection": { "type": "boolean", "const": true },
        "runtime_promotion_ready": { "type": "boolean", "const": false }
      }
    },
    "promotion_gate_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "satisfied_promotion_gate_ids",
        "remaining_promotion_gate_ids",
        "approval_criterion_count",
        "scenario_approval_count",
        "runtime_promotion_authorized"
      ],
      "properties": {
        "satisfied_promotion_gate_ids": {
          "type": "array",
          "prefixItems": [
            { "const": "operator_shadow_pilot_observation" },
            { "const": "runtime_promotion_approval" }
          ],
          "minItems": 2,
          "maxItems": 2
        },
        "remaining_promotion_gate_ids": {
          "type": "array",
          "prefixItems": [
            { "const": "replay_recovery_witness" },
            { "const": "terminal_closure_certificate" }
          ],
          "minItems": 2,
          "maxItems": 2
        },
        "approval_criterion_count": { "type": "integer", "const": 7 },
        "scenario_approval_count": { "type": "integer", "const": 5 },
        "runtime_promotion_authorized": { "type": "boolean", "const": false }
      }
    },
    "remaining_promotion_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gate_id",
        "status",
        "required_evidence_ref",
        "blocks_runtime_promotion"
      ],
      "properties": {
        "gate_id": {
          "type": "string",
          "enum": [
            "replay_recovery_witness",
            "terminal_closure_certificate"
          ]
        },
        "status": { "type": "string", "const": "AwaitingEvidence" },
        "required_evidence_ref": {
          "type": "string",
          "pattern": "^unknown://governed-planning-profile/[A-Za-z0-9._:/#-]+$"
        },
        "blocks_runtime_promotion": { "type": "boolean", "const": true }
      }
    },
    "authority_denials": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime_promotion_authorized",
        "execution_allowed",
        "dispatch_allowed",
        "runtime_replanning_enabled",
        "success_claim_allowed",
        "terminal_closure"
      ],
      "properties": {
        "runtime_promotion_authorized": { "type": "boolean", "const": false },
        "execution_allowed": { "type": "boolean", "const": false },
        "dispatch_allowed": { "type": "boolean", "const": false },
        "runtime_replanning_enabled": { "type": "boolean", "const": false },
        "success_claim_allowed": { "type": "boolean", "const": false },
        "terminal_closure": { "type": "boolean", "const": false }
      }
    },
    "validator_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["validator_id", "command"],
      "properties": {
        "validator_id": { "type": "string", "minLength": 1 },
        "command": { "type": "string", "minLength": 1 }
      }
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    }
  }
}
