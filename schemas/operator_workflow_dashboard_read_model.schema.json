{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:operator-workflow-dashboard-read-model:1",
  "title": "OperatorWorkflowDashboardReadModel",
  "description": "Projection-only operator dashboard row model that unifies local workflow status, receipts, safe local action, rollback, and approval boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_ref",
    "read_model_id",
    "projection_only",
    "execution_performed",
    "external_effects_allowed",
    "dashboard_id",
    "mode",
    "task_count",
    "blocked_effects",
    "rows",
    "promotion_filters",
    "source_projections",
    "source_refs",
    "dashboard_hash"
  ],
  "properties": {
    "schema_ref": {"type": "string", "const": "urn:mullusi:schema:operator-workflow-dashboard-read-model:1"},
    "read_model_id": {"type": "string", "const": "operator_workflow_dashboard.read_model"},
    "projection_only": {"type": "boolean", "const": true},
    "execution_performed": {"type": "boolean", "const": false},
    "external_effects_allowed": {"type": "boolean", "const": false},
    "dashboard_id": {"type": "string", "const": "operator_workflow_dashboard.foundation.v1"},
    "mode": {"type": "string", "const": "local_lab"},
    "task_count": {"type": "integer", "minimum": 1, "maximum": 16},
    "blocked_effects": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1, "maxLength": 80}
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "items": {"$ref": "#/$defs/dashboard_row"}
    },
    "source_projections": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "local_workflow_receipt",
        "workflow_status",
        "safe_local_action",
        "capability_passports",
        "closure_packet",
        "safe_local_action_rehearsal",
        "causal_repair"
      ],
      "properties": {
        "local_workflow_receipt": {"type": "string", "minLength": 1, "maxLength": 260},
        "workflow_status": {"type": "string", "const": "operator_developer_workflow_status.read_model"},
        "safe_local_action": {"type": "string", "const": "operator_safe_local_action.read_model"},
        "capability_passports": {"type": "string", "const": "capability_passports.foundation.v1"},
        "closure_packet": {"type": "string", "const": "local_developer_workflow_v1.closure_packet"},
        "safe_local_action_rehearsal": {"type": "string", "const": "safe_local_action_rehearsal.foundation.v1"},
        "causal_repair": {"type": "string", "const": "causal_repair_service.foundation.v1"}
      }
    },
    "promotion_filters": {"$ref": "#/$defs/promotion_filters"},
    "source_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "builder",
        "local_workflow_receipt",
        "closure_packet",
        "safe_local_action_rehearsal",
        "causal_repair"
      ],
      "properties": {
        "builder": {"type": "string", "const": "gateway/operator_workflow_dashboard.py"},
        "local_workflow_receipt": {"type": "string", "minLength": 1, "maxLength": 260},
        "closure_packet": {"type": "string", "minLength": 1, "maxLength": 260},
        "safe_local_action_rehearsal": {"type": "string", "minLength": 1, "maxLength": 260},
        "causal_repair": {"type": "string", "minLength": 1, "maxLength": 260}
      }
    },
    "dashboard_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  },
  "$defs": {
    "dashboard_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task",
        "status",
        "current_gate",
        "missing_evidence",
        "next_action",
        "risk",
        "receipts",
        "rollback",
        "approval_needed",
        "approval",
        "closure_packet",
        "safe_local_action_rehearsal",
        "causal_repair",
        "readiness_lane",
        "source_ref"
      ],
      "properties": {
        "task": {"type": "string", "minLength": 1, "maxLength": 160},
        "status": {"type": "string", "minLength": 1, "maxLength": 120},
        "current_gate": {"$ref": "#/$defs/current_gate"},
        "missing_evidence": {
          "type": "array",
          "maxItems": 8,
          "items": {"type": "string", "minLength": 1, "maxLength": 180}
        },
        "next_action": {"type": "string", "minLength": 1, "maxLength": 260},
        "risk": {"type": "string", "minLength": 1, "maxLength": 160},
        "receipts": {"$ref": "#/$defs/receipts"},
        "rollback": {"$ref": "#/$defs/rollback"},
        "approval_needed": {"type": "boolean"},
        "approval": {"$ref": "#/$defs/approval"},
        "closure_packet": {"$ref": "#/$defs/closure_packet"},
        "safe_local_action_rehearsal": {"$ref": "#/$defs/safe_local_action_rehearsal"},
        "causal_repair": {"$ref": "#/$defs/causal_repair"},
        "readiness_lane": {"$ref": "#/$defs/readiness_lane"},
        "source_ref": {"type": "string", "minLength": 1, "maxLength": 260}
      }
    },
    "promotion_filters": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ladder_id",
        "source_ref",
        "capability_count",
        "level_counts",
        "levels",
        "filter_is_not_execution_authority",
        "live_execution_enabled",
        "external_effects_allowed"
      ],
      "properties": {
        "ladder_id": {"type": "string", "const": "mullu.capability_promotion_ladder.v1"},
        "source_ref": {"type": "string", "minLength": 1, "maxLength": 160},
        "capability_count": {"type": "integer", "minimum": 1, "maximum": 1000},
        "level_counts": {"$ref": "#/$defs/promotion_level_counts"},
        "levels": {
          "type": "array",
          "minItems": 10,
          "maxItems": 10,
          "items": {"$ref": "#/$defs/promotion_filter_level"}
        },
        "filter_is_not_execution_authority": {"type": "boolean", "const": true},
        "live_execution_enabled": {"type": "boolean", "const": false},
        "external_effects_allowed": {"type": "boolean", "const": false}
      }
    },
    "promotion_level_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["L0", "L1", "L2", "L3", "L4", "L5", "L6", "L7", "L8", "L9"],
      "properties": {
        "L0": {"type": "integer", "minimum": 0, "maximum": 1000},
        "L1": {"type": "integer", "minimum": 0, "maximum": 1000},
        "L2": {"type": "integer", "minimum": 0, "maximum": 1000},
        "L3": {"type": "integer", "minimum": 0, "maximum": 1000},
        "L4": {"type": "integer", "minimum": 0, "maximum": 1000},
        "L5": {"type": "integer", "minimum": 0, "maximum": 1000},
        "L6": {"type": "integer", "minimum": 0, "maximum": 1000},
        "L7": {"type": "integer", "minimum": 0, "maximum": 1000},
        "L8": {"type": "integer", "minimum": 0, "maximum": 1000},
        "L9": {"type": "integer", "minimum": 0, "maximum": 1000}
      }
    },
    "promotion_filter_level": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "level_id",
        "level_number",
        "level_name",
        "summary",
        "capability_count",
        "requires_operator_approval",
        "requires_receipt",
        "requires_rollback",
        "requires_live_witness",
        "filter_query",
        "filter_is_not_execution_authority",
        "live_execution_enabled"
      ],
      "properties": {
        "level_id": {"type": "string", "pattern": "^L[0-9]$"},
        "level_number": {"type": "integer", "minimum": 0, "maximum": 9},
        "level_name": {
          "type": "string",
          "enum": [
            "read-only",
            "draft-only",
            "proposal-only",
            "sandbox-write",
            "test-run",
            "pr-preview",
            "pr-create-with-approval",
            "merge-request-with-approval",
            "live-connector-read",
            "live-connector-write"
          ]
        },
        "summary": {"type": "string", "minLength": 1, "maxLength": 220},
        "capability_count": {"type": "integer", "minimum": 0, "maximum": 1000},
        "requires_operator_approval": {"type": "boolean"},
        "requires_receipt": {"type": "boolean"},
        "requires_rollback": {"type": "boolean"},
        "requires_live_witness": {"type": "boolean"},
        "filter_query": {"type": "string", "pattern": "^current_promotion_level == 'L[0-9]'$"},
        "filter_is_not_execution_authority": {"type": "boolean", "const": true},
        "live_execution_enabled": {"type": "boolean", "const": false}
      }
    },
    "current_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stage_id",
        "stage_type",
        "status",
        "evidence",
        "projection_only",
        "execution_performed",
        "external_effects_allowed"
      ],
      "properties": {
        "stage_id": {"type": "string", "minLength": 1, "maxLength": 120},
        "stage_type": {"type": "string", "enum": ["skill_execution", "approval_gate", "observation", "communication", "wait_for_event"]},
        "status": {"type": "string", "minLength": 1, "maxLength": 80},
        "evidence": {"type": "string", "minLength": 1, "maxLength": 260},
        "projection_only": {"type": "boolean", "const": true},
        "execution_performed": {"type": "boolean", "const": false},
        "external_effects_allowed": {"type": "boolean", "const": false}
      }
    },
    "receipts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "completed",
        "required",
        "receipt_hash",
        "receipt_groups",
        "source_ref",
        "execution_performed",
        "external_effects_allowed"
      ],
      "properties": {
        "status": {"type": "string", "enum": ["pending", "complete"]},
        "completed": {"type": "integer", "minimum": 0, "maximum": 16},
        "required": {"type": "integer", "minimum": 0, "maximum": 16},
        "receipt_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "receipt_groups": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "items": {"type": "string", "minLength": 1, "maxLength": 120}
        },
        "source_ref": {"type": "string", "minLength": 1, "maxLength": 260},
        "execution_performed": {"type": "boolean", "const": false},
        "external_effects_allowed": {"type": "boolean", "const": false}
      }
    },
    "rollback": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "status",
        "command_count",
        "executed",
        "execution_performed",
        "external_effects_allowed"
      ],
      "properties": {
        "required": {"type": "boolean"},
        "status": {"type": "string", "enum": ["required_not_executed", "not_required"]},
        "command_count": {"type": "integer", "minimum": 0, "maximum": 16},
        "executed": {"type": "boolean", "const": false},
        "execution_performed": {"type": "boolean", "const": false},
        "external_effects_allowed": {"type": "boolean", "const": false}
      }
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "needed",
        "status",
        "gate",
        "approval_boundary",
        "performed",
        "external_effects_allowed"
      ],
      "properties": {
        "needed": {"type": "boolean"},
        "status": {"type": "string", "minLength": 1, "maxLength": 80},
        "gate": {"type": "string", "minLength": 1, "maxLength": 120},
        "approval_boundary": {"type": "string", "minLength": 1, "maxLength": 120},
        "performed": {"type": "boolean", "const": false},
        "external_effects_allowed": {"type": "boolean", "const": false}
      }
    },
    "closure_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "linked",
        "source_ref",
        "packet_id",
        "status",
        "solver_outcome",
        "current_gate",
        "missing_evidence_refs",
        "next_required_proof_step",
        "approval_boundary",
        "rollback",
        "command_preview_refs",
        "packet_hash",
        "projection_only",
        "execution_performed",
        "external_effects_allowed"
      ],
      "properties": {
        "linked": {"type": "boolean"},
        "source_ref": {"type": "string", "minLength": 1, "maxLength": 260},
        "packet_id": {"type": "string", "minLength": 1, "maxLength": 160},
        "status": {"type": "string", "minLength": 1, "maxLength": 120},
        "solver_outcome": {"type": "string", "minLength": 1, "maxLength": 120},
        "current_gate": {"$ref": "#/$defs/closure_current_gate"},
        "missing_evidence_refs": {
          "type": "array",
          "maxItems": 8,
          "items": {"type": "string", "minLength": 1, "maxLength": 180}
        },
        "next_required_proof_step": {"type": "string", "minLength": 1, "maxLength": 260},
        "approval_boundary": {"$ref": "#/$defs/closure_approval_boundary"},
        "rollback": {"$ref": "#/$defs/closure_rollback"},
        "command_preview_refs": {
          "type": "array",
          "maxItems": 8,
          "items": {"$ref": "#/$defs/closure_command_preview_ref"}
        },
        "packet_hash": {"type": "string", "maxLength": 64},
        "projection_only": {"type": "boolean", "const": true},
        "execution_performed": {"type": "boolean", "const": false},
        "external_effects_allowed": {"type": "boolean", "const": false}
      }
    },
    "closure_current_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gate_id", "gate_type", "status", "projection_only", "execution_performed"],
      "properties": {
        "gate_id": {"type": "string", "minLength": 1, "maxLength": 120},
        "gate_type": {"type": "string", "minLength": 1, "maxLength": 80},
        "status": {"type": "string", "minLength": 1, "maxLength": 120},
        "projection_only": {"type": "boolean", "const": true},
        "execution_performed": {"type": "boolean", "const": false}
      }
    },
    "closure_approval_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "approval_request_id",
        "approval_required",
        "approval_status",
        "approval_performed",
        "approval_does_not_authorize_execution"
      ],
      "properties": {
        "approval_request_id": {"type": "string", "minLength": 1, "maxLength": 120},
        "approval_required": {"type": "boolean"},
        "approval_status": {"type": "string", "minLength": 1, "maxLength": 120},
        "approval_performed": {"type": "boolean", "const": false},
        "approval_does_not_authorize_execution": {"type": "boolean", "const": true}
      }
    },
    "closure_rollback": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "strategy", "rollback_executed", "execution_performed"],
      "properties": {
        "required": {"type": "boolean"},
        "strategy": {"type": "string", "minLength": 1, "maxLength": 180},
        "rollback_executed": {"type": "boolean", "const": false},
        "execution_performed": {"type": "boolean", "const": false}
      }
    },
    "closure_command_preview_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command_id", "effect", "execution_allowed"],
      "properties": {
        "command_id": {"type": "string", "minLength": 1, "maxLength": 120},
        "effect": {"type": "string", "minLength": 1, "maxLength": 120},
        "execution_allowed": {"type": "boolean", "const": false}
      }
    },
    "safe_local_action_rehearsal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "linked",
        "source_ref",
        "receipt_id",
        "capability_id",
        "rehearsal_status",
        "solver_outcome",
        "selected_action",
        "scenario_count",
        "scenario_refs",
        "approval",
        "proof_boundary",
        "blocked_effects",
        "receipt_hash",
        "live_execution_enabled",
        "execution_performed",
        "external_effects_allowed"
      ],
      "properties": {
        "linked": {"type": "boolean"},
        "source_ref": {"type": "string", "minLength": 1, "maxLength": 260},
        "receipt_id": {"type": "string", "minLength": 1, "maxLength": 160},
        "capability_id": {"type": "string", "const": "govern.safe_local_action.rehearsal"},
        "rehearsal_status": {"type": "string", "minLength": 1, "maxLength": 120},
        "solver_outcome": {"type": "string", "minLength": 1, "maxLength": 120},
        "selected_action": {"$ref": "#/$defs/rehearsal_selected_action"},
        "scenario_count": {"type": "integer", "minimum": 0, "maximum": 16},
        "scenario_refs": {
          "type": "array",
          "maxItems": 8,
          "items": {"$ref": "#/$defs/rehearsal_scenario_ref"}
        },
        "approval": {"$ref": "#/$defs/rehearsal_approval"},
        "proof_boundary": {"$ref": "#/$defs/rehearsal_proof_boundary"},
        "blocked_effects": {
          "type": "array",
          "maxItems": 12,
          "items": {"type": "string", "minLength": 1, "maxLength": 80}
        },
        "receipt_hash": {"type": "string", "maxLength": 64},
        "live_execution_enabled": {"type": "boolean", "const": false},
        "execution_performed": {"type": "boolean", "const": false},
        "external_effects_allowed": {"type": "boolean", "const": false}
      }
    },
    "rehearsal_selected_action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["task", "next_action", "current_gate"],
      "properties": {
        "task": {"type": "string", "minLength": 1, "maxLength": 160},
        "next_action": {"type": "string", "minLength": 1, "maxLength": 260},
        "current_gate": {"type": "string", "minLength": 1, "maxLength": 120}
      }
    },
    "rehearsal_scenario_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scenario_id", "status", "mutation_performed"],
      "properties": {
        "scenario_id": {"type": "string", "minLength": 1, "maxLength": 120},
        "status": {"type": "string", "minLength": 1, "maxLength": 80},
        "mutation_performed": {"type": "boolean", "const": false}
      }
    },
    "rehearsal_approval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required_for_live_execution", "approval_status", "approval_performed"],
      "properties": {
        "required_for_live_execution": {"type": "boolean", "const": true},
        "approval_status": {"type": "string", "minLength": 1, "maxLength": 120},
        "approval_performed": {"type": "boolean", "const": false}
      }
    },
    "rehearsal_proof_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rehearsal_is_not_execution_proof", "post_execution_evidence_required"],
      "properties": {
        "rehearsal_is_not_execution_proof": {"type": "boolean", "const": true},
        "post_execution_evidence_required": {"type": "boolean", "const": true}
      }
    },
    "causal_repair": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "linked",
        "source_ref",
        "receipt_id",
        "service_id",
        "service_status",
        "solver_outcome",
        "case_count",
        "high_severity_cases",
        "next_actions",
        "blocked_effects",
        "receipt_hash",
        "live_execution_enabled",
        "repair_execution_performed"
      ],
      "properties": {
        "linked": {"type": "boolean"},
        "source_ref": {"type": "string", "minLength": 1, "maxLength": 260},
        "receipt_id": {"type": "string", "minLength": 1, "maxLength": 160},
        "service_id": {"type": "string", "const": "mcoi.causal_repair.service"},
        "service_status": {"type": "string", "minLength": 1, "maxLength": 120},
        "solver_outcome": {"type": "string", "minLength": 1, "maxLength": 120},
        "case_count": {"type": "integer", "minimum": 0, "maximum": 32},
        "high_severity_cases": {
          "type": "array",
          "maxItems": 8,
          "items": {"type": "string", "minLength": 1, "maxLength": 120}
        },
        "next_actions": {
          "type": "array",
          "maxItems": 8,
          "items": {"$ref": "#/$defs/causal_repair_next_action"}
        },
        "blocked_effects": {
          "type": "array",
          "maxItems": 12,
          "items": {"type": "string", "minLength": 1, "maxLength": 80}
        },
        "receipt_hash": {"type": "string", "maxLength": 64},
        "live_execution_enabled": {"type": "boolean", "const": false},
        "repair_execution_performed": {"type": "boolean", "const": false}
      }
    },
    "causal_repair_next_action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["failure_id", "operator_outcome", "next_action", "execution_performed"],
      "properties": {
        "failure_id": {"type": "string", "minLength": 1, "maxLength": 120},
        "operator_outcome": {"type": "string", "minLength": 1, "maxLength": 120},
        "next_action": {"type": "string", "minLength": 1, "maxLength": 260},
        "execution_performed": {"type": "boolean", "const": false}
      }
    },
    "readiness_lane": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lane_id",
        "lane_status",
        "proof_state",
        "operator_outcome",
        "primary_blocker",
        "current_gate_id",
        "next_action",
        "required_evidence_refs",
        "linked_receipts",
        "readiness_is_not_execution_authority",
        "projection_only",
        "execution_authority_granted",
        "live_execution_enabled",
        "external_effects_allowed"
      ],
      "properties": {
        "lane_id": {"type": "string", "const": "operator_workflow_dashboard.readiness_lane.foundation.v1"},
        "lane_status": {
          "type": "string",
          "enum": [
            "awaiting_closure_packet",
            "awaiting_rehearsal_receipt",
            "awaiting_causal_repair_receipt",
            "blocked_by_causal_repair",
            "awaiting_approval_evidence",
            "awaiting_evidence",
            "ready_for_review_only_handoff"
          ]
        },
        "proof_state": {"type": "string", "minLength": 1, "maxLength": 120},
        "operator_outcome": {"type": "string", "minLength": 1, "maxLength": 120},
        "primary_blocker": {"type": "string", "minLength": 1, "maxLength": 160},
        "current_gate_id": {"type": "string", "minLength": 1, "maxLength": 120},
        "next_action": {"type": "string", "minLength": 1, "maxLength": 260},
        "required_evidence_refs": {
          "type": "array",
          "maxItems": 12,
          "items": {"type": "string", "minLength": 1, "maxLength": 180}
        },
        "linked_receipts": {"$ref": "#/$defs/readiness_linked_receipts"},
        "readiness_is_not_execution_authority": {"type": "boolean", "const": true},
        "projection_only": {"type": "boolean", "const": true},
        "execution_authority_granted": {"type": "boolean", "const": false},
        "live_execution_enabled": {"type": "boolean", "const": false},
        "external_effects_allowed": {"type": "boolean", "const": false}
      }
    },
    "readiness_linked_receipts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["closure_packet", "safe_local_action_rehearsal", "causal_repair"],
      "properties": {
        "closure_packet": {"type": "boolean"},
