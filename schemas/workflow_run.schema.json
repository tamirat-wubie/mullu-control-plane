{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:workflow-run:1",
  "title": "WorkflowRun",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "workflow_run_id",
    "workflow_id",
    "tenant_id",
    "actor_id",
    "goal",
    "status",
    "tasks",
    "task_runs",
    "evidence_refs",
    "terminal_certificate_id",
    "run_hash",
    "metadata"
  ],
  "properties": {
    "workflow_run_id": {
      "type": "string",
      "minLength": 1
    },
    "workflow_id": {
      "type": "string",
      "minLength": 1
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "actor_id": {
      "type": "string",
      "minLength": 1
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "created",
        "planned",
        "waiting_for_approval",
        "approved",
        "executing",
        "waiting_for_verification",
        "committed",
        "compensated",
        "accepted_risk",
        "requires_review",
        "failed"
      ]
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/task_spec"
      }
    },
    "task_runs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/task_run"
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "terminal_certificate_id": {
      "type": "string"
    },
    "run_hash": {
      "type": "string",
      "minLength": 32
    },
    "metadata": {
      "type": "object"
    }
  },
  "$defs": {
    "task_spec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_id",
        "task_type",
        "action",
        "depends_on",
        "approval_required",
        "verification_required",
        "retry_limit",
        "compensation_task_id",
        "evidence_required",
        "metadata"
      ],
      "properties": {
        "task_id": {
          "type": "string",
          "minLength": 1
        },
        "task_type": {
          "type": "string",
          "enum": [
            "task",
            "approval_task",
            "human_review_task",
            "wait_until",
            "retry",
            "compensate",
            "verify_effect",
            "close_certificate"
          ]
        },
        "action": {
          "type": "string",
          "minLength": 1
        },
        "depends_on": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "approval_required": {
          "type": "boolean"
        },
        "verification_required": {
          "type": "boolean"
        },
        "retry_limit": {
          "type": "integer",
          "minimum": 0
        },
        "compensation_task_id": {
          "type": "string"
        },
        "evidence_required": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "metadata": {
          "type": "object"
        }
      }
    },
    "task_run": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_run_id",
        "workflow_run_id",
        "task_id",
        "status",
        "attempts",
        "max_attempts",
        "approval_ref",
        "evidence_refs",
        "terminal_certificate_id",
        "failure_reason",
        "task_hash",
        "metadata"
      ],
      "properties": {
        "task_run_id": {
          "type": "string",
          "minLength": 1
        },
        "workflow_run_id": {
          "type": "string",
          "minLength": 1
        },
        "task_id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "created",
            "waiting_for_approval",
            "approved",
            "executing",
            "waiting_for_verification",
            "committed",
            "compensated",
            "requires_review",
            "failed"
          ]
        },
        "attempts": {
          "type": "integer",
          "minimum": 0
        },
        "max_attempts": {
          "type": "integer",
          "minimum": 0
        },
        "approval_ref": {
          "type": "string"
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "terminal_certificate_id": {
          "type": "string"
        },
        "failure_reason": {
          "type": "string"
        },
        "task_hash": {
          "type": "string",
          "minLength": 32
        },
        "metadata": {
          "type": "object"
        }
      }
    }
  }
}
