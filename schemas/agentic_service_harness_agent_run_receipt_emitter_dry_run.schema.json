{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:agentic-service-harness-agent-run-receipt-emitter-dry-run:1",
  "title": "Agentic Service Harness AgentRun Receipt Emitter Dry Run",
  "description": "Foundation Mode dry-run receipt for the AgentRun read-model surface receipt emitter. This schema records only simulated receipt emission and an append-admission denial; it does not admit live adapter execution, runtime writes, branch creation, pull-request creation, mutation routes, receipt-store append, deployment, DNS mutation, secret serialization, destructive operations, or terminal closure.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "report_id",
    "schema_version",
    "generated_at",
    "solver_outcome",
    "source_contract_ref",
    "scope",
    "dry_run_contract",
    "simulated_receipt_emission",
    "append_admission_gate",
    "authority_denials",
    "receipt_refs",
    "validators",
    "next_action",
    "report_is_not_terminal_closure",
    "terminal_closure_required"
  ],
  "properties": {
    "report_id": {
      "type": "string",
      "const": "agentic_service_harness_agent_run_receipt_emitter_dry_run"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "solver_outcome": {
      "type": "string",
      "const": "SolvedVerified"
    },
    "source_contract_ref": {
      "type": "string",
      "const": "examples/agentic_service_harness_read_models.foundation.json"
    },
    "scope": {
      "$ref": "#/$defs/scope"
    },
    "dry_run_contract": {
      "$ref": "#/$defs/dry_run_contract"
    },
    "simulated_receipt_emission": {
      "$ref": "#/$defs/simulated_receipt_emission"
    },
    "append_admission_gate": {
      "$ref": "#/$defs/append_admission_gate"
    },
    "authority_denials": {
      "$ref": "#/$defs/authority_denials"
    },
    "receipt_refs": {
      "$ref": "#/$defs/receipt_refs"
    },
    "validators": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/validator_ref"
      }
    },
    "next_action": {
      "type": "string",
      "minLength": 1
    },
    "report_is_not_terminal_closure": {
      "type": "boolean",
      "const": true
    },
    "terminal_closure_required": {
      "type": "boolean",
      "const": true
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "evidence_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/#$-]*$"
    },
    "evidence_ref_list": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/evidence_ref"
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tenant_id",
        "organization_id",
        "project_id",
        "repository_connection_id",
        "repository_slug",
        "agent_run_id",
        "agent_run_mode",
        "foundation_phase",
        "read_only",
        "dry_run_only",
        "receipt_store_append_enabled",
        "external_adapter_integrated",
        "secret_values_serialized"
      ],
      "properties": {
        "tenant_id": { "$ref": "#/$defs/identifier" },
        "organization_id": { "$ref": "#/$defs/identifier" },
        "project_id": { "$ref": "#/$defs/identifier" },
        "repository_connection_id": { "$ref": "#/$defs/identifier" },
        "repository_slug": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
        },
        "agent_run_id": {
          "type": "string",
          "const": "run-read-model-foundation"
        },
        "agent_run_mode": {
          "type": "string",
          "const": "read_only"
        },
        "foundation_phase": {
          "type": "string",
          "const": "foundation_dry_run_only"
        },
        "read_only": {
          "type": "boolean",
          "const": true
        },
        "dry_run_only": {
          "type": "boolean",
          "const": true
        },
        "receipt_store_append_enabled": {
          "type": "boolean",
          "const": false
        },
        "external_adapter_integrated": {
          "type": "boolean",
          "const": false
        },
        "secret_values_serialized": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "dry_run_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "emitter_id",
        "emitter_mode",
        "source_task_ref",
        "allowed_action_classes",
        "forbidden_action_classes",
        "required_source_refs",
        "required_gate_refs",
        "emission_obligations_checked",
        "validation_refs",
        "read_only"
      ],
      "properties": {
        "emitter_id": {
          "type": "string",
          "const": "agent-run-receipt-emitter-dry-run-foundation"
        },
        "emitter_mode": {
          "type": "string",
          "const": "EMITTER_DRY_RUN_ONLY"
        },
        "source_task_ref": {
          "type": "string",
          "const": "task://agentic-service-harness/agent-run-read-model-foundation"
        },
        "allowed_action_classes": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1,
          "items": {
            "type": "string",
            "const": "dry_run"
          }
        },
        "forbidden_action_classes": {
          "type": "array",
          "minItems": 6,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "execute_adapter",
              "write_to_branch",
              "open_pr",
              "append_receipt_store",
              "deploy",
              "dns_mutation",
              "secret_mutation",
              "destructive_operation",
              "terminal_closure"
            ]
          }
        },
        "required_source_refs": {
          "$ref": "#/$defs/evidence_ref_list"
        },
        "required_gate_refs": {
          "$ref": "#/$defs/evidence_ref_list"
        },
        "emission_obligations_checked": {
          "$ref": "#/$defs/evidence_ref_list"
        },
        "validation_refs": {
          "$ref": "#/$defs/evidence_ref_list"
        },
        "read_only": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "simulated_receipt_emission": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "result_state",
        "simulated_receipt_kind",
        "dry_run_receipt_recorded",
        "runtime_receipt_emitted",
        "receipt_store_appended",
        "adapter_executed",
        "branch_created",
        "pull_request_opened",
        "runtime_state_written",
        "mutation_route_called",
        "external_effects_observed",
        "filesystem_writes_observed",
        "connector_calls_observed",
        "raw_output_included",
        "raw_secret_material_included",
        "output_digest",
        "terminal_closure",
        "success_claim_allowed"
      ],
      "properties": {
        "result_state": {
          "type": "string",
          "const": "DRY_RUN_RECORDED"
        },
        "simulated_receipt_kind": {
          "type": "string",
          "const": "future_agent_run_receipt"
        },
        "dry_run_receipt_recorded": {
          "type": "boolean",
          "const": true
        },
        "runtime_receipt_emitted": {
          "type": "boolean",
          "const": false
        },
        "receipt_store_appended": {
          "type": "boolean",
          "const": false
        },
        "adapter_executed": {
          "type": "boolean",
          "const": false
        },
        "branch_created": {
          "type": "boolean",
          "const": false
        },
        "pull_request_opened": {
          "type": "boolean",
          "const": false
        },
        "runtime_state_written": {
          "type": "boolean",
          "const": false
        },
        "mutation_route_called": {
          "type": "boolean",
          "const": false
        },
        "external_effects_observed": {
          "type": "boolean",
          "const": false
        },
        "filesystem_writes_observed": {
          "type": "boolean",
          "const": false
        },
        "connector_calls_observed": {
          "type": "boolean",
          "const": false
        },
        "raw_output_included": {
          "type": "boolean",
          "const": false
        },
        "raw_secret_material_included": {
          "type": "boolean",
          "const": false
        },
        "output_digest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "terminal_closure": {
          "type": "boolean",
          "const": false
        },
        "success_claim_allowed": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "append_admission_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision",
        "append_admitted",
        "append_target_ref",
        "required_before_append_refs",
        "blocked_reason_refs",
        "terminal_closure_allowed"
      ],
      "properties": {
        "decision": {
          "type": "string",
          "const": "APPEND_BLOCKED_AWAITING_APPROVAL_AND_STORE_BINDING"
        },
        "append_admitted": {
          "type": "boolean",
          "const": false
        },
        "append_target_ref": {
          "type": "string",
          "const": "receipt-store://agentic-service-harness/agent-run"
        },
        "required_before_append_refs": {
          "$ref": "#/$defs/evidence_ref_list"
        },
        "blocked_reason_refs": {
          "$ref": "#/$defs/evidence_ref_list"
        },
        "terminal_closure_allowed": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "authority_denials": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "live_adapter_execution_enabled",
        "receipt_store_append_enabled",
        "branch_write_enabled",
        "pull_request_creation_enabled",
        "runtime_state_write_enabled",
        "mutation_route_enabled",
        "deployment_enabled",
        "dns_mutation_enabled",
        "secret_mutation_enabled",
        "destructive_operation_enabled",
        "terminal_closure",
        "default_high_risk_authority"
      ],
      "properties": {
        "live_adapter_execution_enabled": { "type": "boolean", "const": false },
        "receipt_store_append_enabled": { "type": "boolean", "const": false },
        "branch_write_enabled": { "type": "boolean", "const": false },
        "pull_request_creation_enabled": { "type": "boolean", "const": false },
        "runtime_state_write_enabled": { "type": "boolean", "const": false },
        "mutation_route_enabled": { "type": "boolean", "const": false },
        "deployment_enabled": { "type": "boolean", "const": false },
        "dns_mutation_enabled": { "type": "boolean", "const": false },
        "secret_mutation_enabled": { "type": "boolean", "const": false },
        "destructive_operation_enabled": { "type": "boolean", "const": false },
        "terminal_closure": { "type": "boolean", "const": false },
        "default_high_risk_authority": { "type": "boolean", "const": false }
      }
    },
    "receipt_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "agent_run_receipt_emitter_dry_run_schema",
        "read_models_schema",
        "agentic_service_harness_schema",
        "agentic_service_harness_read_models_schema"
      ],
      "properties": {
        "agent_run_receipt_emitter_dry_run_schema": {
          "type": "string",
          "const": "schemas/agentic_service_harness_agent_run_receipt_emitter_dry_run.schema.json"
        },
        "read_models_schema": {
          "type": "string",
          "const": "schemas/agentic_service_harness_read_models.schema.json"
        },
        "agentic_service_harness_schema": {
          "type": "string",
          "const": "schemas/agentic_service_harness.schema.json"
        },
        "agentic_service_harness_read_models_schema": {
          "type": "string",
          "const": "schemas/agentic_service_harness_read_models.schema.json"
        }
      }
    },
    "validator_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["validator_id", "command", "required_for_closure"],
      "properties": {
        "validator_id": { "$ref": "#/$defs/identifier" },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "required_for_closure": {
          "type": "boolean"
        }
      }
    }
  }
}
