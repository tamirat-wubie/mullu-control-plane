{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:component-route-family-promotion-route-binding-decision-report:1",
  "title": "Mullu Component Route-Family Promotion Route-Binding Decision Report",
  "description": "Read-only Component Harness report that records a denial-only route-binding decision without mutating router inventory.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "route_binding_decision_report_id",
    "mode",
    "governed",
    "target_surface_id",
    "target_component_id",
    "decision",
    "preflight_outcome",
    "outcome",
    "route_binding_decision_state",
    "promotion_decision",
    "authority_decision_state",
    "record_evidence_satisfied",
    "action_requirement_satisfied",
    "authority_granted",
    "route_binding_authorized",
    "router_inventory_delta_authorized",
    "selected_component_binding_authorized",
    "route_family_ownership_authorized",
    "route_binding_decision_is_not_router_mutation",
    "route_binding_decision_is_not_promotion_approval",
    "route_binding_decision_is_not_authority_grant",
    "foundation_fixture_decision_is_not_live_operator_evidence",
    "separate_router_inventory_delta_required",
    "separate_route_binding_receipt_required",
    "separate_lifecycle_transition_required",
    "separate_authority_upgrade_witness_required",
    "separate_product_ownership_decision_required",
    "terminal_closure_required",
    "live_execution_enabled",
    "live_connector_send_enabled",
    "can_execute",
    "can_mutate",
    "can_call_connector",
    "can_claim_terminal_closure",
    "mutates_router_inventory",
    "ready_for_promotion",
    "source_refs",
    "summary",
    "route_binding_decisions",
    "route_binding_decision_refs",
    "source_authority_decision_refs",
    "authority_fuse_refs",
    "authority_fuse_blocking_refs",
    "satisfied_gate_evaluation_refs",
    "accepted_record_refs",
    "route_binding_receipt_refs",
    "router_inventory_delta_refs",
    "selected_component_binding_refs",
    "authority_grant_refs",
    "promotion_approval_refs",
    "lifecycle_transition_refs",
    "terminal_closure_refs",
    "accepted_evidence_refs",
    "rejected_evidence_refs",
    "approval_evidence_required",
    "required_followup_decisions",
    "missing_route_binding_witnesses",
    "operator_submission_channels",
    "blocked_actions",
    "expected_receipts",
    "validators",
    "next_action"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "route_binding_decision_report_id": { "$ref": "#/$defs/identifier" },
    "mode": { "type": "string", "enum": ["foundation", "read_only"] },
    "governed": { "type": "boolean", "const": true },
    "target_surface_id": { "$ref": "#/$defs/identifier" },
    "target_component_id": { "$ref": "#/$defs/identifier" },
    "decision": { "type": "string", "const": "blocked" },
    "preflight_outcome": { "type": "string", "const": "GovernanceBlocked" },
    "outcome": { "type": "string", "const": "AwaitingEvidence" },
    "route_binding_decision_state": {
      "type": "string",
      "const": "denied_pending_router_inventory_witness"
    },
    "promotion_decision": {
      "type": "string",
      "const": "blocked_route_binding_not_authorized"
    },
    "authority_decision_state": {
      "type": "string",
      "const": "denied_pending_governed_witnesses"
    },
    "record_evidence_satisfied": { "type": "boolean", "const": true },
    "action_requirement_satisfied": { "type": "boolean", "const": false },
    "authority_granted": { "type": "boolean", "const": false },
    "route_binding_authorized": { "type": "boolean", "const": false },
    "router_inventory_delta_authorized": { "type": "boolean", "const": false },
    "selected_component_binding_authorized": { "type": "boolean", "const": false },
    "route_family_ownership_authorized": { "type": "boolean", "const": false },
    "route_binding_decision_is_not_router_mutation": { "type": "boolean", "const": true },
    "route_binding_decision_is_not_promotion_approval": { "type": "boolean", "const": true },
    "route_binding_decision_is_not_authority_grant": { "type": "boolean", "const": true },
    "foundation_fixture_decision_is_not_live_operator_evidence": { "type": "boolean", "const": true },
    "separate_router_inventory_delta_required": { "type": "boolean", "const": true },
    "separate_route_binding_receipt_required": { "type": "boolean", "const": true },
    "separate_lifecycle_transition_required": { "type": "boolean", "const": true },
    "separate_authority_upgrade_witness_required": { "type": "boolean", "const": true },
    "separate_product_ownership_decision_required": { "type": "boolean", "const": true },
    "terminal_closure_required": { "type": "boolean", "const": true },
    "live_execution_enabled": { "type": "boolean", "const": false },
    "live_connector_send_enabled": { "type": "boolean", "const": false },
    "can_execute": { "type": "boolean", "const": false },
    "can_mutate": { "type": "boolean", "const": false },
    "can_call_connector": { "type": "boolean", "const": false },
    "can_claim_terminal_closure": { "type": "boolean", "const": false },
    "mutates_router_inventory": { "type": "boolean", "const": false },
    "ready_for_promotion": { "type": "boolean", "const": false },
    "source_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "authority_decision_report",
        "component_authority_fuse",
        "gate_satisfaction_evaluator",
        "promotion_preflight",
        "proof_matrix"
      ],
      "properties": {
        "authority_decision_report": { "$ref": "#/$defs/repo_path" },
        "component_authority_fuse": { "$ref": "#/$defs/repo_path" },
        "gate_satisfaction_evaluator": { "$ref": "#/$defs/repo_path" },
        "promotion_preflight": { "$ref": "#/$defs/repo_path" },
        "proof_matrix": { "$ref": "#/$defs/repo_path" }
      }
    },
    "summary": { "$ref": "#/$defs/summary" },
    "route_binding_decisions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/route_binding_decision" }
    },
    "route_binding_decision_refs": { "$ref": "#/$defs/single_ref" },
    "source_authority_decision_refs": { "$ref": "#/$defs/single_ref" },
    "authority_fuse_refs": { "$ref": "#/$defs/single_ref" },
    "authority_fuse_blocking_refs": { "$ref": "#/$defs/single_ref" },
    "satisfied_gate_evaluation_refs": { "$ref": "#/$defs/single_ref" },
    "accepted_record_refs": { "$ref": "#/$defs/single_ref" },
    "route_binding_receipt_refs": { "$ref": "#/$defs/empty_refs" },
    "router_inventory_delta_refs": { "$ref": "#/$defs/empty_refs" },
    "selected_component_binding_refs": { "$ref": "#/$defs/empty_refs" },
    "authority_grant_refs": { "$ref": "#/$defs/empty_refs" },
    "promotion_approval_refs": { "$ref": "#/$defs/empty_refs" },
    "lifecycle_transition_refs": { "$ref": "#/$defs/empty_refs" },
    "terminal_closure_refs": { "$ref": "#/$defs/empty_refs" },
    "accepted_evidence_refs": { "$ref": "#/$defs/empty_refs" },
    "rejected_evidence_refs": { "$ref": "#/$defs/empty_refs" },
    "approval_evidence_required": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/identifier_or_ref" }
    },
    "required_followup_decisions": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/identifier" }
    },
    "missing_route_binding_witnesses": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/identifier" }
    },
    "operator_submission_channels": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/identifier_or_ref" }
    },
    "blocked_actions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/identifier" }
    },
    "expected_receipts": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/identifier" }
    },
    "validators": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/identifier" }
    },
    "next_action": { "type": "string", "minLength": 1, "maxLength": 420 }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "identifier_or_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/#{}@+ -]*$"
    },
    "repo_path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9._~:/{}@+ -]+$"
    },
    "empty_refs": {
      "type": "array",
      "maxItems": 0,
      "items": { "$ref": "#/$defs/identifier_or_ref" }
    },
    "single_ref": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/identifier" }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "route_binding_decision_count",
        "route_binding_denial_count",
        "route_binding_authorization_count",
        "router_inventory_delta_authorization_count",
        "router_inventory_mutation_count",
        "selected_component_binding_count",
        "authority_grant_count",
        "promotion_approval_count",
        "accepted_evidence_count",
        "rejected_evidence_count",
        "accepted_record_count",
        "route_binding_receipt_count",
        "authority_fuse_blocking_count",
        "router_inventory_delta_ref_count",
        "approval_artifact_requirement_count",
        "required_followup_decision_count"
      ],
      "properties": {
        "route_binding_decision_count": { "type": "integer", "const": 1 },
        "route_binding_denial_count": { "type": "integer", "const": 1 },
        "route_binding_authorization_count": { "type": "integer", "const": 0 },
        "router_inventory_delta_authorization_count": { "type": "integer", "const": 0 },
        "router_inventory_mutation_count": { "type": "integer", "const": 0 },
        "selected_component_binding_count": { "type": "integer", "const": 0 },
        "authority_grant_count": { "type": "integer", "const": 0 },
        "promotion_approval_count": { "type": "integer", "const": 0 },
        "accepted_evidence_count": { "type": "integer", "const": 0 },
        "rejected_evidence_count": { "type": "integer", "const": 0 },
        "accepted_record_count": { "type": "integer", "const": 1 },
        "route_binding_receipt_count": { "type": "integer", "const": 0 },
        "authority_fuse_blocking_count": { "type": "integer", "const": 1 },
        "router_inventory_delta_ref_count": { "type": "integer", "const": 0 },
        "approval_artifact_requirement_count": { "type": "integer", "minimum": 1 },
        "required_followup_decision_count": { "type": "integer", "const": 5 }
      }
    },
    "route_binding_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "route_binding_decision_id",
        "source_authority_decision_id",
        "source_gate_evaluation_id",
        "source_operator_submitted_record_id",
        "gate_id",
        "record_kind",
        "evidence_key",
        "decision_state",
        "decision_basis",
        "proof_state",
        "record_evidence_satisfied",
        "source_authority_decision_denied",
        "authority_fuse_blocks_promotion",
        "requires_external_authority_upgrade_evidence",
        "action_requirement_satisfied",
        "route_binding_authorized",
        "router_inventory_delta_authorized",
        "selected_component_binding_authorized",
        "route_family_ownership_authorized",
        "authority_granted",
        "promotion_approved",
        "can_execute",
        "can_mutate",
        "can_call_connector",
        "can_claim_terminal_closure",
        "mutates_router_inventory",
        "requires_router_inventory_delta",
        "requires_component_route_binding_receipt",
        "requires_lifecycle_transition",
        "requires_authority_upgrade_witness",
        "requires_product_ownership_decision",
        "requires_terminal_closure",
        "decision_is_not_router_mutation",
        "decision_is_not_promotion_approval",
        "decision_is_not_authority_grant",
        "foundation_fixture_decision_is_not_live_operator_evidence",
        "source_authority_decision_refs",
        "authority_fuse_refs",
        "authority_fuse_blocking_refs",
        "satisfied_gate_evaluation_refs",
        "accepted_record_refs",
        "route_binding_receipt_refs",
        "router_inventory_delta_refs",
        "selected_component_binding_refs",
        "authority_grant_refs",
        "promotion_approval_refs",
        "accepted_evidence_refs",
        "rejected_evidence_refs",
        "missing_route_binding_witnesses",
        "decision_reason"
      ],
      "properties": {
        "route_binding_decision_id": { "$ref": "#/$defs/identifier" },
        "source_authority_decision_id": { "$ref": "#/$defs/identifier" },
        "source_gate_evaluation_id": { "$ref": "#/$defs/identifier" },
        "source_operator_submitted_record_id": { "$ref": "#/$defs/identifier" },
        "gate_id": { "type": "string", "const": "route_binding_gate" },
        "record_kind": { "type": "string", "const": "route_binding" },
        "evidence_key": { "$ref": "#/$defs/identifier" },
        "decision_state": { "type": "string", "const": "denied" },
        "decision_basis": { "type": "string", "const": "authority_decision_denial" },
        "proof_state": { "type": "string", "const": "Pass" },
        "record_evidence_satisfied": { "type": "boolean", "const": true },
        "source_authority_decision_denied": { "type": "boolean", "const": true },
        "authority_fuse_blocks_promotion": { "type": "boolean", "const": true },
        "requires_external_authority_upgrade_evidence": { "type": "boolean", "const": true },
        "action_requirement_satisfied": { "type": "boolean", "const": false },
        "route_binding_authorized": { "type": "boolean", "const": false },
        "router_inventory_delta_authorized": { "type": "boolean", "const": false },
        "selected_component_binding_authorized": { "type": "boolean", "const": false },
        "route_family_ownership_authorized": { "type": "boolean", "const": false },
        "authority_granted": { "type": "boolean", "const": false },
        "promotion_approved": { "type": "boolean", "const": false },
        "can_execute": { "type": "boolean", "const": false },
        "can_mutate": { "type": "boolean", "const": false },
        "can_call_connector": { "type": "boolean", "const": false },
        "can_claim_terminal_closure": { "type": "boolean", "const": false },
        "mutates_router_inventory": { "type": "boolean", "const": false },
        "requires_router_inventory_delta": { "type": "boolean", "const": true },
        "requires_component_route_binding_receipt": { "type": "boolean", "const": true },
        "requires_lifecycle_transition": { "type": "boolean", "const": true },
        "requires_authority_upgrade_witness": { "type": "boolean", "const": true },
        "requires_product_ownership_decision": { "type": "boolean", "const": true },
        "requires_terminal_closure": { "type": "boolean", "const": true },
        "decision_is_not_router_mutation": { "type": "boolean", "const": true },
        "decision_is_not_promotion_approval": { "type": "boolean", "const": true },
        "decision_is_not_authority_grant": { "type": "boolean", "const": true },
        "foundation_fixture_decision_is_not_live_operator_evidence": { "type": "boolean", "const": true },
        "source_authority_decision_refs": { "$ref": "#/$defs/single_ref" },
        "authority_fuse_refs": { "$ref": "#/$defs/single_ref" },
        "authority_fuse_blocking_refs": { "$ref": "#/$defs/single_ref" },
        "satisfied_gate_evaluation_refs": { "$ref": "#/$defs/single_ref" },
        "accepted_record_refs": { "$ref": "#/$defs/single_ref" },
        "route_binding_receipt_refs": { "$ref": "#/$defs/empty_refs" },
        "router_inventory_delta_refs": { "$ref": "#/$defs/empty_refs" },
        "selected_component_binding_refs": { "$ref": "#/$defs/empty_refs" },
        "authority_grant_refs": { "$ref": "#/$defs/empty_refs" },
        "promotion_approval_refs": { "$ref": "#/$defs/empty_refs" },
        "accepted_evidence_refs": { "$ref": "#/$defs/empty_refs" },
        "rejected_evidence_refs": { "$ref": "#/$defs/empty_refs" },
        "missing_route_binding_witnesses": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/identifier" }
        },
        "decision_reason": { "type": "string", "minLength": 1, "maxLength": 260 }
      }
    }
  }
}
