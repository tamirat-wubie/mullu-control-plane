{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:agentic-service-harness-dashboard-data-contract:1",
  "title": "Agentic Service Harness Dashboard Data Contract",
  "description": "Foundation Mode read-only data contract for a future Agentic Service Harness dashboard. This contract defines display data, widget bindings, and state evidence without creating UI, admitting routes, executing adapters, appending receipts, serializing secrets, or claiming terminal closure.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "report_id",
    "schema_version",
    "generated_at",
    "solver_outcome",
    "source_read_model_ref",
    "source_task_intake_ref",
    "scope",
    "data_contract",
    "widgets",
    "data_bindings",
    "screen_states",
    "authority_denials",
    "receipt_refs",
    "validators",
    "next_action",
    "report_is_not_terminal_closure",
    "terminal_closure_required"
  ],
  "properties": {
    "report_id": {
      "type": "string",
      "const": "agentic_service_harness_dashboard_data_contract"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "solver_outcome": {
      "type": "string",
      "const": "SolvedVerified"
    },
    "source_read_model_ref": {
      "type": "string",
      "const": "examples/agentic_service_harness_read_models.foundation.json"
    },
    "source_task_intake_ref": {
      "type": "string",
      "const": "examples/agentic_service_harness_github_repo_task_intake.foundation.json"
    },
    "scope": {
      "$ref": "#/$defs/scope"
    },
    "data_contract": {
      "$ref": "#/$defs/data_contract"
    },
    "widgets": {
      "type": "array",
      "minItems": 7,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/widget_contract"
      }
    },
    "data_bindings": {
      "type": "array",
      "minItems": 7,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/data_binding"
      }
    },
    "screen_states": {
      "type": "array",
      "minItems": 4,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/screen_state"
      }
    },
    "authority_denials": {
      "$ref": "#/$defs/authority_denials"
    },
    "receipt_refs": {
      "$ref": "#/$defs/receipt_refs"
    },
    "validators": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/validator_ref"
      }
    },
    "next_action": {
      "type": "string",
      "minLength": 1
    },
    "report_is_not_terminal_closure": {
      "type": "boolean",
      "const": true
    },
    "terminal_closure_required": {
      "type": "boolean",
      "const": true
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "evidence_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/#$-]*$"
    },
    "evidence_ref_list": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/evidence_ref"
      }
    },
    "string_list": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 128
      }
    },
    "source_collection": {
      "type": "string",
      "enum": [
        "accounts",
        "projects",
        "repositories",
        "runs",
        "approvals",
        "receipts",
        "evidence",
        "result_summaries",
        "workspace_allocations",
        "permission_snapshot",
        "github_repo_task_intake"
      ]
    },
    "widget_id": {
      "type": "string",
      "enum": [
        "account_summary",
        "repository_connection",
        "run_status",
        "approval_gate",
        "receipt_evidence",
        "workspace_safety",
        "readiness_next_action"
      ]
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tenant_id",
        "organization_id",
        "project_id",
        "dashboard_contract_id",
        "foundation_phase",
        "read_only",
        "dashboard_implemented",
        "ui_created",
        "route_admitted",
        "mutation_endpoints_admitted",
        "external_adapter_integrated",
        "adapter_executed",
        "runtime_state_write_enabled",
        "receipt_store_append_enabled",
        "secret_values_serialized"
      ],
      "properties": {
        "tenant_id": { "$ref": "#/$defs/identifier" },
        "organization_id": { "$ref": "#/$defs/identifier" },
        "project_id": { "$ref": "#/$defs/identifier" },
        "dashboard_contract_id": { "$ref": "#/$defs/identifier" },
        "foundation_phase": {
          "type": "string",
          "const": "foundation_read_only_dashboard_data_contract"
        },
        "read_only": {
          "type": "boolean",
          "const": true
        },
        "dashboard_implemented": {
          "type": "boolean",
          "const": false
        },
        "ui_created": {
          "type": "boolean",
          "const": false
        },
        "route_admitted": {
          "type": "boolean",
          "const": false
        },
        "mutation_endpoints_admitted": {
          "type": "boolean",
          "const": false
        },
        "external_adapter_integrated": {
          "type": "boolean",
          "const": false
        },
        "adapter_executed": {
          "type": "boolean",
          "const": false
        },
        "runtime_state_write_enabled": {
          "type": "boolean",
          "const": false
        },
        "receipt_store_append_enabled": {
          "type": "boolean",
          "const": false
        },
        "secret_values_serialized": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "data_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision",
        "display_surface",
        "binding_mode",
        "source_collections",
        "update_strategy",
        "redaction_policy",
        "allowed_action_classes",
        "forbidden_action_classes",
        "required_gate_refs",
        "blocked_reason_refs",
        "polling_enabled",
        "subscription_enabled",
        "route_registered",
        "mutation_controls_allowed",
        "approval_required_for_effects",
        "read_only"
      ],
      "properties": {
        "decision": {
          "type": "string",
          "const": "READ_ONLY_DASHBOARD_DATA_CONTRACT_ACCEPTED"
        },
        "display_surface": {
          "type": "string",
          "const": "future_dashboard_data_contract"
        },
        "binding_mode": {
          "type": "string",
          "const": "read_only_projection"
        },
        "source_collections": {
          "type": "array",
          "minItems": 11,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/source_collection"
          }
        },
        "update_strategy": {
          "type": "string",
          "const": "static_foundation_snapshot"
        },
        "redaction_policy": {
          "type": "string",
          "const": "hash_or_reference_only"
        },
        "allowed_action_classes": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1,
          "items": {
            "type": "string",
            "const": "read_only"
          }
        },
        "forbidden_action_classes": {
          "type": "array",
          "minItems": 10,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "create_ui",
              "register_route",
              "mutation_endpoint",
              "execute_adapter",
              "write_to_branch",
              "open_pr",
              "append_receipt_store",
              "deploy",
              "dns_mutation",
              "secret_mutation",
              "destructive_operation",
              "terminal_closure"
            ]
          }
        },
        "required_gate_refs": { "$ref": "#/$defs/evidence_ref_list" },
        "blocked_reason_refs": { "$ref": "#/$defs/evidence_ref_list" },
        "polling_enabled": {
          "type": "boolean",
          "const": false
        },
        "subscription_enabled": {
          "type": "boolean",
          "const": false
        },
        "route_registered": {
          "type": "boolean",
          "const": false
        },
        "mutation_controls_allowed": {
          "type": "boolean",
          "const": false
        },
        "approval_required_for_effects": {
          "type": "boolean",
          "const": true
        },
        "read_only": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "widget_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "widget_id",
        "title",
        "source_collection",
        "required_fields",
        "empty_state",
        "evidence_refs",
        "read_only",
        "ui_component_created",
        "action_links_allowed",
        "mutation_controls_allowed",
        "route_admitted"
      ],
      "properties": {
        "widget_id": { "$ref": "#/$defs/widget_id" },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "source_collection": { "$ref": "#/$defs/source_collection" },
        "required_fields": { "$ref": "#/$defs/string_list" },
        "empty_state": {
          "type": "string",
          "minLength": 1
        },
        "evidence_refs": { "$ref": "#/$defs/evidence_ref_list" },
        "read_only": {
          "type": "boolean",
          "const": true
        },
        "ui_component_created": {
          "type": "boolean",
          "const": false
        },
        "action_links_allowed": {
          "type": "boolean",
          "const": false
        },
        "mutation_controls_allowed": {
          "type": "boolean",
          "const": false
        },
        "route_admitted": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "data_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "binding_id",
        "widget_id",
        "source_ref",
        "source_collection",
        "entity_kind",
        "identity_keys",
        "freshness_state",
        "fallback_state",
        "evidence_refs",
        "requires_live_adapter",
        "permits_mutation",
        "secret_values_serialized",
        "read_only"
      ],
      "properties": {
        "binding_id": { "$ref": "#/$defs/identifier" },
        "widget_id": { "$ref": "#/$defs/widget_id" },
        "source_ref": { "$ref": "#/$defs/evidence_ref" },
        "source_collection": { "$ref": "#/$defs/source_collection" },
        "entity_kind": {
          "type": "string",
          "enum": [
            "User",
            "Project",
            "RepositoryConnection",
            "AgentRun",
            "ApprovalRequest",
            "Receipt",
            "EvidenceBundle",
            "WorkspaceAllocation",
            "ReadinessDecision"
          ]
        },
        "identity_keys": { "$ref": "#/$defs/string_list" },
        "freshness_state": {
          "type": "string",
          "enum": [
            "foundation_static",
            "awaiting_runtime_source",
            "stale_allowed_read_only"
          ]
        },
        "fallback_state": {
          "type": "string",
          "minLength": 1
        },
        "evidence_refs": { "$ref": "#/$defs/evidence_ref_list" },
        "requires_live_adapter": {
          "type": "boolean",
          "const": false
        },
        "permits_mutation": {
          "type": "boolean",
          "const": false
        },
        "secret_values_serialized": {
          "type": "boolean",
          "const": false
        },
        "read_only": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "screen_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state_id",
        "status",
        "display_rule",
        "evidence_refs",
        "read_only",
        "action_cta_allowed",
        "mutation_controls_allowed",
        "route_admitted"
      ],
      "properties": {
        "state_id": { "$ref": "#/$defs/identifier" },
        "status": {
          "type": "string",
          "enum": [
            "loading",
            "ready",
            "empty",
            "blocked",
            "error"
          ]
        },
        "display_rule": {
          "type": "string",
          "minLength": 1
        },
        "evidence_refs": { "$ref": "#/$defs/evidence_ref_list" },
        "read_only": {
          "type": "boolean",
          "const": true
        },
        "action_cta_allowed": {
          "type": "boolean",
          "const": false
        },
        "mutation_controls_allowed": {
          "type": "boolean",
          "const": false
        },
        "route_admitted": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "authority_denials": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dashboard_ui_creation_enabled",
        "route_registration_enabled",
        "mutation_endpoint_enabled",
        "live_adapter_execution_enabled",
        "branch_write_enabled",
        "pull_request_creation_enabled",
        "repository_write_enabled",
        "receipt_store_append_enabled",
        "runtime_state_write_enabled",
        "deployment_enabled",
        "dns_mutation_enabled",
        "secret_mutation_enabled",
        "destructive_operation_enabled",
        "terminal_closure",
        "default_high_risk_authority"
      ],
      "properties": {
        "dashboard_ui_creation_enabled": { "type": "boolean", "const": false },
        "route_registration_enabled": { "type": "boolean", "const": false },
        "mutation_endpoint_enabled": { "type": "boolean", "const": false },
        "live_adapter_execution_enabled": { "type": "boolean", "const": false },
        "branch_write_enabled": { "type": "boolean", "const": false },
        "pull_request_creation_enabled": { "type": "boolean", "const": false },
        "repository_write_enabled": { "type": "boolean", "const": false },
        "receipt_store_append_enabled": { "type": "boolean", "const": false },
        "runtime_state_write_enabled": { "type": "boolean", "const": false },
        "deployment_enabled": { "type": "boolean", "const": false },
        "dns_mutation_enabled": { "type": "boolean", "const": false },
        "secret_mutation_enabled": { "type": "boolean", "const": false },
        "destructive_operation_enabled": { "type": "boolean", "const": false },
        "terminal_closure": { "type": "boolean", "const": false },
        "default_high_risk_authority": { "type": "boolean", "const": false }
      }
    },
    "receipt_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dashboard_data_contract_schema",
        "dashboard_data_contract_fixture",
        "harness_read_models_schema",
        "harness_read_models_fixture",
        "github_repo_task_intake_schema",
        "github_repo_task_intake_fixture",
        "readiness_map"
      ],
      "properties": {
        "dashboard_data_contract_schema": {
          "type": "string",
          "const": "schemas/agentic_service_harness_dashboard_data_contract.schema.json"
        },
        "dashboard_data_contract_fixture": {
          "type": "string",
          "const": "examples/agentic_service_harness_dashboard_data_contract.foundation.json"
        },
        "harness_read_models_schema": {
          "type": "string",
          "const": "schemas/agentic_service_harness_read_models.schema.json"
        },
        "harness_read_models_fixture": {
          "type": "string",
          "const": "examples/agentic_service_harness_read_models.foundation.json"
        },
        "github_repo_task_intake_schema": {
          "type": "string",
          "const": "schemas/agentic_service_harness_github_repo_task_intake.schema.json"
        },
        "github_repo_task_intake_fixture": {
          "type": "string",
          "const": "examples/agentic_service_harness_github_repo_task_intake.foundation.json"
        },
        "readiness_map": {
          "type": "string",
          "const": "MULLUSI_AGENTIC_SERVICE_HARNESS_READINESS_MAP.md"
        }
      }
    },
    "validator_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "validator_id",
        "command",
        "required_for_closure"
      ],
      "properties": {
        "validator_id": { "$ref": "#/$defs/identifier" },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "required_for_closure": {
          "type": "boolean",
          "const": true
        }
      }
    }
  }
}
