{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:general-agent-promotion-terminal-certificate-gate:1",
  "title": "General Agent Promotion Terminal Certificate Gate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "gate_id",
    "generated_at",
    "source_queue_path",
    "approval_receipt_path",
    "ready_for_terminal_certificate",
    "action_count",
    "admitted_action_count",
    "blocked_action_count",
    "approval_bound_admitted_count",
    "missing_approval_count",
    "blocked_reasons",
    "actions",
    "metadata"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "gate_id": {
      "type": "string",
      "pattern": "^general-agent-promotion-terminal-certificate-gate-[0-9a-f]{16}$"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_queue_path": {
      "type": "string",
      "minLength": 1
    },
    "approval_receipt_path": {
      "type": "string",
      "minLength": 1
    },
    "ready_for_terminal_certificate": {
      "type": "boolean"
    },
    "action_count": {
      "type": "integer",
      "minimum": 0
    },
    "admitted_action_count": {
      "type": "integer",
      "minimum": 0
    },
    "blocked_action_count": {
      "type": "integer",
      "minimum": 0
    },
    "approval_bound_admitted_count": {
      "type": "integer",
      "minimum": 0
    },
    "missing_approval_count": {
      "type": "integer",
      "minimum": 0
    },
    "blocked_reasons": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/gate_action"
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gate_is_not_execution",
        "secret_values_serialized",
        "approval_receipt_present",
        "approval_receipt_valid",
        "queue_id",
        "queue_hash",
        "queue_ready_to_execute",
        "terminal_certificate_schema_id"
      ],
      "properties": {
        "gate_is_not_execution": {
          "type": "boolean",
          "const": true
        },
        "secret_values_serialized": {
          "type": "boolean",
          "const": false
        },
        "approval_receipt_present": {
          "type": "boolean"
        },
        "approval_receipt_valid": {
          "type": "boolean"
        },
        "queue_id": {
          "type": "string"
        },
        "queue_hash": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "queue_ready_to_execute": {
          "type": "boolean"
        },
        "terminal_certificate_schema_id": {
          "type": "string",
          "const": "urn:mullusi:schema:terminal-closure-certificate:1"
        }
      }
    }
  },
  "$defs": {
    "gate_action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gate_item_id",
        "source_queue_item_id",
        "source_action_id",
        "source_plan_type",
        "execution_class",
        "terminal_gate_status",
        "approval_required",
        "approval_ref_present",
        "approval_ref",
        "certificate_candidate_id",
        "blocked_reasons",
        "evidence_required",
        "receipt_validator"
      ],
      "properties": {
        "gate_item_id": {
          "type": "string",
          "pattern": "^terminal-certificate-gate-item-[0-9]{2}-[a-z0-9-]+$"
        },
        "source_queue_item_id": {
          "type": "string",
          "minLength": 1
        },
        "source_action_id": {
          "type": "string",
          "minLength": 1
        },
        "source_plan_type": {
          "type": "string",
          "enum": [
            "adapter",
            "deployment",
            "portfolio"
          ]
        },
        "execution_class": {
          "type": "string",
          "enum": [
            "runnable_local",
            "requires_environment_binding",
            "requires_execution_environment",
            "requires_approval",
            "approval_and_environment_blocked",
            "review_only"
          ]
        },
        "terminal_gate_status": {
          "type": "string",
          "enum": [
            "admitted_runnable",
            "admitted_approved",
            "blocked_environment",
            "blocked_approval",
            "blocked_approval_and_environment",
            "blocked_invalid_queue_item"
          ]
        },
        "approval_required": {
          "type": "boolean"
        },
        "approval_ref_present": {
          "type": "boolean"
        },
        "approval_ref": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "certificate_candidate_id": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^terminal-certificate-candidate-[0-9a-f]{16}$"
        },
        "blocked_reasons": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "evidence_required": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "receipt_validator": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
