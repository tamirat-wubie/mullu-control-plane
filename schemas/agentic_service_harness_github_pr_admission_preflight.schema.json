{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:agentic-service-harness-github-pr-admission-preflight:1",
  "title": "Agentic Service Harness GitHub PR Admission Preflight",
  "description": "Foundation Mode preflight contract for admitting a future GitHub pull-request action. This schema records only approval-gate evaluation and denial evidence after binding the read-only GitHub task dry-run, non-empty diff file summary receipt, and terminal closure certificate read model. It does not admit branch writes, pull-request creation, repository writes, live adapter execution, connector calls, mutation routes, receipt-store append, deployment, DNS mutation, secret serialization, destructive operations, or terminal closure.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "report_id",
    "schema_version",
    "generated_at",
    "solver_outcome",
    "source_receipt_emitter_ref",
    "source_non_empty_diff_file_summary_receipt_ref",
    "source_terminal_closure_certificate_read_model_ref",
    "scope",
    "preflight_contract",
    "approval_admission_gate",
    "simulated_pr_admission",
    "authority_denials",
    "receipt_refs",
    "validators",
    "next_action",
    "report_is_not_terminal_closure",
    "terminal_closure_required"
  ],
  "properties": {
    "report_id": {
      "type": "string",
      "const": "agentic_service_harness_github_pr_admission_preflight"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "solver_outcome": {
      "type": "string",
      "const": "SolvedVerified"
    },
    "source_receipt_emitter_ref": {
      "type": "string",
      "const": "examples/agentic_service_harness_github_task_receipt_emitter_dry_run.foundation.json"
    },
    "source_non_empty_diff_file_summary_receipt_ref": {
      "type": "string",
      "const": "examples/agentic_service_harness_non_empty_diff_file_summary_receipt.foundation.json"
    },
    "source_terminal_closure_certificate_read_model_ref": {
      "type": "string",
      "const": "examples/agentic_service_harness_github_pr_terminal_closure_certificate_read_model.foundation.json"
    },
    "scope": {
      "$ref": "#/$defs/scope"
    },
    "preflight_contract": {
      "$ref": "#/$defs/preflight_contract"
    },
    "approval_admission_gate": {
      "$ref": "#/$defs/approval_admission_gate"
    },
    "simulated_pr_admission": {
      "$ref": "#/$defs/simulated_pr_admission"
    },
    "authority_denials": {
      "$ref": "#/$defs/authority_denials"
    },
    "receipt_refs": {
      "$ref": "#/$defs/receipt_refs"
    },
    "validators": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/validator_ref"
      }
    },
    "next_action": {
      "type": "string",
      "minLength": 1
    },
    "report_is_not_terminal_closure": {
      "type": "boolean",
      "const": true
    },
    "terminal_closure_required": {
      "type": "boolean",
      "const": true
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "evidence_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/#$-]*$"
    },
    "evidence_ref_list": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/evidence_ref"
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tenant_id",
        "organization_id",
        "project_id",
        "repository_connection_id",
        "repository_slug",
        "task_service_id",
        "foundation_phase",
        "read_only",
        "preflight_only",
        "operator_approval_present",
        "branch_write_authority_enabled",
        "pull_request_creation_enabled",
        "repository_write_enabled",
        "external_adapter_integrated",
        "secret_values_serialized"
      ],
      "properties": {
        "tenant_id": { "$ref": "#/$defs/identifier" },
        "organization_id": { "$ref": "#/$defs/identifier" },
        "project_id": { "$ref": "#/$defs/identifier" },
        "repository_connection_id": { "$ref": "#/$defs/identifier" },
        "repository_slug": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
        },
        "task_service_id": {
          "type": "string",
          "const": "github-repo-task-service-read-only-foundation"
        },
        "foundation_phase": {
          "type": "string",
          "const": "foundation_pr_admission_preflight_only"
        },
        "read_only": {
          "type": "boolean",
          "const": true
        },
        "preflight_only": {
          "type": "boolean",
          "const": true
        },
        "operator_approval_present": {
          "type": "boolean",
          "const": false
        },
        "branch_write_authority_enabled": {
          "type": "boolean",
          "const": false
        },
        "pull_request_creation_enabled": {
          "type": "boolean",
          "const": false
        },
        "repository_write_enabled": {
          "type": "boolean",
          "const": false
        },
        "external_adapter_integrated": {
          "type": "boolean",
          "const": false
        },
        "secret_values_serialized": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "preflight_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "preflight_id",
        "preflight_mode",
        "source_task_ref",
        "allowed_action_classes",
        "forbidden_action_classes",
        "required_source_refs",
        "required_gate_refs",
        "admission_obligations_checked",
        "validation_refs",
        "read_only"
      ],
      "properties": {
        "preflight_id": {
          "type": "string",
          "const": "github-pr-admission-preflight-foundation"
        },
        "preflight_mode": {
          "type": "string",
          "const": "PR_ADMISSION_PREFLIGHT_ONLY"
        },
        "source_task_ref": {
          "type": "string",
          "const": "task://agentic-service-harness/github-repo-read-only"
        },
        "allowed_action_classes": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "dry_run",
              "approval_preflight"
            ]
          }
        },
        "forbidden_action_classes": {
          "type": "array",
          "minItems": 8,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "execute_adapter",
              "write_to_branch",
              "open_pr",
              "append_receipt_store",
              "deploy",
              "dns_mutation",
              "secret_mutation",
              "destructive_operation",
              "terminal_closure"
            ]
          }
        },
        "required_source_refs": {
          "$ref": "#/$defs/evidence_ref_list"
        },
        "required_gate_refs": {
          "$ref": "#/$defs/evidence_ref_list"
        },
        "admission_obligations_checked": {
          "$ref": "#/$defs/evidence_ref_list"
        },
        "validation_refs": {
          "$ref": "#/$defs/evidence_ref_list"
        },
        "read_only": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "approval_admission_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision",
        "pr_admitted",
        "approval_target_ref",
        "required_before_pr_refs",
        "blocked_reason_refs",
        "terminal_closure_allowed"
      ],
      "properties": {
        "decision": {
          "type": "string",
          "const": "PR_ADMISSION_BLOCKED_AWAITING_OPERATOR_APPROVAL_AND_BRANCH_BINDING"
        },
        "pr_admitted": {
          "type": "boolean",
          "const": false
        },
        "approval_target_ref": {
          "type": "string",
          "const": "github-pr://agentic-service-harness/task-run"
        },
        "required_before_pr_refs": {
          "$ref": "#/$defs/evidence_ref_list"
        },
        "blocked_reason_refs": {
          "$ref": "#/$defs/evidence_ref_list"
        },
        "terminal_closure_allowed": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "simulated_pr_admission": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "result_state",
        "simulated_action_kind",
        "preflight_recorded",
        "operator_approval_observed",
        "branch_created",
        "pull_request_opened",
        "repository_written",
        "adapter_executed",
        "connector_calls_observed",
        "mutation_route_called",
        "receipt_store_appended",
        "external_effects_observed",
        "raw_secret_material_included",
        "output_digest",
        "terminal_closure",
        "success_claim_allowed"
      ],
      "properties": {
        "result_state": {
          "type": "string",
          "const": "PR_ADMISSION_PREFLIGHT_RECORDED"
        },
        "simulated_action_kind": {
          "type": "string",
          "const": "future_github_pull_request_admission"
        },
        "preflight_recorded": {
          "type": "boolean",
          "const": true
        },
        "operator_approval_observed": {
          "type": "boolean",
          "const": false
        },
        "branch_created": {
          "type": "boolean",
          "const": false
        },
        "pull_request_opened": {
          "type": "boolean",
          "const": false
        },
        "repository_written": {
          "type": "boolean",
          "const": false
        },
        "adapter_executed": {
          "type": "boolean",
          "const": false
        },
        "connector_calls_observed": {
          "type": "boolean",
          "const": false
        },
        "mutation_route_called": {
          "type": "boolean",
          "const": false
        },
        "receipt_store_appended": {
          "type": "boolean",
          "const": false
        },
        "external_effects_observed": {
          "type": "boolean",
          "const": false
        },
        "raw_secret_material_included": {
          "type": "boolean",
          "const": false
        },
        "output_digest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "terminal_closure": {
          "type": "boolean",
          "const": false
        },
        "success_claim_allowed": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "authority_denials": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "live_adapter_execution_enabled",
        "branch_write_enabled",
        "pull_request_creation_enabled",
        "repository_write_enabled",
        "mutation_route_enabled",
        "receipt_store_append_enabled",
        "deployment_enabled",
        "dns_mutation_enabled",
        "secret_mutation_enabled",
        "destructive_operation_enabled",
        "terminal_closure",
        "default_high_risk_authority"
      ],
      "properties": {
        "live_adapter_execution_enabled": { "type": "boolean", "const": false },
        "branch_write_enabled": { "type": "boolean", "const": false },
        "pull_request_creation_enabled": { "type": "boolean", "const": false },
        "repository_write_enabled": { "type": "boolean", "const": false },
        "mutation_route_enabled": { "type": "boolean", "const": false },
        "receipt_store_append_enabled": { "type": "boolean", "const": false },
        "deployment_enabled": { "type": "boolean", "const": false },
        "dns_mutation_enabled": { "type": "boolean", "const": false },
        "secret_mutation_enabled": { "type": "boolean", "const": false },
        "destructive_operation_enabled": { "type": "boolean", "const": false },
        "terminal_closure": { "type": "boolean", "const": false },
        "default_high_risk_authority": { "type": "boolean", "const": false }
      }
    },
    "receipt_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "github_pr_admission_preflight_schema",
        "non_empty_diff_file_summary_receipt_schema",
        "non_empty_diff_file_summary_receipt_example",
        "terminal_closure_certificate_read_model_schema",
        "terminal_closure_certificate_read_model_example",
        "github_task_receipt_emitter_dry_run_schema",
        "github_repo_task_service_schema",
        "agentic_service_harness_schema",
        "agentic_service_harness_read_models_schema"
      ],
      "properties": {
        "github_pr_admission_preflight_schema": { "$ref": "#/$defs/evidence_ref" },
        "non_empty_diff_file_summary_receipt_schema": { "$ref": "#/$defs/evidence_ref" },
        "non_empty_diff_file_summary_receipt_example": { "$ref": "#/$defs/evidence_ref" },
        "terminal_closure_certificate_read_model_schema": { "$ref": "#/$defs/evidence_ref" },
        "terminal_closure_certificate_read_model_example": { "$ref": "#/$defs/evidence_ref" },
        "github_task_receipt_emitter_dry_run_schema": { "$ref": "#/$defs/evidence_ref" },
        "github_repo_task_service_schema": { "$ref": "#/$defs/evidence_ref" },
        "agentic_service_harness_schema": { "$ref": "#/$defs/evidence_ref" },
        "agentic_service_harness_read_models_schema": { "$ref": "#/$defs/evidence_ref" }
      }
    },
    "validator_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "validator_id",
        "command",
        "required_for_closure"
      ],
      "properties": {
        "validator_id": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "required_for_closure": {
          "type": "boolean",
          "const": true
        }
      }
    }
  }
}
