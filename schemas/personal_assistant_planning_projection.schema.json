{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:personal-assistant-planning-projection:1",
  "title": "Personal Assistant Planning Projection",
  "description": "No-effect evidence envelope for Personal Assistant schedule planning previews.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "projection_set_id",
    "generated_at",
    "governed",
    "source_projection",
    "projection_count",
    "projection_ids",
    "receipt_ids",
    "connectors_used",
    "projections",
    "effect_boundary",
    "private_payload_policy",
    "assurance",
    "metadata"
  ],
  "properties": {
    "projection_set_id": {"type": "string", "pattern": "^pa_planning_projection_[a-z0-9][a-z0-9_:-]*$"},
    "generated_at": {"type": "string", "minLength": 1},
    "governed": {"const": true},
    "source_projection": {"const": "operator_supplied_schedule_values"},
    "projection_count": {"type": "integer", "minimum": 1},
    "projection_ids": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "pattern": "^pa_planning_projection_item_[a-z0-9][a-z0-9_:-]*$"},
      "uniqueItems": true
    },
    "receipt_ids": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "pattern": "^pa_receipt_[a-z0-9][a-z0-9_:-]*$"},
      "uniqueItems": true
    },
    "connectors_used": {"type": "array", "maxItems": 0},
    "projections": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/projection"}},
    "effect_boundary": {"$ref": "#/$defs/effect_boundary"},
    "private_payload_policy": {"$ref": "#/$defs/private_payload_policy"},
    "assurance": {"$ref": "#/$defs/assurance"},
    "metadata": {"$ref": "#/$defs/metadata"}
  },
  "$defs": {
    "projection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["projection_id", "request_id", "skill_id", "plan_type", "plan", "receipt"],
      "properties": {
        "projection_id": {"type": "string", "pattern": "^pa_planning_projection_item_[a-z0-9][a-z0-9_:-]*$"},
        "request_id": {"type": "string", "pattern": "^pa_request_[a-z0-9][a-z0-9_:-]*$"},
        "skill_id": {"const": "planning.optimize_schedule"},
        "plan_type": {"const": "planning_schedule_foundation"},
        "plan": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "plan_type",
            "objective",
            "requested_result",
            "time_windows",
            "work_items",
            "assumptions",
            "constraints",
            "assignment_plan",
            "capacity_summary",
            "planning_summary",
            "planning_decision",
            "answer_claim_authority",
            "evidence_gate",
            "effect_boundary",
            "execution_allowed",
            "live_connector_execution_allowed",
            "calendar_write_allowed",
            "task_write_allowed",
            "invite_allowed",
            "message_person_allowed",
            "system_of_record_write_allowed",
            "connector_mutation_allowed",
            "external_submission_allowed",
            "public_post_allowed",
            "money_movement_allowed",
            "paid_subscription_allowed",
            "deployment_allowed",
            "memory_write_allowed",
            "nested_mind_live_activation_allowed"
          ],
          "properties": {
            "plan_type": {"const": "planning_schedule_foundation"},
            "objective": {"type": "string", "minLength": 1},
            "requested_result": {"type": "string", "minLength": 1},
            "time_windows": {"type": "array", "items": {"$ref": "#/$defs/time_window"}},
            "work_items": {"type": "array", "items": {"$ref": "#/$defs/work_item"}},
            "assumptions": {"type": "array", "items": {"type": "string", "minLength": 1}},
            "constraints": {"type": "array", "items": {"type": "string", "minLength": 1}},
            "assignment_plan": {"type": "array", "items": {"$ref": "#/$defs/assignment"}},
            "capacity_summary": {"type": "array", "items": {"$ref": "#/$defs/capacity_summary"}},
            "planning_summary": {"type": "string", "minLength": 1},
            "planning_decision": {"const": "preview_only"},
            "answer_claim_authority": {"enum": ["operator_supplied_schedule_values_only", "awaiting_operator_schedule_values"]},
            "evidence_gate": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "operator_supplied_schedule_complete",
                "evidence_refs",
                "blocking_reasons",
                "calendar_event_created",
                "calendar_event_moved",
                "calendar_event_cancelled",
                "invite_sent",
                "task_written",
                "task_system_mutated",
                "person_messaged",
                "system_of_record_written",
                "connector_state_mutated",
                "external_submission_sent",
                "public_post_created",
                "payment_moved",
                "deployment_started"
              ],
              "properties": {
                "operator_supplied_schedule_complete": {"type": "boolean"},
                "evidence_refs": {"type": "array", "items": {"type": "string", "minLength": 1}},
                "blocking_reasons": {"type": "array", "items": {"type": "string", "minLength": 1}},
                "calendar_event_created": {"const": false},
                "calendar_event_moved": {"const": false},
                "calendar_event_cancelled": {"const": false},
                "invite_sent": {"const": false},
                "task_written": {"const": false},
                "task_system_mutated": {"const": false},
                "person_messaged": {"const": false},
                "system_of_record_written": {"const": false},
                "connector_state_mutated": {"const": false},
                "external_submission_sent": {"const": false},
                "public_post_created": {"const": false},
                "payment_moved": {"const": false},
                "deployment_started": {"const": false}
              }
            },
            "effect_boundary": {"const": "schedule_planning_preview_only_no_external_effect"},
            "execution_allowed": {"const": false},
            "live_connector_execution_allowed": {"const": false},
            "calendar_write_allowed": {"const": false},
            "task_write_allowed": {"const": false},
            "invite_allowed": {"const": false},
            "message_person_allowed": {"const": false},
            "system_of_record_write_allowed": {"const": false},
            "connector_mutation_allowed": {"const": false},
            "external_submission_allowed": {"const": false},
            "public_post_allowed": {"const": false},
            "money_movement_allowed": {"const": false},
            "paid_subscription_allowed": {"const": false},
            "deployment_allowed": {"const": false},
            "memory_write_allowed": {"const": false},
            "nested_mind_live_activation_allowed": {"const": false}
          }
        },
        "receipt": {"type": "object", "additionalProperties": true}
      }
    },
    "time_window": {
      "type": "object",
      "additionalProperties": false,
      "required": ["window_ref", "label", "start", "end", "capacity_minutes", "source_ref", "notes"],
      "properties": {
        "window_ref": {"type": "string", "minLength": 1},
        "label": {"type": "string", "minLength": 1},
        "start": {"type": "string", "minLength": 1},
        "end": {"type": "string", "minLength": 1},
        "capacity_minutes": {"type": "integer", "minimum": 1, "maximum": 1440},
        "source_ref": {"type": "string", "minLength": 1},
        "notes": {"type": "string"}
      }
    },
    "work_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "item_ref",
        "title",
        "estimated_minutes",
        "priority",
        "earliest_start",
        "due",
        "required_window_ref",
        "source_ref",
        "notes"
      ],
      "properties": {
        "item_ref": {"type": "string", "minLength": 1},
        "title": {"type": "string", "minLength": 1},
        "estimated_minutes": {"type": "integer", "minimum": 1, "maximum": 1440},
        "priority": {"type": "integer", "minimum": 1, "maximum": 5},
        "earliest_start": {"type": "string"},
        "due": {"type": "string"},
        "required_window_ref": {"type": "string"},
        "source_ref": {"type": "string", "minLength": 1},
        "notes": {"type": "string"}
      }
    },
    "assignment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["item_ref", "title", "window_ref", "estimated_minutes", "status", "reason"],
      "properties": {
        "item_ref": {"type": "string", "minLength": 1},
        "title": {"type": "string", "minLength": 1},
        "window_ref": {"type": "string"},
        "estimated_minutes": {"type": "string", "pattern": "^[0-9]+$"},
        "status": {"enum": ["assigned", "blocked"]},
        "reason": {"type": "string", "minLength": 1}
      }
    },
    "capacity_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["window_ref", "label", "capacity_minutes", "assigned_minutes", "remaining_minutes", "status"],
      "properties": {
        "window_ref": {"type": "string", "minLength": 1},
        "label": {"type": "string", "minLength": 1},
        "capacity_minutes": {"type": "string", "pattern": "^[0-9]+$"},
        "assigned_minutes": {"type": "string", "pattern": "^[0-9]+$"},
        "remaining_minutes": {"type": "string", "pattern": "^-?[0-9]+$"},
        "status": {"enum": ["within_capacity", "over_capacity"]}
      }
    },
    "effect_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "planning_projection_records_allowed",
        "execution_allowed",
        "live_connector_execution_allowed",
        "calendar_write_allowed",
        "task_write_allowed",
        "invite_allowed",
        "message_person_allowed",
        "system_of_record_write_allowed",
        "connector_mutation_allowed",
        "external_submission_allowed",
        "public_post_allowed",
        "money_movement_allowed",
        "paid_subscription_allowed",
        "deployment_allowed",
        "memory_write_allowed",
        "public_readiness_claim_allowed",
        "customer_readiness_claim_allowed",
        "nested_mind_live_activation_allowed"
      ],
      "properties": {
        "planning_projection_records_allowed": {"const": true},
        "execution_allowed": {"const": false},
        "live_connector_execution_allowed": {"const": false},
        "calendar_write_allowed": {"const": false},
        "task_write_allowed": {"const": false},
        "invite_allowed": {"const": false},
        "message_person_allowed": {"const": false},
        "system_of_record_write_allowed": {"const": false},
        "connector_mutation_allowed": {"const": false},
        "external_submission_allowed": {"const": false},
        "public_post_allowed": {"const": false},
        "money_movement_allowed": {"const": false},
        "paid_subscription_allowed": {"const": false},
        "deployment_allowed": {"const": false},
        "memory_write_allowed": {"const": false},
        "public_readiness_claim_allowed": {"const": false},
        "customer_readiness_claim_allowed": {"const": false},
        "nested_mind_live_activation_allowed": {"const": false}
      }
    },
    "private_payload_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raw_private_payload_serialized",
        "secret_values_serialized",
        "connector_payload_projection",
        "body_projection"
      ],
      "properties": {
        "raw_private_payload_serialized": {"const": false},
        "secret_values_serialized": {"const": false},
        "connector_payload_projection": {"const": "no_connector_payload"},
        "body_projection": {"const": "none"}
      }
    },
    "assurance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "assurance_id",
        "outcome",
        "foundation_only",
        "ready_for_calendar_write",
        "ready_for_task_write",
        "ready_for_invite",
        "ready_for_message_send",
        "ready_for_system_write",
        "ready_for_money_movement",
        "ready_for_paid_action",
        "ready_for_external_submission",
        "ready_for_public_posting",
        "ready_for_deployment",
        "ready_for_customer_readiness_claim",
        "authority_drift_detected",
        "checked_controls",
        "blocking_reasons",
        "next_action"
      ],
      "properties": {
        "assurance_id": {"const": "personal_assistant_planning_projection_no_effect_assurance"},
        "outcome": {"enum": ["SolvedVerified", "AwaitingEvidence", "GovernanceBlocked"]},
        "foundation_only": {"const": true},
        "ready_for_calendar_write": {"const": false},
        "ready_for_task_write": {"const": false},
        "ready_for_invite": {"const": false},
        "ready_for_message_send": {"const": false},
        "ready_for_system_write": {"const": false},
        "ready_for_money_movement": {"const": false},
        "ready_for_paid_action": {"const": false},
        "ready_for_external_submission": {"const": false},
        "ready_for_public_posting": {"const": false},
        "ready_for_deployment": {"const": false},
        "ready_for_customer_readiness_claim": {"const": false},
        "authority_drift_detected": {"type": "boolean"},
        "checked_controls": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
        "blocking_reasons": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "next_action": {"type": "string", "minLength": 1}
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "foundation_only",
        "projection_contract",
        "runtime_boundary",
        "live_connector_execution_allowed",
        "calendar_write_allowed",
        "task_write_allowed",
        "system_of_record_write_allowed",
        "external_submission_allowed",
        "public_post_allowed",
        "deployment_allowed"
      ],
      "properties": {
        "foundation_only": {"const": true},
        "projection_contract": {"const": "schedule_planning_preview_only"},
        "runtime_boundary": {"const": "planning_projection_does_not_write_calendar_tasks_or_records"},
        "live_connector_execution_allowed": {"const": false},
        "calendar_write_allowed": {"const": false},
        "task_write_allowed": {"const": false},
        "system_of_record_write_allowed": {"const": false},
        "external_submission_allowed": {"const": false},
        "public_post_allowed": {"const": false},
        "deployment_allowed": {"const": false}
      }
    }
  }
}
