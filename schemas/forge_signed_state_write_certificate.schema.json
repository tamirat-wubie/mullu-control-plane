{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:forge-signed-state-write-certificate:1",
  "$comment": "Purpose: reference-only contract for the mullu-forge-runtime-v0.1.0-dev3 PhiGov signed state-write certificate. Governance scope: [OCE, RAG, CDCV, CQTE, UWMA, SRCA, PRS]. Invariants: development-only, hash-bound, nonce-bound, signature-bound, and not production state-write authority.",
  "title": "ForgeSignedStateWriteCertificate",
  "description": "Development-only signed PhiGov state-write certificate shape imported from the Forge dev3 service-separated write spine as a control-plane contract.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "certificate_id",
    "issuer",
    "request_id",
    "decision_receipt_hash",
    "mesh_id",
    "snapshot_id",
    "before_state_hash",
    "after_state_hash",
    "delta_hash",
    "policy_hash",
    "evaluation_context_hash",
    "execution_scope_hash",
    "issued_at",
    "expires_at",
    "development_only",
    "certificate_profile",
    "key_id",
    "trust_epoch",
    "nonce",
    "signature",
    "certificate_hash"
  ],
  "properties": {
    "certificate_id": { "type": "string", "minLength": 1 },
    "issuer": { "type": "string", "minLength": 1 },
    "request_id": { "type": "string", "minLength": 1 },
    "decision_receipt_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "mesh_id": { "type": "string", "minLength": 1 },
    "snapshot_id": { "type": "string", "minLength": 1 },
    "before_state_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "after_state_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "delta_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "policy_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "evaluation_context_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "execution_scope_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "issued_at": { "type": "string", "format": "date-time" },
    "expires_at": { "type": "string", "format": "date-time" },
    "development_only": { "type": "boolean", "const": true },
    "certificate_profile": { "type": "string", "const": "forge.phigov.ed25519-state-write.v0.1" },
    "key_id": { "type": "string", "minLength": 1 },
    "trust_epoch": { "type": "integer", "minimum": 1 },
    "nonce": { "type": "string", "minLength": 1 },
    "signature": { "type": "string", "minLength": 40 },
    "certificate_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  }
}
