{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:operator-workflow-next-action-packet:1",
  "title": "OperatorWorkflowNextActionPacket",
  "description": "Projection-only next-action handoff packet derived from the operator workflow dashboard readiness lane.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_ref",
    "packet_id",
    "source_dashboard_id",
    "task",
    "lane_status",
    "proof_state",
    "operator_outcome",
    "primary_blocker",
    "current_gate_id",
    "next_action",
    "required_evidence_refs",
    "linked_receipts",
    "approval",
    "blocked_effects",
    "source_refs",
    "readiness_is_not_execution_authority",
    "projection_only",
    "execution_authority_granted",
    "execution_performed",
    "live_execution_enabled",
    "external_effects_allowed",
    "packet_hash"
  ],
  "properties": {
    "schema_ref": {"type": "string", "const": "urn:mullusi:schema:operator-workflow-next-action-packet:1"},
    "packet_id": {"type": "string", "const": "operator_workflow_next_action_packet.foundation.v1"},
    "source_dashboard_id": {"type": "string", "const": "operator_workflow_dashboard.foundation.v1"},
    "task": {"type": "string", "minLength": 1, "maxLength": 160},
    "lane_status": {
      "type": "string",
      "enum": [
        "awaiting_closure_packet",
        "awaiting_rehearsal_receipt",
        "awaiting_causal_repair_receipt",
        "blocked_by_causal_repair",
        "awaiting_approval_evidence",
        "awaiting_evidence",
        "ready_for_review_only_handoff"
      ]
    },
    "proof_state": {"type": "string", "minLength": 1, "maxLength": 120},
    "operator_outcome": {"type": "string", "minLength": 1, "maxLength": 120},
    "primary_blocker": {"type": "string", "minLength": 1, "maxLength": 160},
    "current_gate_id": {"type": "string", "minLength": 1, "maxLength": 120},
    "next_action": {"type": "string", "minLength": 1, "maxLength": 260},
    "required_evidence_refs": {
      "type": "array",
      "maxItems": 12,
      "items": {"type": "string", "minLength": 1, "maxLength": 180}
    },
    "linked_receipts": {"$ref": "#/$defs/linked_receipts"},
    "approval": {"$ref": "#/$defs/approval"},
    "blocked_effects": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1, "maxLength": 80}
    },
    "source_refs": {"$ref": "#/$defs/source_refs"},
    "readiness_is_not_execution_authority": {"type": "boolean", "const": true},
    "projection_only": {"type": "boolean", "const": true},
    "execution_authority_granted": {"type": "boolean", "const": false},
    "execution_performed": {"type": "boolean", "const": false},
    "live_execution_enabled": {"type": "boolean", "const": false},
    "external_effects_allowed": {"type": "boolean", "const": false},
    "packet_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  },
  "$defs": {
    "linked_receipts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["closure_packet", "safe_local_action_rehearsal", "causal_repair"],
      "properties": {
        "closure_packet": {"type": "boolean"},
        "safe_local_action_rehearsal": {"type": "boolean"},
        "causal_repair": {"type": "boolean"}
      }
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["needed", "status", "performed"],
      "properties": {
        "needed": {"type": "boolean"},
        "status": {"type": "string", "minLength": 1, "maxLength": 120},
        "performed": {"type": "boolean", "const": false}
      }
    },
    "source_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dashboard", "builder"],
      "properties": {
        "dashboard": {"type": "string", "minLength": 1, "maxLength": 260},
        "builder": {"type": "string", "const": "scripts/build_operator_workflow_next_action_packet.py"}
      }
    }
  }
}
