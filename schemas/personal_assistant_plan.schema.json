{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:personal-assistant-plan:1",
  "title": "Personal Assistant Plan",
  "description": "Preview or draft execution plan produced from a governed personal-assistant request.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "plan_id",
    "request_id",
    "created_at",
    "goal",
    "risk_level",
    "mode",
    "requires_approval",
    "dry_run_available",
    "execution_allowed",
    "approval_gate",
    "steps",
    "actions_not_authorized",
    "receipt_refs",
    "evidence_refs",
    "metadata"
  ],
  "properties": {
    "plan_id": { "type": "string", "pattern": "^pa_plan_[a-z0-9][a-z0-9_:-]*$" },
    "request_id": { "type": "string", "pattern": "^pa_request_[a-z0-9][a-z0-9_:-]*$" },
    "created_at": { "type": "string", "format": "date-time" },
    "goal": { "type": "string", "minLength": 1 },
    "risk_level": { "type": "string", "enum": ["P0", "P1", "P2", "P3", "P4", "P5"] },
    "mode": { "type": "string", "enum": ["dry_run", "preview", "draft", "execute_with_approval", "blocked", "read_and_draft_only"] },
    "requires_approval": { "type": "boolean" },
    "dry_run_available": { "type": "boolean" },
    "execution_allowed": { "type": "boolean" },
    "approval_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["approval_required", "approval_level", "approval_ref", "reason_codes"],
      "properties": {
        "approval_required": { "type": "boolean" },
        "approval_level": { "type": "string", "enum": ["none", "P0", "P1", "P2", "P3", "P4", "P5"] },
        "approval_ref": { "type": "string" },
        "reason_codes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "step_id",
          "skill_id",
          "capability_refs",
          "mode",
          "risk_level",
          "action",
          "approval_required",
          "produces_receipt",
          "effect_boundary"
        ],
        "properties": {
          "step_id": { "type": "string", "minLength": 1 },
          "skill_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*(\\.[a-z0-9_]+)+$" },
          "capability_refs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "mode": { "type": "string", "enum": ["dry_run", "preview", "draft", "execute_with_approval", "blocked", "read_and_draft_only"] },
          "risk_level": { "type": "string", "enum": ["P0", "P1", "P2", "P3", "P4", "P5"] },
          "action": { "type": "string", "minLength": 1 },
          "approval_required": { "type": "boolean" },
          "produces_receipt": { "type": "boolean" },
          "effect_boundary": { "type": "string", "minLength": 1 }
        }
      }
    },
    "actions_not_authorized": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "receipt_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "metadata": { "type": "object", "additionalProperties": true }
  }
}
