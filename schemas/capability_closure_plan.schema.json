{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:capability-closure-plan:1",
  "title": "Capability Closure Plan",
  "description": "Read-only plan selecting one capability debt closure lane without granting execution authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "plan_id",
    "mode",
    "plan_is_not_execution_authority",
    "live_execution_enabled",
    "selected_capability_id",
    "selected_capability_name",
    "selected_family",
    "selected_debt_id",
    "selected_category",
    "selection_policy",
    "source_refs",
    "selected_debt_item",
    "closure_lane",
    "blocked_effects",
    "validators",
    "next_action"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "plan_id": { "$ref": "#/$defs/identifier" },
    "mode": { "type": "string", "const": "foundation" },
    "plan_is_not_execution_authority": { "type": "boolean", "const": true },
    "live_execution_enabled": { "type": "boolean", "const": false },
    "selected_capability_id": { "$ref": "#/$defs/identifier" },
    "selected_capability_name": { "type": "string", "minLength": 1, "maxLength": 180 },
    "selected_family": { "type": "string", "minLength": 1, "maxLength": 80 },
    "selected_debt_id": { "$ref": "#/$defs/identifier" },
    "selected_category": { "$ref": "#/$defs/category" },
    "selection_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_id",
        "preferred_category",
        "preferred_capability_ids",
        "fallback_order",
        "selection_reason"
      ],
      "properties": {
        "policy_id": { "$ref": "#/$defs/identifier" },
        "preferred_category": { "$ref": "#/$defs/category" },
        "preferred_capability_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/identifier" }
        },
        "fallback_order": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": { "type": "string", "minLength": 1 }
        },
        "selection_reason": {
          "type": "string",
          "enum": ["preferred_approval_lane", "highest_ranked_debt_item"]
        }
      }
    },
    "source_refs": { "$ref": "#/$defs/source_refs" },
    "selected_debt_item": { "$ref": "#/$defs/debt_item" },
    "closure_lane": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lane_id",
        "lane_type",
        "current_gate",
        "proof_state",
        "outcome",
        "missing_ref_count",
        "next_required_proof_step"
      ],
      "properties": {
        "lane_id": { "$ref": "#/$defs/identifier" },
        "lane_type": { "$ref": "#/$defs/category" },
        "current_gate": { "$ref": "#/$defs/identifier" },
        "proof_state": { "type": "string", "const": "Unknown" },
        "outcome": { "type": "string", "const": "AwaitingEvidence" },
        "missing_ref_count": { "type": "integer", "minimum": 1 },
        "next_required_proof_step": { "type": "string", "minLength": 1, "maxLength": 640 }
      }
    },
    "blocked_effects": {
      "type": "array",
      "minItems": 8,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "live_execution",
          "connector_mutation",
          "external_write",
          "target_repository_mutation",
          "branch_push",
          "pull_request_create",
          "merge",
          "production_claim"
        ]
      }
    },
    "validators": {
      "type": "array",
      "minItems": 2,
      "items": { "$ref": "#/$defs/validator_ref" }
    },
    "next_action": { "type": "string", "minLength": 1, "maxLength": 640 }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 260,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "category": {
      "type": "string",
      "enum": ["approval", "evidence", "rollback", "replay", "promotion", "live_action"]
    },
    "severity": {
      "type": "string",
      "enum": ["critical", "high", "medium", "low"]
    },
    "string_list": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 320 }
    },
    "source_refs": {
      "type": "object",
      "additionalProperties": { "type": "string", "minLength": 1, "maxLength": 320 },
      "required": [
        "debt_report_id",
        "debt_row_id",
        "selected_debt_id",
        "evidence_passport_id"
      ]
    },
    "debt_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["debt_id", "category", "severity", "description", "missing_refs", "fix"],
      "properties": {
        "debt_id": { "$ref": "#/$defs/identifier" },
        "category": { "$ref": "#/$defs/category" },
        "severity": { "$ref": "#/$defs/severity" },
        "description": { "type": "string", "minLength": 1, "maxLength": 220 },
        "missing_refs": { "$ref": "#/$defs/string_list" },
        "fix": { "type": "string", "minLength": 1, "maxLength": 640 }
      }
    },
    "validator_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["validator_id", "command", "required_for_closure"],
      "properties": {
        "validator_id": { "$ref": "#/$defs/identifier" },
        "command": { "type": "string", "minLength": 1, "maxLength": 260 },
        "required_for_closure": { "type": "boolean", "const": true }
      }
    }
  }
}
