{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:sdlc-work-plan:1",
  "title": "SDLC Work Plan",
  "description": "Governed ordered work plan for a software change.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "plan_id",
    "design_id",
    "steps",
    "dependencies",
    "risk_order",
    "required_validators",
    "required_tests",
    "expected_artifacts",
    "owner",
    "uao_ref",
    "causal_decision_trace_ref",
    "receipt_ref"
  ],
  "properties": {
    "plan_id": { "type": "string", "minLength": 1 },
    "design_id": { "type": "string", "minLength": 1 },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/work_step" }
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "risk_order": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "required_validators": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "required_tests": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "expected_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "owner": { "type": "string", "minLength": 1 },
    "uao_ref": { "type": "string", "minLength": 1 },
    "causal_decision_trace_ref": { "type": "string", "minLength": 1 },
    "receipt_ref": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "work_step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["order", "action", "expected_artifact", "depends_on"],
      "properties": {
        "order": { "type": "integer", "minimum": 1 },
        "action": { "type": "string", "minLength": 1 },
        "expected_artifact": { "type": "string", "minLength": 1 },
        "depends_on": {
          "type": "array",
          "items": { "type": "integer", "minimum": 1 },
          "uniqueItems": true
        }
      }
    }
  }
}
