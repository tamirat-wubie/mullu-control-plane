{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:agentic-service-harness-live-producer-execution-authority-admission:1",
  "title": "Agentic Service Harness Live Producer Execution Authority Admission",
  "description": "Read-only live producer execution authority admission. This artifact names the reusable evidence ladder while keeping live execution, mutation routes, connector calls, receipt append, runtime writes, secret access, and terminal closure denied.",
  "type": "object",
  "additionalProperties": false,
  "required": ["admission_id", "schema_version", "generated_at", "solver_outcome", "admission_status", "source_admission_gate_ref", "source_admission_gate_state", "planning_only", "read_only", "live_producer_implemented", "live_execution_authorized", "authority_granted", "terminal_closure", "required_components", "missing_evidence", "authority_denials", "effect_boundary", "validators", "next_action"],
  "properties": {
    "admission_id": { "type": "string", "const": "agentic-service-harness-live-producer-execution-authority-admission" },
    "schema_version": { "type": "integer", "const": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "solver_outcome": { "type": "string", "const": "AwaitingEvidence" },
    "admission_status": { "type": "string", "const": "blocked_awaiting_live_execution_authority_components" },
    "source_admission_gate_ref": { "$ref": "#/$defs/evidence_ref" },
    "source_admission_gate_state": { "type": "string", "const": "blocked_pending_live_authority" },
    "planning_only": { "type": "boolean", "const": true },
    "read_only": { "type": "boolean", "const": true },
    "live_producer_implemented": { "type": "boolean", "const": false },
    "live_execution_authorized": { "type": "boolean", "const": false },
    "authority_granted": { "type": "boolean", "const": false },
    "terminal_closure": { "type": "boolean", "const": false },
    "required_components": { "type": "array", "minItems": 9, "maxItems": 9, "items": { "$ref": "#/$defs/required_component" }, "uniqueItems": true },
    "missing_evidence": { "type": "array", "minItems": 9, "maxItems": 9, "items": { "$ref": "#/$defs/missing_evidence_item" }, "uniqueItems": true },
    "authority_denials": { "$ref": "#/$defs/authority_denials" },
    "effect_boundary": { "$ref": "#/$defs/effect_boundary" },
    "validators": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/validator_ref" } },
    "next_action": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "identifier": { "type": "string", "minLength": 1, "maxLength": 180, "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$" },
    "evidence_ref": { "type": "string", "minLength": 1, "maxLength": 360, "pattern": "^(?:future://|examples/)[A-Za-z0-9][A-Za-z0-9._:/#-]*$" },
    "component_id": { "type": "string", "enum": ["admission_gate_ref", "operator_approval_ref", "effect_receipt_packet_ref", "external_adapter_evidence_packet_ref", "secret_handoff_packet_ref", "rollback_proof_packet_ref", "uao_admission_ref", "life_meaning_judgment_ref", "temporal_lease_ref"] },
    "required_component": { "type": "object", "additionalProperties": false, "required": ["component_id", "required_ref", "status", "blocks_live_execution"], "properties": { "component_id": { "$ref": "#/$defs/component_id" }, "required_ref": { "$ref": "#/$defs/evidence_ref" }, "status": { "type": "string", "const": "AwaitingEvidence" }, "blocks_live_execution": { "type": "boolean", "const": true } } },
    "missing_evidence_item": { "type": "object", "additionalProperties": false, "required": ["evidence_id", "status", "blocks_live_execution"], "properties": { "evidence_id": { "$ref": "#/$defs/component_id" }, "status": { "type": "string", "const": "AwaitingEvidence" }, "blocks_live_execution": { "type": "boolean", "const": true } } },
    "authority_denials": { "type": "object", "additionalProperties": false, "required": ["ui_created", "mutation_endpoints_admitted", "external_adapter_integrated", "branch_write_enabled", "pull_request_creation_enabled", "deployment_enabled", "dns_mutation_enabled", "secret_mutation_enabled", "destructive_operation_enabled", "runtime_state_written", "receipt_store_append_enabled", "connector_call_enabled", "live_execution_authorized"], "properties": { "ui_created": { "type": "boolean", "const": false }, "mutation_endpoints_admitted": { "type": "boolean", "const": false }, "external_adapter_integrated": { "type": "boolean", "const": false }, "branch_write_enabled": { "type": "boolean", "const": false }, "pull_request_creation_enabled": { "type": "boolean", "const": false }, "deployment_enabled": { "type": "boolean", "const": false }, "dns_mutation_enabled": { "type": "boolean", "const": false }, "secret_mutation_enabled": { "type": "boolean", "const": false }, "destructive_operation_enabled": { "type": "boolean", "const": false }, "runtime_state_written": { "type": "boolean", "const": false }, "receipt_store_append_enabled": { "type": "boolean", "const": false }, "connector_call_enabled": { "type": "boolean", "const": false }, "live_execution_authorized": { "type": "boolean", "const": false } } },
    "effect_boundary": { "type": "object", "additionalProperties": false, "required": ["ui_created", "mutation_endpoints_admitted", "external_adapter_integrated", "branch_write_enabled", "pull_request_creation_enabled", "deployment_enabled", "dns_mutation_enabled", "secret_mutation_enabled", "destructive_operation_enabled", "runtime_state_written", "receipt_store_append_enabled", "connector_call_enabled", "live_execution_authorized", "network_policy"], "properties": { "ui_created": { "type": "boolean", "const": false }, "mutation_endpoints_admitted": { "type": "boolean", "const": false }, "external_adapter_integrated": { "type": "boolean", "const": false }, "branch_write_enabled": { "type": "boolean", "const": false }, "pull_request_creation_enabled": { "type": "boolean", "const": false }, "deployment_enabled": { "type": "boolean", "const": false }, "dns_mutation_enabled": { "type": "boolean", "const": false }, "secret_mutation_enabled": { "type": "boolean", "const": false }, "destructive_operation_enabled": { "type": "boolean", "const": false }, "runtime_state_written": { "type": "boolean", "const": false }, "receipt_store_append_enabled": { "type": "boolean", "const": false }, "connector_call_enabled": { "type": "boolean", "const": false }, "live_execution_authorized": { "type": "boolean", "const": false }, "network_policy": { "type": "string", "const": "none" } } },
    "validator_ref": { "type": "object", "additionalProperties": false, "required": ["validator_id", "command", "required_for_closure"], "properties": { "validator_id": { "$ref": "#/$defs/identifier" }, "command": { "type": "string", "minLength": 1 }, "required_for_closure": { "type": "boolean", "const": true } } }
  }
}
