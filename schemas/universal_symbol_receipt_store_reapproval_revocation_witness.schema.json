{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:universal-symbol-receipt-store-reapproval-revocation-witness:1",
  "title": "Universal Symbol Receipt Store Reapproval Revocation Witness",
  "description": "Foundation Mode witness for a future UniversalSymbol receipt-store reapproval and revocation boundary. This witness defines approval decision binding, active grant identity, reapproval window, expiry evidence, revocation request, revocation effect boundary, replacement decision, and audit receipt obligations while denying reapproval recording, revocation recording, approval decision recording, approval recording, receipt append, raw payload storage, raw secret storage, runtime dispatch, connector calls, state mutation, terminal closure, and production readiness.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "witness_id",
    "schema_version",
    "generated_at",
    "witness_scope",
    "solver_outcome",
    "foundation_mode",
    "reapproval_revocation_decision",
    "reapproval_revocation_witness_is_not_lifecycle_authority",
    "lifecycle_requirements",
    "authority_denials",
    "lifecycle_constraints",
    "rejection_policy",
    "blocked_reasons",
    "next_actions",
    "evidence_refs",
    "contract_summary"
  ],
  "properties": {
    "witness_id": { "type": "string", "const": "universal-symbol-receipt-store-reapproval-revocation-witness-foundation" },
    "schema_version": { "type": "integer", "const": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "witness_scope": { "type": "string", "const": "foundation-mode-universal-symbol-receipt-store-reapproval-revocation" },
    "solver_outcome": { "type": "string", "const": "AwaitingEvidence" },
    "foundation_mode": { "type": "boolean", "const": true },
    "reapproval_revocation_decision": { "type": "string", "const": "blocked_pending_approval_decision_grant_expiry_revocation_replacement_and_audit_evidence" },
    "reapproval_revocation_witness_is_not_lifecycle_authority": { "type": "boolean", "const": true },
    "lifecycle_requirements": {
      "type": "array",
      "minItems": 8,
      "items": { "$ref": "#/$defs/lifecycle_requirement" },
      "uniqueItems": true
    },
    "authority_denials": { "$ref": "#/$defs/authority_denials" },
    "lifecycle_constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "approval_decision_witness_required",
        "active_grant_identity_required",
        "reapproval_window_required",
        "expiry_evidence_required",
        "revocation_request_required",
        "revocation_effect_boundary_required",
        "replacement_decision_path_required",
        "lifecycle_audit_receipt_required"
      ],
      "properties": {
        "approval_decision_witness_required": { "type": "boolean", "const": true },
        "active_grant_identity_required": { "type": "boolean", "const": true },
        "reapproval_window_required": { "type": "boolean", "const": true },
        "expiry_evidence_required": { "type": "boolean", "const": true },
        "revocation_request_required": { "type": "boolean", "const": true },
        "revocation_effect_boundary_required": { "type": "boolean", "const": true },
        "replacement_decision_path_required": { "type": "boolean", "const": true },
        "lifecycle_audit_receipt_required": { "type": "boolean", "const": true }
      }
    },
    "rejection_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "missing_approval_decision_blocks_lifecycle_change",
        "missing_active_grant_blocks_lifecycle_change",
        "missing_reapproval_window_blocks_lifecycle_change",
        "missing_revocation_boundary_blocks_lifecycle_change",
        "unknown_hard_constraint_blocks_lifecycle_change",
        "failed_precondition_logs_delta_reject"
      ],
      "properties": {
        "missing_approval_decision_blocks_lifecycle_change": { "type": "boolean", "const": true },
        "missing_active_grant_blocks_lifecycle_change": { "type": "boolean", "const": true },
        "missing_reapproval_window_blocks_lifecycle_change": { "type": "boolean", "const": true },
        "missing_revocation_boundary_blocks_lifecycle_change": { "type": "boolean", "const": true },
        "unknown_hard_constraint_blocks_lifecycle_change": { "type": "boolean", "const": true },
        "failed_precondition_logs_delta_reject": { "type": "boolean", "const": true }
      }
    },
    "blocked_reasons": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "string",
        "enum": [
          "approval_decision_witness_missing",
          "active_grant_identity_missing",
          "reapproval_window_missing",
          "expiry_evidence_missing",
          "revocation_request_missing",
          "revocation_effect_boundary_missing",
          "replacement_decision_path_missing",
          "lifecycle_audit_receipt_missing",
          "receipt_store_lifecycle_recording_forbidden",
          "terminal_closure_not_allowed"
        ]
      },
      "uniqueItems": true
    },
    "next_actions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/ref" },
      "uniqueItems": true
    },
    "contract_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lifecycle_requirement_count",
        "authority_denial_count",
        "lifecycle_constraint_count",
        "rejection_check_count",
        "blocked_reason_count",
        "evidence_ref_count"
      ],
      "properties": {
        "lifecycle_requirement_count": { "type": "integer", "minimum": 8 },
        "authority_denial_count": { "type": "integer", "const": 13 },
        "lifecycle_constraint_count": { "type": "integer", "const": 8 },
        "rejection_check_count": { "type": "integer", "const": 6 },
        "blocked_reason_count": { "type": "integer", "minimum": 8 },
        "evidence_ref_count": { "type": "integer", "minimum": 1 }
      }
    }
  },
  "$defs": {
    "ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/#-]*$"
    },
    "lifecycle_requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requirement_id",
        "proof_state",
        "required_evidence_ref",
        "current_decision",
        "delta_reject_ref"
      ],
      "properties": {
        "requirement_id": { "$ref": "#/$defs/ref" },
        "proof_state": { "type": "string", "enum": ["Unknown", "BudgetUnknown", "Fail"] },
        "required_evidence_ref": { "$ref": "#/$defs/ref" },
        "current_decision": { "type": "string", "const": "lifecycle_change_blocked" },
        "delta_reject_ref": { "$ref": "#/$defs/ref" }
      }
    },
    "authority_denials": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_store_reapproval_recorded",
        "receipt_store_revocation_recorded",
        "receipt_store_approval_decision_recorded",
        "receipt_store_operator_approval_recorded",
        "receipt_store_write_path_registered",
        "receipt_store_append_performed",
        "replacement_decision_recorded",
        "raw_payload_stored",
        "raw_secret_stored",
        "runtime_dispatch_performed",
        "connector_call_performed",
        "state_mutation_performed",
        "terminal_closure_allowed"
      ],
      "properties": {
        "receipt_store_reapproval_recorded": { "type": "boolean", "const": false },
        "receipt_store_revocation_recorded": { "type": "boolean", "const": false },
        "receipt_store_approval_decision_recorded": { "type": "boolean", "const": false },
        "receipt_store_operator_approval_recorded": { "type": "boolean", "const": false },
        "receipt_store_write_path_registered": { "type": "boolean", "const": false },
        "receipt_store_append_performed": { "type": "boolean", "const": false },
        "replacement_decision_recorded": { "type": "boolean", "const": false },
        "raw_payload_stored": { "type": "boolean", "const": false },
        "raw_secret_stored": { "type": "boolean", "const": false },
        "runtime_dispatch_performed": { "type": "boolean", "const": false },
        "connector_call_performed": { "type": "boolean", "const": false },
        "state_mutation_performed": { "type": "boolean", "const": false },
        "terminal_closure_allowed": { "type": "boolean", "const": false }
      }
    }
  }
}
