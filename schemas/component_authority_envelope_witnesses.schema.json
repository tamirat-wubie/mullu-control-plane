{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:component-authority-envelope-witnesses:1",
  "title": "Mullu Component Authority Envelope Witnesses",
  "description": "Foundation-stage Component Harness authority envelope witness set. It mirrors registry authority and denies live effects without granting promotion authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "witness_set_id",
    "mode",
    "source_registry",
    "witness_set_is_not_execution_authority",
    "live_execution_enabled",
    "live_connector_send_enabled",
    "terminal_closure_required",
    "authority_policy",
    "authority_witnesses",
    "validators",
    "next_action"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "witness_set_id": {
      "$ref": "#/$defs/identifier"
    },
    "mode": {
      "type": "string",
      "const": "foundation"
    },
    "source_registry": {
      "$ref": "#/$defs/repo_path"
    },
    "witness_set_is_not_execution_authority": {
      "type": "boolean",
      "const": true
    },
    "live_execution_enabled": {
      "type": "boolean",
      "const": false
    },
    "live_connector_send_enabled": {
      "type": "boolean",
      "const": false
    },
    "terminal_closure_required": {
      "type": "boolean",
      "const": true
    },
    "authority_policy": {
      "$ref": "#/$defs/authority_policy"
    },
    "authority_witnesses": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/authority_witness"
      }
    },
    "validators": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/validator_ref"
      }
    },
    "next_action": {
      "type": "string",
      "minLength": 1,
      "maxLength": 260
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "repo_path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9._~:/{}@+ -]+$"
    },
    "evidence_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/#-]*$"
    },
    "lifecycle_state": {
      "type": "string",
      "enum": [
        "not_present",
        "present",
        "registered",
        "validated",
        "bootstrapped",
        "mounted",
        "read_only",
        "draft_only",
        "live_probe",
        "approval_required",
        "approved_live_action",
        "blocked",
        "deprecated"
      ]
    },
    "wiring_state": {
      "type": "string",
      "enum": [
        "present",
        "imported",
        "bootstrapped",
        "mounted",
        "bootstrapped_and_mounted",
        "read_only",
        "draft_only",
        "live_probe",
        "approval_required",
        "live_action_enabled",
        "blocked",
        "deprecated"
      ]
    },
    "authority_level": {
      "type": "string",
      "enum": [
        "none",
        "registry_only",
        "read_only",
        "read_only_advisory",
        "draft_only",
        "live_probe",
        "approval_required",
        "approved_live_action",
        "blocked"
      ]
    },
    "blocked_action": {
      "type": "string",
      "enum": [
        "account_binding_claim",
        "autonomous_execution",
        "calendar_write",
        "connector_call",
        "customer_exposure",
        "deploy",
        "dns_mutation",
        "external_send",
        "filesystem_write",
        "live_dispatch",
        "mailbox_mutation",
        "memory_topology_activation",
        "money_movement",
        "provider_write",
        "public_readiness_claim",
        "route_execution",
        "runtime_mutation",
        "secret_mutation",
        "send_email",
        "terminal_closure"
      ]
    },
    "authority_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "default_all_live_effect_flags_false",
        "live_effect_flags",
        "preview_only_flags",
        "authority_upgrade_requires_separate_witness"
      ],
      "properties": {
        "default_all_live_effect_flags_false": {
          "type": "boolean",
          "const": true
        },
        "live_effect_flags": {
          "type": "array",
          "minItems": 6,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "preview_only_flags": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "authority_upgrade_requires_separate_witness": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "can_call_connector",
        "can_claim_terminal_closure",
        "can_draft",
        "can_emit_receipt",
        "can_execute",
        "can_mutate",
        "can_preview",
        "can_read",
        "can_send_external_message",
        "can_write_files"
      ],
      "properties": {
        "can_call_connector": {
          "type": "boolean",
          "const": false
        },
        "can_claim_terminal_closure": {
          "type": "boolean",
          "const": false
        },
        "can_draft": {
          "type": "boolean"
        },
        "can_emit_receipt": {
          "type": "boolean"
        },
        "can_execute": {
          "type": "boolean",
          "const": false
        },
        "can_mutate": {
          "type": "boolean",
          "const": false
        },
        "can_preview": {
          "type": "boolean"
        },
        "can_read": {
          "type": "boolean"
        },
        "can_send_external_message": {
          "type": "boolean",
          "const": false
        },
        "can_write_files": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "authority_witness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "witness_id",
        "component_id",
        "lifecycle_state",
        "wiring_state",
        "authority_level",
        "proof_state",
        "authority",
        "authority_matches_registry",
        "blocked_actions",
        "evidence_refs",
        "required_validator_refs",
        "witness_is_not_execution_authority",
        "witness_is_not_terminal_closure",
        "authority_upgrade_requires_separate_witness",
        "external_effect"
      ],
      "properties": {
        "witness_id": {
          "$ref": "#/$defs/identifier"
        },
        "component_id": {
          "$ref": "#/$defs/identifier"
        },
        "lifecycle_state": {
          "$ref": "#/$defs/lifecycle_state"
        },
        "wiring_state": {
          "$ref": "#/$defs/wiring_state"
        },
        "authority_level": {
          "$ref": "#/$defs/authority_level"
        },
        "proof_state": {
          "type": "string",
          "enum": [
            "Pass"
          ]
        },
        "authority": {
          "$ref": "#/$defs/authority"
        },
        "authority_matches_registry": {
          "type": "boolean",
          "const": true
        },
        "blocked_actions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/blocked_action"
          }
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/evidence_ref"
          }
        },
        "required_validator_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "witness_is_not_execution_authority": {
          "type": "boolean",
          "const": true
        },
        "witness_is_not_terminal_closure": {
          "type": "boolean",
          "const": true
        },
        "authority_upgrade_requires_separate_witness": {
          "type": "boolean",
          "const": true
        },
        "external_effect": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "validator_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "validator_id",
        "command",
        "required_for_closure"
      ],
      "properties": {
        "validator_id": {
          "$ref": "#/$defs/identifier"
        },
        "command": {
          "type": "string",
          "minLength": 1,
          "maxLength": 240
        },
        "required_for_closure": {
          "type": "boolean",
          "const": true
        }
      }
    }
  }
}
