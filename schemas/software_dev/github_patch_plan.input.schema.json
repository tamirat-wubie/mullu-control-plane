{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:software-dev:github-patch-plan-input:1",
  "title": "Software Dev GitHub Patch Plan Input",
  "description": "Governed local request for drafting a GitHub patch plan from bounded evidence. The request cannot write files, create branches, create pull requests, create issues, post GitHub comments, mutate repository state, or claim fix completion.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "capability_id",
    "request_id",
    "repository_ref",
    "workspace_ref",
    "objective",
    "evidence_refs",
    "evidence_summaries",
    "verification_expectations",
    "metadata"
  ],
  "properties": {
    "capability_id": {
      "const": "software_dev.github_patch_plan.draft"
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "repository_ref": {
      "type": "string",
      "minLength": 1
    },
    "workspace_ref": {
      "type": "string",
      "minLength": 1
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidence_summaries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "verification_expectations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "write_authority_granted": {
      "const": false
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
