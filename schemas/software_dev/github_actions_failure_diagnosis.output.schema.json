{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:github-actions-failure-diagnosis-receipt:1",
  "title": "Software Dev GitHub Actions Failure Diagnosis Receipt",
  "description": "Read-only GitHub Actions failure diagnosis receipt with hash-bound evidence and no repository mutation authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receipt_id",
    "repository",
    "workflow_run_id",
    "status",
    "failure_summary",
    "suspected_failed_jobs",
    "evidence_refs",
    "payload_hashes",
    "actions_blocked",
    "recommended_next_action",
    "write_authority_granted",
    "metadata"
  ],
  "properties": {
    "receipt_id": {
      "type": "string",
      "minLength": 1
    },
    "repository": {
      "type": "string",
      "minLength": 1
    },
    "workflow_run_id": {
      "type": "integer",
      "minimum": 1
    },
    "status": {
      "enum": ["diagnosed", "needs_evidence", "not_failed"]
    },
    "failure_summary": {
      "type": "string",
      "minLength": 1
    },
    "suspected_failed_jobs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "payload_hashes": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "string",
        "pattern": "^sha256:[0-9a-f]{64}$"
      }
    },
    "actions_blocked": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "rerun_workflow_without_explicit_approval",
          "cancel_workflow_without_explicit_approval",
          "dispatch_workflow_without_explicit_approval",
          "post_github_comment_without_write_admission",
          "mutate_repository_without_write_admission"
        ]
      }
    },
    "recommended_next_action": {
      "type": "string",
      "minLength": 1
    },
    "write_authority_granted": {
      "const": false
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
