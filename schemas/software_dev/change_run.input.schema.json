{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:software-dev:change-run-input:1",
  "title": "Software Dev Change Run Input",
  "description": "Governed effect-bearing software change request. The request must bind planning evidence, approval evidence, sandbox constraints, rollback evidence, and no-network execution policy.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "capability_id",
    "request_id",
    "software_request_id",
    "repository_ref",
    "commit_sha",
    "target_branch",
    "context_bundle_ref",
    "gate_plan_ref",
    "approval_ref",
    "workspace_snapshot_ref",
    "rollback_snapshot_ref",
    "work_kind",
    "mode",
    "summary",
    "affected_files",
    "acceptance_criteria",
    "quality_gates",
    "rollback_required",
    "sandbox_profile",
    "command_policy",
    "metadata"
  ],
  "properties": {
    "capability_id": {
      "const": "software_dev.change.run"
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "software_request_id": {
      "type": "string",
      "minLength": 1
    },
    "repository_ref": {
      "type": "string",
      "minLength": 1
    },
    "commit_sha": {
      "type": "string",
      "minLength": 1
    },
    "target_branch": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*//)(?!.*\\.lock$)(?!.*(?:^|/)\\.\\.(?:/|$))[^ ~^:?*\\[\\]\\\\\\r\\n]+$"
    },
    "context_bundle_ref": {
      "type": "string",
      "minLength": 1
    },
    "gate_plan_ref": {
      "type": "string",
      "minLength": 1
    },
    "approval_ref": {
      "type": "string",
      "minLength": 1
    },
    "workspace_snapshot_ref": {
      "type": "string",
      "minLength": 1
    },
    "rollback_snapshot_ref": {
      "type": "string",
      "minLength": 1
    },
    "work_kind": {
      "$ref": "#/$defs/software_work_kind"
    },
    "mode": {
      "enum": ["patch_only", "patch_and_test", "patch_test_review", "commit_candidate"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "affected_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/repository_path"
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "quality_gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/software_quality_gate"
      }
    },
    "max_self_debug_iterations": {
      "type": "integer",
      "minimum": 0,
      "maximum": 5
    },
    "rollback_required": {
      "const": true
    },
    "sandbox_profile": {
      "enum": ["workspace_network_none", "docker_network_none"]
    },
    "command_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "network_allowed",
        "allowed_executables",
        "denied_executables",
        "denied_git_subcommands",
        "max_timeout_seconds",
        "max_output_bytes"
      ],
      "properties": {
        "network_allowed": {
          "const": false
        },
        "allowed_executables": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "denied_executables": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "denied_git_subcommands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": ["push", "pull", "fetch", "clone", "remote", "submodule", "credential"]
          }
        },
        "max_timeout_seconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 900
        },
        "max_output_bytes": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "repository_path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?![A-Za-z]:)[^\\r\\n]+$"
    },
    "software_quality_gate": {
      "enum": ["unit_tests", "integration_tests", "lint", "typecheck", "security_scan", "build", "review"]
    },
    "software_work_kind": {
      "enum": ["bug_fix", "feature", "refactor", "review", "investigate", "test_generation", "security_fix", "docs", "migration", "dependency_update", "rollback"]
    }
  }
}
