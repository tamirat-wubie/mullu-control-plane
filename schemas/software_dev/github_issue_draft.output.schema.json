{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:github-issue-draft-receipt:1",
  "title": "GitHub Issue Draft Receipt",
  "description": "Causal receipt for a governed local GitHub issue draft.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receipt_id",
    "event_id",
    "actor_id",
    "surface",
    "intent",
    "target_object",
    "risk_class",
    "evidence_used",
    "policy_decision",
    "actions_taken",
    "actions_blocked",
    "assumptions",
    "verification_result",
    "final_judgment",
    "memory_update",
    "timestamp"
  ],
  "properties": {
    "receipt_id": {
      "type": "string",
      "pattern": "^github-issue-draft-receipt:"
    },
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "actor_id": {
      "type": "string",
      "minLength": 1
    },
    "surface": {
      "const": "github_operations_workroom"
    },
    "intent": {
      "const": "DRAFT_GITHUB_ISSUE"
    },
    "target_object": {
      "type": "string",
      "pattern": "^github_repository:"
    },
    "risk_class": {
      "const": "class_1_prepare"
    },
    "evidence_used": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "policy_decision": {
      "const": "allow_draft_only"
    },
    "actions_taken": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "actions_blocked": {
      "type": "array",
      "contains": {
        "const": "create_github_issue_without_explicit_approval"
      },
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "assumptions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "verification_result": {
      "type": "string",
      "minLength": 1
    },
    "final_judgment": {
      "type": "string",
      "minLength": 1
    },
    "memory_update": {
      "enum": ["store", "defer"]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "partial_failure_reasons": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
