{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:software-dev:capability-manifest:1",
  "title": "Software Dev Capability Manifest",
  "description": "Governed manifest contract for admitting one software-development capability into a dynamic registry.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "capability_id",
    "version",
    "kind",
    "risk",
    "owner",
    "input_schema_ref",
    "output_schema_ref",
    "allowed_environments",
    "required_gates",
    "rollback_required",
    "sandbox_required",
    "effect_bearing",
    "maturity",
    "evidence_refs",
    "policy_refs",
    "receipt_contract_ref",
    "metadata"
  ],
  "properties": {
    "capability_id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "kind": {
      "const": "software_dev"
    },
    "risk": {
      "enum": ["low", "medium", "high", "critical"]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "input_schema_ref": {
      "type": "string",
      "minLength": 1
    },
    "output_schema_ref": {
      "type": "string",
      "minLength": 1
    },
    "allowed_environments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": ["local", "pilot", "production"]
      }
    },
    "required_gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "rollback_required": {
      "type": "boolean"
    },
    "sandbox_required": {
      "type": "boolean"
    },
    "effect_bearing": {
      "type": "boolean"
    },
    "maturity": {
      "enum": ["C0", "C1", "C2", "C3", "C4", "C5", "C6", "C7"]
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "policy_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "receipt_contract_ref": {
      "type": "string",
      "minLength": 1
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
