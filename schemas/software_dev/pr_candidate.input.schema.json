{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:software-dev:pr-candidate-input:1",
  "title": "Software Dev PR Candidate Input",
  "description": "Governed pull-request candidate preparation request. It may create a review packet and local command candidates, but it cannot push git refs, open a pull request, or deploy.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "capability_id",
    "request_id",
    "repository_ref",
    "base_branch",
    "app_task_graph_ref",
    "software_receipt_refs",
    "quality_gate_refs",
    "approval_request_ref",
    "local_git_push_allowed",
    "open_pull_request_allowed",
    "production_deployment_allowed",
    "metadata"
  ],
  "properties": {
    "capability_id": {
      "const": "software_dev.pr_candidate.prepare"
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "repository_ref": {
      "type": "string",
      "minLength": 1
    },
    "base_branch": {
      "$ref": "#/$defs/git_ref"
    },
    "candidate_branch": {
      "$ref": "#/$defs/git_ref"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "app_task_graph_ref": {
      "type": "string",
      "minLength": 1
    },
    "software_receipt_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "quality_gate_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "approval_request_ref": {
      "type": "string",
      "minLength": 1
    },
    "local_git_push_allowed": {
      "const": false
    },
    "open_pull_request_allowed": {
      "const": false
    },
    "production_deployment_allowed": {
      "const": false
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "git_ref": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*//)(?!.*\\.lock$)(?!.*(?:^|/)\\.\\.(?:/|$))[^ ~^:?*\\[\\]\\\\\\r\\n]+$"
    }
  }
}
