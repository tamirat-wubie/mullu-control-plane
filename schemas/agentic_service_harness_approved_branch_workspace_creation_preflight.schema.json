{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:agentic-service-harness-approved-branch-workspace-creation-preflight:1",
  "title": "Agentic Service Harness Approved Branch Workspace Creation Preflight",
  "description": "Foundation Mode approval-binding preflight for a future branch workspace. This contract binds task-creation admission, temporary branch workspace, and workspace sandbox evidence while keeping branch workspace creation, filesystem writes, adapter execution, connector calls, receipt append, secret serialization, and terminal closure blocked.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "report_id",
    "schema_version",
    "generated_at",
    "solver_outcome",
    "source_contract_refs",
    "scope",
    "approval_binding",
    "required_evidence",
    "authority_denials",
    "validators",
    "next_action",
    "report_is_not_terminal_closure",
    "terminal_closure_required"
  ],
  "properties": {
    "report_id": {
      "type": "string",
      "const": "agentic_service_harness_approved_branch_workspace_creation_preflight"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "solver_outcome": {
      "type": "string",
      "const": "SolvedVerified"
    },
    "source_contract_refs": {
      "type": "array",
      "minItems": 4,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/evidence_ref" }
    },
    "scope": {
      "$ref": "#/$defs/scope"
    },
    "approval_binding": {
      "$ref": "#/$defs/approval_binding"
    },
    "required_evidence": {
      "$ref": "#/$defs/required_evidence"
    },
    "authority_denials": {
      "$ref": "#/$defs/authority_denials"
    },
    "validators": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/validator_ref" }
    },
    "next_action": {
      "type": "string",
      "minLength": 1
    },
    "report_is_not_terminal_closure": {
      "type": "boolean",
      "const": true
    },
    "terminal_closure_required": {
      "type": "boolean",
      "const": true
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "evidence_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/#$-]*$"
    },
    "evidence_ref_list": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/evidence_ref" }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tenant_id",
        "organization_id",
        "project_id",
        "repository_connection_id",
        "repository_slug",
        "task_creation_preflight_id",
        "temporary_workspace_preflight_id",
        "workspace_sandbox_preflight_id",
        "approval_gate_id",
        "foundation_phase",
        "preflight_only",
        "read_only_sources",
        "branch_workspace_creation_admitted",
        "branch_created",
        "filesystem_write_enabled",
        "cleanup_verified",
        "secret_values_serialized"
      ],
      "properties": {
        "tenant_id": { "$ref": "#/$defs/identifier" },
        "organization_id": { "$ref": "#/$defs/identifier" },
        "project_id": { "$ref": "#/$defs/identifier" },
        "repository_connection_id": { "$ref": "#/$defs/identifier" },
        "repository_slug": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
        },
        "task_creation_preflight_id": { "$ref": "#/$defs/identifier" },
        "temporary_workspace_preflight_id": { "$ref": "#/$defs/identifier" },
        "workspace_sandbox_preflight_id": { "$ref": "#/$defs/identifier" },
        "approval_gate_id": { "$ref": "#/$defs/identifier" },
        "foundation_phase": {
          "type": "string",
          "const": "foundation_approved_branch_workspace_creation_preflight"
        },
        "preflight_only": { "type": "boolean", "const": true },
        "read_only_sources": { "type": "boolean", "const": true },
        "branch_workspace_creation_admitted": { "type": "boolean", "const": false },
        "branch_created": { "type": "boolean", "const": false },
        "filesystem_write_enabled": { "type": "boolean", "const": false },
        "cleanup_verified": { "type": "boolean", "const": false },
        "secret_values_serialized": { "type": "boolean", "const": false }
      }
    },
    "approval_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requested_action",
        "requested_route_ref",
        "approval_state",
        "task_creation_admission_valid",
        "temporary_workspace_policy_valid",
        "workspace_sandbox_policy_valid",
        "operator_approval_collected",
        "uao_admission_collected",
        "cleanup_evidence_collected",
        "workspace_create_route_admitted",
        "branch_name_template",
        "workspace_mode",
        "required_before_create_refs",
        "blocked_reason_refs",
        "next_required_evidence_refs"
      ],
      "properties": {
        "requested_action": {
          "type": "string",
          "const": "create_approved_branch_workspace"
        },
        "requested_route_ref": {
          "type": "string",
          "const": "route://harness/branch-workspace/create/not-admitted"
        },
        "approval_state": {
          "type": "string",
          "const": "AWAITING_OPERATOR_APPROVAL"
        },
        "task_creation_admission_valid": { "type": "boolean", "const": true },
        "temporary_workspace_policy_valid": { "type": "boolean", "const": true },
        "workspace_sandbox_policy_valid": { "type": "boolean", "const": true },
        "operator_approval_collected": { "type": "boolean", "const": false },
        "uao_admission_collected": { "type": "boolean", "const": false },
        "cleanup_evidence_collected": { "type": "boolean", "const": false },
        "workspace_create_route_admitted": { "type": "boolean", "const": false },
        "branch_name_template": {
          "type": "string",
          "pattern": "^codex/harness-[A-Za-z0-9._-]+-\\{run_id\\}$"
        },
        "workspace_mode": {
          "type": "string",
          "const": "approved_branch_workspace_preflight_only"
        },
        "required_before_create_refs": { "$ref": "#/$defs/evidence_ref_list" },
        "blocked_reason_refs": { "$ref": "#/$defs/evidence_ref_list" },
        "next_required_evidence_refs": { "$ref": "#/$defs/evidence_ref_list" }
      }
    },
    "required_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "must_have_before_workspace_create",
        "must_have_before_filesystem_write",
        "must_have_before_adapter_execution",
        "must_have_before_receipt_append"
      ],
      "properties": {
        "must_have_before_workspace_create": { "$ref": "#/$defs/evidence_ref_list" },
        "must_have_before_filesystem_write": { "$ref": "#/$defs/evidence_ref_list" },
        "must_have_before_adapter_execution": { "$ref": "#/$defs/evidence_ref_list" },
        "must_have_before_receipt_append": { "$ref": "#/$defs/evidence_ref_list" }
      }
    },
    "authority_denials": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "branch_workspace_create_enabled",
        "filesystem_write_enabled",
        "branch_write_enabled",
        "pull_request_creation_enabled",
        "adapter_execution_enabled",
        "connector_calls_enabled",
        "receipt_store_append_enabled",
        "runtime_state_write_enabled",
        "mutation_route_enabled",
        "secret_values_serialized",
        "terminal_closure",
        "default_high_risk_authority"
      ],
      "properties": {
        "branch_workspace_create_enabled": { "type": "boolean", "const": false },
        "filesystem_write_enabled": { "type": "boolean", "const": false },
        "branch_write_enabled": { "type": "boolean", "const": false },
        "pull_request_creation_enabled": { "type": "boolean", "const": false },
        "adapter_execution_enabled": { "type": "boolean", "const": false },
        "connector_calls_enabled": { "type": "boolean", "const": false },
        "receipt_store_append_enabled": { "type": "boolean", "const": false },
        "runtime_state_write_enabled": { "type": "boolean", "const": false },
        "mutation_route_enabled": { "type": "boolean", "const": false },
        "secret_values_serialized": { "type": "boolean", "const": false },
        "terminal_closure": { "type": "boolean", "const": false },
        "default_high_risk_authority": { "type": "boolean", "const": false }
      }
    },
    "validator_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["validator_id", "command", "required_for_closure"],
      "properties": {
        "validator_id": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "required_for_closure": {
          "type": "boolean",
          "const": true
        }
      }
    }
  }
}
