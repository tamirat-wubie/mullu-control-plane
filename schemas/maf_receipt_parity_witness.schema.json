{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:maf-receipt-parity-witness:1",
  "title": "MAF Receipt Parity Witness",
  "description": "Foundation Mode witness that maps Python receipt schemas to Rust MAF crate surfaces by digest only, while denying runtime binding, subprocess, CLI, and external effect authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "witness_id",
    "witness_version",
    "generated_at",
    "solver_outcome",
    "parity_scope",
    "python_schema_surfaces",
    "rust_crate_surfaces",
    "parity_mappings",
    "authority_boundary",
    "receipt_refs",
    "contract_summary",
    "evidence_refs"
  ],
  "properties": {
    "witness_id": {"type": "string", "minLength": 1},
    "witness_version": {"const": "maf_receipt_parity_witness.v1"},
    "generated_at": {"type": "string", "format": "date-time"},
    "solver_outcome": {"type": "string", "enum": ["AwaitingEvidence", "SolvedUnverified"]},
    "parity_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_family",
        "foundation_mode",
        "parity_mode",
        "runtime_binding_claimed",
        "rust_execution_performed",
        "python_to_rust_call_path_claimed",
        "direct_runtime_binding_deferred",
        "uao_ref",
        "life_meaning_judgment_ref",
        "required_future_witnesses"
      ],
      "properties": {
        "source_family": {"const": "maf/rust"},
        "foundation_mode": {"type": "boolean"},
        "parity_mode": {"const": "digest_only_static_surface_map"},
        "runtime_binding_claimed": {"type": "boolean"},
        "rust_execution_performed": {"type": "boolean"},
        "python_to_rust_call_path_claimed": {"type": "boolean"},
        "direct_runtime_binding_deferred": {"type": "boolean"},
        "uao_ref": {"type": "string", "minLength": 1},
        "life_meaning_judgment_ref": {"type": "string", "minLength": 1},
        "required_future_witnesses": {"$ref": "#/$defs/non_empty_string_array"}
      }
    },
    "python_schema_surfaces": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/python_schema_surface"}
    },
    "rust_crate_surfaces": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/rust_crate_surface"}
    },
    "parity_mappings": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/parity_mapping"}
    },
    "authority_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "digest_only_static_read_allowed",
        "pyo3_binding_allowed",
        "subprocess_execution_allowed",
        "cli_execution_allowed",
        "rust_crate_execution_allowed",
        "python_imports_rust_allowed",
        "external_connector_call_allowed",
        "network_call_allowed",
        "secret_access_allowed",
        "filesystem_write_allowed",
        "runtime_dispatch_allowed",
        "canonical_state_mutation_allowed",
        "terminal_closure_allowed",
        "success_claim_allowed"
      ],
      "properties": {
        "digest_only_static_read_allowed": {"type": "boolean"},
        "pyo3_binding_allowed": {"type": "boolean"},
        "subprocess_execution_allowed": {"type": "boolean"},
        "cli_execution_allowed": {"type": "boolean"},
        "rust_crate_execution_allowed": {"type": "boolean"},
        "python_imports_rust_allowed": {"type": "boolean"},
        "external_connector_call_allowed": {"type": "boolean"},
        "network_call_allowed": {"type": "boolean"},
        "secret_access_allowed": {"type": "boolean"},
        "filesystem_write_allowed": {"type": "boolean"},
        "runtime_dispatch_allowed": {"type": "boolean"},
        "canonical_state_mutation_allowed": {"type": "boolean"},
        "terminal_closure_allowed": {"type": "boolean"},
        "success_claim_allowed": {"type": "boolean"}
      }
    },
    "receipt_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "maf_receipt_parity_witness_schema",
        "maf_receipt_parity_witness_example",
        "maf_receipt_parity_witness_validator",
        "maf_receipt_parity_witness_tests",
        "maf_boundary_doc",
        "maf_receipt_coverage_doc",
        "rust_workspace_manifest",
        "universal_action_orchestration_schema",
        "life_meaning_judgment_schema",
        "worker_failure_receipt_schema"
      ],
      "properties": {
        "maf_receipt_parity_witness_schema": {"type": "string", "minLength": 1},
        "maf_receipt_parity_witness_example": {"type": "string", "minLength": 1},
        "maf_receipt_parity_witness_validator": {"type": "string", "minLength": 1},
        "maf_receipt_parity_witness_tests": {"type": "string", "minLength": 1},
        "maf_boundary_doc": {"type": "string", "minLength": 1},
        "maf_receipt_coverage_doc": {"type": "string", "minLength": 1},
        "rust_workspace_manifest": {"type": "string", "minLength": 1},
        "universal_action_orchestration_schema": {"type": "string", "minLength": 1},
        "life_meaning_judgment_schema": {"type": "string", "minLength": 1},
        "worker_failure_receipt_schema": {"type": "string", "minLength": 1}
      }
    },
    "contract_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "python_schema_surface_count",
        "rust_crate_surface_count",
        "parity_mapping_count",
        "authority_denial_count",
        "awaiting_gap_count",
        "evidence_ref_count"
      ],
      "properties": {
        "python_schema_surface_count": {"type": "integer", "minimum": 0},
        "rust_crate_surface_count": {"type": "integer", "minimum": 0},
        "parity_mapping_count": {"type": "integer", "minimum": 0},
        "authority_denial_count": {"type": "integer", "minimum": 0},
        "awaiting_gap_count": {"type": "integer", "minimum": 0},
        "evidence_ref_count": {"type": "integer", "minimum": 0}
      }
    },
    "evidence_refs": {"$ref": "#/$defs/non_empty_string_array"}
  },
  "$defs": {
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "python_schema_surface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_id",
        "schema_ref",
        "schema_digest_sha256",
        "surface_family",
        "parity_role",
        "required_for_parity"
      ],
      "properties": {
        "schema_id": {"type": "string", "minLength": 1},
        "schema_ref": {"type": "string", "minLength": 1},
        "schema_digest_sha256": {"$ref": "#/$defs/sha256"},
        "surface_family": {"type": "string", "minLength": 1},
        "parity_role": {"type": "string", "minLength": 1},
        "required_for_parity": {"type": "boolean"}
      }
    },
    "rust_crate_surface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "crate_name",
        "crate_manifest_ref",
        "crate_manifest_digest_sha256",
        "crate_entry_ref",
        "crate_entry_digest_sha256",
        "crate_kind",
        "execution_authority_denied",
        "cli_surface"
      ],
      "properties": {
        "crate_name": {"type": "string", "minLength": 1},
        "crate_manifest_ref": {"type": "string", "minLength": 1},
        "crate_manifest_digest_sha256": {"$ref": "#/$defs/sha256"},
        "crate_entry_ref": {"type": "string", "minLength": 1},
        "crate_entry_digest_sha256": {"$ref": "#/$defs/sha256"},
        "crate_kind": {"type": "string", "enum": ["library", "binary"]},
        "execution_authority_denied": {"type": "boolean"},
        "cli_surface": {"type": "boolean"}
      }
    },
    "parity_mapping": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mapping_id",
        "python_schema_ref",
        "rust_crate_name",
        "parity_status",
        "matched_evidence_refs",
        "gap_refs",
        "runtime_binding_allowed"
      ],
      "properties": {
        "mapping_id": {"type": "string", "minLength": 1},
        "python_schema_ref": {"type": "string", "minLength": 1},
        "rust_crate_name": {"type": "string", "minLength": 1},
        "parity_status": {"type": "string", "enum": ["digest_recorded_gap_open", "authority_denied"]},
        "matched_evidence_refs": {"$ref": "#/$defs/non_empty_string_array"},
        "gap_refs": {"$ref": "#/$defs/non_empty_string_array"},
        "runtime_binding_allowed": {"type": "boolean"}
      }
    }
  }
}
