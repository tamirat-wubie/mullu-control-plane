{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:personal-assistant-memory-review:1",
  "title": "Personal Assistant Memory Observation Review Evidence",
  "description": "No-effect evidence envelope for operator review of personal-assistant memory observation candidates.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "review_set_id",
    "generated_at",
    "governed",
    "source_projection",
    "review_count",
    "review_ids",
    "memory_observation_ids",
    "receipt_ids",
    "reviews",
    "effect_boundary",
    "private_payload_policy",
    "assurance",
    "metadata"
  ],
  "properties": {
    "review_set_id": {
      "type": "string",
      "pattern": "^pa_memory_review_set_[a-z0-9][a-z0-9_:-]*$"
    },
    "generated_at": {"type": "string", "minLength": 1},
    "governed": {"const": true},
    "source_projection": {"const": "operator_supplied_memory_review_evidence"},
    "review_count": {"type": "integer", "minimum": 1},
    "review_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^pa_memory_review_[a-z0-9][a-z0-9_:-]*$"
      },
      "uniqueItems": true
    },
    "memory_observation_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^pa_memory_[a-z0-9][a-z0-9_:-]*$"
      },
      "uniqueItems": true
    },
    "receipt_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^pa_receipt_[a-z0-9][a-z0-9_:-]*$"
      },
      "uniqueItems": true
    },
    "reviews": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/review_evidence"}
    },
    "effect_boundary": {"$ref": "#/$defs/effect_boundary"},
    "private_payload_policy": {"$ref": "#/$defs/private_payload_policy"},
    "assurance": {"$ref": "#/$defs/assurance"},
    "metadata": {"$ref": "#/$defs/metadata"}
  },
  "$defs": {
    "review_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "review_id",
        "memory_observation_id",
        "decision",
        "reviewed_at",
        "reviewer_ref",
        "reason_codes",
        "review",
        "candidate",
        "receipt"
      ],
      "properties": {
        "review_id": {
          "type": "string",
          "pattern": "^pa_memory_review_[a-z0-9][a-z0-9_:-]*$"
        },
        "memory_observation_id": {
          "type": "string",
          "pattern": "^pa_memory_[a-z0-9][a-z0-9_:-]*$"
        },
        "decision": {
          "enum": [
            "kept_for_operator_review",
            "rejected",
            "revision_requested",
            "deferred",
            "expired"
          ]
        },
        "reviewed_at": {"type": "string", "minLength": 1},
        "reviewer_ref": {"type": "string", "minLength": 1},
        "reason_codes": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "review": {
          "type": "object",
          "additionalProperties": true
        },
        "candidate": {
          "type": "object",
          "additionalProperties": true
        },
        "receipt": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "effect_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "memory_review_records_allowed",
        "execution_allowed",
        "live_memory_write_allowed",
        "memory_admission_allowed",
        "nested_mind_live_activation_allowed",
        "raw_private_payload_storage_allowed",
        "secret_value_storage_allowed",
        "connector_mutation_allowed",
        "system_of_record_write_allowed",
        "deployment_mutation_allowed",
        "public_readiness_claim_allowed",
        "customer_readiness_claim_allowed"
      ],
      "properties": {
        "memory_review_records_allowed": {"const": true},
        "execution_allowed": {"const": false},
        "live_memory_write_allowed": {"const": false},
        "memory_admission_allowed": {"const": false},
        "nested_mind_live_activation_allowed": {"const": false},
        "raw_private_payload_storage_allowed": {"const": false},
        "secret_value_storage_allowed": {"const": false},
        "connector_mutation_allowed": {"const": false},
        "system_of_record_write_allowed": {"const": false},
        "deployment_mutation_allowed": {"const": false},
        "public_readiness_claim_allowed": {"const": false},
        "customer_readiness_claim_allowed": {"const": false}
      }
    },
    "private_payload_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raw_private_payload_serialized",
        "secret_values_serialized",
        "connector_payload_projection",
        "review_payload_projection"
      ],
      "properties": {
        "raw_private_payload_serialized": {"const": false},
        "secret_values_serialized": {"const": false},
        "connector_payload_projection": {"const": "ref_only"},
        "review_payload_projection": {"const": "bounded_operator_review_record"}
      }
    },
    "assurance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "assurance_id",
        "outcome",
        "foundation_only",
        "ready_for_live_memory_write",
        "ready_for_live_nested_mind_activation",
        "ready_for_customer_readiness_claim",
        "authority_drift_detected",
        "checked_controls",
        "blocking_reasons",
        "next_action"
      ],
      "properties": {
        "assurance_id": {"const": "personal_assistant_memory_review_no_effect_assurance"},
        "outcome": {"enum": ["SolvedVerified", "GovernanceBlocked"]},
        "foundation_only": {"const": true},
        "ready_for_live_memory_write": {"const": false},
        "ready_for_live_nested_mind_activation": {"const": false},
        "ready_for_customer_readiness_claim": {"const": false},
        "authority_drift_detected": {"type": "boolean"},
        "checked_controls": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "blocking_reasons": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "next_action": {"type": "string", "minLength": 1}
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "foundation_only",
        "projection_contract",
        "runtime_boundary",
        "live_memory_write_allowed",
        "memory_admission_allowed",
        "nested_mind_live_activation_allowed",
        "connector_mutation_allowed",
        "system_of_record_write_allowed"
      ],
      "properties": {
        "foundation_only": {"const": true},
        "projection_contract": {"const": "memory_review_evidence_only"},
        "runtime_boundary": {"const": "review_does_not_write_memory"},
        "live_memory_write_allowed": {"const": false},
        "memory_admission_allowed": {"const": false},
        "nested_mind_live_activation_allowed": {"const": false},
        "connector_mutation_allowed": {"const": false},
        "system_of_record_write_allowed": {"const": false}
      }
    }
  }
}
