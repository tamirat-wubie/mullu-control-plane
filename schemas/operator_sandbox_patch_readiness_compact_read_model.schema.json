{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:operator-sandbox-patch-readiness-compact-read-model:1",
  "title": "OperatorSandboxPatchReadinessCompactReadModel",
  "description": "Projection-only read model for the first blocked sandbox patch readiness stage.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "read_model_id",
    "projection_only",
    "external_effects_allowed",
    "summary",
    "source_ref"
  ],
  "properties": {
    "read_model_id": {
      "type": "string",
      "const": "operator_sandbox_patch_readiness_compact.read_model"
    },
    "projection_only": {
      "type": "boolean",
      "const": true
    },
    "external_effects_allowed": {
      "type": "boolean",
      "const": false
    },
    "summary": {
      "$ref": "#/$defs/compact_summary"
    },
    "source_ref": {
      "type": "string",
      "const": "gateway.operator_sandbox_patch_readiness.SANDBOX_PATCH_READINESS_REGISTRY compact first-blocker projection"
    }
  },
  "$defs": {
    "compact_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary_id",
        "blocked_stage_summary_key",
        "blocked_stage_summary_id",
        "blocked_stage_status",
        "blocked_stage_target",
        "next_evidence_id",
        "missing_prerequisite_count",
        "required_before_unlock",
        "external_effects_allowed",
        "operator_message",
        "source_ref"
      ],
      "properties": {
        "summary_id": {
          "type": "string",
          "const": "operator_sandbox_patch_readiness_compact.foundation"
        },
        "blocked_stage_summary_key": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "blocked_stage_summary_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "blocked_stage_status": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "blocked_stage_target": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        },
        "next_evidence_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "missing_prerequisite_count": {
          "type": "integer",
          "minimum": 0
        },
        "required_before_unlock": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          }
        },
        "external_effects_allowed": {
          "type": "boolean",
          "const": false
        },
        "operator_message": {
          "type": "string",
          "minLength": 1,
          "maxLength": 320
        },
        "source_ref": {
          "type": "string",
          "minLength": 1,
          "maxLength": 180
        }
      }
    }
  }
}
