{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:component-route-family-promotion-approval-intake:1",
  "title": "Mullu Component Route-Family Promotion Approval Intake",
  "description": "Read-only Component Harness report that opens operator evidence intake requests for blocked route-family promotion gates without approving promotion or granting execution authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "approval_intake_id",
    "mode",
    "governed",
    "target_surface_id",
    "target_component_id",
    "decision",
    "preflight_outcome",
    "outcome",
    "intake_decision",
    "approval_intake_is_not_execution_authority",
    "live_execution_enabled",
    "live_connector_send_enabled",
    "can_execute",
    "can_mutate",
    "can_call_connector",
    "can_claim_terminal_closure",
    "mutates_router_inventory",
    "ready_for_promotion",
    "terminal_closure_required",
    "source_refs",
    "summary",
    "approval_requests",
    "approval_evidence_required",
    "operator_submission_channels",
    "blocked_actions",
    "expected_receipts",
    "validators",
    "next_action"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "approval_intake_id": {
      "$ref": "#/$defs/identifier"
    },
    "mode": {
      "type": "string",
      "enum": [
        "foundation",
        "read_only"
      ]
    },
    "governed": {
      "type": "boolean",
      "const": true
    },
    "target_surface_id": {
      "$ref": "#/$defs/identifier"
    },
    "target_component_id": {
      "$ref": "#/$defs/identifier"
    },
    "decision": {
      "type": "string",
      "const": "blocked"
    },
    "preflight_outcome": {
      "type": "string",
      "const": "GovernanceBlocked"
    },
    "outcome": {
      "type": "string",
      "const": "AwaitingEvidence"
    },
    "intake_decision": {
      "type": "string",
      "const": "awaiting_operator_evidence"
    },
    "approval_intake_is_not_execution_authority": {
      "type": "boolean",
      "const": true
    },
    "live_execution_enabled": {
      "type": "boolean",
      "const": false
    },
    "live_connector_send_enabled": {
      "type": "boolean",
      "const": false
    },
    "can_execute": {
      "type": "boolean",
      "const": false
    },
    "can_mutate": {
      "type": "boolean",
      "const": false
    },
    "can_call_connector": {
      "type": "boolean",
      "const": false
    },
    "can_claim_terminal_closure": {
      "type": "boolean",
      "const": false
    },
    "mutates_router_inventory": {
      "type": "boolean",
      "const": false
    },
    "ready_for_promotion": {
      "type": "boolean",
      "const": false
    },
    "terminal_closure_required": {
      "type": "boolean",
      "const": true
    },
    "source_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "promotion_approval_candidates",
        "promotion_witness_evidence",
        "promotion_witness_requirements",
        "promotion_preflight",
        "proof_matrix"
      ],
      "properties": {
        "promotion_approval_candidates": {
          "$ref": "#/$defs/repo_path"
        },
        "promotion_witness_evidence": {
          "$ref": "#/$defs/repo_path"
        },
        "promotion_witness_requirements": {
          "$ref": "#/$defs/repo_path"
        },
        "promotion_preflight": {
          "$ref": "#/$defs/repo_path"
        },
        "proof_matrix": {
          "$ref": "#/$defs/repo_path"
        }
      }
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "approval_requests": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/approval_request"
      }
    },
    "approval_evidence_required": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/identifier_or_ref"
      }
    },
    "operator_submission_channels": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/identifier_or_ref"
      }
    },
    "blocked_actions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/identifier"
      }
    },
    "expected_receipts": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/identifier"
      }
    },
    "validators": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/identifier"
      }
    },
    "next_action": {
      "type": "string",
      "minLength": 1,
      "maxLength": 420
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "identifier_or_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/#{}@+ -]*$"
    },
    "repo_path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9._~:/{}@+ -]+$"
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "intake_request_count",
        "open_request_count",
        "not_submitted_request_count",
        "submitted_evidence_count",
        "accepted_evidence_count",
        "rejected_evidence_count",
        "approval_artifact_requirement_count",
        "required_operator_approval_count",
        "authority_grant_count"
      ],
      "properties": {
        "intake_request_count": {
          "type": "integer",
          "const": 4
        },
        "open_request_count": {
          "type": "integer",
          "const": 4
        },
        "not_submitted_request_count": {
          "type": "integer",
          "const": 4
        },
        "submitted_evidence_count": {
          "type": "integer",
          "const": 0
        },
        "accepted_evidence_count": {
          "type": "integer",
          "const": 0
        },
        "rejected_evidence_count": {
          "type": "integer",
          "const": 0
        },
        "approval_artifact_requirement_count": {
          "type": "integer",
          "minimum": 1
        },
        "required_operator_approval_count": {
          "type": "integer",
          "const": 4
        },
        "authority_grant_count": {
          "type": "integer",
          "const": 0
        }
      }
    },
    "approval_request": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "request_id",
        "source_candidate_id",
        "gate_id",
        "request_kind",
        "evidence_key",
        "intake_state",
        "approval_state",
        "evidence_submission_state",
        "proof_state",
        "operator_required",
        "blocks_promotion",
        "satisfies_requirement",
        "request_is_not_execution_authority",
        "mutates_router_inventory",
        "grants_execution_authority",
        "grants_connector_authority",
        "grants_terminal_closure",
        "required_artifacts",
        "acceptance_criteria",
        "rejection_conditions",
        "submitted_evidence_refs"
      ],
      "properties": {
        "request_id": {
          "$ref": "#/$defs/identifier"
        },
        "source_candidate_id": {
          "$ref": "#/$defs/identifier"
        },
        "gate_id": {
          "type": "string",
          "enum": [
            "route_binding_gate",
            "lifecycle_gate",
            "authority_upgrade_gate",
            "product_specific_boundary_gate"
          ]
        },
        "request_kind": {
          "type": "string",
          "enum": [
            "route_binding",
            "lifecycle_transition",
            "authority_upgrade",
            "product_specific_ownership"
          ]
        },
        "evidence_key": {
          "$ref": "#/$defs/identifier"
        },
        "intake_state": {
          "type": "string",
          "const": "open"
        },
        "approval_state": {
          "type": "string",
          "const": "not_approved"
        },
        "evidence_submission_state": {
          "type": "string",
          "const": "not_submitted"
        },
        "proof_state": {
          "type": "string",
          "const": "Unknown"
        },
        "operator_required": {
          "type": "boolean",
          "const": true
        },
        "blocks_promotion": {
          "type": "boolean",
          "const": true
        },
        "satisfies_requirement": {
          "type": "boolean",
          "const": false
        },
        "request_is_not_execution_authority": {
          "type": "boolean",
          "const": true
        },
        "mutates_router_inventory": {
          "type": "boolean",
          "const": false
        },
        "grants_execution_authority": {
          "type": "boolean",
          "const": false
        },
        "grants_connector_authority": {
          "type": "boolean",
          "const": false
        },
        "grants_terminal_closure": {
          "type": "boolean",
          "const": false
        },
        "required_artifacts": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifier_or_ref"
          }
        },
        "acceptance_criteria": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifier_or_ref"
          }
        },
        "rejection_conditions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifier_or_ref"
          }
        },
        "submitted_evidence_refs": {
          "type": "array",
          "maxItems": 0,
          "items": {
            "$ref": "#/$defs/identifier_or_ref"
          }
        }
      }
    }
  }
}
