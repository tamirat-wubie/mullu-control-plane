{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:universal-symbol-receipt-store-write-path-idempotency-witness:1",
  "title": "Universal Symbol Receipt Store Write Path Idempotency Witness",
  "description": "Foundation Mode witness for a future UniversalSymbol receipt-store write-path idempotency boundary. This witness defines idempotency obligations while denying idempotency binding, write-path registration, path custody registration, receipt append, duplicate append, raw payload storage, raw secret storage, runtime dispatch, connector calls, state mutation, terminal closure, and production readiness.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "witness_id",
    "schema_version",
    "generated_at",
    "witness_scope",
    "solver_outcome",
    "foundation_mode",
    "idempotency_decision",
    "idempotency_witness_is_not_append_authority",
    "idempotency_requirements",
    "authority_denials",
    "idempotency_constraints",
    "rejection_policy",
    "blocked_reasons",
    "next_actions",
    "evidence_refs",
    "contract_summary"
  ],
  "properties": {
    "witness_id": { "type": "string", "const": "universal-symbol-receipt-store-write-path-idempotency-witness-foundation" },
    "schema_version": { "type": "integer", "const": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "witness_scope": { "type": "string", "const": "foundation-mode-universal-symbol-receipt-store-write-path-idempotency" },
    "solver_outcome": { "type": "string", "const": "AwaitingEvidence" },
    "foundation_mode": { "type": "boolean", "const": true },
    "idempotency_decision": { "type": "string", "const": "blocked_pending_key_derivation_digest_replay_and_collision_evidence" },
    "idempotency_witness_is_not_append_authority": { "type": "boolean", "const": true },
    "idempotency_requirements": {
      "type": "array",
      "minItems": 8,
      "items": { "$ref": "#/$defs/idempotency_requirement" },
      "uniqueItems": true
    },
    "authority_denials": { "$ref": "#/$defs/authority_denials" },
    "idempotency_constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "deterministic_key_derivation_required",
        "canonical_input_required",
        "tenant_actor_binding_required",
        "write_path_binding_required",
        "payload_digest_binding_required",
        "replay_collision_check_required",
        "duplicate_effect_denial_required",
        "audit_receipt_required"
      ],
      "properties": {
        "deterministic_key_derivation_required": { "type": "boolean", "const": true },
        "canonical_input_required": { "type": "boolean", "const": true },
        "tenant_actor_binding_required": { "type": "boolean", "const": true },
        "write_path_binding_required": { "type": "boolean", "const": true },
        "payload_digest_binding_required": { "type": "boolean", "const": true },
        "replay_collision_check_required": { "type": "boolean", "const": true },
        "duplicate_effect_denial_required": { "type": "boolean", "const": true },
        "audit_receipt_required": { "type": "boolean", "const": true }
      }
    },
    "rejection_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "missing_key_derivation_blocks_idempotency",
        "missing_canonical_input_blocks_idempotency",
        "missing_digest_binding_blocks_idempotency",
        "missing_replay_collision_check_blocks_idempotency",
        "unknown_hard_constraint_blocks_idempotency",
        "failed_precondition_logs_delta_reject"
      ],
      "properties": {
        "missing_key_derivation_blocks_idempotency": { "type": "boolean", "const": true },
        "missing_canonical_input_blocks_idempotency": { "type": "boolean", "const": true },
        "missing_digest_binding_blocks_idempotency": { "type": "boolean", "const": true },
        "missing_replay_collision_check_blocks_idempotency": { "type": "boolean", "const": true },
        "unknown_hard_constraint_blocks_idempotency": { "type": "boolean", "const": true },
        "failed_precondition_logs_delta_reject": { "type": "boolean", "const": true }
      }
    },
    "blocked_reasons": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "string",
        "enum": [
          "deterministic_key_derivation_missing",
          "canonical_input_missing",
          "tenant_actor_binding_missing",
          "write_path_binding_missing",
          "payload_digest_binding_missing",
          "replay_collision_check_missing",
          "duplicate_effect_denial_missing",
          "audit_receipt_missing",
          "receipt_store_write_path_idempotency_forbidden",
          "terminal_closure_not_allowed"
        ]
      },
      "uniqueItems": true
    },
    "next_actions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/ref" },
      "uniqueItems": true
    },
    "contract_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "idempotency_requirement_count",
        "authority_denial_count",
        "idempotency_constraint_count",
        "rejection_check_count",
        "blocked_reason_count",
        "evidence_ref_count"
      ],
      "properties": {
        "idempotency_requirement_count": { "type": "integer", "minimum": 8 },
        "authority_denial_count": { "type": "integer", "const": 11 },
        "idempotency_constraint_count": { "type": "integer", "const": 8 },
        "rejection_check_count": { "type": "integer", "const": 6 },
        "blocked_reason_count": { "type": "integer", "minimum": 8 },
        "evidence_ref_count": { "type": "integer", "minimum": 1 }
      }
    }
  },
  "$defs": {
    "ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/#-]*$"
    },
    "idempotency_requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requirement_id",
        "proof_state",
        "required_evidence_ref",
        "current_decision",
        "delta_reject_ref"
      ],
      "properties": {
        "requirement_id": { "$ref": "#/$defs/ref" },
        "proof_state": { "type": "string", "enum": ["Unknown", "BudgetUnknown", "Fail"] },
        "required_evidence_ref": { "$ref": "#/$defs/ref" },
        "current_decision": { "type": "string", "const": "idempotency_blocked" },
        "delta_reject_ref": { "$ref": "#/$defs/ref" }
      }
    },
    "authority_denials": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_store_write_path_idempotency_bound",
        "receipt_store_write_path_registered",
        "receipt_store_path_custody_registered",
        "receipt_store_append_performed",
        "duplicate_append_allowed",
        "raw_payload_stored",
        "raw_secret_stored",
        "runtime_dispatch_performed",
        "connector_call_performed",
        "state_mutation_performed",
        "terminal_closure_allowed"
      ],
      "properties": {
        "receipt_store_write_path_idempotency_bound": { "type": "boolean", "const": false },
        "receipt_store_write_path_registered": { "type": "boolean", "const": false },
        "receipt_store_path_custody_registered": { "type": "boolean", "const": false },
        "receipt_store_append_performed": { "type": "boolean", "const": false },
        "duplicate_append_allowed": { "type": "boolean", "const": false },
        "raw_payload_stored": { "type": "boolean", "const": false },
        "raw_secret_stored": { "type": "boolean", "const": false },
        "runtime_dispatch_performed": { "type": "boolean", "const": false },
        "connector_call_performed": { "type": "boolean", "const": false },
        "state_mutation_performed": { "type": "boolean", "const": false },
        "terminal_closure_allowed": { "type": "boolean", "const": false }
      }
    }
  }
}
