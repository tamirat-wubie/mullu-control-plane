        "explicit_operator_value_present",
        "template_accepted_as_value",
        "authority_granted",
        "execution_worker_admission_allowed",
        "dispatch_allowed",
        "live_connector_execution_allowed",
        "connector_mutation_allowed",
        "system_of_record_write_allowed",
        "memory_write_allowed"
      ],
      "properties": {
        "foundation_only": {"const": true},
        "projection_contract": {"const": "operator_reapproval_decision_receipt_value_template_evidence_only"},
        "runtime_boundary": {"const": "value_template_records_required_submitted_value_shape_without_collecting_value"},
        "operator_value_collected": {"const": false},
        "explicit_operator_value_present": {"const": false},
        "template_accepted_as_value": {"const": false},
        "authority_granted": {"const": false},
        "execution_worker_admission_allowed": {"const": false},
        "dispatch_allowed": {"const": false},
        "live_connector_execution_allowed": {"const": false},
        "connector_mutation_allowed": {"const": false},
        "system_of_record_write_allowed": {"const": false},
