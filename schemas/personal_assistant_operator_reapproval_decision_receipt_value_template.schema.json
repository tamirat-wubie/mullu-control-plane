{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:personal-assistant-operator-reapproval-decision-receipt-value-template:1",
  "title": "Personal Assistant Operator Reapproval Decision Receipt Value Template",
  "description": "Foundation Mode no-effect template contract that records required submitted-value fields without collecting operator authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "value_template_set_id",
    "generated_at",
    "governed",
    "source_projection",
    "source_operator_reapproval_decision_receipt_value_absence_set_id",
    "template_count",
    "template_ids",
    "source_absence_ids",
    "receipt_ids",
    "templates",
    "effect_boundary",
    "private_payload_policy",
    "assurance",
    "metadata"
  ],
  "properties": {
    "value_template_set_id": {"type": "string", "pattern": "^pa_operator_reapproval_decision_receipt_value_template_[a-z0-9][a-z0-9_:-]*$"},
    "generated_at": {"type": "string", "minLength": 1},
    "governed": {"const": true},
    "source_projection": {"const": "operator_reapproval_decision_receipt_value_absence"},
