    "template_count": {"type": "integer", "minimum": 1},
    "template_ids": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "pattern": "^pa_operator_reapproval_decision_receipt_value_template_item_[a-z0-9][a-z0-9_:-]*$"},
      "uniqueItems": true
    },
    "source_absence_ids": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "pattern": "^pa_operator_reapproval_decision_receipt_value_absence_item_[a-z0-9][a-z0-9_:-]*$"},
      "uniqueItems": true
    },
    "receipt_ids": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "pattern": "^pa_receipt_[a-z0-9][a-z0-9_:-]*$"},
      "uniqueItems": true
    },
    "templates": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/template_item"}
    },
    "effect_boundary": {"$ref": "#/$defs/effect_boundary"},
    "private_payload_policy": {"$ref": "#/$defs/private_payload_policy"},
    "assurance": {"$ref": "#/$defs/assurance"},
    "metadata": {"$ref": "#/$defs/metadata"}
  },
