{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:snet-operator-read-model:1",
  "title": "SNet Operator Read Model",
  "description": "Read-only bounded operator projection for SNet recursive WH symbolic mesh state.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "enabled",
    "surface",
    "raw_answers_exposed",
    "raw_metadata_values_exposed",
    "execution_authority_granted",
    "connector_authority_granted",
    "route_authority_granted",
    "filesystem_authority_granted",
    "episode_replay",
    "receipt_reconstruction",
    "audit_explanation",
    "blocked_authorities",
    "symbol_count",
    "question_count",
    "answer_count",
    "metadata_count",
    "relation_count",
    "unknown_count",
    "contradiction_count",
    "settlement_counts",
    "selected_symbols",
    "truncated_symbol_count",
    "receipt"
  ],
  "properties": {
    "enabled": {
      "type": "boolean",
      "const": true
    },
    "surface": {
      "type": "string",
      "const": "read_only_snet_recursive_mesh"
    },
    "raw_answers_exposed": {
      "type": "boolean",
      "const": false
    },
    "raw_metadata_values_exposed": {
      "type": "boolean",
      "const": false
    },
    "execution_authority_granted": {
      "type": "boolean",
      "const": false
    },
    "connector_authority_granted": {
      "type": "boolean",
      "const": false
    },
    "route_authority_granted": {
      "type": "boolean",
      "const": false
    },
    "filesystem_authority_granted": {
      "type": "boolean",
      "const": false
    },
    "episode_replay": {
      "$ref": "#/$defs/episode_replay"
    },
    "receipt_reconstruction": {
      "$ref": "#/$defs/receipt_reconstruction"
    },
    "audit_explanation": {
      "$ref": "#/$defs/audit_explanation"
    },
    "blocked_authorities": {
      "type": "array",
      "minItems": 5,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "snet_live_execution_authority",
          "snet_connector_authority",
          "snet_filesystem_authority",
          "snet_autonomous_action_routing",
          "terminal_closure_authority"
        ]
      }
    },
    "symbol_count": {
      "$ref": "#/$defs/non_negative_integer"
    },
    "question_count": {
      "$ref": "#/$defs/non_negative_integer"
    },
    "answer_count": {
      "$ref": "#/$defs/non_negative_integer"
    },
    "metadata_count": {
      "$ref": "#/$defs/non_negative_integer"
    },
    "relation_count": {
      "$ref": "#/$defs/non_negative_integer"
    },
    "unknown_count": {
      "$ref": "#/$defs/non_negative_integer"
    },
    "contradiction_count": {
      "$ref": "#/$defs/non_negative_integer"
    },
    "settlement_counts": {
      "$ref": "#/$defs/settlement_counts"
    },
    "selected_symbols": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/symbol_summary"
      }
    },
    "truncated_symbol_count": {
      "$ref": "#/$defs/non_negative_integer"
    },
    "receipt": {
      "$ref": "#/$defs/snet_mesh_receipt"
    }
  },
  "$defs": {
    "unit_number": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "non_negative_integer": {
      "type": "integer",
      "minimum": 0
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "episode_replay": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface",
        "mode",
        "operator_read_model_only",
        "receipt_reconstruction_allowed",
        "audit_explanation_allowed",
        "live_execution_authority_granted",
        "connector_authority_granted",
        "filesystem_authority_granted",
        "autonomous_action_routing_granted",
        "source_refs",
        "expected_receipt_id",
        "expected_mesh_digest"
      ],
      "properties": {
        "surface": {
          "type": "string",
          "const": "snet_episode_replay"
        },
        "mode": {
          "type": "string",
          "const": "deterministic_local"
        },
        "operator_read_model_only": {
          "type": "boolean",
          "const": true
        },
        "receipt_reconstruction_allowed": {
          "type": "boolean",
          "const": true
        },
        "audit_explanation_allowed": {
          "type": "boolean",
          "const": true
        },
        "live_execution_authority_granted": {
          "type": "boolean",
          "const": false
        },
        "connector_authority_granted": {
          "type": "boolean",
          "const": false
        },
        "filesystem_authority_granted": {
          "type": "boolean",
          "const": false
        },
        "autonomous_action_routing_granted": {
          "type": "boolean",
          "const": false
        },
        "source_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "expected_receipt_id": {
          "type": "string",
          "pattern": "^snet-mesh-[0-9a-f]{16}$"
        },
        "expected_mesh_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      }
    },
    "receipt_reconstruction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reconstruction_mode",
        "deterministic",
        "receipt_id",
        "mesh_digest",
        "evidence_refs",
        "raw_answers_required",
        "raw_metadata_required",
        "terminal_closure_granted"
      ],
      "properties": {
        "reconstruction_mode": {
          "type": "string",
          "const": "receipt_from_bounded_mesh_digest"
        },
        "deterministic": {
          "type": "boolean",
          "const": true
        },
        "receipt_id": {
          "type": "string",
          "pattern": "^snet-mesh-[0-9a-f]{16}$"
        },
        "mesh_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "evidence_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        },
        "raw_answers_required": {
          "type": "boolean",
          "const": false
        },
        "raw_metadata_required": {
          "type": "boolean",
          "const": false
        },
        "terminal_closure_granted": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "audit_explanation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "explanation_mode",
        "summary",
        "receipt_id",
        "live_execution_authority_denied",
        "connector_authority_denied",
        "filesystem_authority_denied",
        "autonomous_action_routing_denied",
        "terminal_closure_denied"
      ],
      "properties": {
        "explanation_mode": {
          "type": "string",
          "const": "bounded_operator_summary"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "receipt_id": {
          "type": "string",
          "pattern": "^snet-mesh-[0-9a-f]{16}$"
        },
        "live_execution_authority_denied": {
          "type": "boolean",
          "const": true
        },
        "connector_authority_denied": {
          "type": "boolean",
          "const": true
        },
        "filesystem_authority_denied": {
          "type": "boolean",
          "const": true
        },
        "autonomous_action_routing_denied": {
          "type": "boolean",
          "const": true
        },
        "terminal_closure_denied": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "settlement_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "active",
        "expanding",
        "settled",
        "dormant",
        "contradictory",
        "unknown_heavy",
        "deprecated"
      ],
      "properties": {
        "active": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "expanding": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "settled": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "dormant": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "contradictory": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "unknown_heavy": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "deprecated": {
          "$ref": "#/$defs/non_negative_integer"
        }
      }
    },
    "symbol_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "symbol_id",
        "label",
        "symbol_type",
        "sense_id",
        "ontology_status",
        "settlement_state",
        "depth",
        "parent_context",
        "metadata_count",
        "relation_count",
        "inquiry_count"
      ],
      "properties": {
        "symbol_id": {
          "type": "string",
          "pattern": "^snet-symbol:[0-9a-f]{20}$"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "symbol_type": {
          "type": "string",
          "minLength": 1
        },
        "sense_id": {
          "type": "string"
        },
        "ontology_status": {
          "type": "string",
          "enum": [
            "known",
            "candidate",
            "unknown_status",
            "rejected"
          ]
        },
        "settlement_state": {
          "type": "string",
          "enum": [
            "active",
            "expanding",
            "settled",
            "dormant",
            "contradictory",
            "unknown_heavy",
            "deprecated"
          ]
        },
        "depth": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "parent_context": {
          "type": "string"
        },
        "metadata_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "relation_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "inquiry_count": {
          "$ref": "#/$defs/non_negative_integer"
        }
      }
    },
    "snet_mesh_receipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_id",
        "snet_version",
        "semantics_hash",
        "mesh_digest",
        "surface",
        "symbol_count",
        "question_count",
        "answer_count",
        "metadata_count",
        "relation_count",
        "unknown_count",
        "contradiction_count",
        "max_depth",
        "promotion_threshold",
        "settlement_counts",
        "terminal_closure_required",
        "receipt_is_not_terminal_closure",
        "raw_answers_exposed",
        "raw_metadata_values_exposed",
        "execution_authority_granted",
        "connector_authority_granted",
        "route_authority_granted",
        "filesystem_authority_granted",
        "evidence_refs"
      ],
      "properties": {
        "receipt_id": {
          "type": "string",
          "pattern": "^snet-mesh-[0-9a-f]{16}$"
        },
        "snet_version": {
          "type": "string",
          "minLength": 1
        },
        "semantics_hash": {
          "type": "string",
          "pattern": "^sha256:.+"
        },
        "mesh_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "surface": {
          "type": "string",
          "const": "read_only_snet_recursive_mesh"
        },
        "symbol_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "question_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "answer_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "metadata_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "relation_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "unknown_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "contradiction_count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "max_depth": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "promotion_threshold": {
          "$ref": "#/$defs/unit_number"
        },
        "settlement_counts": {
          "$ref": "#/$defs/settlement_counts"
        },
        "terminal_closure_required": {
          "type": "boolean",
          "const": true
        },
        "receipt_is_not_terminal_closure": {
          "type": "boolean",
          "const": true
        },
        "raw_answers_exposed": {
          "type": "boolean",
          "const": false
        },
        "raw_metadata_values_exposed": {
          "type": "boolean",
          "const": false
        },
        "execution_authority_granted": {
          "type": "boolean",
          "const": false
        },
        "connector_authority_granted": {
          "type": "boolean",
          "const": false
        },
        "route_authority_granted": {
          "type": "boolean",
          "const": false
        },
        "filesystem_authority_granted": {
          "type": "boolean",
          "const": false
        },
        "evidence_refs": {
          "$ref": "#/$defs/non_empty_string_array"
        }
      }
    }
  }
}
