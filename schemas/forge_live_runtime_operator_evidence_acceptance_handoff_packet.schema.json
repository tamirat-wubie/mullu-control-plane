{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:forge-live-runtime-operator-evidence-acceptance-handoff-packet:1",
  "title": "Forge Live Runtime Operator Evidence Acceptance Handoff Packet",
  "description": "Foundation Mode packet that hands independently verified operator evidence toward acceptance review without granting acceptance, runtime, production, commit, or signed receipt population authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "packet_id",
    "schema_ref",
    "schema_version",
    "bridge_ref",
    "source_operator_evidence_verification_gate_ref",
    "source_operator_evidence_verification_gate_hash",
    "handoff_mode",
    "handoff_status",
    "solver_outcome",
    "proof_state",
    "handoff_items",
    "handoff_item_count",
    "ready_item_count",
    "required_item_count",
    "all_items_ready_for_acceptance_review",
    "acceptance_review_allowed",
    "acceptance_authority_effect",
    "signed_receipt_population_allowed",
    "runtime_authority_effect",
    "secret_values_present",
    "blocked_reasons",
    "required_controls",
    "disallowed_authority",
    "next_allowed_action",
    "validators",
    "packet_hash"
  ],
  "properties": {
    "packet_id": {
      "type": "string",
      "const": "forge-live-runtime-operator-evidence-acceptance-handoff-packet.v1"
    },
    "schema_ref": {
      "type": "string",
      "const": "urn:mullusi:schema:forge-live-runtime-operator-evidence-acceptance-handoff-packet:1"
    },
    "schema_version": { "type": "integer", "const": 1 },
    "bridge_ref": { "type": "string", "const": "forge_write_spine_bridge.v1" },
    "source_operator_evidence_verification_gate_ref": {
      "type": "string",
      "pattern": "^(examples/)?[A-Za-z0-9_./-]+\\.json$"
    },
    "source_operator_evidence_verification_gate_hash": { "$ref": "#/$defs/hash" },
    "handoff_mode": {
      "type": "string",
      "const": "verified_operator_evidence_to_acceptance_review"
    },
    "handoff_status": {
      "type": "string",
      "enum": [
        "blocked_awaiting_verified_operator_evidence",
        "verified_operator_evidence_ready_for_acceptance_review"
      ]
    },
    "solver_outcome": { "type": "string", "const": "AwaitingEvidence" },
    "proof_state": { "type": "string", "const": "Unknown" },
    "handoff_items": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "items": { "$ref": "#/$defs/handoff_item" }
    },
    "handoff_item_count": { "type": "integer", "const": 10 },
    "ready_item_count": { "type": "integer", "minimum": 0, "maximum": 10 },
    "required_item_count": { "type": "integer", "const": 10 },
    "all_items_ready_for_acceptance_review": { "type": "boolean" },
    "acceptance_review_allowed": { "type": "boolean" },
    "acceptance_authority_effect": { "type": "boolean", "const": false },
    "signed_receipt_population_allowed": { "type": "boolean", "const": false },
    "runtime_authority_effect": { "type": "boolean", "const": false },
    "secret_values_present": { "type": "boolean", "const": false },
    "blocked_reasons": {
      "type": "array",
      "minItems": 0,
      "maxItems": 10,
      "items": { "type": "string", "minLength": 1 }
    },
    "required_controls": {
      "type": "array",
      "minItems": 11,
      "maxItems": 11,
      "items": { "type": "string", "minLength": 1 }
    },
    "disallowed_authority": { "$ref": "#/$defs/disallowed_authority" },
    "next_allowed_action": {
      "type": "string",
      "const": "route_verified_operator_evidence_to_acceptance_review"
    },
    "validators": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": { "$ref": "#/$defs/validator" }
    },
    "packet_hash": { "$ref": "#/$defs/hash" }
  },
  "$defs": {
    "hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "handoff_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_id",
        "target_evidence_ref",
        "source_verification_ref",
        "verification_status",
        "verified_ref_count",
        "required_verification_count",
        "ready_for_acceptance_review",
        "acceptance_authority_effect",
        "signed_receipt_population_allowed",
        "blocker_reason"
      ],
      "properties": {
        "evidence_id": { "type": "string", "minLength": 1 },
        "target_evidence_ref": {
          "type": "string",
          "pattern": "^evidence://forge/live-runtime/[a-z0-9-]+$"
        },
        "source_verification_ref": {
          "type": "string",
          "pattern": "^verification://forge/live-runtime/operator-evidence/[a-z0-9-]+$"
        },
        "verification_status": {
          "type": "string",
          "enum": ["missing", "verified_pending_acceptance"]
        },
        "verified_ref_count": { "type": "integer", "minimum": 0, "maximum": 8 },
        "required_verification_count": { "type": "integer", "const": 8 },
        "ready_for_acceptance_review": { "type": "boolean" },
        "acceptance_authority_effect": { "type": "boolean", "const": false },
        "signed_receipt_population_allowed": { "type": "boolean", "const": false },
        "blocker_reason": { "type": "string" }
      }
    },
    "disallowed_authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "live_runtime_authorized",
        "state_write_runtime_registered",
        "production_authorized",
        "external_effects_allowed",
        "commit_allowed",
        "terminal_closure"
      ],
      "properties": {
        "live_runtime_authorized": { "type": "boolean", "const": false },
        "state_write_runtime_registered": { "type": "boolean", "const": false },
        "production_authorized": { "type": "boolean", "const": false },
        "external_effects_allowed": { "type": "boolean", "const": false },
        "commit_allowed": { "type": "boolean", "const": false },
        "terminal_closure": { "type": "boolean", "const": false }
      }
    },
    "validator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["validator_id", "command", "required_for_closure"],
      "properties": {
        "validator_id": {
          "type": "string",
          "const": "forge-live-runtime-operator-evidence-acceptance-handoff-packet"
        },
        "command": {
          "type": "string",
          "const": "python scripts/validate_forge_live_runtime_operator_evidence_acceptance_handoff_packet.py"
        },
        "required_for_closure": { "type": "boolean", "const": true }
      }
    }
  }
}
