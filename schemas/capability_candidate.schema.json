{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:capability-candidate:1",
  "title": "Capability Candidate Package",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "package_id",
    "capability_id",
    "version",
    "domain",
    "risk",
    "side_effects",
    "schemas",
    "adapter",
    "policy_rules",
    "evals",
    "mock_provider",
    "sandbox_tests",
    "receipt_contract",
    "rollback_path",
    "documentation",
    "certification_status",
    "promotion_blocked",
    "package_hash"
  ],
  "properties": {
    "package_id": {
      "type": "string",
      "minLength": 1
    },
    "capability_id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "domain": {
      "type": "string",
      "minLength": 1
    },
    "risk": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "side_effects": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "schemas": {
      "$ref": "#/$defs/schema_bundle"
    },
    "adapter": {
      "$ref": "#/$defs/adapter_spec"
    },
    "policy_rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/policy_rule"
      }
    },
    "evals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/eval_case"
      }
    },
    "mock_provider": {
      "$ref": "#/$defs/mock_provider"
    },
    "sandbox_tests": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/sandbox_test"
      }
    },
    "receipt_contract": {
      "$ref": "#/$defs/receipt_contract"
    },
    "rollback_path": {
      "$ref": "#/$defs/rollback_path"
    },
    "documentation": {
      "$ref": "#/$defs/documentation"
    },
    "certification_status": {
      "type": "string",
      "const": "candidate"
    },
    "promotion_blocked": {
      "type": "boolean",
      "const": true
    },
    "package_hash": {
      "type": "string",
      "minLength": 1
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "schema_bundle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "input_schema_ref",
        "output_schema_ref",
        "error_schema_ref",
        "receipt_schema_ref"
      ],
      "properties": {
        "input_schema_ref": {
          "type": "string",
          "minLength": 1
        },
        "output_schema_ref": {
          "type": "string",
          "minLength": 1
        },
        "error_schema_ref": {
          "type": "string",
          "minLength": 1
        },
        "receipt_schema_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "adapter_spec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "adapter_id",
        "adapter_type",
        "entrypoint",
        "sandbox_required",
        "network_allowlist",
        "secret_scope"
      ],
      "properties": {
        "adapter_id": {
          "type": "string",
          "minLength": 1
        },
        "adapter_type": {
          "type": "string",
          "minLength": 1
        },
        "entrypoint": {
          "type": "string",
          "minLength": 1
        },
        "sandbox_required": {
          "type": "boolean"
        },
        "network_allowlist": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "secret_scope": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "policy_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "rule_type",
        "required",
        "description"
      ],
      "properties": {
        "rule_id": {
          "type": "string",
          "minLength": 1
        },
        "rule_type": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean"
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "eval_case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "eval_id",
        "eval_type",
        "fixture_ref",
        "required"
      ],
      "properties": {
        "eval_id": {
          "type": "string",
          "minLength": 1
        },
        "eval_type": {
          "type": "string",
          "minLength": 1
        },
        "fixture_ref": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean"
        }
      }
    },
    "mock_provider": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider_id",
        "fixture_ref",
        "deterministic"
      ],
      "properties": {
        "provider_id": {
          "type": "string",
          "minLength": 1
        },
        "fixture_ref": {
          "type": "string",
          "minLength": 1
        },
        "deterministic": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "sandbox_test": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "test_id",
        "scenario_ref",
        "expected_receipt_ref"
      ],
      "properties": {
        "test_id": {
          "type": "string",
          "minLength": 1
        },
        "scenario_ref": {
          "type": "string",
          "minLength": 1
        },
        "expected_receipt_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "receipt_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_type",
        "required_fields",
        "terminal_certificate_required"
      ],
      "properties": {
        "receipt_type": {
          "type": "string",
          "minLength": 1
        },
        "required_fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "terminal_certificate_required": {
          "type": "boolean"
        }
      }
    },
    "rollback_path": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rollback_type",
        "review_required",
        "compensation_required"
      ],
      "properties": {
        "rollback_type": {
          "type": "string",
          "minLength": 1
        },
        "capability_ref": {
          "type": "string"
        },
        "review_required": {
          "type": "boolean"
        },
        "compensation_required": {
          "type": "boolean"
        }
      }
    },
    "documentation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operator_runbook_ref",
        "promotion_evidence_ref",
        "limitations_ref"
      ],
      "properties": {
        "operator_runbook_ref": {
          "type": "string",
          "minLength": 1
        },
        "promotion_evidence_ref": {
          "type": "string",
          "minLength": 1
        },
        "limitations_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
