{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:team-ops-shared-inbox-terminal-closure-review-packet:1",
  "title": "TeamOps Shared Inbox Terminal Closure Review Packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receipt_id",
    "schema_version",
    "workflow_id",
    "source_sent_message_observation_receipt_ref",
    "source_sent_message_observation_receipt_id",
    "sent_message_observation_receipt_valid",
    "sent_message_observation_receipt_ready",
    "provider_observation_receipt_ref",
    "provider_observation_receipt_id",
    "provider_observation_receipt_valid",
    "status",
    "solver_outcome",
    "proof_state",
    "reviewed_at",
    "closure_review_state",
    "closure_review_ready",
    "terminal_closure_candidate_ready",
    "terminal_closure_certificate_required",
    "review_packet_ref",
    "review_packet_hash",
    "send_execution_ref",
    "dispatch_receipt_ref",
    "provider_message_ref",
    "provider_message_hash",
    "first_observation_ref",
    "first_observation_hash",
    "second_observation_ref",
    "second_observation_hash",
    "duplicate_absence_observed",
    "replay_ref",
    "replay_hash",
    "deterministic_replay_observed",
    "required_terminal_evidence_refs",
    "approval_chain_reviewed",
    "send_execution_reviewed",
    "sent_message_observation_reviewed",
    "duplicate_absence_reviewed",
    "deterministic_replay_reviewed",
    "review_performed_by_producer",
    "terminal_closure_certificate_minted_by_producer",
    "external_message_sent_by_producer",
    "external_mailbox_write_performed_by_producer",
    "provider_mutation_performed_by_producer",
    "provider_call_performed_by_producer",
    "draft_created_by_producer",
    "raw_message_content_serialized",
    "raw_recipient_serialized",
    "raw_subject_serialized",
    "raw_body_serialized",
    "raw_provider_payload_serialized",
    "no_secret_values_serialized",
    "report_is_not_terminal_closure",
    "production_ready_claimed",
    "evidence_refs",
    "blocked_until",
    "recovery_actions",
    "validation_commands"
  ],
  "properties": {
    "receipt_id": {
      "type": "string",
      "pattern": "^teamops-shared-inbox-terminal-closure-review-packet-[0-9a-f]{16}$"
    },
    "schema_version": { "type": "integer", "const": 1 },
    "workflow_id": { "type": "string", "const": "team_ops.shared_inbox_triage" },
    "source_sent_message_observation_receipt_ref": { "type": "string", "minLength": 1 },
    "source_sent_message_observation_receipt_id": { "type": "string" },
    "sent_message_observation_receipt_valid": { "type": "boolean" },
    "sent_message_observation_receipt_ready": { "type": "boolean" },
    "provider_observation_receipt_ref": { "type": "string" },
    "provider_observation_receipt_id": {
      "type": "string",
      "pattern": "^$|^teamops-shared-inbox-provider-observation-receipt-[0-9a-f]{16}$"
    },
    "provider_observation_receipt_valid": { "type": "boolean" },
    "status": { "type": "string", "enum": ["blocked", "failed", "passed"] },
    "solver_outcome": {
      "type": "string",
      "enum": ["AwaitingEvidence", "GovernanceBlocked", "SolvedVerified"]
    },
    "proof_state": { "type": "string", "enum": ["Unknown", "Fail", "Pass"] },
    "reviewed_at": { "type": "string", "format": "date-time" },
    "closure_review_state": {
      "type": "string",
      "enum": ["missing", "assembled", "invalid"]
    },
    "closure_review_ready": { "type": "boolean" },
    "terminal_closure_candidate_ready": { "type": "boolean" },
    "terminal_closure_certificate_required": { "type": "boolean", "const": true },
    "review_packet_ref": { "type": "string" },
    "review_packet_hash": { "type": "string", "pattern": "^$|^[0-9a-f]{64}$" },
    "send_execution_ref": { "type": "string" },
    "dispatch_receipt_ref": { "type": "string" },
    "provider_message_ref": { "type": "string" },
    "provider_message_hash": { "type": "string", "pattern": "^$|^[0-9a-f]{64}$" },
    "first_observation_ref": { "type": "string" },
    "first_observation_hash": { "type": "string", "pattern": "^$|^[0-9a-f]{64}$" },
    "second_observation_ref": { "type": "string" },
    "second_observation_hash": { "type": "string", "pattern": "^$|^[0-9a-f]{64}$" },
    "duplicate_absence_observed": { "type": "boolean" },
    "replay_ref": { "type": "string" },
    "replay_hash": { "type": "string", "pattern": "^$|^[0-9a-f]{64}$" },
    "deterministic_replay_observed": { "type": "boolean" },
    "required_terminal_evidence_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "approval_chain_reviewed": { "type": "boolean" },
    "send_execution_reviewed": { "type": "boolean" },
    "sent_message_observation_reviewed": { "type": "boolean" },
    "duplicate_absence_reviewed": { "type": "boolean" },
    "deterministic_replay_reviewed": { "type": "boolean" },
    "review_performed_by_producer": { "type": "boolean", "const": false },
    "terminal_closure_certificate_minted_by_producer": { "type": "boolean", "const": false },
    "external_message_sent_by_producer": { "type": "boolean", "const": false },
    "external_mailbox_write_performed_by_producer": { "type": "boolean", "const": false },
    "provider_mutation_performed_by_producer": { "type": "boolean", "const": false },
    "provider_call_performed_by_producer": { "type": "boolean", "const": false },
    "draft_created_by_producer": { "type": "boolean", "const": false },
    "raw_message_content_serialized": { "type": "boolean", "const": false },
    "raw_recipient_serialized": { "type": "boolean", "const": false },
    "raw_subject_serialized": { "type": "boolean", "const": false },
    "raw_body_serialized": { "type": "boolean", "const": false },
    "raw_provider_payload_serialized": { "type": "boolean", "const": false },
    "no_secret_values_serialized": { "type": "boolean", "const": true },
    "report_is_not_terminal_closure": { "type": "boolean", "const": true },
    "production_ready_claimed": { "type": "boolean", "const": false },
    "evidence_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "blocked_until": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "recovery_actions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "validation_commands": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "passed" } }, "required": ["status"] },
      "then": {
        "properties": {
          "sent_message_observation_receipt_valid": { "const": true },
          "sent_message_observation_receipt_ready": { "const": true },
          "provider_observation_receipt_ref": { "minLength": 1 },
          "provider_observation_receipt_id": {
            "pattern": "^teamops-shared-inbox-provider-observation-receipt-[0-9a-f]{16}$"
          },
          "provider_observation_receipt_valid": { "const": true },
          "solver_outcome": { "const": "SolvedVerified" },
          "proof_state": { "const": "Pass" },
          "closure_review_state": { "const": "assembled" },
          "closure_review_ready": { "const": true },
          "terminal_closure_candidate_ready": { "const": true },
          "review_packet_ref": { "minLength": 1 },
          "review_packet_hash": { "pattern": "^[0-9a-f]{64}$" },
          "send_execution_ref": { "minLength": 1 },
          "dispatch_receipt_ref": { "minLength": 1 },
          "provider_message_ref": { "minLength": 1 },
          "provider_message_hash": { "pattern": "^[0-9a-f]{64}$" },
          "first_observation_ref": { "minLength": 1 },
          "first_observation_hash": { "pattern": "^[0-9a-f]{64}$" },
          "second_observation_ref": { "minLength": 1 },
          "second_observation_hash": { "pattern": "^[0-9a-f]{64}$" },
          "duplicate_absence_observed": { "const": true },
          "replay_ref": { "minLength": 1 },
          "replay_hash": { "pattern": "^[0-9a-f]{64}$" },
          "deterministic_replay_observed": { "const": true },
          "required_terminal_evidence_refs": { "minItems": 9 },
          "approval_chain_reviewed": { "const": true },
          "send_execution_reviewed": { "const": true },
          "sent_message_observation_reviewed": { "const": true },
          "duplicate_absence_reviewed": { "const": true },
          "deterministic_replay_reviewed": { "const": true },
          "evidence_refs": { "minItems": 9 },
          "blocked_until": { "maxItems": 0 }
        }
      }
    }
  ]
}
