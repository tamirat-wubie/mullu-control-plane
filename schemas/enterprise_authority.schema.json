{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:enterprise-authority:1",
  "title": "Enterprise Authority Decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "decision_id",
    "request_id",
    "actor_id",
    "tenant_id",
    "verdict",
    "reason",
    "required_controls",
    "matched_grant_ids",
    "evidence_refs",
    "decision_hash",
    "metadata"
  ],
  "properties": {
    "decision_id": {"type": "string", "minLength": 1},
    "request_id": {"type": "string", "minLength": 1},
    "actor_id": {"type": "string", "minLength": 1},
    "tenant_id": {"type": "string", "minLength": 1},
    "verdict": {"type": "string", "enum": ["allow", "deny", "escalate"]},
    "reason": {"type": "string", "minLength": 1},
    "required_controls": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "matched_grant_ids": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "decision_hash": {"type": "string", "minLength": 1},
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "decision_is_not_execution",
        "separation_of_duty_checked",
        "credential_lease_checked"
      ],
      "properties": {
        "decision_is_not_execution": {"type": "boolean", "const": true},
        "separation_of_duty_checked": {"type": "boolean", "const": true},
        "credential_lease_checked": {"type": "boolean", "const": true}
      }
    }
  },
  "$defs": {
    "enterprise_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "identity_id",
        "identity_type",
        "tenant_id",
        "display_name",
        "status",
        "source",
        "external_subject",
        "teams",
        "roles",
        "created_at",
        "expires_at",
        "evidence_refs",
        "identity_hash",
        "metadata"
      ],
      "properties": {
        "identity_id": {"type": "string", "minLength": 1},
        "identity_type": {"type": "string", "enum": ["human", "agent", "service"]},
        "tenant_id": {"type": "string", "minLength": 1},
        "display_name": {"type": "string", "minLength": 1},
        "status": {"type": "string", "enum": ["active", "suspended", "revoked"]},
        "source": {"type": "string", "minLength": 1},
        "external_subject": {"type": "string", "minLength": 1},
        "teams": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "roles": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "created_at": {"type": "string", "format": "date-time"},
        "expires_at": {"type": "string"},
        "evidence_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "identity_hash": {"type": "string", "minLength": 1},
        "metadata": {
          "type": "object",
          "additionalProperties": true,
          "required": ["tenant_bound_identity", "identity_type_explicit", "directory_evidence_required"],
          "properties": {
            "tenant_bound_identity": {"type": "boolean", "const": true},
            "identity_type_explicit": {"type": "boolean", "const": true},
            "directory_evidence_required": {"type": "boolean", "const": true}
          }
        }
      }
    },
    "authority_grant": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "grant_id",
        "identity_id",
        "tenant_id",
        "grant_type",
        "value",
        "resource",
        "issued_by",
        "issued_at",
        "expires_at",
        "evidence_refs",
        "max_amount",
        "separation_of_duty",
        "grant_hash",
        "metadata"
      ],
      "properties": {
        "grant_id": {"type": "string", "minLength": 1},
        "identity_id": {"type": "string", "minLength": 1},
        "tenant_id": {"type": "string", "minLength": 1},
        "grant_type": {"type": "string", "enum": ["role", "permission", "capability", "approval_authority", "delegation"]},
        "value": {"type": "string", "minLength": 1},
        "resource": {"type": "string", "minLength": 1},
        "issued_by": {"type": "string", "minLength": 1},
        "issued_at": {"type": "string", "format": "date-time"},
        "expires_at": {"type": "string", "format": "date-time"},
        "evidence_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "max_amount": {"type": "number", "minimum": 0},
        "separation_of_duty": {"type": "boolean"},
        "grant_hash": {"type": "string", "minLength": 1},
        "metadata": {
          "type": "object",
          "additionalProperties": true,
          "required": ["grant_is_expiring", "grant_is_tenant_scoped"],
          "properties": {
            "grant_is_expiring": {"type": "boolean", "const": true},
            "grant_is_tenant_scoped": {"type": "boolean", "const": true}
          }
        }
      }
    },
    "credential_lease": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lease_id",
        "identity_id",
        "tenant_id",
        "scopes",
        "issued_at",
        "expires_at",
        "evidence_refs",
        "revoked_at",
        "lease_hash"
      ],
      "properties": {
        "lease_id": {"type": "string", "minLength": 1},
        "identity_id": {"type": "string", "minLength": 1},
        "tenant_id": {"type": "string", "minLength": 1},
        "scopes": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "issued_at": {"type": "string", "format": "date-time"},
        "expires_at": {"type": "string", "format": "date-time"},
        "evidence_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "revoked_at": {"type": "string"},
        "lease_hash": {"type": "string", "minLength": 1}
      }
    }
  },
  "allOf": [
    {
      "if": {"properties": {"verdict": {"const": "allow"}}, "required": ["verdict"]},
      "then": {"properties": {"reason": {"const": "authority_grant_satisfied"}}}
    },
    {
      "if": {"properties": {"reason": {"const": "authority_grant_satisfied"}}, "required": ["reason"]},
      "then": {"properties": {"matched_grant_ids": {"minItems": 1}}}
    }
  ]
}
