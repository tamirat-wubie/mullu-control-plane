{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:agentic-service-harness-live-producer-witness-requirements:1",
  "title": "Agentic Service Harness Live Producer Witness Requirements",
  "description": "Read-only requirements packet for witnesses required before any live task/run producer implementation. This schema records missing evidence only and does not admit UI, mutation endpoints, live adapters, branch writes, pull-request creation, deployment, DNS mutation, secret mutation, destructive operations, runtime state writes, or terminal closure.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "requirements_id",
    "schema_version",
    "generated_at",
    "solver_outcome",
    "source_admission_gate_ref",
    "admission_decision",
    "planning_only",
    "read_only",
    "live_producer_implemented",
    "report_is_not_terminal_closure",
    "terminal_closure",
    "scope",
    "witnesses",
    "governed_witness_collection",
    "authority_denials",
    "effect_boundary",
    "validators",
    "next_action"
  ],
  "properties": {
    "requirements_id": {
      "type": "string",
      "const": "agentic-service-harness-live-producer-witness-requirements"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "solver_outcome": {
      "type": "string",
      "const": "AwaitingEvidence"
    },
    "source_admission_gate_ref": {
      "$ref": "#/$defs/evidence_ref"
    },
    "admission_decision": {
      "type": "string",
      "const": "blocked"
    },
    "planning_only": {
      "type": "boolean",
      "const": true
    },
    "read_only": {
      "type": "boolean",
      "const": true
    },
    "live_producer_implemented": {
      "type": "boolean",
      "const": false
    },
    "report_is_not_terminal_closure": {
      "type": "boolean",
      "const": true
    },
    "terminal_closure": {
      "type": "boolean",
      "const": false
    },
    "scope": {
      "$ref": "#/$defs/scope"
    },
    "witnesses": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": {
        "$ref": "#/$defs/witness_requirement"
      },
      "uniqueItems": true
    },
    "governed_witness_collection": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": {
        "$ref": "#/$defs/governed_witness_collection_entry"
      },
      "uniqueItems": true
    },
    "authority_denials": {
      "$ref": "#/$defs/authority_denials"
    },
    "effect_boundary": {
      "$ref": "#/$defs/effect_boundary"
    },
    "validators": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/validator_ref"
      }
    },
    "next_action": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "evidence_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/#-]*$"
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tenant_id",
        "organization_id",
        "project_id",
        "repository_connection_id",
        "read_only"
      ],
      "properties": {
        "tenant_id": { "$ref": "#/$defs/identifier" },
        "organization_id": { "$ref": "#/$defs/identifier" },
        "project_id": { "$ref": "#/$defs/identifier" },
        "repository_connection_id": { "$ref": "#/$defs/identifier" },
        "read_only": { "type": "boolean", "const": true }
      }
    },
    "witness_requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "witness_id",
        "witness_kind",
        "required",
        "status",
        "evidence_ref",
        "admission_effect",
        "authority_granted",
        "next_action"
      ],
      "properties": {
        "witness_id": { "$ref": "#/$defs/identifier" },
        "witness_kind": {
          "type": "string",
          "enum": [
            "operator_approval",
            "effect_receipt",
            "external_adapter_evidence",
            "secret_handoff",
            "rollback_proof"
          ]
        },
        "required": { "type": "boolean", "const": true },
        "status": { "type": "string", "const": "AwaitingEvidence" },
        "evidence_ref": { "$ref": "#/$defs/evidence_ref" },
        "admission_effect": { "type": "string", "const": "blocks_live_producer" },
        "authority_granted": { "type": "boolean", "const": false },
        "next_action": { "type": "string", "minLength": 1 }
      }
    },
    "governed_witness_collection_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "collection_id",
        "witness_kind",
        "requirements_evidence_ref",
        "governed_artifact_ref",
        "validator_id",
        "validator_command",
        "status",
        "authority_granted",
        "blocks_live_producer"
      ],
      "properties": {
        "collection_id": { "$ref": "#/$defs/identifier" },
        "witness_kind": {
          "type": "string",
          "enum": [
            "operator_approval",
            "effect_receipt",
            "external_adapter_evidence",
            "secret_handoff",
            "rollback_proof"
          ]
        },
        "requirements_evidence_ref": { "$ref": "#/$defs/evidence_ref" },
        "governed_artifact_ref": {
          "type": "string",
          "pattern": "^examples/agentic_service_harness_live_producer_.*\\.local\\.json$"
        },
        "validator_id": { "$ref": "#/$defs/identifier" },
        "validator_command": {
          "type": "string",
          "pattern": "^python scripts/validate_agentic_service_harness_live_producer_.*\\.py$"
        },
        "status": { "type": "string", "const": "AwaitingEvidence" },
        "authority_granted": { "type": "boolean", "const": false },
        "blocks_live_producer": { "type": "boolean", "const": true }
      }
    },
    "authority_denials": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ui_created",
        "mutation_endpoints_admitted",
        "external_adapter_integrated",
        "branch_write_enabled",
        "pull_request_creation_enabled",
        "deployment_enabled",
        "dns_mutation_enabled",
        "secret_mutation_enabled",
        "destructive_operation_enabled",
        "runtime_state_written",
        "live_execution_authorized"
      ],
      "properties": {
        "ui_created": { "type": "boolean", "const": false },
        "mutation_endpoints_admitted": { "type": "boolean", "const": false },
        "external_adapter_integrated": { "type": "boolean", "const": false },
        "branch_write_enabled": { "type": "boolean", "const": false },
        "pull_request_creation_enabled": { "type": "boolean", "const": false },
        "deployment_enabled": { "type": "boolean", "const": false },
        "dns_mutation_enabled": { "type": "boolean", "const": false },
        "secret_mutation_enabled": { "type": "boolean", "const": false },
        "destructive_operation_enabled": { "type": "boolean", "const": false },
        "runtime_state_written": { "type": "boolean", "const": false },
        "live_execution_authorized": { "type": "boolean", "const": false }
      }
    },
    "effect_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ui_created",
        "mutation_endpoints_admitted",
        "external_adapter_integrated",
        "branch_write_enabled",
        "pull_request_creation_enabled",
        "deployment_enabled",
        "dns_mutation_enabled",
        "secret_mutation_enabled",
        "destructive_operation_enabled",
        "runtime_state_written",
        "network_policy"
      ],
      "properties": {
        "ui_created": { "type": "boolean", "const": false },
        "mutation_endpoints_admitted": { "type": "boolean", "const": false },
        "external_adapter_integrated": { "type": "boolean", "const": false },
        "branch_write_enabled": { "type": "boolean", "const": false },
        "pull_request_creation_enabled": { "type": "boolean", "const": false },
        "deployment_enabled": { "type": "boolean", "const": false },
        "dns_mutation_enabled": { "type": "boolean", "const": false },
        "secret_mutation_enabled": { "type": "boolean", "const": false },
        "destructive_operation_enabled": { "type": "boolean", "const": false },
        "runtime_state_written": { "type": "boolean", "const": false },
        "network_policy": { "type": "string", "const": "none" }
      }
    },
    "validator_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "validator_id",
        "command",
        "required_for_closure"
      ],
      "properties": {
        "validator_id": { "$ref": "#/$defs/identifier" },
        "command": { "type": "string", "minLength": 1 },
        "required_for_closure": { "type": "boolean", "const": true }
      }
    }
  }
}
