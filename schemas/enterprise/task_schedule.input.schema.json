{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/enterprise/task_schedule.input.schema.json",
  "type": "object",
  "anyOf": [
    {"required": ["title"]},
    {"required": ["name"]}
  ],
  "properties": {
    "title": {"type": "string", "minLength": 1},
    "name": {"type": "string", "minLength": 1},
    "description": {"type": "string"},
    "intent": {"type": "string", "minLength": 1},
    "owner": {"type": "string", "minLength": 1},
    "assignee": {"type": "string", "minLength": 1},
    "timezone": {"type": "string", "minLength": 1},
    "due_at": {"type": "string", "minLength": 1},
    "action": {"type": "string", "minLength": 1},
    "action_params": {
      "type": "object",
      "additionalProperties": true
    },
    "trigger": {
      "type": "object",
      "required": ["type", "value"],
      "properties": {
        "type": {
          "enum": ["at_time", "after_duration", "recurring", "condition_until"]
        },
        "value": {"type": "string", "minLength": 1},
        "reference_time": {"type": "string", "minLength": 1},
        "timezone": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "approval_required": {"type": "boolean"},
    "expiry_policy": {
      "type": "object",
      "properties": {
        "mode": {"enum": ["none", "expires_at", "evidence_ttl"]},
        "expires_at": {"type": "string", "minLength": 1},
        "evidence_ttl_seconds": {"type": "integer", "minimum": 1},
        "stale_evidence_action": {"enum": ["block", "escalate", "refresh"]}
      },
      "additionalProperties": false
    },
    "rollback_plan": {
      "type": "object",
      "required": ["strategy"],
      "properties": {
        "strategy": {"type": "string", "minLength": 1},
        "steps": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        }
      },
      "additionalProperties": false
    },
    "evidence_refs": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    }
  },
  "additionalProperties": false
}
