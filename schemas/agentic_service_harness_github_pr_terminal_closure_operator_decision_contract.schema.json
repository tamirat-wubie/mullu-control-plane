{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:agentic-service-harness-github-pr-terminal-closure-operator-decision-contract:1",
  "title": "Agentic Service Harness GitHub PR Terminal Closure Operator Decision Contract",
  "description": "Foundation Mode contract for the explicit operator decision required before a GitHub PR terminal closure certificate can be minted. This contract defines the required decision shape only and does not collect approval, mint a certificate, grant authority, or claim terminal closure.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "binding_id",
    "schema_version",
    "generated_at",
    "solver_outcome",
    "source_approval_gate_ref",
    "witness_kind",
    "requested_operator_decision_ref",
    "contract_status",
    "operator_decision_contract_ready",
    "operator_decision_collected",
    "terminal_closure_certificate_minted",
    "terminal_closure_authorized",
    "authority_granted",
    "read_only",
    "report_is_not_terminal_closure",
    "terminal_closure",
    "scope",
    "decision_contract",
    "remaining_witnesses",
    "authority_denials",
    "effect_boundary",
    "receipt_refs",
    "validators",
    "next_action"
  ],
  "properties": {
    "binding_id": {
      "type": "string",
      "const": "agentic_service_harness_github_pr_terminal_closure_operator_decision_contract"
    },
    "schema_version": { "type": "integer", "const": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "solver_outcome": { "type": "string", "const": "AwaitingEvidence" },
