{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:read-only-worker-runtime-receipt-schema-binding-witness:1",
  "title": "Read-Only Worker Runtime Receipt Schema Binding Witness",
  "description": "Foundation Mode witness for future read_only_repo_inspection runtime receipt schema binding evidence without binding the schema, registering a runner, dispatch endpoint, or runtime emitter, invoking a worker, writing files, calling connectors, emitting a runtime receipt, claiming success, or allowing terminal closure.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receipt_id",
    "receipt_version",
    "runtime_receipt_candidate_ref",
    "runner_binding_witness_ref",
    "emitter_dry_run_ref",
    "handoff_ref",
    "binding_ref",
    "lease_preflight_ref",
    "rehearsal_receipt_ref",
    "selected_worker_path",
    "tenant_id",
    "actor_id",
    "created_at",
    "solver_outcome",
    "authority_scope",
    "schema_binding_witness_contract",
    "binding_evaluation",
    "admission_decision",
    "receipt_refs",
    "contract_summary",
    "governance_refs",
    "receipt_envelope",
    "evidence_refs"
  ],
  "properties": {
    "receipt_id": { "type": "string", "pattern": "^read-only-worker-runtime-receipt-schema-binding-witness-[a-z0-9-]+$" },
    "receipt_version": { "type": "string", "const": "read_only_worker_runtime_receipt_schema_binding_witness.v1" },
    "runtime_receipt_candidate_ref": { "type": "string", "const": "examples/read_only_worker_runtime_receipt_candidate.foundation.json" },
    "runner_binding_witness_ref": { "type": "string", "const": "examples/read_only_worker_runtime_runner_binding_witness.foundation.json" },
    "emitter_dry_run_ref": { "type": "string", "const": "examples/read_only_worker_runtime_receipt_emitter_dry_run.foundation.json" },
    "handoff_ref": { "type": "string", "const": "examples/read_only_worker_runtime_receipt_handoff.foundation.json" },
    "binding_ref": { "type": "string", "const": "examples/read_only_worker_binding.foundation.json" },
    "lease_preflight_ref": { "type": "string", "const": "examples/read_only_worker_lease_preflight.foundation.json" },
    "rehearsal_receipt_ref": { "type": "string", "const": "examples/read_only_worker_rehearsal_receipt.foundation.json" },
    "selected_worker_path": { "type": "string", "const": "read_only_repo_inspection" },
    "tenant_id": { "type": "string", "minLength": 1 },
    "actor_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "solver_outcome": {
      "type": "string",
      "enum": ["SolvedVerified", "AwaitingEvidence", "GovernanceBlocked"]
    },
    "authority_scope": { "$ref": "#/$defs/authority_scope" },
    "schema_binding_witness_contract": { "$ref": "#/$defs/schema_binding_witness_contract" },
    "binding_evaluation": { "$ref": "#/$defs/binding_evaluation" },
    "admission_decision": { "$ref": "#/$defs/admission_decision" },
    "receipt_refs": { "$ref": "#/$defs/receipt_refs" },
    "contract_summary": { "$ref": "#/$defs/contract_summary" },
    "governance_refs": { "$ref": "#/$defs/non_empty_string_array" },
    "receipt_envelope": { "$ref": "#/$defs/receipt_envelope" },
    "evidence_refs": { "$ref": "#/$defs/non_empty_string_array" },
    "metadata": { "type": "object", "additionalProperties": true }
  },
  "$defs": {
    "authority_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "read_only",
        "foundation_witness_only",
        "runtime_runner_registration_performed",
        "dispatch_endpoint_registration_performed",
        "runtime_receipt_emitter_registration_performed",
        "runtime_receipt_schema_binding_performed",
        "runtime_receipt_schema_registry_write_performed",
        "runtime_dispatch_allowed",
        "runtime_receipt_emission_allowed",
        "external_network_allowed",
        "secret_access_allowed",
        "filesystem_write_allowed",
        "connector_authority_allowed",
        "terminal_closure_allowed",
        "success_claim_allowed",
        "mfidel_atomicity_preserved"
      ],
      "properties": {
        "read_only": { "type": "boolean", "const": true },
        "foundation_witness_only": { "type": "boolean", "const": true },
        "runtime_runner_registration_performed": { "type": "boolean", "const": false },
        "dispatch_endpoint_registration_performed": { "type": "boolean", "const": false },
        "runtime_receipt_emitter_registration_performed": { "type": "boolean", "const": false },
        "runtime_receipt_schema_binding_performed": { "type": "boolean", "const": false },
        "runtime_receipt_schema_registry_write_performed": { "type": "boolean", "const": false },
        "runtime_dispatch_allowed": { "type": "boolean", "const": false },
        "runtime_receipt_emission_allowed": { "type": "boolean", "const": false },
        "external_network_allowed": { "type": "boolean", "const": false },
        "secret_access_allowed": { "type": "boolean", "const": false },
        "filesystem_write_allowed": { "type": "boolean", "const": false },
        "connector_authority_allowed": { "type": "boolean", "const": false },
        "terminal_closure_allowed": { "type": "boolean", "const": false },
        "success_claim_allowed": { "type": "boolean", "const": false },
        "mfidel_atomicity_preserved": { "type": "boolean", "const": true }
      }
    },
    "schema_binding_witness_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "worker_id",
        "capability",
        "operation_family",
        "witness_mode",
        "runtime_receipt_kind",
        "source_runtime_receipt_candidate_ref",
        "source_candidate_schema_ref",
        "target_runtime_receipt_schema_ref",
        "required_source_receipt_refs",
        "required_schema_binding_input_refs",
        "schema_binding_obligations_checked",
        "validation_refs"
      ],
      "properties": {
        "worker_id": { "type": "string", "const": "worker_local_read_only_repo_inspection" },
        "capability": { "type": "string", "const": "read_only_repo_inspection" },
        "operation_family": { "type": "string", "const": "local_repo_inspection" },
        "witness_mode": { "type": "string", "const": "SCHEMA_BINDING_WITNESS_ONLY" },
        "runtime_receipt_kind": { "type": "string", "const": "future_worker_runtime_receipt" },
        "source_runtime_receipt_candidate_ref": { "type": "string", "const": "examples/read_only_worker_runtime_receipt_candidate.foundation.json" },
        "source_candidate_schema_ref": { "type": "string", "const": "schemas/read_only_worker_runtime_receipt_candidate.schema.json" },
        "target_runtime_receipt_schema_ref": { "type": "string", "const": "candidate://schema/future-worker-runtime-receipt" },
        "required_source_receipt_refs": { "$ref": "#/$defs/non_empty_string_array" },
        "required_schema_binding_input_refs": { "$ref": "#/$defs/non_empty_string_array" },
        "schema_binding_obligations_checked": { "$ref": "#/$defs/non_empty_string_array" },
        "validation_refs": { "$ref": "#/$defs/non_empty_string_array" }
      }
    },
    "binding_evaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_schema_validated",
        "candidate_example_validated",
        "upstream_runner_binding_witness_validated",
        "upstream_emitter_dry_run_validated",
        "source_candidate_obligations_preserved",
        "runtime_receipt_schema_binding_performed",
        "runtime_receipt_schema_registry_write_performed",
        "runtime_receipt_emitted",
        "raw_output_policy",
        "worker_failure_receipt_required_on_error",
        "effect_reconciliation_required",
        "mfidel_atomicity_preserved"
      ],
      "properties": {
        "candidate_schema_validated": { "type": "boolean", "const": true },
        "candidate_example_validated": { "type": "boolean", "const": true },
        "upstream_runner_binding_witness_validated": { "type": "boolean", "const": true },
        "upstream_emitter_dry_run_validated": { "type": "boolean", "const": true },
        "source_candidate_obligations_preserved": { "type": "boolean", "const": true },
        "runtime_receipt_schema_binding_performed": { "type": "boolean", "const": false },
        "runtime_receipt_schema_registry_write_performed": { "type": "boolean", "const": false },
        "runtime_receipt_emitted": { "type": "boolean", "const": false },
        "raw_output_policy": { "type": "string", "const": "DIGEST_ONLY_NO_RAW_OUTPUT" },
        "worker_failure_receipt_required_on_error": { "type": "boolean", "const": true },
        "effect_reconciliation_required": { "type": "boolean", "const": true },
        "mfidel_atomicity_preserved": { "type": "boolean", "const": true }
      }
    },
    "admission_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision",
        "schema_binding_witness_defined",
        "runtime_receipt_schema_bound",
        "runtime_receipt_emission_admitted",
        "runtime_dispatch_admitted",
        "terminal_closure_allowed",
        "remaining_denied_until_refs",
        "blocked_reason_refs"
      ],
      "properties": {
        "decision": { "type": "string", "const": "RUNTIME_RECEIPT_SCHEMA_BINDING_WITNESS_BLOCKED_AWAITING_LIVE_RUNNER_AND_RECEIPT_STORE" },
        "schema_binding_witness_defined": { "type": "boolean", "const": true },
        "runtime_receipt_schema_bound": { "type": "boolean", "const": false },
        "runtime_receipt_emission_admitted": { "type": "boolean", "const": false },
        "runtime_dispatch_admitted": { "type": "boolean", "const": false },
        "terminal_closure_allowed": { "type": "boolean", "const": false },
        "remaining_denied_until_refs": { "$ref": "#/$defs/non_empty_string_array" },
        "blocked_reason_refs": { "$ref": "#/$defs/non_empty_string_array" }
      }
    },
    "receipt_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "read_only_worker_runtime_receipt_schema_binding_witness_schema",
        "read_only_worker_runtime_receipt_candidate_schema",
        "read_only_worker_runtime_runner_binding_witness_schema",
        "read_only_worker_runtime_receipt_emitter_dry_run_schema",
        "read_only_worker_runtime_receipt_handoff_schema",
        "read_only_worker_binding_schema",
        "read_only_worker_lease_preflight_schema",
        "read_only_worker_rehearsal_receipt_schema",
        "temporal_lease_window_receipt_schema",
        "worker_failure_receipt_schema",
        "worker_mesh_schema",
        "universal_action_orchestration_schema"
      ],
      "properties": {
        "read_only_worker_runtime_receipt_schema_binding_witness_schema": { "type": "string", "const": "schemas/read_only_worker_runtime_receipt_schema_binding_witness.schema.json" },
        "read_only_worker_runtime_receipt_candidate_schema": { "type": "string", "const": "schemas/read_only_worker_runtime_receipt_candidate.schema.json" },
        "read_only_worker_runtime_runner_binding_witness_schema": { "type": "string", "const": "schemas/read_only_worker_runtime_runner_binding_witness.schema.json" },
        "read_only_worker_runtime_receipt_emitter_dry_run_schema": { "type": "string", "const": "schemas/read_only_worker_runtime_receipt_emitter_dry_run.schema.json" },
        "read_only_worker_runtime_receipt_handoff_schema": { "type": "string", "const": "schemas/read_only_worker_runtime_receipt_handoff.schema.json" },
        "read_only_worker_binding_schema": { "type": "string", "const": "schemas/read_only_worker_binding.schema.json" },
        "read_only_worker_lease_preflight_schema": { "type": "string", "const": "schemas/read_only_worker_lease_preflight.schema.json" },
        "read_only_worker_rehearsal_receipt_schema": { "type": "string", "const": "schemas/read_only_worker_rehearsal_receipt.schema.json" },
        "temporal_lease_window_receipt_schema": { "type": "string", "const": "schemas/temporal_lease_window_receipt.schema.json" },
        "worker_failure_receipt_schema": { "type": "string", "const": "schemas/worker_failure_receipt.schema.json" },
        "worker_mesh_schema": { "type": "string", "const": "schemas/worker_mesh.schema.json" },
        "universal_action_orchestration_schema": { "type": "string", "const": "schemas/universal_action_orchestration.schema.json" }
      }
    },
    "contract_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_receipt_ref_count",
        "schema_binding_input_ref_count",
        "schema_binding_obligation_count",
        "validation_ref_count",
        "binding_true_check_count",
        "remaining_denied_until_ref_count",
        "blocked_reason_ref_count",
        "receipt_ref_count",
        "evidence_ref_count"
      ],
      "properties": {
        "source_receipt_ref_count": { "type": "integer", "minimum": 6 },
        "schema_binding_input_ref_count": { "type": "integer", "minimum": 8 },
        "schema_binding_obligation_count": { "type": "integer", "minimum": 7 },
        "validation_ref_count": { "type": "integer", "minimum": 5 },
        "binding_true_check_count": { "type": "integer", "const": 8 },
        "remaining_denied_until_ref_count": { "type": "integer", "minimum": 8 },
        "blocked_reason_ref_count": { "type": "integer", "minimum": 8 },
        "receipt_ref_count": { "type": "integer", "const": 12 },
        "evidence_ref_count": { "type": "integer", "minimum": 15 }
      }
    },
    "receipt_envelope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["uao_ref", "causal_decision_trace_ref", "receipt_ref"],
      "properties": {
        "uao_ref": { "type": "string", "pattern": "^uao://.+$" },
        "causal_decision_trace_ref": { "type": "string", "pattern": "^trace://.+$" },
        "receipt_ref": { "type": "string", "pattern": "^receipt://.+$" }
      }
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
