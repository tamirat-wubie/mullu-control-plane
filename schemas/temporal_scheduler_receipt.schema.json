{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:temporal-scheduler-receipt:1",
  "title": "Temporal Scheduler Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receipt_id",
    "schedule_id",
    "command_id",
    "tenant_id",
    "actor_id",
    "action_type",
    "risk_level",
    "status",
    "blocked_reasons",
    "deferral_reasons",
    "missed_reasons",
    "retry_reasons",
    "required_controls",
    "runtime_now_utc",
    "requested_at",
    "execute_at",
    "expires_at",
    "recurring",
    "recurrence_rule",
    "retry_after",
    "max_attempts",
    "attempt_count",
    "last_attempt_at",
    "idempotency_key",
    "approval_ref",
    "temporal_receipt_ref",
    "lease_id",
    "lease_owner",
    "lease_expires_at",
    "lease_hash",
    "lease_acquired",
    "evidence_refs",
    "receipt_schema_ref",
    "terminal_closure_required",
    "receipt_hash",
    "metadata"
  ],
  "properties": {
    "receipt_id": {
      "type": "string",
      "pattern": "^scheduler-receipt-[0-9a-f]{16}$"
    },
    "schedule_id": {"type": "string", "minLength": 1},
    "command_id": {"type": "string", "minLength": 1},
    "tenant_id": {"type": "string", "minLength": 1},
    "actor_id": {"type": "string", "minLength": 1},
    "action_type": {"type": "string", "minLength": 1},
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "status": {
      "type": "string",
      "enum": ["leased", "deferred", "blocked", "missed", "retry_wait"]
    },
    "blocked_reasons": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "deferral_reasons": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "missed_reasons": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "retry_reasons": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "required_controls": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "runtime_now_utc": {"type": "string", "format": "date-time"},
    "requested_at": {"type": "string"},
    "execute_at": {"type": "string"},
    "expires_at": {"type": "string"},
    "recurring": {"type": "boolean"},
    "recurrence_rule": {"type": "string"},
    "retry_after": {"type": "string"},
    "max_attempts": {"type": "integer", "minimum": 1},
    "attempt_count": {"type": "integer", "minimum": 0},
    "last_attempt_at": {"type": "string"},
    "idempotency_key": {"type": "string"},
    "approval_ref": {"type": "string"},
    "temporal_receipt_ref": {"type": "string"},
    "lease_id": {"type": "string"},
    "lease_owner": {"type": "string"},
    "lease_expires_at": {"type": "string"},
    "lease_hash": {"type": "string"},
    "lease_acquired": {"type": "boolean"},
    "evidence_refs": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "receipt_schema_ref": {
      "type": "string",
      "const": "urn:mullusi:schema:temporal-scheduler-receipt:1"
    },
    "terminal_closure_required": {"type": "boolean", "const": true},
    "receipt_hash": {"type": "string", "minLength": 1},
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "receipt_is_not_terminal_closure",
        "dispatch_allowed",
        "missed_run_receipt",
        "retry_window_checked",
        "lease_required_before_dispatch",
        "idempotency_required"
      ],
      "properties": {
        "receipt_is_not_terminal_closure": {"type": "boolean", "const": true},
        "dispatch_allowed": {"type": "boolean"},
        "missed_run_receipt": {"type": "boolean"},
        "retry_window_checked": {"type": "boolean"},
        "lease_required_before_dispatch": {"type": "boolean", "const": true},
        "idempotency_required": {"type": "boolean", "const": true}
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {"status": {"const": "leased"}},
        "required": ["status"]
      },
      "then": {
        "properties": {
          "blocked_reasons": {"maxItems": 0},
          "deferral_reasons": {"maxItems": 0},
          "missed_reasons": {"maxItems": 0},
          "retry_reasons": {"maxItems": 0},
          "lease_id": {"minLength": 1},
          "lease_hash": {"minLength": 1},
          "lease_acquired": {"const": true},
          "metadata": {
            "properties": {
              "dispatch_allowed": {"const": true}
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {"status": {"const": "deferred"}},
        "required": ["status"]
      },
      "then": {
        "properties": {
          "deferral_reasons": {"minItems": 1},
          "lease_acquired": {"const": false},
          "metadata": {
            "properties": {
              "dispatch_allowed": {"const": false}
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {"status": {"const": "blocked"}},
        "required": ["status"]
      },
      "then": {
        "properties": {
          "blocked_reasons": {"minItems": 1},
          "lease_acquired": {"const": false},
          "metadata": {
            "properties": {
              "dispatch_allowed": {"const": false}
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {"status": {"const": "missed"}},
        "required": ["status"]
      },
      "then": {
        "properties": {
          "missed_reasons": {"minItems": 1},
          "lease_acquired": {"const": false},
          "metadata": {
            "properties": {
              "dispatch_allowed": {"const": false},
              "missed_run_receipt": {"const": true}
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {"status": {"const": "retry_wait"}},
        "required": ["status"]
      },
      "then": {
        "properties": {
          "retry_reasons": {"minItems": 1},
          "lease_acquired": {"const": false},
          "metadata": {
            "properties": {
              "dispatch_allowed": {"const": false}
            }
          }
        }
      }
    }
  ]
}
