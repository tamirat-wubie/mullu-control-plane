{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:self-improvement-cycle-report:1",
  "title": "Self-Improvement Cycle Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "generated_at",
    "crawled_surface_count",
    "actionable_gap_count",
    "ranked_gaps",
    "route_gaps",
    "portfolio",
    "recorded_proposals",
    "healing_receipts",
    "activation_blocked",
    "promotion_blocked",
    "report_hash",
    "metadata"
  ],
  "properties": {
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "crawled_surface_count": {
      "type": "integer",
      "minimum": 0
    },
    "actionable_gap_count": {
      "type": "integer",
      "minimum": 0
    },
    "ranked_gaps": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/surface_gap"
      }
    },
    "route_gaps": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/route_coverage_gap"
      }
    },
    "portfolio": {
      "type": ["object", "null"]
    },
    "recorded_proposals": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "healing_receipts": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "activation_blocked": {
      "type": "boolean",
      "const": true
    },
    "promotion_blocked": {
      "type": "boolean",
      "const": true
    },
    "report_hash": {
      "type": "string",
      "minLength": 1
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "cycle_is_not_execution",
        "promotes_capabilities",
        "mutates_registry",
        "edits_source",
        "ledger_backend"
      ],
      "properties": {
        "cycle_is_not_execution": {
          "type": "boolean",
          "const": true
        },
        "promotes_capabilities": {
          "type": "boolean",
          "const": false
        },
        "mutates_registry": {
          "type": "boolean",
          "const": false
        },
        "edits_source": {
          "type": "boolean",
          "const": false
        },
        "ledger_backend": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "$defs": {
    "surface_gap": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_id",
        "runtime_witness_count",
        "unanchored_witness_count",
        "anchored_witness_count",
        "evidence_refs"
      ],
      "properties": {
        "surface_id": {
          "type": "string",
          "minLength": 1
        },
        "runtime_witness_count": {
          "type": "integer",
          "minimum": 0
        },
        "unanchored_witness_count": {
          "type": "integer",
          "minimum": 0
        },
        "anchored_witness_count": {
          "type": "integer",
          "minimum": 0
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "route_coverage_gap": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surface_id", "route", "coverage_state"],
      "properties": {
        "surface_id": {
          "type": "string"
        },
        "route": {
          "type": "string",
          "minLength": 1
        },
        "coverage_state": {
          "type": "string",
          "enum": ["witnessed", "unproven"]
        }
      }
    }
  }
}
