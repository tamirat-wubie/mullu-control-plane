{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:universal-symbol-receipt-store-writer-registration-witness:1",
  "title": "Universal Symbol Receipt Store Writer Registration Witness",
  "description": "Foundation Mode witness for future UniversalSymbol receipt-store writer registration. This witness defines writer identity and writer-scope requirements while denying writer registration, write-path registration, receipt append, raw payload storage, raw secret storage, runtime dispatch, connector calls, state mutation, terminal closure, and production readiness.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "witness_id",
    "schema_version",
    "generated_at",
    "witness_scope",
    "solver_outcome",
    "foundation_mode",
    "writer_registration_decision",
    "writer_registration_is_not_append_authority",
    "writer_requirements",
    "authority_denials",
    "writer_scope_constraints",
    "rejection_policy",
    "blocked_reasons",
    "next_actions",
    "evidence_refs",
    "contract_summary"
  ],
  "properties": {
    "witness_id": { "type": "string", "const": "universal-symbol-receipt-store-writer-registration-witness-foundation" },
    "schema_version": { "type": "integer", "const": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "witness_scope": { "type": "string", "const": "foundation-mode-universal-symbol-receipt-store-writer-registration" },
    "solver_outcome": { "type": "string", "const": "AwaitingEvidence" },
    "foundation_mode": { "type": "boolean", "const": true },
    "writer_registration_decision": { "type": "string", "const": "blocked_pending_write_path_and_operator_authority" },
    "writer_registration_is_not_append_authority": { "type": "boolean", "const": true },
    "writer_requirements": {
      "type": "array",
      "minItems": 8,
      "items": { "$ref": "#/$defs/writer_requirement" },
      "uniqueItems": true
    },
    "authority_denials": { "$ref": "#/$defs/authority_denials" },
    "writer_scope_constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "writer_identity_required",
        "operator_approval_required",
        "append_audit_witness_required",
        "write_path_registration_required",
        "lease_or_idempotency_required",
        "rollback_recovery_required",
        "receipt_schema_manifest_required",
        "tenant_scope_required"
      ],
      "properties": {
        "writer_identity_required": { "type": "boolean", "const": true },
        "operator_approval_required": { "type": "boolean", "const": true },
        "append_audit_witness_required": { "type": "boolean", "const": true },
        "write_path_registration_required": { "type": "boolean", "const": true },
        "lease_or_idempotency_required": { "type": "boolean", "const": true },
        "rollback_recovery_required": { "type": "boolean", "const": true },
        "receipt_schema_manifest_required": { "type": "boolean", "const": true },
        "tenant_scope_required": { "type": "boolean", "const": true }
      }
    },
    "rejection_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "missing_writer_identity_blocks_registration",
        "missing_operator_approval_blocks_registration",
        "missing_append_audit_blocks_registration",
        "missing_write_path_blocks_registration",
        "unknown_hard_constraint_blocks_registration",
        "failed_precondition_logs_delta_reject"
      ],
      "properties": {
        "missing_writer_identity_blocks_registration": { "type": "boolean", "const": true },
        "missing_operator_approval_blocks_registration": { "type": "boolean", "const": true },
        "missing_append_audit_blocks_registration": { "type": "boolean", "const": true },
        "missing_write_path_blocks_registration": { "type": "boolean", "const": true },
        "unknown_hard_constraint_blocks_registration": { "type": "boolean", "const": true },
        "failed_precondition_logs_delta_reject": { "type": "boolean", "const": true }
      }
    },
    "blocked_reasons": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "string",
        "enum": [
          "writer_identity_witness_missing",
          "operator_approval_missing",
          "append_audit_witness_missing",
          "receipt_store_write_path_missing",
          "lease_or_idempotency_witness_missing",
          "rollback_recovery_witness_missing",
          "receipt_schema_manifest_binding_missing",
          "tenant_scope_witness_missing",
          "receipt_store_append_forbidden",
          "terminal_closure_not_allowed"
        ]
      },
      "uniqueItems": true
    },
    "next_actions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/ref" },
      "uniqueItems": true
    },
    "contract_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "writer_requirement_count",
        "authority_denial_count",
        "writer_scope_constraint_count",
        "rejection_check_count",
        "blocked_reason_count",
        "evidence_ref_count"
      ],
      "properties": {
        "writer_requirement_count": { "type": "integer", "minimum": 8 },
        "authority_denial_count": { "type": "integer", "const": 10 },
        "writer_scope_constraint_count": { "type": "integer", "const": 8 },
        "rejection_check_count": { "type": "integer", "const": 6 },
        "blocked_reason_count": { "type": "integer", "minimum": 8 },
        "evidence_ref_count": { "type": "integer", "minimum": 1 }
      }
    }
  },
  "$defs": {
    "ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/#-]*$"
    },
    "writer_requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requirement_id",
        "proof_state",
        "required_evidence_ref",
        "current_decision",
        "delta_reject_ref"
      ],
      "properties": {
        "requirement_id": { "$ref": "#/$defs/ref" },
        "proof_state": { "type": "string", "enum": ["Unknown", "BudgetUnknown", "Fail"] },
        "required_evidence_ref": { "$ref": "#/$defs/ref" },
        "current_decision": { "type": "string", "const": "writer_registration_blocked" },
        "delta_reject_ref": { "$ref": "#/$defs/ref" }
      }
    },
    "authority_denials": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_store_writer_registered",
        "receipt_store_write_path_registered",
        "receipt_store_append_performed",
        "writer_registration_claimed_terminal",
        "raw_payload_stored",
        "raw_secret_stored",
        "runtime_dispatch_performed",
        "connector_call_performed",
        "state_mutation_performed",
        "terminal_closure_allowed"
      ],
      "properties": {
        "receipt_store_writer_registered": { "type": "boolean", "const": false },
        "receipt_store_write_path_registered": { "type": "boolean", "const": false },
        "receipt_store_append_performed": { "type": "boolean", "const": false },
        "writer_registration_claimed_terminal": { "type": "boolean", "const": false },
        "raw_payload_stored": { "type": "boolean", "const": false },
        "raw_secret_stored": { "type": "boolean", "const": false },
        "runtime_dispatch_performed": { "type": "boolean", "const": false },
        "connector_call_performed": { "type": "boolean", "const": false },
        "state_mutation_performed": { "type": "boolean", "const": false },
        "terminal_closure_allowed": { "type": "boolean", "const": false }
      }
    }
  }
}
