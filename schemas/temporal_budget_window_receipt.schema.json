{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:temporal-budget-window-receipt:1",
  "title": "Temporal Budget Window Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receipt_id",
    "request_id",
    "tenant_id",
    "actor_id",
    "command_id",
    "action_type",
    "risk_level",
    "policy_id",
    "budget_id",
    "status",
    "timezone_name",
    "period_kind",
    "runtime_now_utc",
    "local_now",
    "period_start",
    "period_end",
    "defer_until",
    "budget_window_required",
    "period_state",
    "budget_state",
    "limit_amount_usd",
    "spent_amount_usd",
    "reserved_amount_usd",
    "estimated_amount_usd",
    "projected_amount_usd",
    "available_amount_usd",
    "overage_amount_usd",
    "deferral_reasons",
    "blocked_reasons",
    "required_controls",
    "evidence_refs",
    "snapshot_evidence_refs",
    "source_temporal_receipt_id",
    "source_dispatch_window_receipt_id",
    "source_reapproval_receipt_id",
    "receipt_schema_ref",
    "terminal_closure_required",
    "receipt_hash",
    "metadata"
  ],
  "properties": {
    "receipt_id": {
      "type": "string",
      "pattern": "^temporal-budget-window-receipt-[0-9a-f]{16}$"
    },
    "request_id": {"type": "string", "minLength": 1},
    "tenant_id": {"type": "string", "minLength": 1},
    "actor_id": {"type": "string", "minLength": 1},
    "command_id": {"type": "string", "minLength": 1},
    "action_type": {"type": "string", "minLength": 1},
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "policy_id": {"type": "string", "minLength": 1},
    "budget_id": {"type": "string", "minLength": 1},
    "status": {
      "type": "string",
      "enum": ["within_budget", "blocked", "deferred", "not_required"]
    },
    "timezone_name": {"type": "string", "minLength": 1},
    "period_kind": {
      "type": "string",
      "enum": ["daily", "weekly", "monthly", "custom"]
    },
    "runtime_now_utc": {"type": "string", "format": "date-time"},
    "local_now": {"type": "string", "minLength": 1},
    "period_start": {"type": "string"},
    "period_end": {"type": "string"},
    "defer_until": {"type": "string"},
    "budget_window_required": {"type": "boolean"},
    "period_state": {
      "type": "string",
      "enum": ["active", "future", "expired", "invalid", "not_required"]
    },
    "budget_state": {
      "type": "string",
      "enum": ["sufficient", "exhausted", "not_required"]
    },
    "limit_amount_usd": {"$ref": "#/$defs/money"},
    "spent_amount_usd": {"$ref": "#/$defs/money"},
    "reserved_amount_usd": {"$ref": "#/$defs/money"},
    "estimated_amount_usd": {"$ref": "#/$defs/money"},
    "projected_amount_usd": {"$ref": "#/$defs/money"},
    "available_amount_usd": {"$ref": "#/$defs/money"},
    "overage_amount_usd": {"$ref": "#/$defs/money"},
    "deferral_reasons": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "blocked_reasons": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "required_controls": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "evidence_refs": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "snapshot_evidence_refs": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "source_temporal_receipt_id": {"type": "string"},
    "source_dispatch_window_receipt_id": {"type": "string"},
    "source_reapproval_receipt_id": {"type": "string"},
    "receipt_schema_ref": {
      "type": "string",
      "const": "urn:mullusi:schema:temporal-budget-window-receipt:1"
    },
    "terminal_closure_required": {"type": "boolean", "const": true},
    "receipt_hash": {"type": "string", "minLength": 1},
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "receipt_is_not_terminal_closure",
        "runtime_owns_time_truth",
        "dispatch_allowed",
        "defer_required",
        "budget_window_checked",
        "reset_window_checked",
        "spend_projection_checked",
        "high_risk_budget_checked"
      ],
      "properties": {
        "receipt_is_not_terminal_closure": {"type": "boolean", "const": true},
        "runtime_owns_time_truth": {"type": "boolean", "const": true},
        "dispatch_allowed": {"type": "boolean"},
        "defer_required": {"type": "boolean"},
        "budget_window_checked": {"type": "boolean", "const": true},
        "reset_window_checked": {"type": "boolean"},
        "spend_projection_checked": {"type": "boolean"},
        "high_risk_budget_checked": {"type": "boolean"}
      }
    }
  },
  "$defs": {
    "money": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]{2}$"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {"status": {"const": "within_budget"}},
        "required": ["status"]
      },
      "then": {
        "properties": {
          "budget_window_required": {"const": true},
          "period_state": {"const": "active"},
          "budget_state": {"const": "sufficient"},
          "deferral_reasons": {"maxItems": 0},
          "blocked_reasons": {"maxItems": 0},
          "defer_until": {"maxLength": 0},
          "metadata": {
            "properties": {
              "dispatch_allowed": {"const": true},
              "defer_required": {"const": false},
              "reset_window_checked": {"const": true},
              "spend_projection_checked": {"const": true}
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {"status": {"const": "deferred"}},
        "required": ["status"]
      },
      "then": {
        "properties": {
          "deferral_reasons": {"minItems": 1},
          "blocked_reasons": {"maxItems": 0},
          "defer_until": {"minLength": 1},
          "metadata": {
            "properties": {
              "dispatch_allowed": {"const": false},
              "defer_required": {"const": true}
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {"status": {"const": "blocked"}},
        "required": ["status"]
      },
      "then": {
        "properties": {
          "blocked_reasons": {"minItems": 1},
          "metadata": {
            "properties": {
              "dispatch_allowed": {"const": false},
              "defer_required": {"const": false}
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {"status": {"const": "not_required"}},
        "required": ["status"]
      },
      "then": {
        "properties": {
          "budget_window_required": {"const": false},
          "period_state": {"const": "not_required"},
          "budget_state": {"const": "not_required"},
          "deferral_reasons": {"maxItems": 0},
          "blocked_reasons": {"maxItems": 0},
          "defer_until": {"maxLength": 0},
          "metadata": {
            "properties": {
              "dispatch_allowed": {"const": true},
              "defer_required": {"const": false},
              "reset_window_checked": {"const": false},
              "spend_projection_checked": {"const": false},
              "high_risk_budget_checked": {"const": false}
            }
          }
        }
      }
    }
  ]
}
