{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:worker-receipt-ledger-read-model:1",
  "title": "Worker Receipt Ledger Read Model",
  "description": "Read-only operator projection over scheduler, lease, worker, failure, runtime-receipt, and connector-promotion receipt refs without reading a live receipt database or admitting worker dispatch.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "read_model_id",
    "read_model_version",
    "generated_at",
    "source_scope",
    "receipt_chains",
    "status_summary",
    "authority_denials",
    "receipt_refs",
    "contract_summary",
    "evidence_refs"
  ],
  "properties": {
    "read_model_id": {"type": "string", "pattern": "^worker-receipt-ledger-read-model-[a-z0-9-]+$"},
    "read_model_version": {"const": "worker_receipt_ledger_read_model.v1"},
    "generated_at": {"type": "string", "format": "date-time"},
    "source_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tenant_id",
        "projection_mode",
        "source_receipt_store_ref",
        "source_receipt_store_live_read_performed",
        "fixture_projection",
        "bounded_entry_limit",
        "raw_payload_policy"
      ],
      "properties": {
        "tenant_id": {"type": "string", "minLength": 1},
        "projection_mode": {"const": "FOUNDATION_FIXTURE_PROJECTION"},
        "source_receipt_store_ref": {"type": ["string", "null"], "minLength": 1},
        "source_receipt_store_live_read_performed": {"type": "boolean", "const": false},
        "fixture_projection": {"type": "boolean", "const": true},
        "bounded_entry_limit": {"type": "integer", "minimum": 1, "maximum": 50},
        "raw_payload_policy": {"const": "DIGEST_AND_REF_ONLY"}
      }
    },
    "receipt_chains": {
      "type": "array",
      "minItems": 1,
      "maxItems": 50,
      "items": {"$ref": "#/$defs/receipt_chain"}
    },
    "status_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "chain_count",
        "ready_chain_count",
        "blocked_chain_count",
        "failure_chain_count",
        "recovery_required_count",
        "terminal_closure_allowed_count",
        "success_claim_allowed_count",
        "raw_payload_included_count",
        "raw_secret_material_included_count"
      ],
      "properties": {
        "chain_count": {"type": "integer", "minimum": 1},
        "ready_chain_count": {"type": "integer", "minimum": 0},
        "blocked_chain_count": {"type": "integer", "minimum": 0},
        "failure_chain_count": {"type": "integer", "minimum": 0},
        "recovery_required_count": {"type": "integer", "minimum": 0},
        "terminal_closure_allowed_count": {"type": "integer", "const": 0},
        "success_claim_allowed_count": {"type": "integer", "const": 0},
        "raw_payload_included_count": {"type": "integer", "const": 0},
        "raw_secret_material_included_count": {"type": "integer", "const": 0}
      }
    },
    "authority_denials": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "live_receipt_store_read_allowed",
        "worker_dispatch_allowed",
        "runtime_receipt_emission_allowed",
        "connector_call_allowed",
        "external_write_allowed",
        "secret_access_allowed",
        "filesystem_write_allowed",
        "deployment_mutation_allowed",
        "terminal_closure_allowed",
        "success_claim_allowed",
        "raw_payload_included",
        "raw_secret_material_included",
        "mfidel_atomicity_preserved"
      ],
      "properties": {
        "live_receipt_store_read_allowed": {"type": "boolean", "const": false},
        "worker_dispatch_allowed": {"type": "boolean", "const": false},
        "runtime_receipt_emission_allowed": {"type": "boolean", "const": false},
        "connector_call_allowed": {"type": "boolean", "const": false},
        "external_write_allowed": {"type": "boolean", "const": false},
        "secret_access_allowed": {"type": "boolean", "const": false},
        "filesystem_write_allowed": {"type": "boolean", "const": false},
        "deployment_mutation_allowed": {"type": "boolean", "const": false},
        "terminal_closure_allowed": {"type": "boolean", "const": false},
        "success_claim_allowed": {"type": "boolean", "const": false},
        "raw_payload_included": {"type": "boolean", "const": false},
        "raw_secret_material_included": {"type": "boolean", "const": false},
        "mfidel_atomicity_preserved": {"type": "boolean", "const": true}
      }
    },
    "receipt_refs": {"$ref": "#/$defs/receipt_refs"},
    "contract_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_chain_count",
        "receipt_ref_count",
        "evidence_ref_count",
        "blocked_reason_ref_count",
        "recovery_obligation_ref_count"
      ],
      "properties": {
        "receipt_chain_count": {"type": "integer", "minimum": 1},
        "receipt_ref_count": {"type": "integer", "minimum": 8},
        "evidence_ref_count": {"type": "integer", "minimum": 8},
        "blocked_reason_ref_count": {"type": "integer", "minimum": 0},
        "recovery_obligation_ref_count": {"type": "integer", "minimum": 0}
      }
    },
    "evidence_refs": {"$ref": "#/$defs/non_empty_string_array"}
  },
  "$defs": {
    "receipt_chain": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "chain_id",
        "job_id",
        "worker_id",
        "tenant_id",
        "chain_status",
        "source_receipt_refs",
        "receipt_kinds",
        "latest_solver_outcome",
        "effect_status",
        "rollback_required",
        "recovery_required",
        "blocked_reason_refs",
        "recovery_obligation_refs",
        "operator_visible_summary",
        "governance_guards"
      ],
      "properties": {
        "chain_id": {"type": "string", "minLength": 1},
        "job_id": {"type": "string", "minLength": 1},
        "worker_id": {"type": "string", "minLength": 1},
        "tenant_id": {"type": "string", "minLength": 1},
        "chain_status": {
          "type": "string",
          "enum": [
            "ready_for_review",
            "blocked_awaiting_evidence",
            "failure_recorded",
            "recovery_required"
          ]
        },
        "source_receipt_refs": {"$ref": "#/$defs/non_empty_string_array"},
        "receipt_kinds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "temporal_scheduler_receipt",
              "distributed_lease_claim_receipt",
              "distributed_lease_execution_receipt",
              "scheduler_worker_runtime_receipt_handoff",
              "scheduler_worker_runtime_receipt_emitter_dry_run",
              "read_only_worker_binding",
              "read_only_worker_runtime_receipt_candidate",
              "worker_failure_receipt",
              "connector_action_promotion_gate"
            ]
          },
          "uniqueItems": true
        },
        "latest_solver_outcome": {
          "type": "string",
          "enum": ["SolvedVerified", "SolvedUnverified", "AwaitingEvidence", "GovernanceBlocked", "SafeHalt"]
        },
        "effect_status": {
          "type": "string",
          "enum": ["no_effect_confirmed", "partial_effect_recorded", "effect_unknown", "rollback_pending", "recovery_pending"]
        },
        "rollback_required": {"type": "boolean"},
        "recovery_required": {"type": "boolean"},
        "blocked_reason_refs": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
        "recovery_obligation_refs": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
        "operator_visible_summary": {"type": "string", "minLength": 1, "maxLength": 400},
        "governance_guards": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "terminal_closure_allowed",
            "success_claim_allowed",
            "raw_payload_included",
            "raw_secret_material_included",
            "live_dispatch_allowed",
            "mfidel_atomicity_preserved"
          ],
          "properties": {
            "terminal_closure_allowed": {"type": "boolean", "const": false},
            "success_claim_allowed": {"type": "boolean", "const": false},
            "raw_payload_included": {"type": "boolean", "const": false},
            "raw_secret_material_included": {"type": "boolean", "const": false},
            "live_dispatch_allowed": {"type": "boolean", "const": false},
            "mfidel_atomicity_preserved": {"type": "boolean", "const": true}
          }
        }
      }
    },
    "receipt_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "worker_receipt_ledger_read_model_schema",
        "worker_failure_receipt_schema",
        "distributed_lease_claim_receipt_schema",
        "distributed_lease_execution_receipt_schema",
        "scheduler_worker_runtime_receipt_handoff_schema",
        "scheduler_worker_runtime_receipt_emitter_dry_run_schema",
        "read_only_worker_binding_schema",
        "read_only_worker_runtime_receipt_candidate_schema",
        "connector_action_promotion_gate_schema",
        "universal_action_orchestration_schema"
      ],
      "properties": {
        "worker_receipt_ledger_read_model_schema": {"const": "schemas/worker_receipt_ledger_read_model.schema.json"},
        "worker_failure_receipt_schema": {"const": "schemas/worker_failure_receipt.schema.json"},
        "distributed_lease_claim_receipt_schema": {"const": "schemas/distributed_lease_claim_receipt.schema.json"},
        "distributed_lease_execution_receipt_schema": {"const": "schemas/distributed_lease_execution_receipt.schema.json"},
        "scheduler_worker_runtime_receipt_handoff_schema": {"const": "schemas/scheduler_worker_runtime_receipt_handoff.schema.json"},
        "scheduler_worker_runtime_receipt_emitter_dry_run_schema": {"const": "schemas/scheduler_worker_runtime_receipt_emitter_dry_run.schema.json"},
        "read_only_worker_binding_schema": {"const": "schemas/read_only_worker_binding.schema.json"},
        "read_only_worker_runtime_receipt_candidate_schema": {"const": "schemas/read_only_worker_runtime_receipt_candidate.schema.json"},
        "connector_action_promotion_gate_schema": {"const": "schemas/connector_action_promotion_gate.schema.json"},
        "universal_action_orchestration_schema": {"const": "schemas/universal_action_orchestration.schema.json"}
      }
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    }
  }
}
