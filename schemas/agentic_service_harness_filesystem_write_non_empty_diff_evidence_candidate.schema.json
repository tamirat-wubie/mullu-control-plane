{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:agentic-service-harness-filesystem-write-non-empty-diff-evidence-candidate:1",
  "title": "Agentic Service Harness Filesystem Write Non-Empty Diff Evidence Candidate",
  "description": "Foundation Mode candidate evidence for one confined filesystem-write diff summary. This contract records redacted non-empty diff evidence, cleanup, rollback, reconciliation, UAO, and receipt-store write-path references while keeping authority promotion, raw diff bodies, raw file content, receipt append, connector calls, PR creation, and terminal closure blocked.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receipt_id",
    "schema_version",
    "generated_at",
    "solver_outcome",
    "candidate_status",
    "source_filesystem_write_admission_preflight_ref",
    "source_non_empty_diff_file_summary_receipt_ref",
    "scope",
    "source_receipts",
    "write_evidence_candidate",
    "effect_reconciliation",
    "authority_denials",
    "redaction_policy",
    "receipt_refs",
    "validators",
    "next_action",
    "receipt_is_not_terminal_closure",
    "terminal_closure_required"
  ],
  "properties": {
    "receipt_id": {
      "type": "string",
      "const": "agentic_service_harness_filesystem_write_non_empty_diff_evidence_candidate"
    },
    "schema_version": { "type": "integer", "const": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "solver_outcome": { "type": "string", "const": "SolvedVerified" },
    "candidate_status": {
      "type": "string",
      "const": "candidate_evidence_collected_without_authority_promotion"
    },
    "source_filesystem_write_admission_preflight_ref": {
      "type": "string",
      "const": "examples/agentic_service_harness_filesystem_write_admission_preflight.foundation.json"
    },
    "source_non_empty_diff_file_summary_receipt_ref": {
      "type": "string",
      "const": "examples/agentic_service_harness_non_empty_diff_file_summary_receipt.foundation.json"
    },
    "scope": { "$ref": "#/$defs/scope" },
    "source_receipts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "filesystem_write_admission_preflight_ref",
        "non_empty_diff_file_summary_receipt_ref",
        "filesystem_write_admission_preflight_verified",
        "non_empty_diff_file_summary_receipt_verified",
        "source_admissions_remain_blocked"
      ],
      "properties": {
        "filesystem_write_admission_preflight_ref": {
          "type": "string",
          "const": "examples/agentic_service_harness_filesystem_write_admission_preflight.foundation.json"
        },
        "non_empty_diff_file_summary_receipt_ref": {
          "type": "string",
          "const": "examples/agentic_service_harness_non_empty_diff_file_summary_receipt.foundation.json"
        },
        "filesystem_write_admission_preflight_verified": { "type": "boolean", "const": true },
        "non_empty_diff_file_summary_receipt_verified": { "type": "boolean", "const": true },
        "source_admissions_remain_blocked": { "type": "boolean", "const": true }
      }
    },
    "write_evidence_candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_write_id",
        "confined_workspace_ref",
        "write_intent_ref",
        "candidate_file_classification",
        "candidate_changed_file_count",
        "changed_file_refs",
        "diff_refs",
        "redacted_diff_bundle_ref",
        "diff_bundle_hash_ref",
        "cleanup_receipt_ref",
        "rollback_plan_ref",
        "raw_diff_body_serialized",
        "raw_file_content_serialized",
        "absolute_paths_allowed",
        "parent_traversal_allowed",
        "secret_paths_allowed",
        "production_paths_allowed"
      ],
      "properties": {
        "candidate_write_id": {
          "type": "string",
          "const": "filesystem-write-non-empty-diff-candidate-001"
        },
        "confined_workspace_ref": {
          "type": "string",
          "const": "evidence://workspace-write-authority/confined-branch-workspace"
        },
        "write_intent_ref": {
          "type": "string",
          "const": "evidence://filesystem-write-intent/governance-fixture-only"
        },
        "candidate_file_classification": {
          "type": "string",
          "const": "governance_fixture_only"
        },
        "candidate_changed_file_count": { "type": "integer", "const": 1 },
        "changed_file_refs": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/evidence_ref" }
        },
        "diff_refs": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/evidence_ref" }
        },
        "redacted_diff_bundle_ref": {
          "type": "string",
          "const": "digest://redacted-filesystem-write-non-empty-diff-bundle"
        },
        "diff_bundle_hash_ref": {
          "type": "string",
          "const": "hash://filesystem-write-non-empty-diff-candidate"
        },
        "cleanup_receipt_ref": {
          "type": "string",
          "const": "receipt://sandbox-cleanup-branchwrite"
        },
        "rollback_plan_ref": {
          "type": "string",
          "const": "evidence://filesystem-write-rollback-plan"
        },
        "raw_diff_body_serialized": { "type": "boolean", "const": false },
        "raw_file_content_serialized": { "type": "boolean", "const": false },
        "absolute_paths_allowed": { "type": "boolean", "const": false },
        "parent_traversal_allowed": { "type": "boolean", "const": false },
        "secret_paths_allowed": { "type": "boolean", "const": false },
        "production_paths_allowed": { "type": "boolean", "const": false }
      }
    },
    "effect_reconciliation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "expected_effect",
        "observed_effect",
        "expected_observed_match",
        "forbidden_effects_checked",
        "unresolved_reconciliation"
      ],
      "properties": {
        "expected_effect": {
          "type": "string",
          "const": "one redacted governance fixture diff summary exists"
        },
        "observed_effect": {
          "type": "string",
          "const": "one redacted governance fixture diff summary exists"
        },
        "expected_observed_match": { "type": "boolean", "const": true },
        "forbidden_effects_checked": { "type": "boolean", "const": true },
        "unresolved_reconciliation": { "type": "boolean", "const": false }
      }
    },
    "authority_denials": { "$ref": "#/$defs/authority_denials" },
    "redaction_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "secret_redaction_required",
        "diff_redaction_required",
        "redaction_evidence_ref",
        "raw_secret_value_storage_allowed",
        "raw_output_storage_allowed"
      ],
      "properties": {
        "secret_redaction_required": { "type": "boolean", "const": true },
        "diff_redaction_required": { "type": "boolean", "const": true },
        "redaction_evidence_ref": {
          "type": "string",
          "const": "evidence://redaction-policy-for-file-change-collection"
        },
        "raw_secret_value_storage_allowed": { "type": "boolean", "const": false },
        "raw_output_storage_allowed": { "type": "boolean", "const": false }
      }
    },
    "receipt_refs": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/evidence_ref" },
      "required": [
        "filesystem_write_non_empty_diff_evidence_candidate_schema",
        "filesystem_write_admission_preflight_example",
        "non_empty_diff_file_summary_receipt_example",
        "receipt_store_write_path_ref",
        "cleanup_receipt_ref",
        "rollback_plan_ref",
        "uao_filesystem_write_evidence_candidate_ref"
      ]
    },
    "validators": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["validator_id", "command", "required_for_closure"],
        "properties": {
          "validator_id": { "$ref": "#/$defs/identifier" },
          "command": { "type": "string", "minLength": 1 },
          "required_for_closure": { "type": "boolean", "const": true }
        }
      }
    },
    "next_action": { "type": "string", "minLength": 1 },
    "receipt_is_not_terminal_closure": { "type": "boolean", "const": true },
    "terminal_closure_required": { "type": "boolean", "const": true }
  },
  "$defs": {
    "authority_denials": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "branch_write_authority_promoted",
        "workspace_write_authority_promoted",
        "filesystem_write_authority_promoted",
        "raw_diff_body_stored",
        "raw_file_content_stored",
        "receipt_store_append_enabled",
        "runtime_state_write_enabled",
        "connector_calls_enabled",
        "mutation_route_enabled",
        "pr_creation_enabled",
        "secret_values_serialized",
        "terminal_closure"
      ],
      "properties": {
        "branch_write_authority_promoted": { "type": "boolean", "const": false },
        "workspace_write_authority_promoted": { "type": "boolean", "const": false },
        "filesystem_write_authority_promoted": { "type": "boolean", "const": false },
        "raw_diff_body_stored": { "type": "boolean", "const": false },
        "raw_file_content_stored": { "type": "boolean", "const": false },
        "receipt_store_append_enabled": { "type": "boolean", "const": false },
        "runtime_state_write_enabled": { "type": "boolean", "const": false },
        "connector_calls_enabled": { "type": "boolean", "const": false },
        "mutation_route_enabled": { "type": "boolean", "const": false },
        "pr_creation_enabled": { "type": "boolean", "const": false },
        "secret_values_serialized": { "type": "boolean", "const": false },
        "terminal_closure": { "type": "boolean", "const": false }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project_id",
        "task_id",
        "run_id",
        "sandbox_id",
        "repository_connection_id",
        "repository_slug",
        "mode",
        "foundation_phase",
        "candidate_only",
        "authority_promotion_allowed"
      ],
      "properties": {
        "project_id": { "$ref": "#/$defs/identifier" },
        "task_id": { "$ref": "#/$defs/identifier" },
        "run_id": { "$ref": "#/$defs/identifier" },
        "sandbox_id": { "$ref": "#/$defs/identifier" },
        "repository_connection_id": { "$ref": "#/$defs/identifier" },
        "repository_slug": { "type": "string", "const": "tamirat-wubie/mullu-control-plane" },
        "mode": { "type": "string", "const": "branch_write" },
        "foundation_phase": {
          "type": "string",
          "const": "foundation_filesystem_write_non_empty_diff_evidence_candidate"
        },
        "candidate_only": { "type": "boolean", "const": true },
        "authority_promotion_allowed": { "type": "boolean", "const": false }
      }
    },
    "evidence_ref": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(approval|blocked|digest|diff-bundle|evidence|examples|hash|receipt|schemas|scripts|witness)://|^(examples|schemas|scripts)/|^MULLUSI_"
    },
    "identifier": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9][a-z0-9_.-]*$"
    }
  }
}
