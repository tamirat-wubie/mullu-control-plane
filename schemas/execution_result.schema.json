{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:execution-result:1",
  "title": "Execution Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "execution_id",
    "goal_id",
    "status",
    "actual_effects",
    "assumed_effects",
    "started_at",
    "finished_at"
  ],
  "properties": {
    "execution_id": {
      "type": "string",
      "minLength": 1
    },
    "goal_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "succeeded",
        "failed",
        "cancelled"
      ]
    },
    "actual_effects": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "details": {}
        }
      }
    },
    "assumed_effects": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "details": {}
        }
      }
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "finished_at": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
