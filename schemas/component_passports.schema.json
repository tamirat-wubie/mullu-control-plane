{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:component-passports:1",
  "title": "Mullu Component Passports",
  "description": "Foundation-stage Component Harness passport set. Each passport is a read-only trust envelope for one registered component and cannot grant execution authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "passport_set_id",
    "mode",
    "source_refs",
    "passport_set_is_not_execution_authority",
    "live_execution_enabled",
    "live_connector_send_enabled",
    "terminal_closure_required",
    "summary",
    "passports",
    "validators",
    "next_action"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "passport_set_id": {
      "$ref": "#/$defs/identifier"
    },
    "mode": {
      "type": "string",
      "const": "foundation"
    },
    "source_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "registry",
        "authority_envelope_witnesses"
      ],
      "properties": {
        "registry": {
          "$ref": "#/$defs/repo_path"
        },
        "authority_envelope_witnesses": {
          "$ref": "#/$defs/repo_path"
        }
      }
    },
    "passport_set_is_not_execution_authority": {
      "type": "boolean",
      "const": true
    },
    "live_execution_enabled": {
      "type": "boolean",
      "const": false
    },
    "live_connector_send_enabled": {
      "type": "boolean",
      "const": false
    },
    "terminal_closure_required": {
      "type": "boolean",
      "const": true
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "passports": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/passport"
      }
    },
    "validators": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/validator_ref"
      }
    },
    "next_action": {
      "type": "string",
      "minLength": 1,
      "maxLength": 320
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "repo_path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9._~:/{}@+ -]+$"
    },
    "evidence_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/#-]*$"
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "component_count",
        "passport_count",
        "authority_witness_count",
        "proof_bound_count",
        "awaiting_binding_count",
        "blocked_component_count"
      ],
      "properties": {
        "component_count": {
          "type": "integer",
          "minimum": 1
        },
        "passport_count": {
          "type": "integer",
          "minimum": 1
        },
        "authority_witness_count": {
          "type": "integer",
          "minimum": 1
        },
        "proof_bound_count": {
          "type": "integer",
          "minimum": 0
        },
        "awaiting_binding_count": {
          "type": "integer",
          "minimum": 0
        },
        "blocked_component_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "can_call_connector",
        "can_claim_terminal_closure",
        "can_draft",
        "can_emit_receipt",
        "can_execute",
        "can_mutate",
        "can_preview",
        "can_read",
        "can_send_external_message",
        "can_write_files"
      ],
      "properties": {
        "can_call_connector": {
          "type": "boolean",
          "const": false
        },
        "can_claim_terminal_closure": {
          "type": "boolean",
          "const": false
        },
        "can_draft": {
          "type": "boolean"
        },
        "can_emit_receipt": {
          "type": "boolean"
        },
        "can_execute": {
          "type": "boolean",
          "const": false
        },
        "can_mutate": {
          "type": "boolean",
          "const": false
        },
        "can_preview": {
          "type": "boolean"
        },
        "can_read": {
          "type": "boolean"
        },
        "can_send_external_message": {
          "type": "boolean",
          "const": false
        },
        "can_write_files": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "string_list": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 256
      }
    },
    "passport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "passport_id",
        "component_id",
        "identity",
        "purpose",
        "lifecycle",
        "authority",
        "proofs",
        "receipts",
        "health",
        "dependencies",
        "blocked_actions",
        "evidence_refs",
        "last_validation",
        "passport_is_not_execution_authority",
        "passport_is_not_terminal_closure"
      ],
      "properties": {
        "passport_id": {
          "$ref": "#/$defs/identifier"
        },
        "component_id": {
          "$ref": "#/$defs/identifier"
        },
        "identity": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "name",
            "type",
            "aliases",
            "owner_surface"
          ],
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1,
              "maxLength": 160
            },
            "type": {
              "$ref": "#/$defs/identifier"
            },
            "aliases": {
              "$ref": "#/$defs/string_list"
            },
            "owner_surface": {
              "$ref": "#/$defs/identifier"
            }
          }
        },
        "purpose": {
          "type": "string",
          "maxLength": 320
        },
        "lifecycle": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "mode",
            "lifecycle_state",
            "wiring_state",
            "authority_level"
          ],
          "properties": {
            "mode": {
              "$ref": "#/$defs/identifier"
            },
            "lifecycle_state": {
              "$ref": "#/$defs/identifier"
            },
            "wiring_state": {
              "$ref": "#/$defs/identifier"
            },
            "authority_level": {
              "$ref": "#/$defs/identifier"
            }
          }
        },
        "authority": {
          "$ref": "#/$defs/authority"
        },
        "proofs": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "proof_surface_status",
            "proof_surface_id",
            "proof_surface_evidence_refs",
            "authority_witness_id",
            "authority_witness_proof_state"
          ],
          "properties": {
            "proof_surface_status": {
              "type": "string",
              "enum": [
                "proof_bound",
                "awaiting_binding"
              ]
            },
            "proof_surface_id": {
              "type": [
                "string",
                "null"
              ],
              "maxLength": 180
            },
            "proof_surface_evidence_refs": {
              "$ref": "#/$defs/string_list"
            },
            "authority_witness_id": {
              "$ref": "#/$defs/identifier"
            },
            "authority_witness_proof_state": {
              "type": "string",
              "const": "Pass"
            }
          }
        },
        "receipts": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "receipt_required",
            "can_emit_receipt",
            "terminal_closure_required",
            "can_claim_terminal_closure"
          ],
          "properties": {
            "receipt_required": {
              "type": "boolean"
            },
            "can_emit_receipt": {
              "type": "boolean"
            },
            "terminal_closure_required": {
              "type": "boolean",
              "const": true
            },
            "can_claim_terminal_closure": {
              "type": "boolean",
              "const": false
            }
          }
        },
        "health": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "source",
            "status"
          ],
          "properties": {
            "source": {
              "type": "object"
            },
            "status": {
              "type": "string",
              "enum": [
                "known",
                "unknown"
              ]
            }
          }
        },
        "dependencies": {
          "$ref": "#/$defs/string_list"
        },
        "blocked_actions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifier"
          },
          "contains": {
            "const": "terminal_closure"
          }
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/evidence_ref"
          }
        },
        "last_validation": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "state",
            "validator_refs"
          ],
          "properties": {
            "state": {
              "type": "string",
              "const": "validated"
            },
            "validator_refs": {
              "type": "array",
              "minItems": 3,
              "uniqueItems": true,
              "items": {
                "$ref": "#/$defs/identifier"
              }
            }
          }
        },
        "passport_is_not_execution_authority": {
          "type": "boolean",
          "const": true
        },
        "passport_is_not_terminal_closure": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "validator_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "validator_id",
        "command",
        "required_for_closure"
      ],
      "properties": {
        "validator_id": {
          "$ref": "#/$defs/identifier"
        },
        "command": {
          "type": "string",
          "minLength": 1,
          "maxLength": 240
        },
        "required_for_closure": {
          "type": "boolean",
          "const": true
        }
      }
    }
  }
}
