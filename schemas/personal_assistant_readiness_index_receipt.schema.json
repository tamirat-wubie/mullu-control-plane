{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:personal-assistant-readiness-index-receipt:1",
  "title": "Mullu Personal Assistant Readiness Index Receipt",
  "description": "No-effect readiness index receipt summarizing personal-assistant foundation evidence, lane maturity, authority blocks, and next allowed work without granting live execution authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "receipt_id",
    "generated_at",
    "proof_state",
    "solver_outcome",
    "governed",
    "receipt_is_not_execution_authority",
    "receipt_is_not_terminal_closure",
    "source_evidence",
    "readiness_index",
    "lane_records",
    "effect_boundary",
    "authority_blocks",
    "summary",
    "lineage"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "personal_assistant.readiness_index_receipt.v1"
    },
    "receipt_id": {
      "type": "string",
      "pattern": "^personal-assistant-readiness-index-[0-9a-f]{16}$"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "proof_state": {
      "type": "string",
      "enum": ["Pass", "Fail"]
    },
    "solver_outcome": {
      "type": "string",
      "enum": ["SolvedVerified", "AwaitingEvidence"]
    },
    "governed": {
      "type": "boolean",
      "const": true
    },
    "receipt_is_not_execution_authority": {
      "type": "boolean",
      "const": true
    },
    "receipt_is_not_terminal_closure": {
      "type": "boolean",
      "const": true
    },
    "source_evidence": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": {
        "$ref": "#/$defs/source_evidence_item"
      }
    },
    "readiness_index": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lane_count",
        "solved_verified_lane_count",
        "awaiting_evidence_lane_count",
        "blocked_action_count",
        "registered_skill_count",
        "foundation_only_skill_count",
        "capability_count",
        "candidate_capability_count",
        "production_ready_capability_count"
      ],
      "properties": {
        "lane_count": {
          "type": "integer",
          "minimum": 1
        },
        "solved_verified_lane_count": {
          "type": "integer",
          "minimum": 0
        },
        "awaiting_evidence_lane_count": {
          "type": "integer",
          "minimum": 0
        },
        "blocked_action_count": {
          "type": "integer",
          "minimum": 1
        },
        "registered_skill_count": {
          "type": "integer",
          "minimum": 1
        },
        "foundation_only_skill_count": {
          "type": "integer",
          "minimum": 1
        },
        "capability_count": {
          "type": "integer",
          "minimum": 1
        },
        "candidate_capability_count": {
          "type": "integer",
          "minimum": 1
        },
        "production_ready_capability_count": {
          "type": "integer",
          "const": 0
        }
      }
    },
    "lane_records": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/lane_record"
      }
    },
    "effect_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "execution_allowed",
        "live_connector_execution_allowed",
        "connector_mutation_allowed",
        "external_effect_allowed",
        "customer_readiness_claim_allowed",
        "nested_mind_live_activation_allowed",
        "production_ready_claim_allowed",
        "secret_values_serialized",
        "raw_private_payloads_serialized"
      ],
      "properties": {
        "execution_allowed": { "type": "boolean", "const": false },
        "live_connector_execution_allowed": { "type": "boolean", "const": false },
        "connector_mutation_allowed": { "type": "boolean", "const": false },
        "external_effect_allowed": { "type": "boolean", "const": false },
        "customer_readiness_claim_allowed": { "type": "boolean", "const": false },
        "nested_mind_live_activation_allowed": { "type": "boolean", "const": false },
        "production_ready_claim_allowed": { "type": "boolean", "const": false },
        "secret_values_serialized": { "type": "boolean", "const": false },
        "raw_private_payloads_serialized": { "type": "boolean", "const": false }
      }
    },
    "authority_blocks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "live_execution_blocked",
        "connector_mutation_blocked",
        "external_communication_blocked",
        "deployment_mutation_blocked",
        "customer_readiness_claim_blocked",
        "nested_mind_live_activation_blocked",
        "secret_serialization_blocked",
        "raw_private_payload_serialization_blocked"
      ],
      "properties": {
        "live_execution_blocked": { "type": "boolean", "const": true },
        "connector_mutation_blocked": { "type": "boolean", "const": true },
        "external_communication_blocked": { "type": "boolean", "const": true },
        "deployment_mutation_blocked": { "type": "boolean", "const": true },
        "customer_readiness_claim_blocked": { "type": "boolean", "const": true },
        "nested_mind_live_activation_blocked": { "type": "boolean", "const": true },
        "secret_serialization_blocked": { "type": "boolean", "const": true },
        "raw_private_payload_serialization_blocked": { "type": "boolean", "const": true }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "readiness_index_closed",
        "foundation_evidence_closed",
        "all_lanes_solved_verified",
        "no_effect_boundary_verified",
        "production_ready",
        "customer_ready",
        "next_allowed_action"
      ],
      "properties": {
        "readiness_index_closed": { "type": "boolean" },
        "foundation_evidence_closed": { "type": "boolean" },
        "all_lanes_solved_verified": { "type": "boolean" },
        "no_effect_boundary_verified": { "type": "boolean" },
        "production_ready": { "type": "boolean", "const": false },
        "customer_ready": { "type": "boolean", "const": false },
        "next_allowed_action": {
          "type": "string",
          "const": "continue_foundation_hardening_only"
        }
      }
    },
    "lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["accepted_deltas", "rejected_deltas"],
      "properties": {
        "accepted_deltas": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/lineage_delta" }
        },
        "rejected_deltas": {
          "type": "array",
          "items": { "$ref": "#/$defs/lineage_delta" }
        }
      }
    }
  },
  "$defs": {
    "source_evidence_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "source_ref",
        "receipt_id",
        "proof_state",
        "solver_outcome",
        "closed",
        "no_effect_boundary_verified"
      ],
      "properties": {
        "source_id": { "$ref": "#/$defs/identifier" },
        "source_ref": { "$ref": "#/$defs/repo_path" },
        "receipt_id": { "$ref": "#/$defs/identifier" },
        "proof_state": { "type": "string", "enum": ["Pass", "Fail"] },
        "solver_outcome": { "type": "string", "enum": ["SolvedVerified", "AwaitingEvidence"] },
        "closed": { "type": "boolean" },
        "no_effect_boundary_verified": { "type": "boolean" }
      }
    },
    "lane_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lane_id",
        "stage",
        "state",
        "route_count",
        "schema_count",
        "validator_count",
        "receipt_required",
        "foundation_only",
        "no_effect_boundary_verified"
      ],
      "properties": {
        "lane_id": { "$ref": "#/$defs/identifier" },
        "stage": { "$ref": "#/$defs/identifier" },
        "state": { "type": "string", "enum": ["SolvedVerified", "AwaitingEvidence"] },
        "route_count": { "type": "integer", "minimum": 0 },
        "schema_count": { "type": "integer", "minimum": 1 },
        "validator_count": { "type": "integer", "minimum": 1 },
        "receipt_required": { "type": "boolean", "const": true },
        "foundation_only": { "type": "boolean", "const": true },
        "no_effect_boundary_verified": { "type": "boolean" }
      }
    },
    "lineage_delta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["delta_id", "reason", "logged_in_lineage"],
      "properties": {
        "delta_id": { "$ref": "#/$defs/identifier" },
        "reason": { "type": "string", "minLength": 1, "maxLength": 500 },
        "logged_in_lineage": { "type": "boolean", "const": true }
      }
    },
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "repo_path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9._~:/{}@+ -]+$"
    }
  }
}
