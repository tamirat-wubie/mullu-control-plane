{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:temporal-memory-refresh-receipt:1",
  "title": "Temporal Memory Refresh Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receipt_id",
    "request_id",
    "memory_id",
    "tenant_id",
    "owner_id",
    "actor_id",
    "refresh_owner_id",
    "scope",
    "subject",
    "risk_level",
    "status",
    "source_memory_status",
    "source_memory_receipt_id",
    "refresh_task_id",
    "refresh_due_at",
    "refresh_window_seconds",
    "stale_seconds",
    "freshness_seconds",
    "required_evidence_types",
    "candidate_evidence_refs",
    "accepted_evidence_refs",
    "rejected_evidence_refs",
    "missing_evidence_types",
    "refresh_reasons",
    "blocked_reasons",
    "supersession_reasons",
    "required_controls",
    "runtime_now_utc",
    "source_runtime_now_utc",
    "receipt_schema_ref",
    "terminal_closure_required",
    "receipt_hash",
    "metadata"
  ],
  "properties": {
    "receipt_id": {
      "type": "string",
      "pattern": "^temporal-memory-refresh-receipt-[0-9a-f]{16}$"
    },
    "request_id": {"type": "string", "minLength": 1},
    "memory_id": {"type": "string", "minLength": 1},
    "tenant_id": {"type": "string", "minLength": 1},
    "owner_id": {"type": "string", "minLength": 1},
    "actor_id": {"type": "string", "minLength": 1},
    "refresh_owner_id": {"type": "string", "minLength": 1},
    "scope": {"type": "string", "minLength": 1},
    "subject": {"type": "string", "minLength": 1},
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "status": {
      "type": "string",
      "enum": ["not_required", "refresh_required", "ready_for_review", "blocked", "superseded"]
    },
    "source_memory_status": {
      "type": "string",
      "enum": ["usable", "refresh_required", "blocked", "superseded"]
    },
    "source_memory_receipt_id": {
      "type": "string",
      "pattern": "^temporal-memory-receipt-[0-9a-f]{16}$"
    },
    "refresh_task_id": {"type": "string"},
    "refresh_due_at": {"type": "string"},
    "refresh_window_seconds": {"type": "integer", "minimum": 0},
    "stale_seconds": {"type": "integer", "minimum": 0},
    "freshness_seconds": {"type": "integer", "minimum": 0},
    "required_evidence_types": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "candidate_evidence_refs": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "accepted_evidence_refs": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "rejected_evidence_refs": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "missing_evidence_types": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "refresh_reasons": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "blocked_reasons": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "supersession_reasons": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "required_controls": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "runtime_now_utc": {"type": "string", "format": "date-time"},
    "source_runtime_now_utc": {"type": "string", "format": "date-time"},
    "receipt_schema_ref": {
      "type": "string",
      "const": "urn:mullusi:schema:temporal-memory-refresh-receipt:1"
    },
    "terminal_closure_required": {"type": "boolean", "const": true},
    "receipt_hash": {"type": "string", "minLength": 1},
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "receipt_is_not_terminal_closure",
        "runtime_owns_time_truth",
        "activation_blocked_until_refresh",
        "memory_refresh_task_created",
        "review_required",
        "source_memory_usable",
        "evidence_type_coverage_complete"
      ],
      "properties": {
        "receipt_is_not_terminal_closure": {"type": "boolean", "const": true},
        "runtime_owns_time_truth": {"type": "boolean", "const": true},
        "activation_blocked_until_refresh": {"type": "boolean"},
        "memory_refresh_task_created": {"type": "boolean"},
        "review_required": {"type": "boolean"},
        "source_memory_usable": {"type": "boolean"},
        "evidence_type_coverage_complete": {"type": "boolean"}
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {"status": {"const": "not_required"}},
        "required": ["status"]
      },
      "then": {
        "properties": {
          "source_memory_status": {"const": "usable"},
          "refresh_task_id": {"maxLength": 0},
          "refresh_due_at": {"maxLength": 0},
          "refresh_reasons": {"maxItems": 0},
          "blocked_reasons": {"maxItems": 0},
          "supersession_reasons": {"maxItems": 0},
          "metadata": {
            "properties": {
              "activation_blocked_until_refresh": {"const": false},
              "memory_refresh_task_created": {"const": false},
              "review_required": {"const": false},
              "source_memory_usable": {"const": true}
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {"status": {"const": "refresh_required"}},
        "required": ["status"]
      },
      "then": {
        "properties": {
          "source_memory_status": {"const": "refresh_required"},
          "refresh_task_id": {
            "pattern": "^temporal-memory-refresh-task-[0-9a-f]{16}$"
          },
          "refresh_due_at": {"minLength": 1},
          "refresh_reasons": {"minItems": 1},
          "blocked_reasons": {"maxItems": 0},
          "supersession_reasons": {"maxItems": 0},
          "missing_evidence_types": {"minItems": 1},
          "metadata": {
            "properties": {
              "activation_blocked_until_refresh": {"const": true},
              "memory_refresh_task_created": {"const": true},
              "review_required": {"const": false},
              "source_memory_usable": {"const": false},
              "evidence_type_coverage_complete": {"const": false}
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {"status": {"const": "ready_for_review"}},
        "required": ["status"]
      },
      "then": {
        "properties": {
          "source_memory_status": {"const": "refresh_required"},
          "refresh_task_id": {
            "pattern": "^temporal-memory-refresh-task-[0-9a-f]{16}$"
          },
          "refresh_due_at": {"minLength": 1},
          "refresh_reasons": {"minItems": 1},
          "blocked_reasons": {"maxItems": 0},
          "supersession_reasons": {"maxItems": 0},
          "missing_evidence_types": {"maxItems": 0},
          "accepted_evidence_refs": {"minItems": 1},
          "metadata": {
            "properties": {
              "activation_blocked_until_refresh": {"const": true},
              "memory_refresh_task_created": {"const": true},
              "review_required": {"const": true},
              "source_memory_usable": {"const": false},
              "evidence_type_coverage_complete": {"const": true}
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {"status": {"const": "blocked"}},
        "required": ["status"]
      },
      "then": {
        "properties": {
          "refresh_task_id": {"maxLength": 0},
          "refresh_due_at": {"maxLength": 0},
          "blocked_reasons": {"minItems": 1},
          "metadata": {
            "properties": {
              "activation_blocked_until_refresh": {"const": true},
              "memory_refresh_task_created": {"const": false}
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {"status": {"const": "superseded"}},
        "required": ["status"]
      },
      "then": {
        "properties": {
          "source_memory_status": {"const": "superseded"},
          "refresh_task_id": {"maxLength": 0},
          "refresh_due_at": {"maxLength": 0},
          "blocked_reasons": {"maxItems": 0},
          "supersession_reasons": {"minItems": 1},
          "metadata": {
            "properties": {
              "activation_blocked_until_refresh": {"const": true},
              "memory_refresh_task_created": {"const": false},
              "review_required": {"const": false},
              "source_memory_usable": {"const": false}
            }
          }
        }
      }
    }
  ]
}
