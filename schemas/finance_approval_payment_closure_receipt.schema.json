{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:finance-approval-payment-closure-receipt:1",
  "title": "Finance Approval Payment Closure Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receipt_id",
    "adapter_id",
    "status",
    "verification_status",
    "checked_at",
    "case_id",
    "tenant_id",
    "invoice_id",
    "amount",
    "effect_type",
    "capability_id",
    "approval_id",
    "idempotency_key",
    "payment_provider_receipt_ref",
    "ledger_reconciliation_ref",
    "external_write",
    "approved_external_write",
    "evidence_refs",
    "blockers"
  ],
  "properties": {
    "receipt_id": {
      "type": "string",
      "minLength": 1
    },
    "adapter_id": {
      "type": "string",
      "const": "finance.payment_adapter"
    },
    "status": {
      "type": "string",
      "enum": [
        "passed",
        "failed"
      ]
    },
    "verification_status": {
      "type": "string",
      "enum": [
        "passed",
        "failed"
      ]
    },
    "checked_at": {
      "type": "string",
      "format": "date-time"
    },
    "case_id": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "invoice_id": {
      "type": "string"
    },
    "amount": {
      "$ref": "#/$defs/money"
    },
    "effect_type": {
      "type": "string",
      "const": "payment_sent_with_approval"
    },
    "capability_id": {
      "type": "string",
      "const": "payment.execute.with_approval"
    },
    "approval_id": {
      "type": "string"
    },
    "idempotency_key": {
      "type": "string"
    },
    "payment_provider_receipt_ref": {
      "type": "string"
    },
    "ledger_reconciliation_ref": {
      "type": "string"
    },
    "external_write": {
      "type": "boolean"
    },
    "approved_external_write": {
      "type": "boolean"
    },
    "provider_receipt": {
      "$ref": "#/$defs/provider_receipt"
    },
    "ledger_reconciliation": {
      "$ref": "#/$defs/ledger_reconciliation"
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "failure_class": {
      "type": "string",
      "enum": [
        "adapter_receipt_missing",
        "provider_receipt_mismatch",
        "ledger_reconciliation_mismatch",
        "unapproved_external_write",
        "probe_exception"
      ]
    },
    "recovery_actions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "passed"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "required": [
          "provider_receipt",
          "ledger_reconciliation"
        ],
        "properties": {
          "verification_status": {
            "const": "passed"
          },
          "case_id": {
            "minLength": 1
          },
          "tenant_id": {
            "minLength": 1
          },
          "invoice_id": {
            "minLength": 1
          },
          "approval_id": {
            "minLength": 1
          },
          "idempotency_key": {
            "minLength": 1
          },
          "payment_provider_receipt_ref": {
            "pattern": "^provider:payment:[A-Za-z0-9._:-]+$"
          },
          "ledger_reconciliation_ref": {
            "pattern": "^ledger:reconciliation:[A-Za-z0-9._:-]+$"
          },
          "external_write": {
            "const": true
          },
          "approved_external_write": {
            "const": true
          },
          "evidence_refs": {
            "minItems": 2
          },
          "blockers": {
            "maxItems": 0
          }
        }
      }
    }
  ],
  "$defs": {
    "money": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "currency",
        "minor_units"
      ],
      "properties": {
        "currency": {
          "type": "string",
          "pattern": "^[A-Z]{3}$"
        },
        "minor_units": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "provider_receipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_ref",
        "provider",
        "provider_operation",
        "transaction_id_hash",
        "amount",
        "external_write",
        "approval_id",
        "idempotency_key",
        "evidence_refs"
      ],
      "properties": {
        "receipt_ref": {
          "type": "string",
          "pattern": "^provider:payment:[A-Za-z0-9._:-]+$"
        },
        "provider": {
          "type": "string",
          "enum": [
            "sandbox",
            "stripe",
            "bank_ach",
            "manual_bank_portal"
          ]
        },
        "provider_operation": {
          "type": "string",
          "const": "payment.execute.with_approval"
        },
        "transaction_id_hash": {
          "$ref": "#/$defs/sha256_hex"
        },
        "amount": {
          "$ref": "#/$defs/money"
        },
        "external_write": {
          "type": "boolean"
        },
        "approval_id": {
          "type": "string"
        },
        "idempotency_key": {
          "type": "string"
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "ledger_reconciliation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_ref",
        "payment_provider_receipt_ref",
        "ledger_system",
        "reconciliation_status",
        "amount_matched",
        "currency_matched",
        "invoice_id",
        "evidence_refs"
      ],
      "properties": {
        "receipt_ref": {
          "type": "string",
          "pattern": "^ledger:reconciliation:[A-Za-z0-9._:-]+$"
        },
        "payment_provider_receipt_ref": {
          "type": "string",
          "pattern": "^provider:payment:[A-Za-z0-9._:-]+$"
        },
        "ledger_system": {
          "type": "string",
          "minLength": 1
        },
        "reconciliation_status": {
          "type": "string",
          "enum": [
            "matched",
            "mismatched"
          ]
        },
        "amount_matched": {
          "type": "boolean"
        },
        "currency_matched": {
          "type": "boolean"
        },
        "invoice_id": {
          "type": "string"
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "sha256_hex": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  }
}
