{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:component-route-family-promotion-gate-satisfaction-evaluator:1",
  "title": "Mullu Component Route-Family Promotion Gate Satisfaction Evaluator",
  "description": "Read-only Component Harness report that evaluates record-only evidence gate satisfaction while keeping promotion approval and authority blocked.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "gate_satisfaction_evaluator_id",
    "mode",
    "governed",
    "target_surface_id",
    "target_component_id",
    "decision",
    "preflight_outcome",
    "outcome",
    "gate_satisfaction_decision",
    "promotion_decision",
    "all_record_evidence_gates_satisfied",
    "all_action_gates_satisfied",
    "gate_satisfaction_is_not_execution_authority",
    "gate_satisfaction_is_not_promotion_authority",
    "foundation_fixture_gate_satisfaction_is_not_live_operator_evidence",
    "separate_authority_decision_required",
    "separate_route_binding_decision_required",
    "separate_lifecycle_transition_required",
    "terminal_closure_required",
    "authority_fuse_enforced",
    "live_execution_enabled",
    "live_connector_send_enabled",
    "can_execute",
    "can_mutate",
    "can_call_connector",
    "can_claim_terminal_closure",
    "mutates_router_inventory",
    "ready_for_promotion",
    "source_refs",
    "summary",
    "gate_evaluations",
    "satisfied_gate_evaluation_refs",
    "accepted_record_refs",
    "rejected_record_refs",
    "authority_decision_refs",
    "authority_fuse_refs",
    "authority_fuse_blocking_refs",
    "promotion_approval_refs",
    "submitted_evidence_refs",
    "accepted_evidence_refs",
    "rejected_evidence_refs",
    "approval_evidence_required",
    "operator_submission_channels",
    "blocked_actions",
    "expected_receipts",
    "validators",
    "next_action"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "gate_satisfaction_evaluator_id": { "$ref": "#/$defs/identifier" },
    "mode": { "type": "string", "enum": ["foundation", "read_only"] },
    "governed": { "type": "boolean", "const": true },
    "target_surface_id": { "$ref": "#/$defs/identifier" },
    "target_component_id": { "$ref": "#/$defs/identifier" },
    "decision": { "type": "string", "const": "blocked" },
    "preflight_outcome": { "type": "string", "const": "GovernanceBlocked" },
    "outcome": { "type": "string", "const": "AwaitingEvidence" },
    "gate_satisfaction_decision": {
      "type": "string",
      "const": "record_evidence_satisfied_authority_pending"
    },
    "promotion_decision": {
      "type": "string",
      "const": "blocked_pending_authority_decision"
    },
    "all_record_evidence_gates_satisfied": { "type": "boolean", "const": true },
    "all_action_gates_satisfied": { "type": "boolean", "const": false },
    "gate_satisfaction_is_not_execution_authority": { "type": "boolean", "const": true },
    "gate_satisfaction_is_not_promotion_authority": { "type": "boolean", "const": true },
    "foundation_fixture_gate_satisfaction_is_not_live_operator_evidence": { "type": "boolean", "const": true },
    "separate_authority_decision_required": { "type": "boolean", "const": true },
    "separate_route_binding_decision_required": { "type": "boolean", "const": true },
    "separate_lifecycle_transition_required": { "type": "boolean", "const": true },
    "terminal_closure_required": { "type": "boolean", "const": true },
    "authority_fuse_enforced": { "type": "boolean", "const": true },
    "live_execution_enabled": { "type": "boolean", "const": false },
    "live_connector_send_enabled": { "type": "boolean", "const": false },
    "can_execute": { "type": "boolean", "const": false },
    "can_mutate": { "type": "boolean", "const": false },
    "can_call_connector": { "type": "boolean", "const": false },
    "can_claim_terminal_closure": { "type": "boolean", "const": false },
    "mutates_router_inventory": { "type": "boolean", "const": false },
    "ready_for_promotion": { "type": "boolean", "const": false },
    "source_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "component_authority_fuse",
        "operator_submitted_evidence_records",
        "submitted_evidence_payload_examples",
        "promotion_approval_intake",
        "promotion_preflight",
        "proof_matrix"
      ],
      "properties": {
        "component_authority_fuse": { "$ref": "#/$defs/repo_path" },
        "operator_submitted_evidence_records": { "$ref": "#/$defs/repo_path" },
        "submitted_evidence_payload_examples": { "$ref": "#/$defs/repo_path" },
        "promotion_approval_intake": { "$ref": "#/$defs/repo_path" },
        "promotion_preflight": { "$ref": "#/$defs/repo_path" },
        "proof_matrix": { "$ref": "#/$defs/repo_path" }
      }
    },
    "summary": { "$ref": "#/$defs/summary" },
    "gate_evaluations": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/gate_evaluation" }
    },
    "satisfied_gate_evaluation_refs": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/identifier" }
    },
    "accepted_record_refs": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/identifier" }
    },
    "rejected_record_refs": { "$ref": "#/$defs/empty_refs" },
    "authority_decision_refs": { "$ref": "#/$defs/empty_refs" },
    "authority_fuse_refs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/identifier" }
    },
    "authority_fuse_blocking_refs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/identifier" }
    },
    "promotion_approval_refs": { "$ref": "#/$defs/empty_refs" },
    "submitted_evidence_refs": { "$ref": "#/$defs/empty_refs" },
    "accepted_evidence_refs": { "$ref": "#/$defs/empty_refs" },
    "rejected_evidence_refs": { "$ref": "#/$defs/empty_refs" },
    "approval_evidence_required": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/identifier_or_ref" }
    },
    "operator_submission_channels": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/identifier_or_ref" }
    },
    "blocked_actions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/identifier" }
    },
    "expected_receipts": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/identifier" }
    },
    "validators": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/identifier" }
    },
    "next_action": { "type": "string", "minLength": 1, "maxLength": 420 }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "identifier_or_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/#{}@+ -]*$"
    },
    "repo_path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9._~:/{}@+ -]+$"
    },
    "empty_refs": {
      "type": "array",
      "maxItems": 0,
      "items": { "$ref": "#/$defs/identifier_or_ref" }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gate_evaluation_count",
        "evaluated_gate_count",
        "record_evidence_satisfied_gate_count",
        "action_satisfied_gate_count",
        "blocking_gate_count",
        "accepted_record_count",
        "rejected_record_count",
        "satisfied_evidence_requirement_count",
        "satisfied_action_requirement_count",
        "authority_decision_count",
        "promotion_approval_count",
        "accepted_evidence_count",
        "rejected_evidence_count",
        "approval_artifact_requirement_count",
        "authority_grant_count",
        "authority_fuse_blocking_count"
      ],
      "properties": {
        "gate_evaluation_count": { "type": "integer", "const": 4 },
        "evaluated_gate_count": { "type": "integer", "const": 4 },
        "record_evidence_satisfied_gate_count": { "type": "integer", "const": 4 },
        "action_satisfied_gate_count": { "type": "integer", "const": 0 },
        "blocking_gate_count": { "type": "integer", "const": 4 },
        "accepted_record_count": { "type": "integer", "const": 4 },
        "rejected_record_count": { "type": "integer", "const": 0 },
        "satisfied_evidence_requirement_count": { "type": "integer", "const": 4 },
        "satisfied_action_requirement_count": { "type": "integer", "const": 0 },
        "authority_decision_count": { "type": "integer", "const": 0 },
        "promotion_approval_count": { "type": "integer", "const": 0 },
        "accepted_evidence_count": { "type": "integer", "const": 0 },
        "rejected_evidence_count": { "type": "integer", "const": 0 },
        "approval_artifact_requirement_count": { "type": "integer", "minimum": 1 },
        "authority_grant_count": { "type": "integer", "const": 0 },
        "authority_fuse_blocking_count": { "type": "integer", "const": 1 }
      }
    },
    "gate_evaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gate_evaluation_id",
        "source_operator_submitted_record_id",
        "source_payload_example_id",
        "source_record_envelope_id",
        "source_verifier_request_id",
        "source_intake_request_id",
        "gate_id",
        "record_kind",
        "evidence_key",
        "evaluation_state",
        "satisfaction_state",
        "proof_state",
        "record_acceptance_state",
        "record_proof_state",
        "record_evidence_satisfies_gate",
        "satisfies_evidence_requirement",
        "satisfies_action_requirement",
        "blocks_promotion",
        "requires_separate_authority_decision",
        "requires_external_authority_upgrade_evidence",
        "authority_fuse_blocks_promotion",
        "requires_route_binding_decision",
        "requires_lifecycle_transition",
        "requires_terminal_closure",
        "gate_satisfaction_is_not_execution_authority",
        "gate_satisfaction_is_not_promotion_authority",
        "foundation_fixture_gate_satisfaction_is_not_live_operator_evidence",
        "mutates_router_inventory",
        "grants_execution_authority",
        "grants_connector_authority",
        "grants_terminal_closure",
        "accepted_record_refs",
        "authority_decision_refs",
        "authority_fuse_refs",
        "promotion_approval_refs",
        "accepted_evidence_refs",
        "rejected_evidence_refs",
        "blocking_reason"
      ],
      "properties": {
        "gate_evaluation_id": { "$ref": "#/$defs/identifier" },
        "source_operator_submitted_record_id": { "$ref": "#/$defs/identifier" },
        "source_payload_example_id": { "$ref": "#/$defs/identifier" },
        "source_record_envelope_id": { "$ref": "#/$defs/identifier" },
        "source_verifier_request_id": { "$ref": "#/$defs/identifier" },
        "source_intake_request_id": { "$ref": "#/$defs/identifier" },
        "gate_id": {
          "type": "string",
          "enum": [
            "route_binding_gate",
            "lifecycle_gate",
            "authority_upgrade_gate",
            "product_specific_boundary_gate"
          ]
        },
        "record_kind": {
          "type": "string",
          "enum": [
            "route_binding",
            "lifecycle_transition",
            "authority_upgrade",
            "product_specific_ownership"
          ]
        },
        "evidence_key": { "$ref": "#/$defs/identifier" },
        "evaluation_state": { "type": "string", "const": "evaluated" },
        "satisfaction_state": { "type": "string", "const": "satisfied_record_only" },
        "proof_state": { "type": "string", "const": "Pass" },
        "record_acceptance_state": { "type": "string", "const": "accepted_record_only" },
        "record_proof_state": { "type": "string", "const": "Pass" },
        "record_evidence_satisfies_gate": { "type": "boolean", "const": true },
        "satisfies_evidence_requirement": { "type": "boolean", "const": true },
        "satisfies_action_requirement": { "type": "boolean", "const": false },
        "blocks_promotion": { "type": "boolean", "const": true },
        "requires_separate_authority_decision": { "type": "boolean", "const": true },
        "requires_external_authority_upgrade_evidence": { "type": "boolean", "const": true },
        "authority_fuse_blocks_promotion": { "type": "boolean", "const": true },
        "requires_route_binding_decision": { "type": "boolean", "const": true },
        "requires_lifecycle_transition": { "type": "boolean", "const": true },
        "requires_terminal_closure": { "type": "boolean", "const": true },
        "gate_satisfaction_is_not_execution_authority": { "type": "boolean", "const": true },
        "gate_satisfaction_is_not_promotion_authority": { "type": "boolean", "const": true },
        "foundation_fixture_gate_satisfaction_is_not_live_operator_evidence": { "type": "boolean", "const": true },
        "mutates_router_inventory": { "type": "boolean", "const": false },
        "grants_execution_authority": { "type": "boolean", "const": false },
        "grants_connector_authority": { "type": "boolean", "const": false },
        "grants_terminal_closure": { "type": "boolean", "const": false },
        "accepted_record_refs": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/identifier" }
        },
        "authority_decision_refs": { "$ref": "#/$defs/empty_refs" },
        "authority_fuse_refs": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/identifier" }
        },
        "promotion_approval_refs": { "$ref": "#/$defs/empty_refs" },
        "accepted_evidence_refs": { "$ref": "#/$defs/empty_refs" },
        "rejected_evidence_refs": { "$ref": "#/$defs/empty_refs" },
        "blocking_reason": { "type": "string", "minLength": 1, "maxLength": 240 }
      }
    }
  }
}
