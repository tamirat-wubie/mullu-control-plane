{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:workflow:1",
  "title": "Workflow",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "workflow_id",
    "name",
    "stages",
    "bindings",
    "created_at"
  ],
  "properties": {
    "workflow_id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "stage_id",
          "stage_type"
        ],
        "properties": {
          "stage_id": {
            "type": "string",
            "minLength": 1
          },
          "stage_type": {
            "type": "string",
            "enum": [
              "skill_execution",
              "approval_gate",
              "observation",
              "communication",
              "wait_for_event"
            ]
          },
          "skill_id": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "predecessors": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "timeout_seconds": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    },
    "bindings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "binding_id",
          "source_stage_id",
          "source_output_key",
          "target_stage_id",
          "target_input_key"
        ],
        "properties": {
          "binding_id": {
            "type": "string",
            "minLength": 1
          },
          "source_stage_id": {
            "type": "string",
            "minLength": 1
          },
          "source_output_key": {
            "type": "string",
            "minLength": 1
          },
          "target_stage_id": {
            "type": "string",
            "minLength": 1
          },
          "target_input_key": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
