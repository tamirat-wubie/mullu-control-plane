{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:temporal-operation-receipt:1",
  "title": "Temporal Operation Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receipt_id",
    "request_id",
    "tenant_id",
    "actor_id",
    "command_id",
    "action_type",
    "risk_level",
    "status",
    "temporal_violations",
    "temporal_warnings",
    "deferral_reasons",
    "required_controls",
    "runtime_now_utc",
    "monotonic_started_ns",
    "monotonic_finished_ns",
    "duration_ns",
    "requested_at",
    "execute_at",
    "expires_at",
    "approval_received_at",
    "approval_expires_at",
    "evidence_observed_at",
    "evidence_fresh_until",
    "budget_period_start",
    "budget_period_end",
    "causal_preconditions",
    "satisfied_preconditions",
    "missing_preconditions",
    "evidence_refs",
    "timezone_name",
    "original_time_text",
    "receipt_schema_ref",
    "terminal_closure_required",
    "receipt_hash",
    "metadata"
  ],
  "properties": {
    "receipt_id": {
      "type": "string",
      "pattern": "^temporal-receipt-[0-9a-f]{16}$"
    },
    "request_id": {"type": "string", "minLength": 1},
    "tenant_id": {"type": "string", "minLength": 1},
    "actor_id": {"type": "string", "minLength": 1},
    "command_id": {"type": "string", "minLength": 1},
    "action_type": {"type": "string", "minLength": 1},
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "status": {
      "type": "string",
      "enum": ["allow", "deny", "defer", "escalate"]
    },
    "temporal_violations": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "temporal_warnings": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "deferral_reasons": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "required_controls": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "runtime_now_utc": {"type": "string", "format": "date-time"},
    "monotonic_started_ns": {"type": "integer", "minimum": 0},
    "monotonic_finished_ns": {"type": "integer", "minimum": 0},
    "duration_ns": {"type": "integer", "minimum": 0},
    "requested_at": {"type": "string"},
    "execute_at": {"type": "string"},
    "expires_at": {"type": "string"},
    "approval_received_at": {"type": "string"},
    "approval_expires_at": {"type": "string"},
    "evidence_observed_at": {"type": "string"},
    "evidence_fresh_until": {"type": "string"},
    "budget_period_start": {"type": "string"},
    "budget_period_end": {"type": "string"},
    "causal_preconditions": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "satisfied_preconditions": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "missing_preconditions": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "timezone_name": {"type": "string", "minLength": 1},
    "original_time_text": {"type": "string"},
    "receipt_schema_ref": {
      "type": "string",
      "const": "urn:mullusi:schema:temporal-operation-receipt:1"
    },
    "terminal_closure_required": {"type": "boolean", "const": true},
    "receipt_hash": {"type": "string", "minLength": 1},
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "receipt_is_not_terminal_closure",
        "dispatch_allowed",
        "runtime_owns_time_truth",
        "wall_clock_used_for_policy",
        "monotonic_used_for_duration",
        "approval_valid_seconds",
        "freshness_seconds"
      ],
      "properties": {
        "receipt_is_not_terminal_closure": {"type": "boolean", "const": true},
        "dispatch_allowed": {"type": "boolean"},
        "runtime_owns_time_truth": {"type": "boolean", "const": true},
        "wall_clock_used_for_policy": {"type": "boolean", "const": true},
        "monotonic_used_for_duration": {"type": "boolean", "const": true},
        "approval_valid_seconds": {"type": "integer", "minimum": 0},
        "freshness_seconds": {"type": "integer", "minimum": 0}
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {"status": {"const": "allow"}},
        "required": ["status"]
      },
      "then": {
        "properties": {
          "temporal_violations": {"maxItems": 0},
          "temporal_warnings": {"maxItems": 0},
          "deferral_reasons": {"maxItems": 0},
          "missing_preconditions": {"maxItems": 0},
          "metadata": {
            "properties": {
              "dispatch_allowed": {"const": true}
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {"status": {"const": "deny"}},
        "required": ["status"]
      },
      "then": {
        "properties": {
          "temporal_violations": {"minItems": 1},
          "metadata": {
            "properties": {
              "dispatch_allowed": {"const": false}
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {"status": {"const": "defer"}},
        "required": ["status"]
      },
      "then": {
        "properties": {
          "temporal_violations": {"maxItems": 0},
          "deferral_reasons": {"minItems": 1},
          "metadata": {
            "properties": {
              "dispatch_allowed": {"const": false}
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {"status": {"const": "escalate"}},
        "required": ["status"]
      },
      "then": {
        "properties": {
          "temporal_violations": {"maxItems": 0},
          "temporal_warnings": {"minItems": 1},
          "metadata": {
            "properties": {
              "dispatch_allowed": {"const": false}
            }
          }
        }
      }
    }
  ]
}
