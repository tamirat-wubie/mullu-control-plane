{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:finance-approval-payment-provider-binding-receipt:1",
  "title": "Finance Approval Payment Provider Binding Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "receipt_id",
    "provider_binding_ref",
    "provider",
    "checked_at",
    "secret_serialization",
    "ready",
    "accepted_binding_names",
    "provider_binding_names",
    "present_binding_names",
    "binding_count",
    "bindings"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "receipt_id": {
      "$ref": "#/$defs/provider_binding_ref"
    },
    "provider_binding_ref": {
      "$ref": "#/$defs/provider_binding_ref"
    },
    "provider": {
      "$ref": "#/$defs/provider"
    },
    "checked_at": {
      "type": "string",
      "format": "date-time"
    },
    "secret_serialization": {
      "type": "string",
      "const": "forbidden"
    },
    "ready": {
      "type": "boolean"
    },
    "accepted_binding_names": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "$ref": "#/$defs/binding_name"
      }
    },
    "provider_binding_names": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {
        "$ref": "#/$defs/binding_name"
      }
    },
    "present_binding_names": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/binding_name"
      }
    },
    "binding_count": {
      "type": "integer",
      "const": 4
    },
    "bindings": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "provider_scope",
          "present",
          "binding_kind",
          "risk",
          "approval_required",
          "receipt_projection",
          "value_serialized"
        ],
        "properties": {
          "name": {
            "$ref": "#/$defs/binding_name"
          },
          "provider_scope": {
            "type": "string",
            "enum": [
              "shared",
              "stripe",
              "bank_ach",
              "manual_bank_portal"
            ]
          },
          "present": {
            "type": "boolean"
          },
          "binding_kind": {
            "type": "string",
            "const": "secret"
          },
          "risk": {
            "type": "string",
            "const": "high"
          },
          "approval_required": {
            "type": "boolean",
            "const": true
          },
          "receipt_projection": {
            "type": "string",
            "const": "name_and_presence_only"
          },
          "value_serialized": {
            "type": "boolean",
            "const": false
          }
        }
      }
    }
  },
  "$defs": {
    "provider": {
      "type": "string",
      "enum": [
        "stripe",
        "bank_ach",
        "manual_bank_portal"
      ]
    },
    "provider_binding_ref": {
      "type": "string",
      "pattern": "^provider-binding:(stripe|bank_ach|manual_bank_portal):[0-9a-f]{16}$"
    },
    "binding_name": {
      "type": "string",
      "enum": [
        "PAYMENT_PROVIDER_CONNECTOR_TOKEN",
        "STRIPE_API_KEY",
        "BANK_ACH_CONNECTOR_TOKEN",
        "MANUAL_BANK_PORTAL_TOKEN"
      ]
    }
  }
}
