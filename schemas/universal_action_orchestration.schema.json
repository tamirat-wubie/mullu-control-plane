{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:universal-action-orchestration:1",
  "title": "Universal Action Orchestration",
  "description": "Machine-readable one-path orchestration record for governed effect-bearing actions.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "orchestration_id",
    "uao_schema_version",
    "action_id",
    "tenant_id",
    "actor_id",
    "created_at",
    "action_envelope",
    "effect_bearing",
    "effect_classes",
    "input_refs",
    "policy_refs",
    "capability_refs",
    "temporal_refs",
    "recovery_plan",
    "claim_ledger",
    "fracture_report",
    "life_meaning_judgment",
    "life_continuity_judgment",
    "exposure_boundary",
    "pipeline_stages",
    "admission_guards",
    "decision",
    "trace_ref",
    "causal_decision_trace_ref",
    "admission_receipt_ref",
    "execution_receipt_ref",
    "receipts",
    "reconciliation",
    "memory_update",
    "closure_state",
    "closure",
    "raw_reasoning_included",
    "lineage"
  ],
  "properties": {
    "orchestration_id": { "type": "string", "minLength": 1 },
    "uao_schema_version": { "type": "string", "const": "uao.v1" },
    "action_id": { "type": "string", "minLength": 1 },
    "tenant_id": { "type": "string", "minLength": 1 },
    "actor_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "action_envelope": { "$ref": "#/$defs/action_envelope" },
    "effect_bearing": { "type": "boolean" },
    "effect_classes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "input_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "policy_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "capability_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "temporal_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "recovery_plan": { "$ref": "#/$defs/recovery_plan" },
    "claim_ledger": { "$ref": "#/$defs/claim_ledger" },
    "fracture_report": { "$ref": "#/$defs/fracture_report" },
    "life_meaning_judgment": { "$ref": "#/$defs/life_meaning_judgment" },
    "life_continuity_judgment": { "$ref": "#/$defs/life_continuity_judgment" },
    "exposure_boundary": { "$ref": "#/$defs/exposure_boundary" },
    "pipeline_stages": {
      "type": "array",
      "minItems": 11,
      "items": { "$ref": "#/$defs/pipeline_stage" }
    },
    "admission_guards": {
      "type": "array",
      "minItems": 11,
      "items": { "$ref": "#/$defs/admission_guard" }
    },
    "decision": { "$ref": "#/$defs/decision" },
    "trace_ref": { "type": "string", "minLength": 1 },
    "causal_decision_trace_ref": { "type": "string", "minLength": 1 },
    "admission_receipt_ref": { "type": "string", "minLength": 1 },
    "execution_receipt_ref": { "type": ["string", "null"] },
    "receipts": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/receipt" }
    },
    "reconciliation": { "$ref": "#/$defs/reconciliation" },
    "memory_update": { "$ref": "#/$defs/memory_update" },
    "closure_state": {
      "type": "string",
      "enum": ["closed_allowed", "closed_blocked", "closed_deferred", "closed_escalated", "closed_simulated"]
    },
    "closure": { "$ref": "#/$defs/closure" },
    "raw_reasoning_included": { "type": "boolean", "const": false },
    "lineage": { "$ref": "#/$defs/lineage" }
  },
  "$defs": {
    "action_envelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "actor",
        "tenant",
        "intent",
        "target",
        "risk",
        "requested_at",
        "approval_ref",
        "evidence_refs",
        "capability_refs"
      ],
      "properties": {
        "source": { "type": "string", "minLength": 1 },
        "actor": { "type": "string", "minLength": 1 },
        "tenant": { "type": "string", "minLength": 1 },
        "intent": { "type": "string", "minLength": 1 },
        "target": { "type": "string", "minLength": 1 },
        "risk": { "type": "string", "enum": ["low", "H1", "H2", "H3", "H4"] },
        "requested_at": { "type": "string", "minLength": 1 },
        "approval_ref": { "type": ["string", "null"] },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "capability_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "exposure_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["redaction_level", "allowed_audiences", "blocked_payload_classes"],
      "properties": {
        "redaction_level": { "type": "string", "enum": ["internal", "operator", "user_safe", "audit", "external"] },
        "allowed_audiences": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "blocked_payload_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "recovery_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "available",
        "recovery_plan_ref",
        "recovery_kind",
        "rollback_plan_ref",
        "compensation_plan_ref",
        "review_required_on_failure",
        "certificate_ref",
        "effect_plan_ref"
      ],
      "properties": {
        "available": { "type": "boolean" },
        "recovery_plan_ref": { "type": ["string", "null"], "minLength": 1 },
        "recovery_kind": {
          "type": "string",
          "enum": ["none", "rollback", "compensation", "rollback_and_compensation"]
        },
        "rollback_plan_ref": { "type": ["string", "null"], "minLength": 1 },
        "compensation_plan_ref": { "type": ["string", "null"], "minLength": 1 },
        "review_required_on_failure": { "type": "boolean" },
        "certificate_ref": { "type": ["string", "null"], "minLength": 1 },
        "effect_plan_ref": { "type": ["string", "null"], "minLength": 1 },
        "causal_repair_admission_ref": { "type": ["string", "null"], "minLength": 1 },
        "causal_repair_admission_status": {
          "type": "string",
          "enum": ["not_required", "admitted", "blocked", "approval_required"]
        },
        "causal_repair_admission_reason": { "type": ["string", "null"], "minLength": 1 },
        "causal_repair_effect_class": {
          "type": ["string", "null"],
          "enum": [
            null,
            "read_only",
            "internal_reversible",
            "internal_versioned",
            "external_mutation",
            "user_visible",
            "financial_or_legal",
            "public_irreversible",
            "physical_world"
          ]
        },
        "causal_repair_reversibility_class": {
          "type": ["string", "null"],
          "enum": [
            null,
            "read_only",
            "exact_rollback",
            "version_restore",
            "semantic_compensation",
            "reconcile_required",
            "human_escalation",
            "forbidden"
          ]
        },
        "causal_repair_snapshot_quality": {
          "type": ["integer", "null"],
          "minimum": 0,
          "maximum": 5
        },
        "causal_repair_idempotency_required": { "type": "boolean" },
        "causal_repair_idempotency_present": { "type": "boolean" },
        "causal_repair_template_id": { "type": ["string", "null"], "minLength": 1 },
        "causal_repair_template_status": {
          "type": ["string", "null"],
          "enum": [null, "admitted", "blocked", "approval_required", "template_missing"]
        },
        "causal_repair_template_reason": { "type": ["string", "null"], "minLength": 1 },
        "causal_repair_template_required_strategy": {
          "type": ["string", "null"],
          "enum": [
            null,
            "none_required",
            "exact_rollback",
            "version_restore",
            "semantic_compensation",
            "reconcile_then_decide",
            "quarantine",
            "escalate",
            "forbid"
          ]
        }
      }
    },
    "claim_ledger": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ledger_ref", "claims", "unverified_claim_ids"],
      "properties": {
        "ledger_ref": { "type": "string", "minLength": 1 },
        "claims": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/claim" }
        },
        "unverified_claim_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim_id", "claim_type", "statement", "evidence_refs", "confidence", "verified"],
      "properties": {
        "claim_id": { "type": "string", "minLength": 1 },
        "claim_type": {
          "type": "string",
          "enum": ["decision", "execution", "reconciliation", "memory", "closure", "recovery"]
        },
        "statement": { "type": "string", "minLength": 1 },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "verified": { "type": "boolean" }
      }
    },
    "fracture_report": {
      "type": "object",
      "additionalProperties": false,
      "required": ["report_ref", "status", "checks", "blocking_check_ids", "risk_notes"],
      "properties": {
        "report_ref": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "enum": ["passed", "failed", "skipped"] },
        "checks": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/fracture_check" }
        },
        "blocking_check_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "risk_notes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "fracture_check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["check_id", "check_type", "status", "proof_state", "reason_code", "evidence_refs", "blocking"],
      "properties": {
        "check_id": { "type": "string", "minLength": 1 },
        "check_type": {
          "type": "string",
          "enum": [
            "policy_conflict",
            "identity_conflict",
            "budget_conflict",
            "schema_conflict",
            "capability_mismatch",
            "memory_contradiction",
            "unverified_claim",
            "missing_recovery",
            "authority_mismatch",
            "duplicate_command",
            "prompt_injection"
          ]
        },
        "status": { "type": "string", "enum": ["passed", "failed", "waived", "not_applicable"] },
        "proof_state": { "$ref": "#/$defs/proof_state" },
        "reason_code": { "type": "string", "minLength": 1 },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "blocking": { "type": "boolean" }
      }
    },
    "life_meaning_judgment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "judgment_id",
        "action_id",
        "decision",
        "affected_symbols",
        "life_impact",
        "feeling_impact",
        "meaning_impact",
        "truth_preserved",
        "dignity_boundary",
        "consent_required",
        "consent_present",
        "love_delta",
        "resonance_delta",
        "domination_risk",
        "justice_repair_required",
        "continuity_delta",
        "irreversible",
        "reasons",
        "evidence_refs",
        "approval_required",
        "rollback_required"
      ],
      "properties": {
        "judgment_id": { "type": "string", "minLength": 1 },
        "action_id": { "type": "string", "minLength": 1 },
        "decision": {
          "type": "string",
          "enum": ["pass", "pause", "block", "escalate"]
        },
        "affected_symbols": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/life_meaning_affected_symbol" }
        },
        "life_impact": { "$ref": "#/$defs/life_meaning_impact" },
        "feeling_impact": { "$ref": "#/$defs/life_meaning_impact" },
        "meaning_impact": { "$ref": "#/$defs/life_meaning_impact" },
        "truth_preserved": { "type": "boolean" },
        "dignity_boundary": { "$ref": "#/$defs/life_meaning_boundary_state" },
        "consent_required": { "type": "boolean" },
        "consent_present": { "type": "boolean" },
        "love_delta": { "$ref": "#/$defs/life_meaning_delta" },
        "resonance_delta": { "$ref": "#/$defs/life_meaning_delta" },
        "domination_risk": { "type": "boolean" },
        "justice_repair_required": { "type": "boolean" },
        "continuity_delta": { "$ref": "#/$defs/life_meaning_delta" },
        "irreversible": { "type": "boolean" },
        "reasons": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "approval_required": { "type": "boolean" },
        "rollback_required": { "type": "boolean" }
      }
    },
    "life_meaning_affected_symbol": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "symbol_id",
        "symbol_kind",
        "life_status",
        "feeling_status",
        "meaning_bearing",
        "fragility_level",
        "agency_level"
      ],
      "properties": {
        "symbol_id": { "type": "string", "minLength": 1 },
        "symbol_kind": { "type": "string", "minLength": 1 },
        "life_status": {
          "type": "string",
          "enum": ["not_life", "life", "unknown"]
        },
        "feeling_status": {
          "type": "string",
          "enum": ["not_feeling", "feeling", "unknown"]
        },
        "meaning_bearing": { "$ref": "#/$defs/life_meaning_impact" },
        "fragility_level": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10
        },
        "agency_level": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10
        }
      }
    },
    "life_meaning_impact": {
      "type": "string",
      "enum": ["none", "indirect", "direct", "unknown"]
    },
    "life_meaning_delta": {
      "type": "string",
      "enum": ["positive", "neutral", "negative", "unknown"]
    },
    "life_meaning_boundary_state": {
      "type": "string",
      "enum": ["pass", "fail", "unknown"]
    },
    "life_continuity_judgment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "judgment_ref",
        "conflict_law_ref",
        "life_impact",
        "feeling_impact",
        "feeling_observer_impact",
        "meaning_impact",
        "meaning_continuity_delta",
        "value_bearing_symbol",
        "lived_meaning_risk",
        "love_delta",
        "resonance_delta",
        "dignity_boundary",
        "truth_preserved",
        "domination_risk",
        "decision",
        "evidence_refs",
        "review_required"
      ],
      "properties": {
        "judgment_ref": { "type": "string", "minLength": 1 },
        "conflict_law_ref": { "type": "string", "minLength": 1 },
        "life_impact": { "$ref": "#/$defs/life_continuity_impact" },
        "feeling_impact": { "$ref": "#/$defs/life_continuity_impact" },
        "feeling_observer_impact": { "$ref": "#/$defs/life_continuity_impact" },
        "meaning_impact": { "$ref": "#/$defs/life_continuity_impact" },
        "meaning_continuity_delta": { "$ref": "#/$defs/life_continuity_delta" },
        "value_bearing_symbol": { "type": "boolean" },
        "lived_meaning_risk": {
          "type": "string",
          "enum": ["none", "low", "medium", "high", "unknown"]
        },
        "love_delta": { "$ref": "#/$defs/life_continuity_delta" },
        "resonance_delta": { "$ref": "#/$defs/life_continuity_delta" },
        "dignity_boundary": {
          "type": "string",
          "enum": ["pass", "fail", "unknown"]
        },
        "truth_preserved": { "type": "boolean" },
        "domination_risk": { "type": "boolean" },
        "decision": {
          "type": "string",
          "enum": ["pass", "pause", "block", "escalate"]
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "review_required": { "type": "boolean" }
      }
    },
    "life_continuity_impact": {
      "type": "string",
      "enum": ["none", "indirect", "direct", "unknown"]
    },
    "life_continuity_delta": {
      "type": "string",
      "enum": ["positive", "neutral", "negative", "unknown"]
    },
    "pipeline_stage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stage_id", "stage_order", "stage_kind", "status", "input_refs", "output_refs", "receipt_ref", "failure_reason"],
      "properties": {
        "stage_id": { "type": "string", "minLength": 1 },
        "stage_order": { "type": "integer", "minimum": 1 },
        "stage_kind": {
          "type": "string",
          "enum": ["action", "evidence", "trace", "admission", "capability", "fracture", "execution", "receipt", "reconciliation", "memory", "closure"]
        },
        "status": { "type": "string", "enum": ["completed", "blocked", "skipped", "deferred", "escalated", "simulated"] },
        "input_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "output_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "receipt_ref": { "type": ["string", "null"] },
        "failure_reason": { "type": ["string", "null"] }
      }
    },
    "admission_guard": {
      "type": "object",
      "additionalProperties": false,
      "required": ["guard", "verdict", "proof_state", "reason_code", "evidence_refs"],
      "properties": {
        "guard": { "type": "string", "minLength": 1 },
        "verdict": { "type": "string", "enum": ["passed", "blocked", "deferred", "escalated", "simulated"] },
        "proof_state": { "$ref": "#/$defs/proof_state" },
        "reason_code": { "type": "string", "minLength": 1 },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reason_code", "proof_state", "solver_outcome", "next_action", "execution_allowed"],
      "properties": {
        "status": { "type": "string", "enum": ["allow", "block", "defer", "escalate", "simulate"] },
        "reason_code": { "type": "string", "minLength": 1 },
        "proof_state": { "$ref": "#/$defs/proof_state" },
        "solver_outcome": { "$ref": "#/$defs/solver_outcome" },
        "next_action": { "type": "string", "minLength": 1 },
        "execution_allowed": { "type": "boolean" }
      }
    },
    "receipt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["receipt_id", "tier", "kind", "stage_id", "confirms", "external_state_confirmed"],
      "properties": {
        "receipt_id": { "type": "string", "minLength": 1 },
        "tier": { "type": "string", "enum": ["R0", "R1", "R2", "R3", "R4"] },
        "kind": { "type": "string", "enum": ["admission", "trace", "execution", "provider", "reconciliation", "closure", "simulation"] },
        "stage_id": { "type": "string", "minLength": 1 },
        "confirms": { "type": "string", "minLength": 1 },
        "external_state_confirmed": { "type": "boolean" }
      }
    },
    "reconciliation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "observed_outcome_ref", "required_for_closure", "mismatch_reason"],
      "properties": {
        "status": { "type": "string", "enum": ["not_required", "pending", "matched", "mismatched", "blocked"] },
        "observed_outcome_ref": { "type": ["string", "null"] },
        "required_for_closure": { "type": "boolean" },
        "mismatch_reason": { "type": ["string", "null"] }
      }
    },
    "memory_update": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "memory_ref", "learning_allowed", "constitution"],
      "properties": {
        "status": { "type": "string", "enum": ["not_allowed", "not_required", "recorded", "blocked", "deferred"] },
        "memory_ref": { "type": ["string", "null"] },
        "learning_allowed": { "type": "boolean" },
        "constitution": { "$ref": "#/$defs/memory_constitution" }
      }
    },
    "memory_constitution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "constitution_ref",
        "source_refs",
        "owner_ref",
        "scope_ref",
        "confidence",
        "sensitivity",
        "expires_at",
        "allowed_uses",
        "forbidden_uses",
        "evidence_refs",
        "last_verified_at",
        "mutation_history_refs"
      ],
      "properties": {
        "constitution_ref": { "type": "string", "minLength": 1 },
        "source_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "owner_ref": { "type": "string", "minLength": 1 },
        "scope_ref": { "type": "string", "minLength": 1 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "sensitivity": {
          "type": "string",
          "enum": ["public", "operational", "tenant_confidential", "financial", "security", "personal", "regulated"]
        },
        "expires_at": { "type": ["string", "null"] },
        "allowed_uses": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "forbidden_uses": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "last_verified_at": { "type": ["string", "null"] },
        "mutation_history_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "closure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "terminal",
        "closure_receipt_ref",
        "reconciliation_ref",
        "memory_ref",
        "next_action"
      ],
      "properties": {
        "status": { "type": "string", "enum": ["closed_allowed", "closed_blocked", "closed_deferred", "closed_escalated", "closed_simulated"] },
        "terminal": { "type": "boolean" },
        "closure_receipt_ref": { "type": "string", "minLength": 1 },
        "reconciliation_ref": { "type": ["string", "null"] },
        "memory_ref": { "type": ["string", "null"] },
        "whqr_replay_binding": {
          "anyOf": [
            { "$ref": "#/$defs/whqr_replay_binding" },
            { "type": "null" }
          ]
        },
        "next_action": { "type": "string", "minLength": 1 }
      }
    },
    "whqr_replay_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["replay_ref", "canonical_hash", "semantics_hash", "version"],
      "properties": {
        "replay_ref": { "type": "string", "pattern": "^whqr://replay/sha256:[0-9a-f]{64}$" },
        "canonical_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "semantics_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "version": { "type": "string", "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$" }
      }
    },
    "lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["delta_ref", "logged_in_lineage", "accepted_deltas", "rejected_deltas"],
      "properties": {
        "delta_ref": { "type": "string", "minLength": 1 },
        "logged_in_lineage": { "type": "boolean", "const": true },
        "accepted_deltas": {
          "type": "array",
          "items": { "$ref": "#/$defs/delta_record" }
        },
        "rejected_deltas": {
          "type": "array",
          "items": { "$ref": "#/$defs/delta_record" }
        }
      }
    },
    "delta_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["delta_id", "reason", "logged_in_lineage"],
      "properties": {
        "delta_id": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 },
        "logged_in_lineage": { "type": "boolean", "const": true }
      }
    },
    "proof_state": {
      "type": "string",
      "enum": ["Pass", "Fail", "Unknown", "BudgetUnknown"]
    },
    "solver_outcome": {
      "type": "string",
      "enum": [
        "SolvedVerified",
        "SolvedUnverified",
        "AwaitingEvidence",
        "SafeHalt",
        "GovernanceBlocked",
        "BudgetExhausted",
        "ImpossibleProved",
        "ModelInvalidated"
      ]
    }
  }
}
