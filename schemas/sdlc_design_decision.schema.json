{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:sdlc-design-decision:1",
  "title": "SDLC Design Decision",
  "description": "Governed design decision artifact for a software change.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "design_id",
    "requirement_id",
    "architecture_summary",
    "affected_modules",
    "data_model_changes",
    "schema_changes",
    "validator_changes",
    "security_model",
    "rollback_plan",
    "migration_plan",
    "test_plan",
    "uao_ref",
    "causal_decision_trace_ref",
    "receipt_ref"
  ],
  "properties": {
    "design_id": { "type": "string", "minLength": 1 },
    "requirement_id": { "type": "string", "minLength": 1 },
    "architecture_summary": { "type": "string", "minLength": 1 },
    "affected_modules": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "data_model_changes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "schema_changes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "validator_changes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "security_model": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raw_reasoning_rejected",
        "secret_fields_rejected",
        "effect_bearing_requires_receipt",
        "tenant_scope_reviewed"
      ],
      "properties": {
        "raw_reasoning_rejected": { "type": "boolean", "const": true },
        "secret_fields_rejected": { "type": "boolean", "const": true },
        "effect_bearing_requires_receipt": { "type": "boolean", "const": true },
        "tenant_scope_reviewed": { "type": "boolean" }
      }
    },
    "rollback_plan": { "type": "string", "minLength": 1 },
    "migration_plan": { "type": "string", "minLength": 1 },
    "test_plan": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "uao_ref": { "type": "string", "minLength": 1 },
    "causal_decision_trace_ref": { "type": "string", "minLength": 1 },
    "receipt_ref": { "type": "string", "minLength": 1 }
  }
}
