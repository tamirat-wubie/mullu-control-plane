{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:llm-interpretation-proposal:1",
  "title": "LLM Interpretation Proposal",
  "description": "Lower-authority interpretation proposal validated behind deterministic gateway interpretation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "proposal_id",
    "request_id",
    "raw_message_hash",
    "proposal_source",
    "proposed_intent_class",
    "proposed_capability_id",
    "proposed_slot_names",
    "proposed_slots_hash",
    "proposal_confidence",
    "deterministic_intent_class",
    "deterministic_capability_id",
    "deterministic_confidence",
    "validation_status",
    "authority_level",
    "deterministic_override_allowed",
    "action_authority_granted",
    "execution_allowed",
    "rejected_reasons",
    "created_at"
  ],
  "properties": {
    "proposal_id": {"type": "string", "pattern": "^interpretation-proposal-[a-f0-9]{16}$"},
    "request_id": {"type": "string", "pattern": "^interpreted-request-[a-f0-9]{16}$"},
    "raw_message_hash": {"type": "string", "minLength": 1},
    "proposal_source": {"type": "string", "minLength": 1, "maxLength": 120},
    "proposed_intent_class": {"$ref": "#/$defs/intent_class"},
    "proposed_capability_id": {"type": "string", "maxLength": 120},
    "proposed_slot_names": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "proposed_slots_hash": {"type": "string", "minLength": 1},
    "proposal_confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "deterministic_intent_class": {"$ref": "#/$defs/intent_class"},
    "deterministic_capability_id": {"type": "string"},
    "deterministic_confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "validation_status": {
      "type": "string",
      "enum": ["accepted_as_proposal", "rejected"]
    },
    "authority_level": {"type": "string", "const": "proposal_only"},
    "deterministic_override_allowed": {"type": "boolean", "const": false},
    "action_authority_granted": {"type": "boolean", "const": false},
    "execution_allowed": {"type": "boolean", "const": false},
    "rejected_reasons": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "created_at": {"type": "string", "minLength": 1}
  },
  "$defs": {
    "intent_class": {
      "type": "string",
      "enum": [
        "question",
        "action_request",
        "explicit_command",
        "approval_response",
        "correction",
        "follow_up",
        "support_issue",
        "document_instruction",
        "connector_request",
        "blocked_request",
        "unclear_message"
      ]
    }
  }
}
