{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:personal-assistant-operator-reapproval-decision-receipt-intake:1",
  "title": "Personal Assistant Operator Reapproval Decision Receipt Intake",
  "description": "Foundation Mode no-effect preflight that records the future operator reapproval decision receipt submission requirements while keeping execution blocked.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "intake_set_id",
    "generated_at",
    "governed",
    "source_projection",
    "source_operator_reapproval_decision_receipt_absence_set_id",
    "intake_count",
    "intake_ids",
    "source_absence_ids",
    "receipt_ids",
    "intakes",
    "effect_boundary",
    "private_payload_policy",
    "assurance",
    "metadata"
  ],
  "properties": {
    "intake_set_id": {"type": "string", "pattern": "^pa_operator_reapproval_decision_receipt_intake_[a-z0-9][a-z0-9_:-]*$"},
    "generated_at": {"type": "string", "minLength": 1},
    "governed": {"const": true},
    "source_projection": {"const": "operator_reapproval_decision_receipt_absence"},
    "source_operator_reapproval_decision_receipt_absence_set_id": {"type": "string", "pattern": "^pa_operator_reapproval_decision_receipt_absence_[a-z0-9][a-z0-9_:-]*$"},
    "intake_count": {"type": "integer", "minimum": 1},
    "intake_ids": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "pattern": "^pa_operator_reapproval_decision_receipt_intake_item_[a-z0-9][a-z0-9_:-]*$"},
      "uniqueItems": true
    },
    "source_absence_ids": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "pattern": "^pa_operator_reapproval_decision_receipt_absence_item_[a-z0-9][a-z0-9_:-]*$"},
      "uniqueItems": true
    },
    "receipt_ids": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "pattern": "^pa_receipt_[a-z0-9][a-z0-9_:-]*$"},
      "uniqueItems": true
    },
    "intakes": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/intake_item"}
    },
    "effect_boundary": {"$ref": "#/$defs/effect_boundary"},
    "private_payload_policy": {"$ref": "#/$defs/private_payload_policy"},
    "assurance": {"$ref": "#/$defs/assurance"},
    "metadata": {"$ref": "#/$defs/metadata"}
  },
  "$defs": {
    "digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "intake_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "intake_id",
        "source_absence_id",
        "approval_id",
        "request_id",
        "plan_id",
        "skill_id",
        "risk_level",
        "absence_witness_ref",
        "receipt_intake_request",
        "execution_admission_block",
        "receipt"
      ],
      "properties": {
        "intake_id": {"type": "string", "pattern": "^pa_operator_reapproval_decision_receipt_intake_item_[a-z0-9][a-z0-9_:-]*$"},
        "source_absence_id": {"type": "string", "pattern": "^pa_operator_reapproval_decision_receipt_absence_item_[a-z0-9][a-z0-9_:-]*$"},
        "approval_id": {"type": "string", "pattern": "^pa_approval_[a-z0-9][a-z0-9_:-]*$"},
        "request_id": {"type": "string", "pattern": "^pa_request_[a-z0-9][a-z0-9_:-]*$"},
        "plan_id": {"type": "string", "pattern": "^pa_plan_[a-z0-9][a-z0-9_:-]*$"},
        "skill_id": {"type": "string", "pattern": "^[a-z][a-z0-9_]*(\\.[a-z0-9_]+)+$"},
        "risk_level": {"enum": ["P3", "P4", "P5"]},
        "absence_witness_ref": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "source_absence_set_id",
            "source_absence_id",
            "required_receipt_ref",
            "decision_receipt_required",
            "decision_receipt_present",
            "absence_reason",
            "execution_worker_admission_allowed"
          ],
          "properties": {
            "source_absence_set_id": {"type": "string", "pattern": "^pa_operator_reapproval_decision_receipt_absence_[a-z0-9][a-z0-9_:-]*$"},
            "source_absence_id": {"type": "string", "pattern": "^pa_operator_reapproval_decision_receipt_absence_item_[a-z0-9][a-z0-9_:-]*$"},
            "required_receipt_ref": {"type": "string", "pattern": "^receipt://personal-assistant/operator-reapproval-decision/pa_approval_[a-z0-9][a-z0-9_:-]*$"},
            "decision_receipt_required": {"const": true},
            "decision_receipt_present": {"const": false},
            "absence_reason": {"const": "operator_reapproval_decision_receipt_absent"},
            "execution_worker_admission_allowed": {"const": false}
          }
        },
        "receipt_intake_request": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "receipt_intake_ref",
            "receipt_intake_digest",
            "accepted_decision_values",
            "operator_decision_value_required",
            "operator_decision_value_present",
            "operator_identity_ref_required",
            "operator_identity_ref_present",
            "operator_signature_ref_required",
            "operator_signature_ref_present",
            "decision_receipt_required",
            "decision_receipt_present",
            "raw_operator_decision_serialized",
            "secret_values_serialized",
            "submission_payload_projection"
          ],
          "properties": {
            "receipt_intake_ref": {"type": "string", "pattern": "^receipt://personal-assistant/operator-reapproval-decision-intake/pa_approval_[a-z0-9][a-z0-9_:-]*$"},
            "receipt_intake_digest": {"$ref": "#/$defs/digest"},
            "accepted_decision_values": {
              "type": "array",
              "prefixItems": [
                {"const": "approved"},
                {"const": "rejected"},
                {"const": "revised"},
                {"const": "expired"}
              ],
              "items": false,
              "minItems": 4,
              "maxItems": 4
            },
            "operator_decision_value_required": {"const": true},
            "operator_decision_value_present": {"const": false},
            "operator_identity_ref_required": {"const": true},
            "operator_identity_ref_present": {"const": false},
            "operator_signature_ref_required": {"const": true},
            "operator_signature_ref_present": {"const": false},
            "decision_receipt_required": {"const": true},
            "decision_receipt_present": {"const": false},
            "raw_operator_decision_serialized": {"const": false},
            "secret_values_serialized": {"const": false},
            "submission_payload_projection": {"const": "absent_until_operator_submits_receipt"}
          }
        },
        "execution_admission_block": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "execution_worker_admission_state",
            "execution_worker_admission_allowed",
            "dispatch_allowed",
            "live_connector_execution_allowed",
            "connector_mutation_allowed",
            "external_send_allowed",
            "system_of_record_write_allowed",
            "memory_write_allowed"
          ],
          "properties": {
            "execution_worker_admission_state": {"const": "blocked_pending_operator_reapproval_decision_receipt_intake"},
            "execution_worker_admission_allowed": {"const": false},
            "dispatch_allowed": {"const": false},
            "live_connector_execution_allowed": {"const": false},
            "connector_mutation_allowed": {"const": false},
            "external_send_allowed": {"const": false},
            "system_of_record_write_allowed": {"const": false},
            "memory_write_allowed": {"const": false}
          }
        },
        "receipt": {"type": "object", "additionalProperties": true}
      }
    },
    "effect_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operator_reapproval_decision_receipt_intake_preflight_allowed",
        "receipt_absence_ref_binding_allowed",
        "decision_receipt_submission_request_allowed",
        "decision_receipt_required",
        "decision_value_required",
        "operator_identity_ref_required",
        "operator_signature_ref_required",
        "decision_value_present",
        "fresh_operator_decision_present",
        "operator_identity_ref_present",
        "operator_signature_ref_present",
        "operator_reapproval_receipt_present",
        "decision_receipt_present",
        "execution_worker_admission_allowed",
        "dispatch_allowed",
        "dispatch_lease_active",
        "live_connector_receipt_present",
        "live_connector_execution_allowed",
        "external_send_allowed",
        "calendar_write_allowed",
        "task_write_allowed",
        "memory_write_allowed",
        "connector_mutation_allowed",
        "system_of_record_write_allowed",
        "deployment_mutation_allowed",
        "nested_mind_live_activation_allowed",
        "public_readiness_claim_allowed"
      ],
      "properties": {
        "operator_reapproval_decision_receipt_intake_preflight_allowed": {"const": true},
        "receipt_absence_ref_binding_allowed": {"const": true},
        "decision_receipt_submission_request_allowed": {"const": true},
        "decision_receipt_required": {"const": true},
        "decision_value_required": {"const": true},
        "operator_identity_ref_required": {"const": true},
        "operator_signature_ref_required": {"const": true},
        "decision_value_present": {"const": false},
        "fresh_operator_decision_present": {"const": false},
        "operator_identity_ref_present": {"const": false},
        "operator_signature_ref_present": {"const": false},
        "operator_reapproval_receipt_present": {"const": false},
        "decision_receipt_present": {"const": false},
        "execution_worker_admission_allowed": {"const": false},
        "dispatch_allowed": {"const": false},
        "dispatch_lease_active": {"const": false},
        "live_connector_receipt_present": {"const": false},
        "live_connector_execution_allowed": {"const": false},
        "external_send_allowed": {"const": false},
        "calendar_write_allowed": {"const": false},
        "task_write_allowed": {"const": false},
        "memory_write_allowed": {"const": false},
        "connector_mutation_allowed": {"const": false},
        "system_of_record_write_allowed": {"const": false},
        "deployment_mutation_allowed": {"const": false},
        "nested_mind_live_activation_allowed": {"const": false},
        "public_readiness_claim_allowed": {"const": false}
      }
    },
    "private_payload_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raw_private_payload_serialized",
        "secret_values_serialized",
        "absence_payload_projection",
        "decision_receipt_payload_projection"
      ],
      "properties": {
        "raw_private_payload_serialized": {"const": false},
        "secret_values_serialized": {"const": false},
        "absence_payload_projection": {"const": "ref_only"},
        "decision_receipt_payload_projection": {"const": "absent_until_operator_submits_receipt"}
      }
    },
    "assurance": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "assurance_id",
        "outcome",
        "foundation_only",
        "ready_for_execution_worker_admission",
        "ready_for_live_execution",
        "ready_for_customer_readiness_claim"
      ],
      "properties": {
        "assurance_id": {"const": "personal_assistant_operator_reapproval_decision_receipt_intake_no_effect_assurance"},
        "outcome": {"enum": ["AwaitingEvidence", "GovernanceBlocked"]},
        "foundation_only": {"const": true},
        "ready_for_execution_worker_admission": {"const": false},
        "ready_for_live_execution": {"const": false},
        "ready_for_customer_readiness_claim": {"const": false}
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "foundation_only",
        "projection_contract",
        "runtime_boundary",
        "decision_value_present",
        "fresh_operator_decision_present",
        "operator_identity_ref_present",
        "operator_signature_ref_present",
        "operator_reapproval_receipt_present",
        "decision_receipt_present",
        "execution_worker_admission_allowed",
        "dispatch_allowed",
        "live_connector_execution_allowed",
        "connector_mutation_allowed",
        "external_send_allowed",
        "system_of_record_write_allowed",
        "memory_write_allowed"
      ],
      "properties": {
        "foundation_only": {"const": true},
        "projection_contract": {"const": "operator_reapproval_decision_receipt_intake_evidence_only"},
        "runtime_boundary": {"const": "intake_preflight_records_submission_requirements_without_collecting_decision"},
        "decision_value_present": {"const": false},
        "fresh_operator_decision_present": {"const": false},
        "operator_identity_ref_present": {"const": false},
        "operator_signature_ref_present": {"const": false},
        "operator_reapproval_receipt_present": {"const": false},
        "decision_receipt_present": {"const": false},
        "execution_worker_admission_allowed": {"const": false},
        "dispatch_allowed": {"const": false},
        "live_connector_execution_allowed": {"const": false},
        "connector_mutation_allowed": {"const": false},
        "external_send_allowed": {"const": false},
        "system_of_record_write_allowed": {"const": false},
        "memory_write_allowed": {"const": false}
      }
    }
  }
}
