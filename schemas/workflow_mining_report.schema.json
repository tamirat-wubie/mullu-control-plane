{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:workflow-mining-report:1",
  "title": "Workflow Mining Report",
  "type": "object",
  "additionalProperties": false,
  "required": ["report_id", "tenant_id", "trace_count", "patterns", "drafts", "report_hash"],
  "properties": {
    "report_id": {"type": "string", "minLength": 1},
    "tenant_id": {"type": "string", "minLength": 1},
    "trace_count": {"type": "integer", "minimum": 0},
    "patterns": {"type": "array", "items": {"$ref": "#/$defs/pattern"}},
    "drafts": {"type": "array", "items": {"$ref": "#/$defs/draft"}},
    "report_hash": {"type": "string", "minLength": 1},
    "metadata": {"type": "object", "additionalProperties": true}
  },
  "$defs": {
    "pattern": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pattern_id", "tenant_id", "operation_signature", "occurrence_count", "source_trace_ids", "confidence", "risk_tier", "evidence_refs"],
      "properties": {
        "pattern_id": {"type": "string", "minLength": 1},
        "tenant_id": {"type": "string", "minLength": 1},
        "operation_signature": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "occurrence_count": {"type": "integer", "minimum": 1},
        "source_trace_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "risk_tier": {"type": "string", "enum": ["low", "medium", "high"]},
        "evidence_refs": {"type": "array", "items": {"type": "string", "minLength": 1}}
      }
    },
    "draft": {
      "type": "object",
      "additionalProperties": false,
      "required": ["draft_id", "tenant_id", "name", "pattern_id", "stages", "policy_requirements", "approval_rules", "evidence_requirements", "eval_cases", "sandbox_replay_required", "operator_review_required", "activation_blocked", "source_trace_ids", "draft_hash"],
      "properties": {
        "draft_id": {"type": "string", "minLength": 1},
        "tenant_id": {"type": "string", "minLength": 1},
        "name": {"type": "string", "minLength": 1},
        "pattern_id": {"type": "string", "minLength": 1},
        "stages": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/stage"}},
        "policy_requirements": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "approval_rules": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "evidence_requirements": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "eval_cases": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "sandbox_replay_required": {"type": "boolean", "const": true},
        "operator_review_required": {"type": "boolean", "const": true},
        "activation_blocked": {"type": "boolean", "const": true},
        "source_trace_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "draft_hash": {"type": "string", "minLength": 1},
        "metadata": {"type": "object", "additionalProperties": true}
      }
    },
    "stage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stage_id", "stage_type", "operation", "predecessors", "required_evidence"],
      "properties": {
        "stage_id": {"type": "string", "minLength": 1},
        "stage_type": {"type": "string", "enum": ["skill_execution", "approval_gate", "observation", "communication", "wait_for_event"]},
        "operation": {"type": "string", "minLength": 1},
        "predecessors": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "required_evidence": {"type": "array", "items": {"type": "string", "minLength": 1}}
      }
    }
  }
}
