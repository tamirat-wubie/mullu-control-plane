{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:capability-registry-entry:1",
  "title": "Capability Registry Entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "capability_id",
    "domain",
    "version",
    "input_schema_ref",
    "output_schema_ref",
    "effect_model",
    "evidence_model",
    "authority_policy",
    "isolation_profile",
    "recovery_plan",
    "cost_model",
    "obligation_model",
    "certification_status",
    "metadata",
    "extensions"
  ],
  "properties": {
    "capability_id": {
      "type": "string",
      "minLength": 1
    },
    "domain": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "input_schema_ref": {
      "type": "string",
      "minLength": 1
    },
    "output_schema_ref": {
      "type": "string",
      "minLength": 1
    },
    "effect_model": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "expected_effects",
        "forbidden_effects",
        "reconciliation_required"
      ],
      "properties": {
        "expected_effects": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "forbidden_effects": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "reconciliation_required": {
          "type": "boolean"
        }
      }
    },
    "evidence_model": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_evidence",
        "terminal_certificate_required"
      ],
      "properties": {
        "required_evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "terminal_certificate_required": {
          "type": "boolean"
        }
      }
    },
    "authority_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_roles",
        "approval_chain",
        "separation_of_duty"
      ],
      "properties": {
        "required_roles": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "approval_chain": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "separation_of_duty": {
          "type": "boolean"
        }
      }
    },
    "isolation_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "execution_plane",
        "network_allowlist",
        "secret_scope"
      ],
      "properties": {
        "execution_plane": {
          "type": "string",
          "minLength": 1
        },
        "network_allowlist": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "secret_scope": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "recovery_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rollback_capability",
        "compensation_capability",
        "review_required_on_failure"
      ],
      "properties": {
        "rollback_capability": {
          "type": "string"
        },
        "compensation_capability": {
          "type": "string"
        },
        "review_required_on_failure": {
          "type": "boolean"
        }
      }
    },
    "cost_model": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "budget_class",
        "max_estimated_cost"
      ],
      "properties": {
        "budget_class": {
          "type": "string",
          "minLength": 1
        },
        "max_estimated_cost": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "obligation_model": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "owner_team",
        "failure_due_seconds",
        "escalation_route"
      ],
      "properties": {
        "owner_team": {
          "type": "string",
          "minLength": 1
        },
        "failure_due_seconds": {
          "type": "integer",
          "minimum": 0
        },
        "escalation_route": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "certification_status": {
      "type": "string",
      "enum": [
        "candidate",
        "certified",
        "suspended",
        "retired"
      ]
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
