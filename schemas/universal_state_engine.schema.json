{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:universal-state-engine:1",
  "title": "Universal State Engine",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "engine_id",
    "version",
    "generated_at",
    "subjects",
    "state_machines",
    "guards",
    "transitions",
    "closures",
    "receipt_refs",
    "metadata"
  ],
  "properties": {
    "engine_id": {"type": "string", "minLength": 1},
    "version": {"type": "string", "minLength": 1},
    "generated_at": {"type": "string", "format": "date-time"},
    "subjects": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/subject"}
    },
    "state_machines": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/state_machine"}
    },
    "guards": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/guard"}
    },
    "transitions": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/transition"}
    },
    "closures": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/closure"}
    },
    "receipt_refs": {"$ref": "#/$defs/non_empty_string_array"},
    "metadata": {"type": "object"}
  },
  "$defs": {
    "subject_kind": {
      "type": "string",
      "enum": [
        "note",
        "memory",
        "receipt",
        "workflow",
        "deployment",
        "case",
        "capability",
        "skill",
        "policy",
        "action"
      ]
    },
    "guard_kind": {
      "type": "string",
      "enum": [
        "evidence_required",
        "authority_required",
        "receipt_required",
        "state_invariant",
        "temporal_window",
        "approval_required"
      ]
    },
    "closure_kind": {
      "type": "string",
      "enum": ["completed", "rejected", "rolled_back", "expired", "superseded", "escalated"]
    },
    "state_category": {
      "type": "string",
      "enum": ["kernel", "runtime", "environment"]
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "string_array": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "unit_number": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "state_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state_id", "category", "state_hash", "captured_at", "metadata", "extensions"],
      "properties": {
        "state_id": {"type": "string", "minLength": 1},
        "category": {"$ref": "#/$defs/state_category"},
        "state_hash": {"type": "string", "minLength": 1},
        "captured_at": {"type": "string", "format": "date-time"},
        "metadata": {"type": "object"},
        "extensions": {"type": "object"}
      }
    },
    "transition_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from_state", "to_state", "action", "guard_label", "emits"],
      "properties": {
        "from_state": {"type": "string", "minLength": 1},
        "to_state": {"type": "string", "minLength": 1},
        "action": {"type": "string", "minLength": 1},
        "guard_label": {"type": "string"},
        "emits": {"type": "string"}
      }
    },
    "state_machine": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "machine_id",
        "name",
        "version",
        "states",
        "initial_state",
        "terminal_states",
        "transitions"
      ],
      "properties": {
        "machine_id": {"type": "string", "minLength": 1},
        "name": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "states": {"$ref": "#/$defs/non_empty_string_array"},
        "initial_state": {"type": "string", "minLength": 1},
        "terminal_states": {"$ref": "#/$defs/string_array"},
        "transitions": {
          "type": "array",
          "items": {"$ref": "#/$defs/transition_rule"}
        }
      }
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "subject_id",
        "subject_kind",
        "machine_id",
        "current_state",
        "state_ref",
        "evidence_refs",
        "updated_at",
        "metadata"
      ],
      "properties": {
        "subject_id": {"type": "string", "minLength": 1},
        "subject_kind": {"$ref": "#/$defs/subject_kind"},
        "machine_id": {"type": "string", "minLength": 1},
        "current_state": {"type": "string", "minLength": 1},
        "state_ref": {"$ref": "#/$defs/state_ref"},
        "evidence_refs": {"$ref": "#/$defs/non_empty_string_array"},
        "updated_at": {"type": "string", "format": "date-time"},
        "metadata": {"type": "object"}
      }
    },
    "guard": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "guard_id",
        "guard_kind",
        "machine_id",
        "from_state",
        "to_state",
        "required_refs",
        "confidence",
        "metadata"
      ],
      "properties": {
        "guard_id": {"type": "string", "minLength": 1},
        "guard_kind": {"$ref": "#/$defs/guard_kind"},
        "machine_id": {"type": "string", "minLength": 1},
        "from_state": {"type": "string", "minLength": 1},
        "to_state": {"type": "string", "minLength": 1},
        "required_refs": {"$ref": "#/$defs/non_empty_string_array"},
        "confidence": {"$ref": "#/$defs/unit_number"},
        "metadata": {"type": "object"}
      }
    },
    "transition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "transition_id",
        "subject_id",
        "machine_id",
        "from_state",
        "to_state",
        "action",
        "guard_ids",
        "receipt_refs",
        "evidence_refs",
        "transitioned_at",
        "metadata"
      ],
      "properties": {
        "transition_id": {"type": "string", "minLength": 1},
        "subject_id": {"type": "string", "minLength": 1},
        "machine_id": {"type": "string", "minLength": 1},
        "from_state": {"type": "string", "minLength": 1},
        "to_state": {"type": "string", "minLength": 1},
        "action": {"type": "string", "minLength": 1},
        "guard_ids": {"$ref": "#/$defs/non_empty_string_array"},
        "receipt_refs": {"$ref": "#/$defs/non_empty_string_array"},
        "evidence_refs": {"$ref": "#/$defs/non_empty_string_array"},
        "transitioned_at": {"type": "string", "format": "date-time"},
        "metadata": {"type": "object"}
      }
    },
    "closure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "closure_id",
        "subject_id",
        "closure_kind",
        "terminal_state",
        "receipt_refs",
        "closed_at",
        "metadata"
      ],
      "properties": {
        "closure_id": {"type": "string", "minLength": 1},
        "subject_id": {"type": "string", "minLength": 1},
        "closure_kind": {"$ref": "#/$defs/closure_kind"},
        "terminal_state": {"type": "string", "minLength": 1},
        "receipt_refs": {"$ref": "#/$defs/non_empty_string_array"},
        "closed_at": {"type": "string", "format": "date-time"},
        "metadata": {"type": "object"}
      }
    }
  }
}
