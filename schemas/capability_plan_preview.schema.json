{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:capability-plan-preview:1",
  "title": "Capability Plan Preview",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "preview_id",
    "plan_id",
    "tenant_id",
    "identity_id",
    "goal_hash",
    "step_count",
    "steps",
    "risk_tier",
    "approval_required",
    "evidence_required",
    "budget",
    "tools",
    "execution_allowed",
    "safe_default",
    "created_at",
    "metadata"
  ],
  "properties": {
    "preview_id": {
      "type": "string",
      "pattern": "^plan-preview-[a-f0-9]{16}$"
    },
    "plan_id": {
      "type": "string",
      "pattern": "^plan-[a-f0-9]{16}$"
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "identity_id": {
      "type": "string",
      "minLength": 1
    },
    "goal_hash": {
      "type": "string",
      "minLength": 32
    },
    "step_count": {
      "type": "integer",
      "minimum": 1
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "step_id",
          "capability_id",
          "depends_on",
          "param_names",
          "params_hash"
        ],
        "properties": {
          "step_id": {
            "type": "string",
            "minLength": 1
          },
          "capability_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*\\.[a-z][a-z0-9_]*$"
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "param_names": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "params_hash": {
            "type": "string",
            "minLength": 32
          }
        }
      }
    },
    "risk_tier": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "approval_required": {
      "type": "boolean"
    },
    "evidence_required": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "budget_required",
        "budget_gate",
        "estimate_state",
        "estimate_source",
        "estimated_cost_units",
        "used_cost_units",
        "used_cost_source",
        "limit_cost_units",
        "remaining_cost_units",
        "currency",
        "required_by_steps",
        "not_required_by_steps",
        "execution_spend_allowed"
      ],
      "properties": {
        "budget_required": {
          "type": "boolean"
        },
        "budget_gate": {
          "type": "string",
          "enum": ["budget_reserved", "not_required"]
        },
        "estimate_state": {
          "type": "string",
          "enum": ["estimated", "partial", "not_calculated", "not_required"]
        },
        "estimate_source": {
          "type": "string",
          "enum": [
            "runtime_budget_gate_required",
            "capability_passport",
            "capability_cost_model"
          ]
        },
        "estimated_cost_units": {
          "type": ["number", "null"],
          "minimum": 0
        },
        "used_cost_units": {
          "type": "number",
          "minimum": 0
        },
        "used_cost_source": {
          "type": "string",
          "enum": ["preview_execution_not_started"]
        },
        "limit_cost_units": {
          "type": ["number", "null"],
          "minimum": 0
        },
        "remaining_cost_units": {
          "type": ["number", "null"],
          "minimum": 0
        },
        "currency": {
          "type": "string",
          "const": "cost_units"
        },
        "required_by_steps": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "not_required_by_steps": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "execution_spend_allowed": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "tools": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "step_id",
          "capability_id",
          "tool_name",
          "tool_type",
          "permission_state",
          "budget_required",
          "estimated_cost_units",
          "external_system",
          "mutates_world",
          "authority_required",
          "requires",
          "execution_allowed"
        ],
        "properties": {
          "step_id": {
            "type": "string",
            "minLength": 1
          },
          "capability_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*\\.[a-z][a-z0-9_]*$"
          },
          "tool_name": {
            "type": "string",
            "minLength": 1
          },
          "tool_type": {
            "type": "string",
            "enum": ["external_system", "local_capability"]
          },
          "permission_state": {
            "type": "string",
            "enum": ["read_only", "approval_required", "preview_only"]
          },
          "budget_required": {
            "type": "boolean"
          },
          "estimated_cost_units": {
            "type": ["number", "null"],
            "minimum": 0
          },
          "external_system": {
            "type": "string"
          },
          "mutates_world": {
            "type": "boolean"
          },
          "authority_required": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "requires": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "execution_allowed": {
            "type": "boolean",
            "const": false
          }
        }
      }
    },
    "execution_allowed": {
      "type": "boolean",
      "const": false
    },
    "safe_default": {
      "type": "string",
      "enum": ["await_approval_or_explicit_execution"]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
