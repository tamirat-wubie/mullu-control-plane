{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:component-proof-binding:1",
  "title": "Mullu Component Proof Binding",
  "description": "Read-only component-to-proof binding for the Mullu Component Harness. The binding joins the canonical component registry, router inventory, and proof coverage matrix without granting execution authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "binding_id",
    "generated_at",
    "mode",
    "source_registry",
    "source_router_inventory",
    "source_proof_matrix",
    "purpose",
    "proof_binding_is_not_execution_authority",
    "live_execution_enabled",
    "terminal_closure_required",
    "component_bindings",
    "validators",
    "next_action"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "binding_id": {
      "$ref": "#/$defs/identifier"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "mode": {
      "type": "string",
      "enum": [
        "foundation",
        "read_only"
      ]
    },
    "source_registry": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "source_router_inventory": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "source_proof_matrix": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "proof_binding_is_not_execution_authority": {
      "type": "boolean",
      "const": true
    },
    "live_execution_enabled": {
      "type": "boolean",
      "const": false
    },
    "terminal_closure_required": {
      "type": "boolean",
      "const": true
    },
    "component_bindings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/component_binding"
      }
    },
    "validators": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/validator_ref"
      }
    },
    "next_action": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "repo_path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9._~:/{}@+ -]+$"
    },
    "blocked_action": {
      "type": "string",
      "enum": [
        "account_binding_claim",
        "autonomous_execution",
        "calendar_write",
        "connector_call",
        "customer_exposure",
        "deploy",
        "dns_mutation",
        "external_send",
        "filesystem_write",
        "live_dispatch",
        "mailbox_mutation",
        "memory_topology_activation",
        "money_movement",
        "provider_write",
        "public_readiness_claim",
        "route_execution",
        "runtime_mutation",
        "secret_mutation",
        "send_email",
        "terminal_closure"
      ]
    },
    "component_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "component_id",
        "proof_binding_state",
        "required_surface_ids",
        "inventory_surface_ids",
        "required_evidence_files",
        "required_runtime_witnesses",
        "receipt_required",
        "blocked_actions",
        "binding_is_not_execution_authority",
        "can_claim_terminal_closure",
        "notes"
      ],
      "properties": {
        "component_id": {
          "$ref": "#/$defs/identifier"
        },
        "proof_binding_state": {
          "type": "string",
          "enum": [
            "proof_bound",
            "awaiting_binding",
            "not_applicable"
          ]
        },
        "required_surface_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "inventory_surface_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "required_evidence_files": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/repo_path"
          }
        },
        "required_runtime_witnesses": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "receipt_required": {
          "type": "boolean"
        },
        "blocked_actions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/blocked_action"
          }
        },
        "binding_is_not_execution_authority": {
          "type": "boolean",
          "const": true
        },
        "can_claim_terminal_closure": {
          "type": "boolean",
          "const": false
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "validator_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "validator_id",
        "command",
        "required_for_closure"
      ],
      "properties": {
        "validator_id": {
          "$ref": "#/$defs/identifier"
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "required_for_closure": {
          "type": "boolean"
        }
      }
    }
  }
}
