{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:sdlc-release-candidate:1",
  "title": "SDLC Release Candidate",
  "description": "Governed release readiness artifact for a software change.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "release_id",
    "version",
    "commit_range",
    "change_set",
    "breaking_changes",
    "migration_required",
    "schemas_changed",
    "validators_changed",
    "security_fixes",
    "docs_updated",
    "tests_passed",
    "security_status",
    "known_limitations",
    "release_notes",
    "deployment_status",
    "rollback_plan",
    "release_receipt",
    "uao_ref",
    "causal_decision_trace_ref",
    "receipt_ref",
    "evidence_bound_claims"
  ],
  "properties": {
    "release_id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "commit_range": { "type": "string", "minLength": 1 },
    "change_set": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "breaking_changes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "migration_required": { "type": "boolean" },
    "schemas_changed": { "type": "boolean" },
    "validators_changed": { "type": "boolean" },
    "security_fixes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "docs_updated": { "type": "boolean" },
    "tests_passed": { "type": "boolean" },
    "security_status": {
      "type": "object",
      "additionalProperties": false,
      "required": ["review_ref", "critical_open", "high_open", "status"],
      "properties": {
        "review_ref": { "type": "string", "minLength": 1 },
        "critical_open": { "type": "integer", "minimum": 0 },
        "high_open": { "type": "integer", "minimum": 0 },
        "status": { "type": "string", "enum": ["passed", "blocked", "not_applicable"] }
      }
    },
    "known_limitations": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "release_notes": { "type": "string", "minLength": 1 },
    "deployment_status": {
      "type": "string",
      "enum": ["not_published", "staging", "pilot", "production_ready", "published"]
    },
    "rollback_plan": { "type": "string", "minLength": 1 },
    "release_receipt": { "type": "string", "minLength": 1 },
    "uao_ref": { "type": "string", "minLength": 1 },
    "causal_decision_trace_ref": { "type": "string", "minLength": 1 },
    "receipt_ref": { "type": "string", "minLength": 1 },
    "evidence_bound_claims": { "type": "boolean", "const": true }
  }
}
