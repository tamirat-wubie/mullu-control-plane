{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:agentic-service-harness-planned-file-change-collection-preflight:1",
  "title": "Agentic Service Harness Planned File Change Collection Preflight",
  "description": "Foundation Mode preflight contract for planned file-change collection after workspace sandbox and branch-write authority binding evidence. This schema records the collection envelope only and does not create branches, write files, collect diffs, execute commands, run tests, append receipt stores, open pull requests, call connectors, serialize secrets, claim success, or issue terminal closure.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "report_id",
    "schema_version",
    "generated_at",
    "solver_outcome",
    "collection_status",
    "source_workspace_sandbox_preflight_ref",
    "source_branch_write_authority_binding_ref",
    "scope",
    "collection_contract",
    "authority_gates",
    "path_policy",
    "redaction_policy",
    "effect_denials",
    "receipt_refs",
    "validators",
    "next_action",
    "report_is_not_terminal_closure",
    "terminal_closure_required"
  ],
  "properties": {
    "report_id": {
      "type": "string",
      "const": "agentic_service_harness_planned_file_change_collection_preflight"
    },
    "schema_version": { "type": "integer", "const": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "solver_outcome": { "type": "string", "const": "SolvedVerified" },
    "collection_status": { "type": "string", "const": "AwaitingEvidence" },
    "source_workspace_sandbox_preflight_ref": {
      "type": "string",
      "const": "examples/agentic_service_harness_workspace_sandbox_preflight.foundation.json"
    },
    "source_branch_write_authority_binding_ref": {
      "type": "string",
      "const": "examples/agentic_service_harness_github_pr_branch_write_authority_binding.foundation.json"
    },
    "scope": { "$ref": "#/$defs/scope" },
    "collection_contract": { "$ref": "#/$defs/collection_contract" },
    "authority_gates": { "$ref": "#/$defs/authority_gates" },
    "path_policy": { "$ref": "#/$defs/path_policy" },
    "redaction_policy": { "$ref": "#/$defs/redaction_policy" },
    "effect_denials": { "$ref": "#/$defs/effect_denials" },
    "receipt_refs": { "$ref": "#/$defs/receipt_refs" },
    "validators": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/validator_ref" }
    },
    "next_action": { "type": "string", "minLength": 1 },
    "report_is_not_terminal_closure": { "type": "boolean", "const": true },
    "terminal_closure_required": { "type": "boolean", "const": true }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "evidence_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/#$-]*$"
    },
    "evidence_ref_list": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/evidence_ref" }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project_id",
        "task_id",
        "run_id",
        "sandbox_id",
        "repository_connection_id",
        "repository_slug",
        "mode",
        "foundation_phase",
        "preflight_only",
        "workspace_write_authority_required",
        "workspace_write_authority_granted",
        "branch_write_authority_collected",
        "cleanup_receipt_emitted",
        "planned_file_change_collection_admitted",
        "actual_file_change_collection_started"
      ],
      "properties": {
        "project_id": { "$ref": "#/$defs/identifier" },
        "task_id": { "$ref": "#/$defs/identifier" },
        "run_id": { "$ref": "#/$defs/identifier" },
        "sandbox_id": { "$ref": "#/$defs/identifier" },
        "repository_connection_id": { "$ref": "#/$defs/identifier" },
        "repository_slug": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
        },
        "mode": { "type": "string", "const": "branch_write" },
        "foundation_phase": { "type": "string", "const": "foundation_contract_only" },
        "preflight_only": { "type": "boolean", "const": true },
        "workspace_write_authority_required": { "type": "boolean", "const": true },
        "workspace_write_authority_granted": { "type": "boolean", "const": false },
        "branch_write_authority_collected": { "type": "boolean", "const": false },
        "cleanup_receipt_emitted": { "type": "boolean", "const": false },
        "planned_file_change_collection_admitted": { "type": "boolean", "const": false },
        "actual_file_change_collection_started": { "type": "boolean", "const": false }
      }
    },
    "collection_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "collection_id",
        "collection_mode",
        "collection_kind",
        "allowed_action_classes",
        "forbidden_action_classes",
        "allowed_file_change_kinds",
        "required_before_collection_refs",
        "required_validation_refs",
        "planned_collection_only",
        "file_change_summary_required_after_collection",
        "diff_receipt_required_after_collection"
      ],
      "properties": {
        "collection_id": {
          "type": "string",
          "const": "planned-file-change-collection-foundation"
        },
        "collection_mode": { "type": "string", "const": "PREFLIGHT_ONLY" },
        "collection_kind": { "type": "string", "const": "planned_file_change_collection" },
        "allowed_action_classes": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1,
          "items": { "type": "string", "const": "preflight" }
        },
        "forbidden_action_classes": {
          "type": "array",
          "minItems": 10,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "create_branch",
              "write_files",
              "collect_actual_diff",
              "execute_commands",
              "run_tests",
              "open_pr",
              "append_receipt_store",
              "call_connector",
              "deploy",
              "dns_mutation",
              "secret_mutation",
              "destructive_operation",
              "terminal_closure"
            ]
          }
        },
        "allowed_file_change_kinds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "schema_patch",
              "example_patch",
              "validator_patch",
              "test_patch",
              "documentation_patch",
              "ci_patch",
              "governance_preflight_patch"
            ]
          }
        },
        "required_before_collection_refs": { "$ref": "#/$defs/evidence_ref_list" },
        "required_validation_refs": { "$ref": "#/$defs/evidence_ref_list" },
        "planned_collection_only": { "type": "boolean", "const": true },
        "file_change_summary_required_after_collection": { "type": "boolean", "const": true },
        "diff_receipt_required_after_collection": { "type": "boolean", "const": true }
      }
    },
    "authority_gates": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workspace_sandbox_preflight_verified",
        "branch_write_authority_binding_verified",
        "branch_write_authority_collected",
        "operator_approval_collected",
        "cleanup_receipt_emitted",
        "workspace_write_authority_granted",
        "collection_admitted",
        "blocked_reason_refs"
      ],
      "properties": {
        "workspace_sandbox_preflight_verified": { "type": "boolean", "const": true },
        "branch_write_authority_binding_verified": { "type": "boolean", "const": true },
        "branch_write_authority_collected": { "type": "boolean", "const": false },
        "operator_approval_collected": { "type": "boolean", "const": false },
        "cleanup_receipt_emitted": { "type": "boolean", "const": false },
        "workspace_write_authority_granted": { "type": "boolean", "const": false },
        "collection_admitted": { "type": "boolean", "const": false },
        "blocked_reason_refs": { "$ref": "#/$defs/evidence_ref_list" }
      }
    },
    "path_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path_allowlist",
        "path_allowlist_bound_to_workspace_sandbox",
        "absolute_paths_allowed",
        "parent_traversal_allowed",
        "secret_paths_allowed",
        "production_paths_allowed"
      ],
      "properties": {
        "path_allowlist": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "path_allowlist_bound_to_workspace_sandbox": { "type": "boolean", "const": true },
        "absolute_paths_allowed": { "type": "boolean", "const": false },
        "parent_traversal_allowed": { "type": "boolean", "const": false },
        "secret_paths_allowed": { "type": "boolean", "const": false },
        "production_paths_allowed": { "type": "boolean", "const": false }
      }
    },
    "redaction_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "secret_redaction_required",
        "diff_redaction_required",
        "credential_value_serialization_allowed",
        "raw_secret_path_serialization_allowed",
        "redaction_evidence_ref"
      ],
      "properties": {
        "secret_redaction_required": { "type": "boolean", "const": true },
        "diff_redaction_required": { "type": "boolean", "const": true },
        "credential_value_serialization_allowed": { "type": "boolean", "const": false },
        "raw_secret_path_serialization_allowed": { "type": "boolean", "const": false },
        "redaction_evidence_ref": { "$ref": "#/$defs/evidence_ref" }
      }
    },
    "effect_denials": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "branch_created",
        "files_written",
        "actual_diff_collected",
        "file_change_summary_emitted",
        "commands_executed",
        "tests_executed",
        "cleanup_executed",
        "pull_request_opened",
        "runtime_state_written",
        "receipt_store_appended",
        "connector_calls_observed",
        "external_effects_observed",
        "secret_values_serialized",
        "terminal_closure",
        "success_claim_allowed"
      ],
      "properties": {
        "branch_created": { "type": "boolean", "const": false },
        "files_written": { "type": "boolean", "const": false },
        "actual_diff_collected": { "type": "boolean", "const": false },
        "file_change_summary_emitted": { "type": "boolean", "const": false },
        "commands_executed": { "type": "boolean", "const": false },
        "tests_executed": { "type": "boolean", "const": false },
        "cleanup_executed": { "type": "boolean", "const": false },
        "pull_request_opened": { "type": "boolean", "const": false },
        "runtime_state_written": { "type": "boolean", "const": false },
        "receipt_store_appended": { "type": "boolean", "const": false },
        "connector_calls_observed": { "type": "boolean", "const": false },
        "external_effects_observed": { "type": "boolean", "const": false },
        "secret_values_serialized": { "type": "boolean", "const": false },
        "terminal_closure": { "type": "boolean", "const": false },
        "success_claim_allowed": { "type": "boolean", "const": false }
      }
    },
    "receipt_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "planned_file_change_collection_preflight_schema",
        "workspace_sandbox_preflight_schema",
        "workspace_sandbox_preflight_example",
        "github_pr_branch_write_authority_binding_schema",
        "github_pr_branch_write_authority_binding_example",
        "agentic_service_harness_schema",
        "cleanup_receipt_ref"
      ],
      "properties": {
        "planned_file_change_collection_preflight_schema": {
          "type": "string",
          "const": "schemas/agentic_service_harness_planned_file_change_collection_preflight.schema.json"
        },
        "workspace_sandbox_preflight_schema": {
          "type": "string",
          "const": "schemas/agentic_service_harness_workspace_sandbox_preflight.schema.json"
        },
        "workspace_sandbox_preflight_example": {
          "type": "string",
          "const": "examples/agentic_service_harness_workspace_sandbox_preflight.foundation.json"
        },
        "github_pr_branch_write_authority_binding_schema": {
          "type": "string",
          "const": "schemas/agentic_service_harness_github_pr_branch_write_authority_binding.schema.json"
        },
        "github_pr_branch_write_authority_binding_example": {
          "type": "string",
          "const": "examples/agentic_service_harness_github_pr_branch_write_authority_binding.foundation.json"
        },
        "agentic_service_harness_schema": {
          "type": "string",
          "const": "schemas/agentic_service_harness.schema.json"
        },
        "cleanup_receipt_ref": { "$ref": "#/$defs/evidence_ref" }
      }
    },
    "validator_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "validator_id",
        "command",
        "required_for_closure"
      ],
      "properties": {
        "validator_id": { "$ref": "#/$defs/identifier" },
        "command": { "type": "string", "minLength": 1 },
        "required_for_closure": { "type": "boolean", "const": true }
      }
    }
  }
}
