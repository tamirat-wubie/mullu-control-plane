{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:evidence-ledger-foundation-source:1",
  "title": "Evidence Ledger Foundation Source",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "source_id",
    "source_version",
    "foundation_mode",
    "repository_local_source",
    "source_is_not_live_evidence",
    "source_is_not_write_path",
    "source_is_not_terminal_closure",
    "observed_at",
    "claim",
    "source_authorities",
    "evidence_records"
  ],
  "properties": {
    "source_id": { "$ref": "#/$defs/identifier" },
    "source_version": { "type": "integer", "const": 1 },
    "foundation_mode": { "type": "boolean", "const": true },
    "repository_local_source": { "type": "boolean", "const": true },
    "source_is_not_live_evidence": { "type": "boolean", "const": true },
    "source_is_not_write_path": { "type": "boolean", "const": true },
    "source_is_not_terminal_closure": { "type": "boolean", "const": true },
    "observed_at": { "$ref": "#/$defs/timestamp" },
    "claim": { "$ref": "#/$defs/claim" },
    "source_authorities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/source_authority" }
    },
    "evidence_records": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/evidence_record" }
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "reference": {
      "type": "string",
      "minLength": 1,
      "maxLength": 260,
      "pattern": "^foundation://[A-Za-z0-9._:/-]+$"
    },
    "short_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 260
    },
    "timestamp": {
      "type": "string",
      "minLength": 20,
      "maxLength": 40,
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:Z|[+-][0-9]{2}:[0-9]{2})$"
    },
    "evidence_kind": {
      "type": "string",
      "enum": [
        "document",
        "email",
        "transaction",
        "api_response",
        "log",
        "sensor_reading",
        "human_statement",
        "raw_evidence",
        "extracted_evidence",
        "interpreted_evidence",
        "derived_evidence",
        "judgment_evidence",
        "negative_evidence"
      ]
    },
    "symbolic_object": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "anyOf": [
          { "type": "string", "maxLength": 260 },
          { "type": "number" },
          { "type": "integer" },
          { "type": "boolean" },
          { "type": "null" },
          {
            "type": "array",
            "maxItems": 20,
            "items": {
              "anyOf": [
                { "type": "string", "maxLength": 260 },
                { "type": "number" },
                { "type": "integer" },
                { "type": "boolean" },
                { "type": "null" }
              ]
            }
          }
        ]
      }
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim_id",
        "claim_type",
        "proposition",
        "subject",
        "scope",
        "temporal_scope",
        "expiration_policy",
        "expected_evidence_profile"
      ],
      "properties": {
        "claim_id": { "$ref": "#/$defs/identifier" },
        "claim_type": { "$ref": "#/$defs/identifier" },
        "proposition": { "$ref": "#/$defs/short_text" },
        "subject": { "$ref": "#/$defs/identifier" },
        "scope": { "$ref": "#/$defs/symbolic_object" },
        "temporal_scope": { "$ref": "#/$defs/symbolic_object" },
        "expiration_policy": { "$ref": "#/$defs/symbolic_object" },
        "expected_evidence_profile": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "required_evidence_kinds",
            "minimum_independent_sources",
            "freshness_window_days"
          ],
          "properties": {
            "required_evidence_kinds": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": { "$ref": "#/$defs/evidence_kind" }
            },
            "optional_evidence_kinds": {
              "type": "array",
              "uniqueItems": true,
              "items": { "$ref": "#/$defs/evidence_kind" }
            },
            "blocking_absences": {
              "type": "array",
              "uniqueItems": true,
              "items": { "$ref": "#/$defs/evidence_kind" }
            },
            "minimum_independent_sources": {
              "type": "integer",
              "minimum": 1,
              "maximum": 20
            },
            "freshness_window_days": {
              "type": "integer",
              "minimum": 0,
              "maximum": 3660
            }
          }
        }
      }
    },
    "source_authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "source_type",
        "authority_domains",
        "forbidden_domains",
        "reliability_score",
        "verification_method",
        "last_verified_at",
        "authority_scope"
      ],
      "properties": {
        "source_id": { "$ref": "#/$defs/identifier" },
        "source_type": { "$ref": "#/$defs/identifier" },
        "authority_domains": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/identifier" }
        },
        "forbidden_domains": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/identifier" }
        },
        "reliability_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "verification_method": { "$ref": "#/$defs/identifier" },
        "last_verified_at": { "$ref": "#/$defs/timestamp" },
        "authority_scope": { "$ref": "#/$defs/short_text" }
      }
    },
    "evidence_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_kind",
        "source_id",
        "observer_id",
        "capture_method",
        "observed_at",
        "ontology_type",
        "authority_domain",
        "sensitivity_level",
        "raw_reference",
        "canonical_reference",
        "raw_payload",
        "canonical_payload"
      ],
      "properties": {
        "evidence_kind": { "$ref": "#/$defs/evidence_kind" },
        "source_id": { "$ref": "#/$defs/identifier" },
        "observer_id": { "$ref": "#/$defs/identifier" },
        "capture_method": { "$ref": "#/$defs/identifier" },
        "observed_at": { "$ref": "#/$defs/timestamp" },
        "ontology_type": { "$ref": "#/$defs/identifier" },
        "authority_domain": { "$ref": "#/$defs/identifier" },
        "sensitivity_level": {
          "type": "string",
          "enum": ["public", "internal", "restricted"]
        },
        "raw_reference": { "$ref": "#/$defs/reference" },
        "canonical_reference": { "$ref": "#/$defs/reference" },
        "raw_payload": { "$ref": "#/$defs/symbolic_object" },
        "canonical_payload": { "$ref": "#/$defs/symbolic_object" }
      }
    }
  }
}
