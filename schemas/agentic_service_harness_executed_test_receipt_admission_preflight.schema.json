{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:agentic-service-harness-executed-test-receipt-admission-preflight:1",
  "title": "Agentic Service Harness Executed Test Receipt Admission Preflight",
  "description": "Foundation Mode admission preflight for future executed-test receipts. This contract binds the dry-run test runner plan, approved branch workspace preflight, and receipt-store append preflight while keeping command execution, subprocess execution, test result claims, coverage claims, receipt append, runtime state writes, mutation routes, raw output storage, secret serialization, and terminal closure blocked.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "report_id",
    "schema_version",
    "generated_at",
    "solver_outcome",
    "admission_status",
    "source_contract_refs",
    "scope",
    "test_execution_admission",
    "executed_test_receipt_contract",
    "authority_denials",
    "validators",
    "next_action",
    "report_is_not_terminal_closure",
    "terminal_closure_required"
  ],
  "properties": {
    "report_id": {
      "type": "string",
      "const": "agentic_service_harness_executed_test_receipt_admission_preflight"
    },
    "schema_version": { "type": "integer", "const": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "solver_outcome": { "type": "string", "const": "SolvedVerified" },
    "admission_status": { "type": "string", "const": "AwaitingEvidence" },
    "source_contract_refs": {
      "type": "array",
      "minItems": 6,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/evidence_ref" }
    },
    "scope": { "$ref": "#/$defs/scope" },
    "test_execution_admission": { "$ref": "#/$defs/test_execution_admission" },
    "executed_test_receipt_contract": { "$ref": "#/$defs/executed_test_receipt_contract" },
    "authority_denials": { "$ref": "#/$defs/authority_denials" },
    "validators": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/validator_ref" }
    },
    "next_action": { "type": "string", "minLength": 1 },
    "report_is_not_terminal_closure": { "type": "boolean", "const": true },
    "terminal_closure_required": { "type": "boolean", "const": true }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "evidence_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/#$-]*$"
    },
    "evidence_ref_list": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/evidence_ref" }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tenant_id",
        "organization_id",
        "project_id",
        "repository_connection_id",
        "repository_slug",
        "agent_run_id",
        "dry_run_test_runner_plan_id",
        "receipt_store_append_preflight_id",
        "foundation_phase",
        "admission_only",
        "read_only_sources",
        "test_execution_admitted",
        "commands_executed",
        "test_results_claimed",
        "executed_test_receipt_admitted",
        "receipt_store_append_enabled",
        "secret_values_serialized"
      ],
      "properties": {
        "tenant_id": { "$ref": "#/$defs/identifier" },
        "organization_id": { "$ref": "#/$defs/identifier" },
        "project_id": { "$ref": "#/$defs/identifier" },
        "repository_connection_id": { "$ref": "#/$defs/identifier" },
        "repository_slug": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
        },
        "agent_run_id": { "$ref": "#/$defs/identifier" },
        "dry_run_test_runner_plan_id": { "$ref": "#/$defs/identifier" },
        "receipt_store_append_preflight_id": { "$ref": "#/$defs/identifier" },
        "foundation_phase": {
          "type": "string",
          "const": "foundation_executed_test_receipt_admission_preflight"
        },
        "admission_only": { "type": "boolean", "const": true },
        "read_only_sources": { "type": "boolean", "const": true },
        "test_execution_admitted": { "type": "boolean", "const": false },
        "commands_executed": { "type": "boolean", "const": false },
        "test_results_claimed": { "type": "boolean", "const": false },
        "executed_test_receipt_admitted": { "type": "boolean", "const": false },
        "receipt_store_append_enabled": { "type": "boolean", "const": false },
        "secret_values_serialized": { "type": "boolean", "const": false }
      }
    },
    "test_execution_admission": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requested_action",
        "requested_route_ref",
        "admission_decision",
        "dry_run_test_runner_plan_valid",
        "approved_branch_workspace_preflight_valid",
        "receipt_store_append_preflight_valid",
        "operator_approval_collected",
        "live_workspace_created",
        "command_timeout_policy_valid",
        "subprocess_redaction_policy_valid",
        "command_execution_performed",
        "exit_code_observed",
        "test_output_redacted",
        "coverage_claimed",
        "receipt_store_append_admitted",
        "executed_test_receipt_admitted",
        "required_before_execution_refs",
        "blocked_reason_refs",
        "next_required_evidence_refs"
      ],
      "properties": {
        "requested_action": {
          "type": "string",
          "const": "admit_executed_test_receipt"
        },
        "requested_route_ref": {
          "type": "string",
          "const": "route://harness/tests/executed-receipt/not-admitted"
        },
        "admission_decision": {
          "type": "string",
          "const": "BLOCKED_PENDING_APPROVED_WORKSPACE_COMMAND_EXECUTION_AND_RESULT_EVIDENCE"
        },
        "dry_run_test_runner_plan_valid": { "type": "boolean", "const": true },
        "approved_branch_workspace_preflight_valid": { "type": "boolean", "const": true },
        "receipt_store_append_preflight_valid": { "type": "boolean", "const": true },
        "operator_approval_collected": { "type": "boolean", "const": false },
        "live_workspace_created": { "type": "boolean", "const": false },
        "command_timeout_policy_valid": { "type": "boolean", "const": false },
        "subprocess_redaction_policy_valid": { "type": "boolean", "const": false },
        "command_execution_performed": { "type": "boolean", "const": false },
        "exit_code_observed": { "type": "boolean", "const": false },
        "test_output_redacted": { "type": "boolean", "const": false },
        "coverage_claimed": { "type": "boolean", "const": false },
        "receipt_store_append_admitted": { "type": "boolean", "const": false },
        "executed_test_receipt_admitted": { "type": "boolean", "const": false },
        "required_before_execution_refs": { "$ref": "#/$defs/evidence_ref_list" },
        "blocked_reason_refs": { "$ref": "#/$defs/evidence_ref_list" },
        "next_required_evidence_refs": { "$ref": "#/$defs/evidence_ref_list" }
      }
    },
    "executed_test_receipt_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_shape_ref",
        "allowed_metadata_refs",
        "forbidden_inline_fields",
        "test_result_claimed",
        "stored_receipt_ref"
      ],
      "properties": {
        "receipt_shape_ref": { "$ref": "#/$defs/evidence_ref" },
        "allowed_metadata_refs": { "$ref": "#/$defs/evidence_ref_list" },
        "forbidden_inline_fields": { "$ref": "#/$defs/evidence_ref_list" },
        "test_result_claimed": { "type": "boolean", "const": false },
        "stored_receipt_ref": {
          "type": "string",
          "const": "executed-test-receipt://not-admitted"
        }
      }
    },
    "authority_denials": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "test_execution_enabled",
        "command_execution_enabled",
        "subprocess_execution_enabled",
        "test_result_claim_enabled",
        "coverage_claim_enabled",
        "receipt_store_append_enabled",
        "receipt_store_append_performed",
        "runtime_state_write_enabled",
        "filesystem_write_enabled",
        "branch_write_enabled",
        "adapter_execution_enabled",
        "connector_calls_enabled",
        "mutation_route_enabled",
        "raw_test_output_stored",
        "secret_values_serialized",
        "terminal_closure",
        "default_high_risk_authority"
      ],
      "properties": {
        "test_execution_enabled": { "type": "boolean", "const": false },
        "command_execution_enabled": { "type": "boolean", "const": false },
        "subprocess_execution_enabled": { "type": "boolean", "const": false },
        "test_result_claim_enabled": { "type": "boolean", "const": false },
        "coverage_claim_enabled": { "type": "boolean", "const": false },
        "receipt_store_append_enabled": { "type": "boolean", "const": false },
        "receipt_store_append_performed": { "type": "boolean", "const": false },
        "runtime_state_write_enabled": { "type": "boolean", "const": false },
        "filesystem_write_enabled": { "type": "boolean", "const": false },
        "branch_write_enabled": { "type": "boolean", "const": false },
        "adapter_execution_enabled": { "type": "boolean", "const": false },
        "connector_calls_enabled": { "type": "boolean", "const": false },
        "mutation_route_enabled": { "type": "boolean", "const": false },
        "raw_test_output_stored": { "type": "boolean", "const": false },
        "secret_values_serialized": { "type": "boolean", "const": false },
        "terminal_closure": { "type": "boolean", "const": false },
        "default_high_risk_authority": { "type": "boolean", "const": false }
      }
    },
    "validator_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["validator_id", "command", "required_for_closure"],
      "properties": {
        "validator_id": { "type": "string", "minLength": 1 },
        "command": { "type": "string", "minLength": 1 },
        "required_for_closure": { "type": "boolean", "const": true }
      }
    }
  }
}
