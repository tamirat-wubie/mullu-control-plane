{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:github-check-run-write-receipt:1",
  "title": "GitHub Check Run Write Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receipt_id",
    "request_id",
    "tenant_id",
    "actor_id",
    "command_id",
    "mode",
    "status",
    "repository_owner",
    "repository_name",
    "head_sha",
    "check_name",
    "check_status",
    "conclusion",
    "endpoint",
    "method",
    "request_payload",
    "request_payload_hash",
    "installation_id",
    "approval_ref",
    "execution_receipt_ref",
    "response_check_run_id",
    "response_payload_hash",
    "blocked_reasons",
    "required_controls",
    "evidence_refs",
    "receipt_schema_ref",
    "terminal_closure_required",
    "external_write_admitted",
    "network_call_performed",
    "request_authentication_performed",
    "receipt_hash",
    "metadata"
  ],
  "properties": {
    "receipt_id": {
      "type": "string",
      "pattern": "^github-check-run-write-receipt-[0-9a-f]{16}$"
    },
    "request_id": {"type": "string", "minLength": 1},
    "tenant_id": {"type": "string", "minLength": 1},
    "actor_id": {"type": "string", "minLength": 1},
    "command_id": {"type": "string", "minLength": 1},
    "mode": {
      "type": "string",
      "enum": ["plan_only", "dry_run", "write_approved"]
    },
    "status": {
      "type": "string",
      "enum": ["planned", "dry_run_accepted", "write_receipt_bound", "blocked"]
    },
    "repository_owner": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9_.-]+$"
    },
    "repository_name": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9_.-]+$"
    },
    "head_sha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "check_name": {"type": "string", "minLength": 1},
    "check_status": {
      "type": "string",
      "enum": ["queued", "in_progress", "completed"]
    },
    "conclusion": {
      "type": "string",
      "enum": ["", "action_required", "cancelled", "failure", "neutral", "success", "skipped", "stale", "timed_out"]
    },
    "endpoint": {
      "type": "string",
      "pattern": "^/repos/[^/]+/[^/]+/check-runs$"
    },
    "method": {"type": "string", "const": "POST"},
    "request_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "head_sha", "status", "output"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "head_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "status": {"type": "string", "enum": ["queued", "in_progress", "completed"]},
        "conclusion": {
          "type": "string",
          "enum": ["action_required", "cancelled", "failure", "neutral", "success", "skipped", "stale", "timed_out"]
        },
        "details_url": {"type": "string"},
        "external_id": {"type": "string"},
        "output": {
          "type": "object",
          "additionalProperties": false,
          "required": ["title", "summary"],
          "properties": {
            "title": {"type": "string", "minLength": 1},
            "summary": {"type": "string", "minLength": 1},
            "text": {"type": "string"}
          }
        }
      }
    },
    "request_payload_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "installation_id": {
      "type": "string",
      "pattern": "^$|^[0-9]+$"
    },
    "approval_ref": {"type": "string"},
    "execution_receipt_ref": {"type": "string"},
    "response_check_run_id": {
      "type": "string",
      "pattern": "^$|^[0-9]+$"
    },
    "response_payload_hash": {
      "type": "string",
      "pattern": "^$|^sha256:[0-9a-f]{64}$"
    },
    "blocked_reasons": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "required_controls": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "evidence_refs": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "receipt_schema_ref": {
      "type": "string",
      "const": "urn:mullusi:schema:github-check-run-write-receipt:1"
    },
    "terminal_closure_required": {"type": "boolean", "const": true},
    "external_write_admitted": {"type": "boolean"},
    "network_call_performed": {"type": "boolean", "const": false},
    "request_authentication_performed": {"type": "boolean", "const": false},
    "receipt_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "receipt_is_not_terminal_closure",
        "github_api_not_called",
        "request_authentication_not_performed",
        "external_write_admitted",
        "payload_hash_bound",
        "secret_absence_verified"
      ],
      "properties": {
        "receipt_is_not_terminal_closure": {"type": "boolean", "const": true},
        "github_api_not_called": {"type": "boolean", "const": true},
        "request_authentication_not_performed": {"type": "boolean", "const": true},
        "external_write_admitted": {"type": "boolean"},
        "payload_hash_bound": {"type": "boolean", "const": true},
        "secret_absence_verified": {"type": "boolean"}
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {"status": {"const": "blocked"}},
        "required": ["status"]
      },
      "then": {
        "properties": {
          "blocked_reasons": {"minItems": 1},
          "external_write_admitted": {"const": false},
          "metadata": {
            "properties": {
              "external_write_admitted": {"const": false}
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {"status": {"const": "planned"}},
        "required": ["status"]
      },
      "then": {
        "properties": {
          "mode": {"const": "plan_only"},
          "status": {"enum": ["planned", "blocked"]},
          "external_write_admitted": {"const": false},
          "execution_receipt_ref": {"maxLength": 0},
          "response_check_run_id": {"maxLength": 0},
          "response_payload_hash": {"maxLength": 0}
        }
      }
    },
    {
      "if": {
        "properties": {"status": {"const": "dry_run_accepted"}},
        "required": ["status"]
      },
      "then": {
        "properties": {
          "mode": {"const": "dry_run"},
          "status": {"enum": ["dry_run_accepted", "blocked"]},
          "external_write_admitted": {"const": false},
          "execution_receipt_ref": {"maxLength": 0},
          "response_check_run_id": {"maxLength": 0},
          "response_payload_hash": {"maxLength": 0}
        }
      }
    },
    {
      "if": {
        "properties": {"status": {"const": "write_receipt_bound"}},
        "required": ["status"]
      },
      "then": {
        "properties": {
          "mode": {"const": "write_approved"},
          "approval_ref": {"minLength": 1},
          "installation_id": {"minLength": 1},
          "execution_receipt_ref": {"minLength": 1},
          "response_check_run_id": {"minLength": 1},
          "response_payload_hash": {
            "pattern": "^sha256:[0-9a-f]{64}$"
          },
          "blocked_reasons": {"maxItems": 0},
          "external_write_admitted": {"const": true},
          "metadata": {
            "properties": {
              "external_write_admitted": {"const": true},
              "secret_absence_verified": {"const": true}
            }
          }
        }
      }
    }
  ]
}
