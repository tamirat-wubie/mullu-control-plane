{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:personal-assistant-receipt:1",
  "title": "Personal Assistant Receipt",
  "description": "Redacted evidence receipt for personal-assistant planning, preview, draft, approval, or blocked action outcomes.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receipt_id",
    "request_id",
    "skill_id",
    "mode",
    "risk_level",
    "inputs_used",
    "connectors_used",
    "decision",
    "approval_required",
    "approval_ref",
    "actions_taken",
    "actions_not_taken",
    "redactions",
    "private_payload_policy",
    "timestamp",
    "evidence_refs",
    "memory_observation_refs",
    "replay_refs",
    "outcome",
    "metadata"
  ],
  "properties": {
    "receipt_id": { "type": "string", "pattern": "^pa_receipt_[a-z0-9][a-z0-9_:-]*$" },
    "request_id": { "type": "string", "pattern": "^pa_request_[a-z0-9][a-z0-9_:-]*$" },
    "skill_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*(\\.[a-z0-9_]+)+$" },
    "mode": { "type": "string", "enum": ["dry_run", "preview", "draft", "execute_with_approval", "blocked", "read_and_draft_only"] },
    "risk_level": { "type": "string", "enum": ["P0", "P1", "P2", "P3", "P4", "P5"] },
    "inputs_used": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "connectors_used": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "decision": { "type": "string", "enum": ["allowed", "blocked", "deferred", "approval_required"] },
    "approval_required": { "type": "boolean" },
    "approval_ref": { "type": "string" },
    "actions_taken": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "actions_not_taken": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "redactions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "private_payload_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raw_private_payload_serialized",
        "secret_values_serialized",
        "connector_payload_projection",
        "body_projection"
      ],
      "properties": {
        "raw_private_payload_serialized": { "type": "boolean", "const": false },
        "secret_values_serialized": { "type": "boolean", "const": false },
        "connector_payload_projection": { "type": "string", "enum": ["digest_only", "ref_only", "redacted_summary", "public_only", "no_connector_payload"] },
        "body_projection": { "type": "string", "enum": ["none", "digest_only", "redacted_summary", "operator_visible_draft"] }
      }
    },
    "timestamp": { "type": "string", "format": "date-time" },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "memory_observation_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "replay_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "outcome": {
      "type": "string",
      "enum": ["SolvedVerified", "SolvedUnverified", "AwaitingEvidence", "SafeHalt", "GovernanceBlocked", "BudgetExhausted", "ImpossibleProved", "ModelInvalidated"]
    },
    "metadata": { "type": "object", "additionalProperties": true }
  }
}
