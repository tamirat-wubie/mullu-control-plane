{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:read-only-worker-runtime-status-read-model:1",
  "title": "Read-Only Worker Runtime Status Read Model",
  "description": "Read-only Foundation Mode projection that answers whether the read-only worker runtime chain is intentionally closed or still awaiting runtime authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "read_model_id",
    "read_model_version",
    "source_closure_summary_ref",
    "projection_scope",
    "operator_status",
    "runtime_status",
    "authority_denials",
    "chain_refs",
    "evidence_refs",
    "summary",
    "next_action"
  ],
  "properties": {
    "read_model_id": {
      "const": "read-only-worker-runtime-status-read-model-foundation"
    },
    "read_model_version": {
      "const": "read_only_worker_runtime_status_read_model.v1"
    },
    "source_closure_summary_ref": {
      "const": "examples/read_only_worker_runtime_foundation_closure_summary.foundation.json"
    },
    "projection_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "projection_mode",
        "fixture_projection",
        "live_runtime_observed",
        "source_fixture_read_performed",
        "source_runtime_invocation_performed",
        "raw_secret_values_included"
      ],
      "properties": {
        "projection_mode": {"const": "FOUNDATION_STATUS_PROJECTION"},
        "fixture_projection": {"type": "boolean", "const": true},
        "live_runtime_observed": {"type": "boolean", "const": false},
        "source_fixture_read_performed": {"type": "boolean", "const": true},
        "source_runtime_invocation_performed": {"type": "boolean", "const": false},
        "raw_secret_values_included": {"type": "boolean", "const": false}
      }
    },
    "operator_status": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "headline",
        "solver_outcome",
        "proof_state",
        "foundation_closure_complete",
        "live_runtime_blocked",
        "status_reason"
      ],
      "properties": {
        "headline": {"const": "Foundation Mode worker runtime is closed with live runtime blocked."},
        "solver_outcome": {"const": "SolvedVerified"},
        "proof_state": {"const": "Pass"},
        "foundation_closure_complete": {"type": "boolean", "const": true},
        "live_runtime_blocked": {"type": "boolean", "const": true},
        "status_reason": {"const": "Evidence is accepted for the Foundation proof thread, but admission, promotion, enablement, dispatch, invocation, and receipt writes remain denied."}
      }
    },
    "runtime_status": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_acceptance_state",
        "runtime_admission_state",
        "runtime_promotion_state",
        "runtime_enablement_state",
        "runtime_dispatch_state",
        "receipt_append_state",
        "terminal_closure_state"
      ],
      "properties": {
        "evidence_acceptance_state": {"const": "accepted_for_foundation_review"},
        "runtime_admission_state": {"const": "denied"},
        "runtime_promotion_state": {"const": "denied_foundation_mode"},
        "runtime_enablement_state": {"const": "not_executed"},
        "runtime_dispatch_state": {"const": "denied"},
        "receipt_append_state": {"const": "denied"},
        "terminal_closure_state": {"const": "foundation_closed_not_live_terminal_closure"}
      }
    },
    "authority_denials": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime_admission_allowed",
        "runtime_promotion_allowed",
        "runtime_enablement_allowed",
        "runtime_dispatch_allowed",
        "worker_invocation_allowed",
        "runtime_receipt_emission_allowed",
        "receipt_append_allowed",
        "terminal_live_closure_allowed",
        "connector_authority_allowed",
        "filesystem_write_allowed",
        "external_network_allowed",
        "secret_values_serialized",
        "success_claim_allowed",
        "mfidel_atomicity_preserved"
      ],
      "properties": {
        "runtime_admission_allowed": {"type": "boolean", "const": false},
        "runtime_promotion_allowed": {"type": "boolean", "const": false},
        "runtime_enablement_allowed": {"type": "boolean", "const": false},
        "runtime_dispatch_allowed": {"type": "boolean", "const": false},
        "worker_invocation_allowed": {"type": "boolean", "const": false},
        "runtime_receipt_emission_allowed": {"type": "boolean", "const": false},
        "receipt_append_allowed": {"type": "boolean", "const": false},
        "terminal_live_closure_allowed": {"type": "boolean", "const": false},
        "connector_authority_allowed": {"type": "boolean", "const": false},
        "filesystem_write_allowed": {"type": "boolean", "const": false},
        "external_network_allowed": {"type": "boolean", "const": false},
        "secret_values_serialized": {"type": "boolean", "const": false},
        "success_claim_allowed": {"type": "boolean", "const": false},
        "mfidel_atomicity_preserved": {"type": "boolean", "const": true}
      }
    },
    "chain_refs": {"$ref": "#/$defs/non_empty_string_array"},
    "evidence_refs": {"$ref": "#/$defs/non_empty_string_array"},
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "chain_ref_count",
        "accepted_evidence_ref_count",
        "blocked_authority_count",
        "runtime_enablement_count",
        "runtime_dispatch_count",
        "receipt_append_count",
        "terminal_live_closure_count"
      ],
      "properties": {
        "chain_ref_count": {"type": "integer", "minimum": 1},
        "accepted_evidence_ref_count": {"type": "integer", "minimum": 1},
        "blocked_authority_count": {"type": "integer", "minimum": 1},
        "runtime_enablement_count": {"type": "integer", "const": 0},
        "runtime_dispatch_count": {"type": "integer", "const": 0},
        "receipt_append_count": {"type": "integer", "const": 0},
        "terminal_live_closure_count": {"type": "integer", "const": 0}
      }
    },
    "next_action": {
      "const": "No runtime action in Foundation Mode; open a separate non-Foundation authority thread only if live runtime is explicitly requested."
    }
  },
  "$defs": {
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    }
  }
}
