{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:browser-submit-approval-rehearsal-packet:1",
  "title": "Browser Submit Approval Rehearsal Packet",
  "description": "Public-safe, no-effect rehearsal packet for browser.submit approval evidence before any live form submission authority is granted.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receipt_id",
    "schema_version",
    "prepared_at",
    "workflow_id",
    "capability_id",
    "status",
    "solver_outcome",
    "proof_state",
    "approval_decision_ready",
    "approval_decision_valid",
    "approval_id",
    "decision",
    "source_approval_decision_ref",
    "source_browser_observation_ref",
    "source_url_hash",
    "target_selector_hash",
    "form_payload_hash",
    "browser_submit_ready",
    "browser_submit_authorized_by_decision",
    "requires_separate_submit_execution_receipt",
    "no_secret_values_serialized",
    "blocked_until",
    "evidence_refs",
    "validation_commands",
    "form_submit_performed",
    "navigation_performed",
    "click_performed",
    "keystroke_injection_performed",
    "external_write_performed",
    "connector_mutation_performed",
    "system_of_record_write_performed",
    "raw_url_serialized",
    "raw_selector_serialized",
    "raw_form_payload_serialized",
    "raw_field_name_serialized",
    "raw_field_value_serialized",
    "cookie_or_session_read",
    "secret_value_serialized"
  ],
  "properties": {
    "receipt_id": {"type": "string", "pattern": "^browser_submit_rehearsal_[0-9a-f]{16}$"},
    "schema_version": {"const": 1},
    "prepared_at": {"type": "string", "format": "date-time"},
    "workflow_id": {"const": "browser.submit.with_approval"},
    "capability_id": {"const": "browser.submit"},
    "status": {"enum": ["blocked", "failed", "passed"]},
    "solver_outcome": {"enum": ["AwaitingEvidence", "GovernanceBlocked", "SolvedVerified"]},
    "proof_state": {"enum": ["Unknown", "Fail", "Pass"]},
    "approval_decision_ready": {"type": "boolean"},
    "approval_decision_valid": {"type": "boolean"},
    "approval_id": {"type": "string", "minLength": 1},
    "decision": {"enum": ["approved", "denied", "pending"]},
    "source_approval_decision_ref": {"type": "string", "minLength": 1},
    "source_browser_observation_ref": {"type": "string", "minLength": 1},
    "source_url_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "target_selector_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "form_payload_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "browser_submit_ready": {"type": "boolean"},
    "browser_submit_authorized_by_decision": {"type": "boolean"},
    "requires_separate_submit_execution_receipt": {"type": "boolean"},
    "no_secret_values_serialized": {"type": "boolean"},
    "blocked_until": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "validation_commands": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "form_submit_performed": {"type": "boolean"},
    "navigation_performed": {"type": "boolean"},
    "click_performed": {"type": "boolean"},
    "keystroke_injection_performed": {"type": "boolean"},
    "external_write_performed": {"type": "boolean"},
    "connector_mutation_performed": {"type": "boolean"},
    "system_of_record_write_performed": {"type": "boolean"},
    "raw_url_serialized": {"type": "boolean"},
    "raw_selector_serialized": {"type": "boolean"},
    "raw_form_payload_serialized": {"type": "boolean"},
    "raw_field_name_serialized": {"type": "boolean"},
    "raw_field_value_serialized": {"type": "boolean"},
    "cookie_or_session_read": {"type": "boolean"},
    "secret_value_serialized": {"type": "boolean"}
  }
}
