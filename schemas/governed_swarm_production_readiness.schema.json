{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:governed-swarm-production-readiness:1",
  "title": "Governed Swarm Production Readiness",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "readiness_id",
    "checked_at",
    "target_environment",
    "pilot_promotion_readiness_ref",
    "deployment_witness_ref",
    "public_health_declaration_ref",
    "control_plane_commit",
    "runtime_path",
    "audit_store_path",
    "public_health_endpoint",
    "ready",
    "readiness_level",
    "outcome",
    "checks",
    "blockers"
  ],
  "properties": {
    "readiness_id": {
      "type": "string",
      "pattern": "^governed-swarm-production-[0-9a-f]{16}$"
    },
    "checked_at": {
      "type": "string",
      "format": "date-time"
    },
    "target_environment": {
      "type": "string",
      "const": "production"
    },
    "pilot_promotion_readiness_ref": {
      "type": "string",
      "minLength": 1
    },
    "deployment_witness_ref": {
      "type": "string",
      "minLength": 1
    },
    "public_health_declaration_ref": {
      "type": "string",
      "minLength": 1
    },
    "control_plane_commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "runtime_path": {
      "type": "string",
      "pattern": "mcoi$"
    },
    "audit_store_path": {
      "type": "string",
      "minLength": 1
    },
    "public_health_endpoint": {
      "type": "string",
      "pattern": "^https://[^\\s]+/health$"
    },
    "ready": {
      "type": "boolean"
    },
    "readiness_level": {
      "type": "string",
      "enum": ["production-ready", "production-blocked"]
    },
    "outcome": {
      "type": "string",
      "enum": ["SolvedVerified", "AwaitingEvidence", "GovernanceBlocked"]
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/check"
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "passed", "detail"],
      "properties": {
        "name": {
          "type": "string",
          "enum": [
            "pilot_readiness_valid",
            "pilot_readiness_ready",
            "deployment_witness_valid",
            "deployment_witness_published",
            "runtime_environment_production",
            "deployment_health_passing",
            "runtime_responsibility_debt_clear",
            "authority_responsibility_debt_clear",
            "public_health_declaration_valid",
            "public_health_declaration_applied",
            "public_health_endpoint_match",
            "production_target_bound"
          ]
        },
        "passed": {
          "type": "boolean"
        },
        "detail": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
