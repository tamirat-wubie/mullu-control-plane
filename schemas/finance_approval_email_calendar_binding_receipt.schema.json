{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:finance-approval-email-calendar-binding-receipt:1",
  "title": "Finance Approval Email Calendar Binding Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "receipt_id",
    "checked_at",
    "secret_serialization",
    "ready",
    "accepted_binding_names",
    "present_binding_names",
    "required_binding_groups",
    "satisfied_binding_groups",
    "read_only_scope_witness_names",
    "invalid_scope_witness_names",
    "readiness_blockers",
    "binding_count",
    "bindings"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "receipt_id": {
      "type": "string",
      "pattern": "^finance-email-calendar-binding-receipt-[0-9a-f]{16}$"
    },
    "checked_at": {
      "type": "string",
      "format": "date-time"
    },
    "secret_serialization": {
      "type": "string",
      "const": "forbidden"
    },
    "ready": {
      "type": "boolean"
    },
    "accepted_binding_names": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "items": {
        "type": "string",
        "enum": [
          "MULLU_EMAIL_CALENDAR_WORKER_URL",
          "MULLU_EMAIL_CALENDAR_WORKER_SECRET",
          "EMAIL_CALENDAR_CONNECTOR_TOKEN",
          "GMAIL_ACCESS_TOKEN",
          "GOOGLE_CALENDAR_ACCESS_TOKEN",
          "MICROSOFT_GRAPH_ACCESS_TOKEN",
          "EMAIL_CALENDAR_CONNECTOR_SCOPE_ID",
          "GMAIL_SCOPE_ID",
          "GOOGLE_CALENDAR_SCOPE_ID",
          "MICROSOFT_GRAPH_SCOPE_ID"
        ]
      }
    },
    "present_binding_names": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "MULLU_EMAIL_CALENDAR_WORKER_URL",
          "MULLU_EMAIL_CALENDAR_WORKER_SECRET",
          "EMAIL_CALENDAR_CONNECTOR_TOKEN",
          "GMAIL_ACCESS_TOKEN",
          "GOOGLE_CALENDAR_ACCESS_TOKEN",
          "MICROSOFT_GRAPH_ACCESS_TOKEN",
          "EMAIL_CALENDAR_CONNECTOR_SCOPE_ID",
          "GMAIL_SCOPE_ID",
          "GOOGLE_CALENDAR_SCOPE_ID",
          "MICROSOFT_GRAPH_SCOPE_ID"
        ]
      }
    },
    "required_binding_groups": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "$ref": "#/$defs/binding_group"
      }
    },
    "satisfied_binding_groups": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/binding_group"
      }
    },
    "read_only_scope_witness_names": {
      "$ref": "#/$defs/scope_witness_name_array"
    },
    "invalid_scope_witness_names": {
      "$ref": "#/$defs/scope_witness_name_array"
    },
    "readiness_blockers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "binding_count": {
      "type": "integer",
      "const": 10
    },
    "bindings": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "present",
          "binding_kind",
          "binding_group",
          "risk",
          "approval_required",
          "receipt_projection",
          "value_serialized"
        ],
        "properties": {
          "name": {
            "type": "string",
            "enum": [
              "MULLU_EMAIL_CALENDAR_WORKER_URL",
              "MULLU_EMAIL_CALENDAR_WORKER_SECRET",
              "EMAIL_CALENDAR_CONNECTOR_TOKEN",
              "GMAIL_ACCESS_TOKEN",
              "GOOGLE_CALENDAR_ACCESS_TOKEN",
              "MICROSOFT_GRAPH_ACCESS_TOKEN",
              "EMAIL_CALENDAR_CONNECTOR_SCOPE_ID",
              "GMAIL_SCOPE_ID",
              "GOOGLE_CALENDAR_SCOPE_ID",
              "MICROSOFT_GRAPH_SCOPE_ID"
            ]
          },
          "present": {
            "type": "boolean"
          },
          "binding_kind": {
            "type": "string",
            "enum": [
              "endpoint",
              "secret",
              "scope_witness"
            ]
          },
          "binding_group": {
            "$ref": "#/$defs/binding_group"
          },
          "risk": {
            "type": "string",
            "const": "high"
          },
          "approval_required": {
            "type": "boolean",
            "const": true
          },
          "receipt_projection": {
            "type": "string",
            "const": "name_and_presence_only"
          },
          "value_serialized": {
            "type": "boolean",
            "const": false
          }
        }
      }
    }
  },
  "$defs": {
    "binding_group": {
      "type": "string",
      "enum": [
        "worker_endpoint",
        "worker_secret",
        "connector_token",
        "read_only_scope_witness"
      ]
    },
    "scope_witness_name_array": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "EMAIL_CALENDAR_CONNECTOR_SCOPE_ID",
          "GMAIL_SCOPE_ID",
          "GOOGLE_CALENDAR_SCOPE_ID",
          "MICROSOFT_GRAPH_SCOPE_ID"
        ]
      }
    }
  }
}
