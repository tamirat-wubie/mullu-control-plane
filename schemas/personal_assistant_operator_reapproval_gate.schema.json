{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:personal-assistant-operator-reapproval-gate:1",
  "title": "Personal Assistant Operator Reapproval Gate",
  "description": "Foundation Mode no-effect gate that records operator reapproval request and wait-state evidence after connector lease witness without authorizing execution-worker admission.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "gate_set_id",
    "generated_at",
    "governed",
    "source_projection",
    "source_connector_lease_witness_set_id",
    "gate_count",
    "gate_ids",
    "source_witness_ids",
    "receipt_ids",
    "gates",
    "effect_boundary",
    "private_payload_policy",
    "assurance",
    "metadata"
  ],
  "properties": {
    "gate_set_id": {"type": "string", "pattern": "^pa_operator_reapproval_gate_[a-z0-9][a-z0-9_:-]*$"},
    "generated_at": {"type": "string", "minLength": 1},
    "governed": {"const": true},
    "source_projection": {"const": "connector_lease_witness"},
    "source_connector_lease_witness_set_id": {"type": "string", "pattern": "^pa_connector_lease_witness_[a-z0-9][a-z0-9_:-]*$"},
    "gate_count": {"type": "integer", "minimum": 1},
    "gate_ids": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "pattern": "^pa_operator_reapproval_gate_item_[a-z0-9][a-z0-9_:-]*$"},
      "uniqueItems": true
    },
    "source_witness_ids": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "pattern": "^pa_connector_lease_witness_item_[a-z0-9][a-z0-9_:-]*$"},
      "uniqueItems": true
    },
    "receipt_ids": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "pattern": "^pa_receipt_[a-z0-9][a-z0-9_:-]*$"},
      "uniqueItems": true
    },
    "gates": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/gate_item"}
    },
    "effect_boundary": {"$ref": "#/$defs/effect_boundary"},
    "private_payload_policy": {"$ref": "#/$defs/private_payload_policy"},
    "assurance": {"$ref": "#/$defs/assurance"},
    "metadata": {"$ref": "#/$defs/metadata"}
  },
  "$defs": {
    "digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "gate_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gate_id",
        "source_witness_id",
        "approval_id",
        "request_id",
        "plan_id",
        "skill_id",
        "risk_level",
        "connector_lease_witness_ref",
        "reapproval_request",
        "wait_state",
        "execution_admission_block",
        "receipt"
      ],
      "properties": {
        "gate_id": {"type": "string", "pattern": "^pa_operator_reapproval_gate_item_[a-z0-9][a-z0-9_:-]*$"},
        "source_witness_id": {"type": "string", "pattern": "^pa_connector_lease_witness_item_[a-z0-9][a-z0-9_:-]*$"},
        "approval_id": {"type": "string", "pattern": "^pa_approval_[a-z0-9][a-z0-9_:-]*$"},
        "request_id": {"type": "string", "pattern": "^pa_request_[a-z0-9][a-z0-9_:-]*$"},
        "plan_id": {"type": "string", "pattern": "^pa_plan_[a-z0-9][a-z0-9_:-]*$"},
        "skill_id": {"type": "string", "pattern": "^[a-z][a-z0-9_]*(\\.[a-z0-9_]+)+$"},
        "risk_level": {"enum": ["P3", "P4", "P5"]},
        "connector_lease_witness_ref": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "source_witness_set_id",
            "source_receipt_id",
            "source_receipt_state",
            "connector_witness_ref_bound",
            "dispatch_lease_ref_bound",
            "dispatch_lease_active",
            "operator_reapproval_required",
            "operator_reapproval_present",
            "live_connector_receipt_present",
            "execution_worker_admission_allowed"
          ],
          "properties": {
            "source_witness_set_id": {"type": "string", "minLength": 1},
            "source_receipt_id": {"type": "string", "pattern": "^pa_receipt_[a-z0-9][a-z0-9_:-]*$"},
            "source_receipt_state": {"const": "deferred"},
            "connector_witness_ref_bound": {"const": true},
            "dispatch_lease_ref_bound": {"const": true},
            "dispatch_lease_active": {"const": false},
            "operator_reapproval_required": {"const": true},
            "operator_reapproval_present": {"const": false},
            "live_connector_receipt_present": {"const": false},
            "execution_worker_admission_allowed": {"const": false}
          }
        },
        "reapproval_request": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "reapproval_request_ref",
            "reapproval_request_digest",
            "reapproval_reason",
            "fresh_operator_decision_required",
            "fresh_operator_decision_present",
            "operator_identity_ref_required",
            "operator_identity_ref_present",
            "operator_reapproval_receipt_required",
            "operator_reapproval_receipt_present",
            "approval_scope",
            "approval_ref",
            "request_packet_serialized",
            "raw_operator_decision_serialized"
          ],
          "properties": {
            "reapproval_request_ref": {"type": "string", "pattern": "^approval://personal-assistant/reapproval-request/pa_approval_[a-z0-9][a-z0-9_:-]*$"},
            "reapproval_request_digest": {"$ref": "#/$defs/digest"},
            "reapproval_reason": {"const": "required_after_connector_lease_binding"},
            "fresh_operator_decision_required": {"const": true},
            "fresh_operator_decision_present": {"const": false},
            "operator_identity_ref_required": {"const": true},
            "operator_identity_ref_present": {"const": false},
            "operator_reapproval_receipt_required": {"const": true},
            "operator_reapproval_receipt_present": {"const": false},
            "approval_scope": {"const": "single_approval_projection"},
            "approval_ref": {"type": "string", "pattern": "^pa_approval_[a-z0-9][a-z0-9_:-]*$"},
            "request_packet_serialized": {"const": true},
            "raw_operator_decision_serialized": {"const": false}
          }
        },
        "wait_state": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "wait_state_id",
            "state",
            "timeout_policy",
            "resume_condition",
            "on_timeout",
            "dispatch_allowed_while_waiting",
            "execution_worker_admission_allowed_while_waiting"
          ],
          "properties": {
            "wait_state_id": {"type": "string", "pattern": "^wait://personal-assistant/operator-reapproval/pa_approval_[a-z0-9][a-z0-9_:-]*$"},
            "state": {"const": "awaiting_operator_reapproval"},
            "timeout_policy": {"const": "suspend_without_dispatch"},
            "resume_condition": {"const": "fresh_operator_reapproval_receipt_bound"},
            "on_timeout": {"const": "remain_blocked"},
            "dispatch_allowed_while_waiting": {"const": false},
            "execution_worker_admission_allowed_while_waiting": {"const": false}
          }
        },
        "execution_admission_block": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "execution_worker_admission_state",
            "execution_worker_admission_allowed",
            "dispatch_allowed",
            "live_connector_execution_allowed",
            "connector_mutation_allowed",
            "external_send_allowed",
            "system_of_record_write_allowed",
            "memory_write_allowed"
          ],
          "properties": {
            "execution_worker_admission_state": {"const": "blocked_pending_operator_reapproval"},
            "execution_worker_admission_allowed": {"const": false},
            "dispatch_allowed": {"const": false},
            "live_connector_execution_allowed": {"const": false},
            "connector_mutation_allowed": {"const": false},
            "external_send_allowed": {"const": false},
            "system_of_record_write_allowed": {"const": false},
            "memory_write_allowed": {"const": false}
          }
        },
        "receipt": {"type": "object", "additionalProperties": true}
      }
    },
    "effect_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operator_reapproval_gate_allowed",
        "operator_reapproval_request_packet_allowed",
        "connector_lease_witness_ref_binding_allowed",
        "fresh_operator_decision_required",
        "operator_reapproval_present",
        "fresh_operator_decision_present",
        "execution_worker_admission_allowed",
        "dispatch_allowed",
        "dispatch_lease_active",
        "live_connector_receipt_present",
        "live_connector_execution_allowed",
        "external_send_allowed",
        "calendar_write_allowed",
        "task_write_allowed",
        "memory_write_allowed",
        "connector_mutation_allowed",
        "system_of_record_write_allowed",
        "deployment_mutation_allowed",
        "nested_mind_live_activation_allowed",
        "public_readiness_claim_allowed"
      ],
      "properties": {
        "operator_reapproval_gate_allowed": {"const": true},
        "operator_reapproval_request_packet_allowed": {"const": true},
        "connector_lease_witness_ref_binding_allowed": {"const": true},
        "fresh_operator_decision_required": {"const": true},
        "operator_reapproval_present": {"const": false},
        "fresh_operator_decision_present": {"const": false},
        "execution_worker_admission_allowed": {"const": false},
        "dispatch_allowed": {"const": false},
        "dispatch_lease_active": {"const": false},
        "live_connector_receipt_present": {"const": false},
        "live_connector_execution_allowed": {"const": false},
        "external_send_allowed": {"const": false},
        "calendar_write_allowed": {"const": false},
        "task_write_allowed": {"const": false},
        "memory_write_allowed": {"const": false},
        "connector_mutation_allowed": {"const": false},
        "system_of_record_write_allowed": {"const": false},
        "deployment_mutation_allowed": {"const": false},
        "nested_mind_live_activation_allowed": {"const": false},
        "public_readiness_claim_allowed": {"const": false}
      }
    },
    "private_payload_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raw_private_payload_serialized",
        "secret_values_serialized",
        "connector_payload_projection",
        "lease_payload_projection",
        "approval_payload_projection"
      ],
      "properties": {
        "raw_private_payload_serialized": {"const": false},
        "secret_values_serialized": {"const": false},
        "connector_payload_projection": {"const": "ref_only"},
        "lease_payload_projection": {"const": "digest_only"},
        "approval_payload_projection": {"const": "ref_only"}
      }
    },
    "assurance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "assurance_id",
        "outcome",
        "foundation_only",
        "ready_for_execution_worker_admission",
        "ready_for_live_execution",
        "ready_for_customer_readiness_claim",
        "authority_drift_detected",
        "checked_controls",
        "blocking_reasons",
        "next_action"
      ],
      "properties": {
        "assurance_id": {"const": "personal_assistant_operator_reapproval_gate_no_effect_assurance"},
        "outcome": {"enum": ["AwaitingEvidence", "GovernanceBlocked"]},
        "foundation_only": {"const": true},
        "ready_for_execution_worker_admission": {"const": false},
        "ready_for_live_execution": {"const": false},
        "ready_for_customer_readiness_claim": {"const": false},
        "authority_drift_detected": {"type": "boolean"},
        "checked_controls": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "blocking_reasons": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "next_action": {"type": "string", "minLength": 1}
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "foundation_only",
        "projection_contract",
        "runtime_boundary",
        "operator_reapproval_present",
        "fresh_operator_decision_present",
        "execution_worker_admission_allowed",
        "dispatch_allowed",
        "live_connector_execution_allowed",
        "connector_mutation_allowed",
        "external_send_allowed",
        "system_of_record_write_allowed",
        "memory_write_allowed"
      ],
      "properties": {
        "foundation_only": {"const": true},
        "projection_contract": {"const": "operator_reapproval_gate_evidence_only"},
        "runtime_boundary": {"const": "gate_records_reapproval_request_and_wait_state_without_execution_worker_admission"},
        "operator_reapproval_present": {"const": false},
        "fresh_operator_decision_present": {"const": false},
        "execution_worker_admission_allowed": {"const": false},
        "dispatch_allowed": {"const": false},
        "live_connector_execution_allowed": {"const": false},
        "connector_mutation_allowed": {"const": false},
        "external_send_allowed": {"const": false},
        "system_of_record_write_allowed": {"const": false},
        "memory_write_allowed": {"const": false}
      }
    }
  }
}
