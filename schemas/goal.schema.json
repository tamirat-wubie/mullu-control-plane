{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:goal:1",
  "title": "Goal",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "goal",
    "subgoals",
    "plan_dag",
    "steps",
    "terminal_conditions",
    "certificate"
  ],
  "properties": {
    "goal": {
      "$ref": "#/$defs/goal"
    },
    "subgoals": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/subgoal"
      }
    },
    "plan_dag": {
      "$ref": "#/$defs/plan_dag"
    },
    "steps": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/plan_step"
      }
    },
    "terminal_conditions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/terminal_condition"
      }
    },
    "certificate": {
      "$ref": "#/$defs/goal_plan_certificate"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "goal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "goal_id",
        "tenant_id",
        "identity_id",
        "objective",
        "risk_tier",
        "success_criteria",
        "status"
      ],
      "properties": {
        "goal_id": {
          "type": "string",
          "minLength": 1
        },
        "tenant_id": {
          "type": "string",
          "minLength": 1
        },
        "identity_id": {
          "type": "string",
          "minLength": 1
        },
        "objective": {
          "type": "string",
          "minLength": 1
        },
        "risk_tier": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "success_criteria": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "status": {
          "type": "string",
          "minLength": 1
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "subgoal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "subgoal_id",
        "goal_id",
        "step_id",
        "objective",
        "owner_id",
        "depends_on",
        "terminal_condition"
      ],
      "properties": {
        "subgoal_id": {
          "type": "string",
          "minLength": 1
        },
        "goal_id": {
          "type": "string",
          "minLength": 1
        },
        "step_id": {
          "type": "string",
          "minLength": 1
        },
        "objective": {
          "type": "string",
          "minLength": 1
        },
        "owner_id": {
          "type": "string",
          "minLength": 1
        },
        "depends_on": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "terminal_condition": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "plan_dag": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "plan_id",
        "goal_id",
        "step_ids",
        "edges",
        "state_hash",
        "registry_hash"
      ],
      "properties": {
        "plan_id": {
          "type": "string",
          "minLength": 1
        },
        "goal_id": {
          "type": "string",
          "minLength": 1
        },
        "step_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "type": "array",
            "prefixItems": [
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "string",
                "minLength": 1
              }
            ],
            "minItems": 2,
            "maxItems": 2
          }
        },
        "state_hash": {
          "type": "string",
          "minLength": 1
        },
        "registry_hash": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "plan_step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step_id",
        "subgoal_id",
        "capability_id",
        "params",
        "depends_on",
        "preconditions",
        "postconditions",
        "required_evidence",
        "rollback",
        "approval",
        "side_effects_bounded"
      ],
      "properties": {
        "step_id": {
          "type": "string",
          "minLength": 1
        },
        "subgoal_id": {
          "type": "string",
          "minLength": 1
        },
        "capability_id": {
          "type": "string",
          "minLength": 1
        },
        "params": {
          "type": "object",
          "additionalProperties": true
        },
        "depends_on": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "preconditions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/precondition"
          }
        },
        "postconditions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/postcondition"
          }
        },
        "required_evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/required_evidence"
          }
        },
        "rollback": {
          "$ref": "#/$defs/rollback_step"
        },
        "approval": {
          "$ref": "#/$defs/approval_requirement"
        },
        "side_effects_bounded": {
          "type": "boolean"
        }
      }
    },
    "precondition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "precondition_id",
        "step_id",
        "condition_type",
        "required_ref",
        "satisfied"
      ],
      "properties": {
        "precondition_id": {
          "type": "string",
          "minLength": 1
        },
        "step_id": {
          "type": "string",
          "minLength": 1
        },
        "condition_type": {
          "type": "string",
          "minLength": 1
        },
        "required_ref": {
          "type": "string",
          "minLength": 1
        },
        "satisfied": {
          "type": "boolean"
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "postcondition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "postcondition_id",
        "step_id",
        "condition_type",
        "expected_ref",
        "verification_required"
      ],
      "properties": {
        "postcondition_id": {
          "type": "string",
          "minLength": 1
        },
        "step_id": {
          "type": "string",
          "minLength": 1
        },
        "condition_type": {
          "type": "string",
          "minLength": 1
        },
        "expected_ref": {
          "type": "string",
          "minLength": 1
        },
        "verification_required": {
          "type": "boolean"
        }
      }
    },
    "required_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_id",
        "step_id",
        "evidence_type",
        "timing",
        "source_ref"
      ],
      "properties": {
        "evidence_id": {
          "type": "string",
          "minLength": 1
        },
        "step_id": {
          "type": "string",
          "minLength": 1
        },
        "evidence_type": {
          "type": "string",
          "minLength": 1
        },
        "timing": {
          "type": "string",
          "enum": [
            "before_step",
            "after_step"
          ]
        },
        "source_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "rollback_step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rollback_id",
        "step_id",
        "action_type",
        "required"
      ],
      "properties": {
        "rollback_id": {
          "type": "string",
          "minLength": 1
        },
        "step_id": {
          "type": "string",
          "minLength": 1
        },
        "action_type": {
          "type": "string",
          "minLength": 1
        },
        "capability_id": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "approval_requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "approval_id",
        "step_id",
        "risk_tier",
        "authority_required",
        "required"
      ],
      "properties": {
        "approval_id": {
          "type": "string",
          "minLength": 1
        },
        "step_id": {
          "type": "string",
          "minLength": 1
        },
        "risk_tier": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "authority_required": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": {
          "type": "boolean"
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "terminal_condition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "terminal_condition_id",
        "scope",
        "ref_id",
        "condition"
      ],
      "properties": {
        "terminal_condition_id": {
          "type": "string",
          "minLength": 1
        },
        "scope": {
          "type": "string",
          "enum": [
            "goal",
            "step"
          ]
        },
        "ref_id": {
          "type": "string",
          "minLength": 1
        },
        "condition": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "goal_plan_certificate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "certificate_id",
        "goal_id",
        "plan_id",
        "tenant_id",
        "identity_id",
        "status",
        "risk_tier",
        "step_count",
        "state_hash",
        "registry_hash",
        "certificate_hash"
      ],
      "properties": {
        "certificate_id": {
          "type": "string",
          "minLength": 1
        },
        "goal_id": {
          "type": "string",
          "minLength": 1
        },
        "plan_id": {
          "type": "string",
          "minLength": 1
        },
        "tenant_id": {
          "type": "string",
          "minLength": 1
        },
        "identity_id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "minLength": 1
        },
        "risk_tier": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "step_count": {
          "type": "integer",
          "minimum": 0
        },
        "state_hash": {
          "type": "string",
          "minLength": 1
        },
        "registry_hash": {
          "type": "string",
          "minLength": 1
        },
        "certificate_hash": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string"
        }
      }
    }
  }
}
