{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:read-only-worker-binding:1",
  "title": "Read-Only Worker Binding",
  "description": "Foundation Mode contract that selects the first read-only worker path and binds its receipt, authority, recovery, and no-dispatch guards.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "binding_id",
    "binding_version",
    "selected_worker_path",
    "selection_state",
    "tenant_id",
    "actor_id",
    "created_at",
    "solver_outcome",
    "authority_scope",
    "worker_contract",
    "contract_summary",
    "governance_refs",
    "receipt_envelope",
    "evidence_refs"
  ],
  "properties": {
    "binding_id": { "type": "string", "pattern": "^read-only-worker-binding-[a-z0-9-]+$" },
    "binding_version": { "type": "string", "const": "read_only_worker_binding.v1" },
    "selected_worker_path": { "type": "string", "const": "read_only_repo_inspection" },
    "selection_state": {
      "type": "string",
      "enum": ["FOUNDATION_SELECTED", "RUNTIME_BLOCKED", "READY_FOR_LOCAL_REHEARSAL"]
    },
    "tenant_id": { "type": "string", "minLength": 1 },
    "actor_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "solver_outcome": {
      "type": "string",
      "enum": ["SolvedVerified", "AwaitingEvidence", "GovernanceBlocked"]
    },
    "authority_scope": { "$ref": "#/$defs/authority_scope" },
    "worker_contract": { "$ref": "#/$defs/worker_contract" },
    "contract_summary": { "$ref": "#/$defs/contract_summary" },
    "governance_refs": { "$ref": "#/$defs/non_empty_string_array" },
    "receipt_envelope": { "$ref": "#/$defs/receipt_envelope" },
    "evidence_refs": { "$ref": "#/$defs/non_empty_string_array" },
    "metadata": { "type": "object", "additionalProperties": true }
  },
  "$defs": {
    "authority_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "read_only",
        "runtime_dispatch_allowed",
        "external_network_allowed",
        "secret_access_allowed",
        "filesystem_write_allowed",
        "connector_authority_allowed",
        "terminal_closure_allowed",
        "raw_output_retention_allowed",
        "mfidel_atomicity_preserved"
      ],
      "properties": {
        "read_only": { "type": "boolean", "const": true },
        "runtime_dispatch_allowed": { "type": "boolean", "const": false },
        "external_network_allowed": { "type": "boolean", "const": false },
        "secret_access_allowed": { "type": "boolean", "const": false },
        "filesystem_write_allowed": { "type": "boolean", "const": false },
        "connector_authority_allowed": { "type": "boolean", "const": false },
        "terminal_closure_allowed": { "type": "boolean", "const": false },
        "raw_output_retention_allowed": { "type": "boolean", "const": false },
        "mfidel_atomicity_preserved": { "type": "boolean", "const": true }
      }
    },
    "worker_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "worker_id",
        "capability",
        "operation_family",
        "allowed_input_refs",
        "forbidden_input_refs",
        "network_allowlist",
        "allowed_output_refs",
        "forbidden_output_refs",
        "timeout_seconds",
        "max_retry_count",
        "receipt_schema_refs",
        "verification_refs",
        "rollback_refs",
        "recovery_refs"
      ],
      "properties": {
        "worker_id": { "type": "string", "const": "worker_local_read_only_repo_inspection" },
        "capability": { "type": "string", "const": "read_only_repo_inspection" },
        "operation_family": { "type": "string", "const": "local_repo_inspection" },
        "allowed_input_refs": { "$ref": "#/$defs/non_empty_string_array" },
        "forbidden_input_refs": { "$ref": "#/$defs/non_empty_string_array" },
        "network_allowlist": {
          "type": "array",
          "maxItems": 0,
          "items": { "type": "string" }
        },
        "allowed_output_refs": { "$ref": "#/$defs/non_empty_string_array" },
        "forbidden_output_refs": { "$ref": "#/$defs/non_empty_string_array" },
        "timeout_seconds": { "type": "integer", "minimum": 1, "maximum": 120 },
        "max_retry_count": { "type": "integer", "minimum": 0, "maximum": 1 },
        "receipt_schema_refs": { "$ref": "#/$defs/non_empty_string_array" },
        "verification_refs": { "$ref": "#/$defs/non_empty_string_array" },
        "rollback_refs": { "$ref": "#/$defs/non_empty_string_array" },
        "recovery_refs": { "$ref": "#/$defs/non_empty_string_array" }
      }
    },
    "contract_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowed_input_count",
        "forbidden_input_count",
        "network_allowlist_count",
        "allowed_output_count",
        "forbidden_output_count",
        "receipt_schema_count",
        "verification_ref_count",
        "rollback_ref_count",
        "recovery_ref_count"
      ],
      "properties": {
        "allowed_input_count": { "type": "integer", "minimum": 1 },
        "forbidden_input_count": { "type": "integer", "minimum": 1 },
        "network_allowlist_count": { "type": "integer", "const": 0 },
        "allowed_output_count": { "type": "integer", "minimum": 1 },
        "forbidden_output_count": { "type": "integer", "minimum": 1 },
        "receipt_schema_count": { "type": "integer", "minimum": 2 },
        "verification_ref_count": { "type": "integer", "minimum": 1 },
        "rollback_ref_count": { "type": "integer", "minimum": 1 },
        "recovery_ref_count": { "type": "integer", "minimum": 1 }
      }
    },
    "receipt_envelope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["uao_ref", "causal_decision_trace_ref", "receipt_ref"],
      "properties": {
        "uao_ref": { "type": "string", "pattern": "^uao://.+$" },
        "causal_decision_trace_ref": { "type": "string", "pattern": "^trace://.+$" },
        "receipt_ref": { "type": "string", "pattern": "^receipt://.+$" }
      }
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
