{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:world-substrate-replay-witness:1",
  "title": "World Substrate Replay Witness",
  "description": "Foundation Mode witness-only contract for SWEWS-style world snapshot replay evidence without live world-service calls, SQLite access, world mutation, replay execution, external effects, raw payload retention, or terminal closure.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "witness_id",
    "witness_version",
    "generated_at",
    "replay_scope",
    "replay_artifacts",
    "invariant_controls",
    "planner_executor_parity",
    "authority_boundary",
    "safety_guards",
    "receipt_refs",
    "contract_summary",
    "evidence_refs"
  ],
  "properties": {
    "witness_id": {"type": "string", "minLength": 1},
    "witness_version": {"const": "world_substrate_replay_witness.v1"},
    "generated_at": {"type": "string", "format": "date-time"},
    "replay_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_family",
        "borrowed_concept",
        "foundation_mode",
        "tenant_scope",
        "world_substrate_mode",
        "uao_ref",
        "life_meaning_judgment_ref"
      ],
      "properties": {
        "source_family": {"const": "external/swews-core"},
        "borrowed_concept": {"const": "world-substrate-replay-witness"},
        "foundation_mode": {"type": "boolean"},
        "tenant_scope": {"type": "string", "minLength": 1},
        "world_substrate_mode": {
          "type": "string",
          "enum": [
            "witness_only_operator_supplied_refs",
            "witness_only_digest_replay"
          ]
        },
        "uao_ref": {"type": "string", "minLength": 1},
        "life_meaning_judgment_ref": {"type": "string", "minLength": 1}
      }
    },
    "replay_artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "world_snapshot_digest_ref",
        "replay_trace_digest_ref",
        "sparse_cache_digest_ref",
        "invariant_registry_digest_ref",
        "legal_geometry_digest_ref",
        "branch_quarantine_digest_ref"
      ],
      "properties": {
        "world_snapshot_digest_ref": {"type": "string", "minLength": 1},
        "replay_trace_digest_ref": {"type": "string", "minLength": 1},
        "sparse_cache_digest_ref": {"type": "string", "minLength": 1},
        "invariant_registry_digest_ref": {"type": "string", "minLength": 1},
        "legal_geometry_digest_ref": {"type": "string", "minLength": 1},
        "branch_quarantine_digest_ref": {"type": "string", "minLength": 1}
      }
    },
    "invariant_controls": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "invariant_refs",
        "sparse_cache_truth_refs",
        "legal_geometry_refs",
        "field_derivation_refs",
        "branch_quarantine_refs",
        "replay_probe_refs"
      ],
      "properties": {
        "invariant_refs": {"$ref": "#/$defs/non_empty_string_array"},
        "sparse_cache_truth_refs": {"$ref": "#/$defs/non_empty_string_array"},
        "legal_geometry_refs": {"$ref": "#/$defs/non_empty_string_array"},
        "field_derivation_refs": {"$ref": "#/$defs/non_empty_string_array"},
        "branch_quarantine_refs": {"$ref": "#/$defs/non_empty_string_array"},
        "replay_probe_refs": {"$ref": "#/$defs/non_empty_string_array"}
      }
    },
    "planner_executor_parity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "planner_trace_ref",
        "executor_trace_ref",
        "parity_result_ref",
        "parity_verified",
        "divergence_count",
        "planner_executor_mismatch_count"
      ],
      "properties": {
        "planner_trace_ref": {"type": "string", "minLength": 1},
        "executor_trace_ref": {"type": "string", "minLength": 1},
        "parity_result_ref": {"type": "string", "minLength": 1},
        "parity_verified": {"type": "boolean"},
        "divergence_count": {"type": "integer", "minimum": 0},
        "planner_executor_mismatch_count": {"type": "integer", "minimum": 0}
      }
    },
    "authority_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "live_world_service_call_performed",
        "sqlite_read_performed",
        "sqlite_write_performed",
        "world_mutation_performed",
        "replay_execution_performed",
        "planner_execution_performed",
        "executor_execution_performed",
        "branch_unquarantined",
        "external_endpoint_called",
        "secret_access_performed",
        "filesystem_write_performed",
        "raw_world_snapshot_stored",
        "raw_replay_trace_stored",
        "terminal_closure_allowed",
        "success_claim_allowed"
      ],
      "properties": {
        "live_world_service_call_performed": {"type": "boolean"},
        "sqlite_read_performed": {"type": "boolean"},
        "sqlite_write_performed": {"type": "boolean"},
        "world_mutation_performed": {"type": "boolean"},
        "replay_execution_performed": {"type": "boolean"},
        "planner_execution_performed": {"type": "boolean"},
        "executor_execution_performed": {"type": "boolean"},
        "branch_unquarantined": {"type": "boolean"},
        "external_endpoint_called": {"type": "boolean"},
        "secret_access_performed": {"type": "boolean"},
        "filesystem_write_performed": {"type": "boolean"},
        "raw_world_snapshot_stored": {"type": "boolean"},
        "raw_replay_trace_stored": {"type": "boolean"},
        "terminal_closure_allowed": {"type": "boolean"},
        "success_claim_allowed": {"type": "boolean"}
      }
    },
    "safety_guards": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "digest_refs_required",
        "sparse_cache_truth_required",
        "legal_geometry_required",
        "invariant_registry_required",
        "planner_executor_parity_required",
        "branch_quarantine_required",
        "raw_world_snapshot_retained",
        "raw_replay_trace_retained",
        "operator_review_required",
        "incident_handoff_required_if_live"
      ],
      "properties": {
        "digest_refs_required": {"type": "boolean"},
        "sparse_cache_truth_required": {"type": "boolean"},
        "legal_geometry_required": {"type": "boolean"},
        "invariant_registry_required": {"type": "boolean"},
        "planner_executor_parity_required": {"type": "boolean"},
        "branch_quarantine_required": {"type": "boolean"},
        "raw_world_snapshot_retained": {"type": "boolean"},
        "raw_replay_trace_retained": {"type": "boolean"},
        "operator_review_required": {"type": "boolean"},
        "incident_handoff_required_if_live": {"type": "boolean"}
      }
    },
    "receipt_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "world_substrate_replay_witness_schema",
        "world_state_schema",
        "universal_action_orchestration_schema",
        "life_meaning_judgment_schema",
        "simulation_receipt_schema",
        "effect_assurance_schema",
        "sdlc_recovery_handoff_receipt_schema"
      ],
      "properties": {
        "world_substrate_replay_witness_schema": {"type": "string", "minLength": 1},
        "world_state_schema": {"type": "string", "minLength": 1},
        "universal_action_orchestration_schema": {"type": "string", "minLength": 1},
        "life_meaning_judgment_schema": {"type": "string", "minLength": 1},
        "simulation_receipt_schema": {"type": "string", "minLength": 1},
        "effect_assurance_schema": {"type": "string", "minLength": 1},
        "sdlc_recovery_handoff_receipt_schema": {"type": "string", "minLength": 1}
      }
    },
    "contract_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "witness_only",
        "world_mutation_denied",
        "replay_execution_denied",
        "invariant_ref_count",
        "sparse_cache_truth_ref_count",
        "legal_geometry_ref_count",
        "field_derivation_ref_count",
        "branch_quarantine_ref_count",
        "replay_probe_ref_count",
        "authority_denial_count",
        "safety_guard_count",
        "receipt_ref_count",
        "evidence_ref_count"
      ],
      "properties": {
        "witness_only": {"type": "boolean"},
        "world_mutation_denied": {"type": "boolean"},
        "replay_execution_denied": {"type": "boolean"},
        "invariant_ref_count": {"type": "integer", "minimum": 0},
        "sparse_cache_truth_ref_count": {"type": "integer", "minimum": 0},
        "legal_geometry_ref_count": {"type": "integer", "minimum": 0},
        "field_derivation_ref_count": {"type": "integer", "minimum": 0},
        "branch_quarantine_ref_count": {"type": "integer", "minimum": 0},
        "replay_probe_ref_count": {"type": "integer", "minimum": 0},
        "authority_denial_count": {"type": "integer", "minimum": 0},
        "safety_guard_count": {"type": "integer", "minimum": 0},
        "receipt_ref_count": {"type": "integer", "minimum": 0},
        "evidence_ref_count": {"type": "integer", "minimum": 0}
      }
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    }
  },
  "$defs": {
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    }
  }
}
