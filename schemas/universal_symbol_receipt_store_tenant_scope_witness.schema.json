{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:universal-symbol-receipt-store-tenant-scope-witness:1",
  "title": "Universal Symbol Receipt Store Tenant Scope Witness",
  "description": "Foundation Mode witness for a future UniversalSymbol receipt-store tenant scope boundary. This witness defines tenant and actor scope obligations while denying tenant binding, operator approval recording, writer identity registration, writer registration, write-path registration, receipt append, raw payload storage, raw secret storage, runtime dispatch, connector calls, state mutation, terminal closure, and production readiness.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "witness_id",
    "schema_version",
    "generated_at",
    "witness_scope",
    "solver_outcome",
    "foundation_mode",
    "tenant_scope_decision",
    "tenant_scope_witness_is_not_tenant_authority",
    "tenant_requirements",
    "authority_denials",
    "tenant_scope_constraints",
    "rejection_policy",
    "blocked_reasons",
    "next_actions",
    "evidence_refs",
    "contract_summary"
  ],
  "properties": {
    "witness_id": { "type": "string", "const": "universal-symbol-receipt-store-tenant-scope-witness-foundation" },
    "schema_version": { "type": "integer", "const": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "witness_scope": { "type": "string", "const": "foundation-mode-universal-symbol-receipt-store-tenant-scope" },
    "solver_outcome": { "type": "string", "const": "AwaitingEvidence" },
    "foundation_mode": { "type": "boolean", "const": true },
    "tenant_scope_decision": { "type": "string", "const": "blocked_pending_tenant_actor_binding_partition_and_isolation_evidence" },
    "tenant_scope_witness_is_not_tenant_authority": { "type": "boolean", "const": true },
    "tenant_requirements": {
      "type": "array",
      "minItems": 8,
      "items": { "$ref": "#/$defs/tenant_requirement" },
      "uniqueItems": true
    },
    "authority_denials": { "$ref": "#/$defs/authority_denials" },
    "tenant_scope_constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tenant_identity_required",
        "actor_identity_required",
        "tenant_actor_binding_required",
        "receipt_store_partition_required",
        "cross_tenant_isolation_required",
        "tenant_policy_required",
        "audit_receipt_required",
        "rebinding_or_revocation_path_required"
      ],
      "properties": {
        "tenant_identity_required": { "type": "boolean", "const": true },
        "actor_identity_required": { "type": "boolean", "const": true },
        "tenant_actor_binding_required": { "type": "boolean", "const": true },
        "receipt_store_partition_required": { "type": "boolean", "const": true },
        "cross_tenant_isolation_required": { "type": "boolean", "const": true },
        "tenant_policy_required": { "type": "boolean", "const": true },
        "audit_receipt_required": { "type": "boolean", "const": true },
        "rebinding_or_revocation_path_required": { "type": "boolean", "const": true }
      }
    },
    "rejection_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "missing_tenant_identity_blocks_scope",
        "missing_actor_identity_blocks_scope",
        "missing_binding_blocks_scope",
        "missing_partition_blocks_scope",
        "unknown_hard_constraint_blocks_scope",
        "failed_precondition_logs_delta_reject"
      ],
      "properties": {
        "missing_tenant_identity_blocks_scope": { "type": "boolean", "const": true },
        "missing_actor_identity_blocks_scope": { "type": "boolean", "const": true },
        "missing_binding_blocks_scope": { "type": "boolean", "const": true },
        "missing_partition_blocks_scope": { "type": "boolean", "const": true },
        "unknown_hard_constraint_blocks_scope": { "type": "boolean", "const": true },
        "failed_precondition_logs_delta_reject": { "type": "boolean", "const": true }
      }
    },
    "blocked_reasons": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "string",
        "enum": [
          "tenant_identity_missing",
          "actor_identity_missing",
          "tenant_actor_binding_missing",
          "receipt_store_partition_missing",
          "cross_tenant_isolation_missing",
          "tenant_policy_missing",
          "audit_receipt_missing",
          "rebinding_or_revocation_path_missing",
          "receipt_store_tenant_scope_forbidden",
          "terminal_closure_not_allowed"
        ]
      },
      "uniqueItems": true
    },
    "next_actions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/ref" },
      "uniqueItems": true
    },
    "contract_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tenant_requirement_count",
        "authority_denial_count",
        "tenant_scope_constraint_count",
        "rejection_check_count",
        "blocked_reason_count",
        "evidence_ref_count"
      ],
      "properties": {
        "tenant_requirement_count": { "type": "integer", "minimum": 8 },
        "authority_denial_count": { "type": "integer", "const": 12 },
        "tenant_scope_constraint_count": { "type": "integer", "const": 8 },
        "rejection_check_count": { "type": "integer", "const": 6 },
        "blocked_reason_count": { "type": "integer", "minimum": 8 },
        "evidence_ref_count": { "type": "integer", "minimum": 1 }
      }
    }
  },
  "$defs": {
    "ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/#-]*$"
    },
    "tenant_requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requirement_id",
        "proof_state",
        "required_evidence_ref",
        "current_decision",
        "delta_reject_ref"
      ],
      "properties": {
        "requirement_id": { "$ref": "#/$defs/ref" },
        "proof_state": { "type": "string", "enum": ["Unknown", "BudgetUnknown", "Fail"] },
        "required_evidence_ref": { "$ref": "#/$defs/ref" },
        "current_decision": { "type": "string", "const": "tenant_scope_blocked" },
        "delta_reject_ref": { "$ref": "#/$defs/ref" }
      }
    },
    "authority_denials": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_store_tenant_scope_bound",
        "receipt_store_operator_approval_recorded",
        "receipt_store_writer_identity_registered",
        "receipt_store_writer_registered",
        "receipt_store_write_path_registered",
        "receipt_store_append_performed",
        "raw_payload_stored",
        "raw_secret_stored",
        "runtime_dispatch_performed",
        "connector_call_performed",
        "state_mutation_performed",
        "terminal_closure_allowed"
      ],
      "properties": {
        "receipt_store_tenant_scope_bound": { "type": "boolean", "const": false },
        "receipt_store_operator_approval_recorded": { "type": "boolean", "const": false },
        "receipt_store_writer_identity_registered": { "type": "boolean", "const": false },
        "receipt_store_writer_registered": { "type": "boolean", "const": false },
        "receipt_store_write_path_registered": { "type": "boolean", "const": false },
        "receipt_store_append_performed": { "type": "boolean", "const": false },
        "raw_payload_stored": { "type": "boolean", "const": false },
        "raw_secret_stored": { "type": "boolean", "const": false },
        "runtime_dispatch_performed": { "type": "boolean", "const": false },
        "connector_call_performed": { "type": "boolean", "const": false },
        "state_mutation_performed": { "type": "boolean", "const": false },
        "terminal_closure_allowed": { "type": "boolean", "const": false }
      }
    }
  }
}
