          }
        },
        "closure_report": {
          "$ref": "#/$defs/closure_report"
        },
        "closure_evidence_pack": {
          "$ref": "#/$defs/closure_evidence_pack"
        },
        "operator_closure_readiness_view": {
          "$ref": "#/$defs/operator_closure_readiness_view"
        },
        "proof_obligation_view": {
          "$ref": "#/$defs/proof_obligation_view"
        },
        "audit_evolution_view": {
