{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:holistic-loop-read-model:1",
  "title": "Holistic Loop Read Model",
  "description": "Read-only bounded summary of registered governed loop contracts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "report_id",
    "status",
    "generated_at",
    "loop_count",
    "returned_count",
    "blocked_count",
    "verified_count",
    "truncated",
    "report_is_not_terminal_closure",
    "terminal_closure_required",
    "loops"
  ],
  "properties": {
    "report_id": {
      "type": "string",
      "const": "holistic_loop_read_model"
    },
    "status": {
      "type": "string",
      "enum": ["blocked", "verified"]
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "loop_count": {
      "type": "integer",
      "minimum": 0
    },
    "returned_count": {
      "type": "integer",
      "minimum": 0
    },
    "blocked_count": {
      "type": "integer",
      "minimum": 0
    },
    "verified_count": {
      "type": "integer",
      "minimum": 0
    },
    "truncated": {
      "type": "boolean"
    },
    "report_is_not_terminal_closure": {
      "type": "boolean",
      "const": true
    },
    "terminal_closure_required": {
      "type": "boolean",
      "const": true
    },
    "loops": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/loop_summary"
      }
    }
  },
  "$defs": {
    "loop_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "loop_id",
        "name",
        "purpose",
        "owner",
        "risk_class",
        "status",
        "mode",
        "current_step",
        "required_authority",
        "authority_bindings",
        "authority_refs",
        "missing_authority",
        "required_evidence",
        "evidence_bindings",
        "step_receipts",
        "evidence_refs",
        "missing_evidence",
        "closure_conditions",
        "closure_report",
        "open_blockers",
        "rollback_policy",
        "learning_policy",
        "updated_at"
      ],
      "properties": {
        "loop_id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "purpose": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "risk_class": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": ["open", "blocked", "verified", "closed"]
        },
        "mode": {
          "type": "string",
          "enum": ["real", "dry_run", "shadow", "simulation", "replay"]
        },
        "current_step": {
          "type": "string",
          "enum": [
            "observe",
            "decide",
            "act",
            "verify",
            "record_receipt",
            "update_state",
            "learn",
            "audit",
            "close"
          ]
        },
        "required_authority": {
          "$ref": "#/$defs/text_list"
        },
        "authority_bindings": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/authority_binding"
          }
        },
        "authority_refs": {
          "$ref": "#/$defs/possibly_empty_text_list"
        },
        "missing_authority": {
          "$ref": "#/$defs/possibly_empty_text_list"
        },
        "required_evidence": {
          "$ref": "#/$defs/text_list"
        },
        "evidence_bindings": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/evidence_binding"
          }
        },
        "step_receipts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/step_receipt"
          }
        },
        "evidence_refs": {
          "$ref": "#/$defs/possibly_empty_text_list"
        },
        "missing_evidence": {
          "$ref": "#/$defs/possibly_empty_text_list"
        },
        "closure_conditions": {
          "$ref": "#/$defs/text_list"
        },
        "closure_report": {
          "$ref": "#/$defs/closure_report"
        },
        "open_blockers": {
          "$ref": "#/$defs/possibly_empty_text_list"
        },
        "rollback_policy": {
          "type": "string",
          "minLength": 1
        },
        "learning_policy": {
          "type": "string",
          "minLength": 1
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "authority_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "authority_ref",
        "purpose",
        "source_refs",
        "validator_refs",
        "proof_surface_refs",
        "read_only",
        "terminal_closure"
      ],
      "properties": {
        "authority_ref": {
          "type": "string",
          "minLength": 1
        },
        "purpose": {
          "type": "string",
          "minLength": 1
        },
        "source_refs": {
          "$ref": "#/$defs/text_list"
        },
        "validator_refs": {
          "$ref": "#/$defs/text_list"
        },
        "proof_surface_refs": {
          "$ref": "#/$defs/text_list"
        },
        "read_only": {
          "type": "boolean",
          "const": true
        },
        "terminal_closure": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "step_receipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "loop_id",
        "step",
        "input_hash",
        "output_hash",
        "decision",
        "evidence_refs",
        "status",
        "errors",
        "timestamp",
        "metadata"
      ],
      "properties": {
        "loop_id": {
          "type": "string",
          "minLength": 1
        },
        "step": {
          "type": "string",
          "enum": [
            "observe",
            "decide",
            "act",
            "verify",
            "record_receipt",
            "update_state",
            "learn",
            "audit",
            "close"
          ]
        },
        "input_hash": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "output_hash": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "decision": {
          "type": "string",
          "minLength": 1
        },
        "evidence_refs": {
          "$ref": "#/$defs/possibly_empty_text_list"
        },
        "status": {
          "type": "string",
          "enum": ["open", "blocked", "verified"]
        },
        "errors": {
          "$ref": "#/$defs/possibly_empty_text_list"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "read_only",
            "synthetic_projection",
            "terminal_closure",
            "behavior_rewrite"
          ],
          "properties": {
            "read_only": {
              "type": "boolean",
              "const": true
            },
            "synthetic_projection": {
              "type": "boolean",
              "const": true
            },
            "terminal_closure": {
              "type": "boolean",
              "const": false
            },
            "behavior_rewrite": {
              "type": "boolean",
              "const": false
            }
          }
        }
      }
    },
    "closure_report": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "loop_id",
        "closed",
        "closure_reason",
        "evidence_complete",
        "unresolved_gaps",
        "rollback_available",
        "learning_candidates",
        "metadata"
      ],
      "properties": {
        "loop_id": {
          "type": "string",
          "minLength": 1
        },
        "closed": {
          "type": "boolean",
          "const": false
        },
        "closure_reason": {
          "type": "string",
          "minLength": 1
        },
        "evidence_complete": {
          "type": "boolean"
        },
        "unresolved_gaps": {
          "$ref": "#/$defs/possibly_empty_text_list"
        },
        "rollback_available": {
          "type": "boolean"
        },
        "learning_candidates": {
          "$ref": "#/$defs/possibly_empty_text_list"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "read_only",
            "terminal_closure",
            "closure_conditions"
          ],
          "properties": {
            "read_only": {
              "type": "boolean",
              "const": true
            },
            "terminal_closure": {
              "type": "boolean",
              "const": false
            },
            "closure_conditions": {
              "$ref": "#/$defs/text_list"
            }
          }
        }
      }
    },
    "evidence_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_ref",
        "purpose",
        "source_refs",
        "validator_refs",
        "proof_surface_refs",
        "read_only",
        "terminal_closure"
      ],
      "properties": {
        "evidence_ref": {
          "type": "string",
          "minLength": 1
        },
        "purpose": {
          "type": "string",
          "minLength": 1
        },
        "source_refs": {
          "$ref": "#/$defs/text_list"
        },
        "validator_refs": {
          "$ref": "#/$defs/text_list"
        },
        "proof_surface_refs": {
          "$ref": "#/$defs/text_list"
        },
        "read_only": {
          "type": "boolean",
          "const": true
        },
        "terminal_closure": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "text_list": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "possibly_empty_text_list": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
