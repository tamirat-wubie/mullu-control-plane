        },
        "recovery_readiness_view": {
          "$ref": "#/$defs/recovery_readiness_view"
        },
        "open_blockers": {
          "$ref": "#/$defs/possibly_empty_text_list"
        },
        "rollback_policy": {
          "type": "string",
          "minLength": 1
        },
        "rollback_binding": {
          "$ref": "#/$defs/rollback_binding"
        },
        "learning_policy": {
          "type": "string",
          "minLength": 1
        },
        "learning_binding": {
          "$ref": "#/$defs/learning_binding"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        }
      }
