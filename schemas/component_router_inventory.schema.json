{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:component-router-inventory:1",
  "title": "Mullu Component Router Inventory",
  "description": "Read-only route-to-component binding inventory for the Mullu Component Harness. The inventory binds declared router families to registered components and proof surfaces without granting route execution or live action authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "inventory_id",
    "generated_at",
    "mode",
    "source_registry",
    "purpose",
    "router_inventory_is_not_execution_authority",
    "live_execution_enabled",
    "live_connector_send_enabled",
    "terminal_closure_required",
    "route_bindings",
    "validators",
    "next_action"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "inventory_id": {
      "$ref": "#/$defs/identifier"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "mode": {
      "type": "string",
      "enum": [
        "foundation",
        "read_only"
      ]
    },
    "source_registry": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "router_inventory_is_not_execution_authority": {
      "type": "boolean",
      "const": true
    },
    "live_execution_enabled": {
      "type": "boolean",
      "const": false
    },
    "live_connector_send_enabled": {
      "type": "boolean",
      "const": false
    },
    "terminal_closure_required": {
      "type": "boolean",
      "const": true
    },
    "route_bindings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/route_binding"
      }
    },
    "validators": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/validator_ref"
      }
    },
    "next_action": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "route_path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^/[A-Za-z0-9._~:/{}*-]+$"
    },
    "blocked_action": {
      "type": "string",
      "enum": [
        "account_binding_claim",
        "autonomous_execution",
        "calendar_write",
        "connector_call",
        "customer_exposure",
        "deploy",
        "dns_mutation",
        "external_send",
        "filesystem_write",
        "live_dispatch",
        "mailbox_mutation",
        "memory_topology_activation",
        "money_movement",
        "provider_write",
        "public_readiness_claim",
        "route_execution",
        "runtime_mutation",
        "secret_mutation",
        "send_email",
        "terminal_closure"
      ]
    },
    "route_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "component_id",
        "binding_state",
        "proof_surface_ids",
        "route_prefixes",
        "expected_routes",
        "blocked_actions",
        "binding_is_not_execution_authority",
        "can_enable_live_action",
        "notes"
      ],
      "properties": {
        "component_id": {
          "$ref": "#/$defs/identifier"
        },
        "binding_state": {
          "type": "string",
          "enum": [
            "bound",
            "no_declared_route",
            "deferred"
          ]
        },
        "proof_surface_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "route_prefixes": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/route_path"
          }
        },
        "expected_routes": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/route_path"
          }
        },
        "blocked_actions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/blocked_action"
          }
        },
        "binding_is_not_execution_authority": {
          "type": "boolean",
          "const": true
        },
        "can_enable_live_action": {
          "type": "boolean",
          "const": false
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "validator_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "validator_id",
        "command",
        "required_for_closure"
      ],
      "properties": {
        "validator_id": {
          "$ref": "#/$defs/identifier"
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "required_for_closure": {
          "type": "boolean"
        }
      }
    }
  }
}
