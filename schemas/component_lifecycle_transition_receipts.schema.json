{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:component-lifecycle-transition-receipts:1",
  "title": "Mullu Component Lifecycle Transition Receipts",
  "description": "Foundation-stage Component Harness lifecycle transition receipt set. It records current component lifecycle transitions as evidence without granting execution authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "receipt_set_id",
    "mode",
    "source_registry",
    "receipt_set_is_not_execution_authority",
    "live_execution_enabled",
    "live_connector_send_enabled",
    "terminal_closure_required",
    "allowed_transition_graph",
    "transition_receipts",
    "validators",
    "next_action"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "receipt_set_id": {
      "$ref": "#/$defs/identifier"
    },
    "mode": {
      "type": "string",
      "const": "foundation"
    },
    "source_registry": {
      "$ref": "#/$defs/repo_path"
    },
    "receipt_set_is_not_execution_authority": {
      "type": "boolean",
      "const": true
    },
    "live_execution_enabled": {
      "type": "boolean",
      "const": false
    },
    "live_connector_send_enabled": {
      "type": "boolean",
      "const": false
    },
    "terminal_closure_required": {
      "type": "boolean",
      "const": true
    },
    "allowed_transition_graph": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/allowed_transition"
      }
    },
    "transition_receipts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/transition_receipt"
      }
    },
    "validators": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/validator_ref"
      }
    },
    "next_action": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "repo_path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9._~:/{}@+ -]+$"
    },
    "lifecycle_state": {
      "type": "string",
      "enum": [
        "not_present",
        "present",
        "registered",
        "validated",
        "bootstrapped",
        "mounted",
        "read_only",
        "draft_only",
        "live_probe",
        "approval_required",
        "approved_live_action",
        "blocked",
        "deprecated"
      ]
    },
    "wiring_state": {
      "type": "string",
      "enum": [
        "present",
        "imported",
        "bootstrapped",
        "mounted",
        "bootstrapped_and_mounted",
        "read_only",
        "draft_only",
        "live_probe",
        "approval_required",
        "live_action_enabled",
        "blocked",
        "deprecated"
      ]
    },
    "authority_level": {
      "type": "string",
      "enum": [
        "none",
        "registry_only",
        "read_only",
        "read_only_advisory",
        "draft_only",
        "live_probe",
        "approval_required",
        "approved_live_action",
        "blocked"
      ]
    },
    "blocked_action": {
      "type": "string",
      "enum": [
        "account_binding_claim",
        "autonomous_execution",
        "calendar_write",
        "connector_call",
        "customer_exposure",
        "deploy",
        "dns_mutation",
        "external_send",
        "filesystem_write",
        "live_dispatch",
        "mailbox_mutation",
        "memory_topology_activation",
        "money_movement",
        "provider_write",
        "public_readiness_claim",
        "route_execution",
        "runtime_mutation",
        "secret_mutation",
        "send_email",
        "terminal_closure"
      ]
    },
    "proof_state": {
      "type": "string",
      "enum": [
        "Pass",
        "Fail",
        "Unknown",
        "BudgetUnknown"
      ]
    },
    "allowed_transition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "from_state",
        "to_state",
        "requires_evidence",
        "requires_operator_approval",
        "external_effect"
      ],
      "properties": {
        "from_state": {
          "$ref": "#/$defs/lifecycle_state"
        },
        "to_state": {
          "$ref": "#/$defs/lifecycle_state"
        },
        "requires_evidence": {
          "type": "boolean",
          "const": true
        },
        "requires_operator_approval": {
          "type": "boolean"
        },
        "external_effect": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "authority_guardrails": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "can_execute",
        "can_mutate",
        "can_call_connector",
        "can_write_files",
        "can_send_external_message",
        "can_claim_terminal_closure"
      ],
      "properties": {
        "can_execute": {
          "type": "boolean",
          "const": false
        },
        "can_mutate": {
          "type": "boolean",
          "const": false
        },
        "can_call_connector": {
          "type": "boolean",
          "const": false
        },
        "can_write_files": {
          "type": "boolean",
          "const": false
        },
        "can_send_external_message": {
          "type": "boolean",
          "const": false
        },
        "can_claim_terminal_closure": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "transition_receipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_id",
        "component_id",
        "from_state",
        "to_state",
        "wiring_state",
        "authority_level",
        "transition_kind",
        "proof_state",
        "evidence_refs",
        "required_validator_refs",
        "blocked_actions",
        "authority_guardrails",
        "receipt_is_not_execution_authority",
        "receipt_is_not_terminal_closure",
        "external_effect",
        "operator_approval_required",
        "reason"
      ],
      "properties": {
        "receipt_id": {
          "$ref": "#/$defs/identifier"
        },
        "component_id": {
          "$ref": "#/$defs/identifier"
        },
        "from_state": {
          "$ref": "#/$defs/lifecycle_state"
        },
        "to_state": {
          "$ref": "#/$defs/lifecycle_state"
        },
        "wiring_state": {
          "$ref": "#/$defs/wiring_state"
        },
        "authority_level": {
          "$ref": "#/$defs/authority_level"
        },
        "transition_kind": {
          "$ref": "#/$defs/identifier"
        },
        "proof_state": {
          "$ref": "#/$defs/proof_state"
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/repo_path"
          }
        },
        "required_validator_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "blocked_actions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "contains": {
            "const": "terminal_closure"
          },
          "items": {
            "$ref": "#/$defs/blocked_action"
          }
        },
        "authority_guardrails": {
          "$ref": "#/$defs/authority_guardrails"
        },
        "receipt_is_not_execution_authority": {
          "type": "boolean",
          "const": true
        },
        "receipt_is_not_terminal_closure": {
          "type": "boolean",
          "const": true
        },
        "external_effect": {
          "type": "boolean",
          "const": false
        },
        "operator_approval_required": {
          "type": "boolean"
        },
        "reason": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        }
      }
    },
    "validator_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "validator_id",
        "command",
        "required_for_closure"
      ],
      "properties": {
        "validator_id": {
          "$ref": "#/$defs/identifier"
        },
        "command": {
          "type": "string",
          "minLength": 1,
          "maxLength": 240
        },
        "required_for_closure": {
          "type": "boolean",
          "const": true
        }
      }
    }
  }
}
