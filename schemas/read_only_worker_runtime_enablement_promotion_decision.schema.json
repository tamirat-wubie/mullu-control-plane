{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:read-only-worker-runtime-enablement-promotion-decision:1",
  "title": "Read-Only Worker Runtime Enablement Promotion Decision",
  "description": "Foundation Mode runtime enablement promotion decision for the selected read-only worker path. The decision consumes the runtime admission gate and denies runtime promotion while preserving all runtime execution boundaries.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "decision_id",
    "decision_version",
    "source_admission_gate_ref",
    "selected_worker_path",
    "solver_outcome",
    "proof_state",
    "decision_state",
    "evidence_accepted",
    "runtime_promotion_decided",
    "runtime_promotion_allowed",
    "runtime_promotion_denied",
    "runtime_admission_allowed",
    "runtime_enablement_allowed",
    "runtime_enablement_executed",
    "runtime_dispatch_allowed",
    "worker_invocation_allowed",
    "runtime_receipt_emission_allowed",
    "receipt_append_allowed",
    "terminal_closure_allowed",
    "success_claim_allowed",
    "secret_values_serialized",
    "connector_authority_allowed",
    "filesystem_write_allowed",
    "external_network_allowed",
    "denial_reasons",
    "reentry_evidence_required",
    "accepted_evidence_refs",
    "blocked_actions",
    "summary",
    "validators",
    "next_action"
  ],
  "properties": {
    "decision_id": {
      "type": "string",
      "const": "read-only-worker-runtime-enablement-promotion-decision-foundation-repo-inspection-20260620"
    },
    "decision_version": {
      "type": "string",
      "const": "read_only_worker_runtime_enablement_promotion_decision.v1"
    },
    "source_admission_gate_ref": {
      "type": "string",
      "const": "examples/read_only_worker_runtime_enablement_admission_gate.foundation.json"
    },
    "selected_worker_path": { "type": "string", "const": "read_only_repo_inspection" },
    "solver_outcome": { "type": "string", "const": "GovernanceBlocked" },
    "proof_state": { "type": "string", "const": "Pass" },
    "decision_state": { "type": "string", "const": "runtime_promotion_denied_foundation_mode" },
    "evidence_accepted": { "type": "boolean", "const": true },
    "runtime_promotion_decided": { "type": "boolean", "const": true },
    "runtime_promotion_allowed": { "type": "boolean", "const": false },
    "runtime_promotion_denied": { "type": "boolean", "const": true },
    "runtime_admission_allowed": { "type": "boolean", "const": false },
    "runtime_enablement_allowed": { "type": "boolean", "const": false },
    "runtime_enablement_executed": { "type": "boolean", "const": false },
    "runtime_dispatch_allowed": { "type": "boolean", "const": false },
    "worker_invocation_allowed": { "type": "boolean", "const": false },
    "runtime_receipt_emission_allowed": { "type": "boolean", "const": false },
    "receipt_append_allowed": { "type": "boolean", "const": false },
    "terminal_closure_allowed": { "type": "boolean", "const": false },
    "success_claim_allowed": { "type": "boolean", "const": false },
    "secret_values_serialized": { "type": "boolean", "const": false },
    "connector_authority_allowed": { "type": "boolean", "const": false },
    "filesystem_write_allowed": { "type": "boolean", "const": false },
    "external_network_allowed": { "type": "boolean", "const": false },
    "denial_reasons": {
      "type": "array",
      "minItems": 3,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/non_empty_string" }
    },
    "reentry_evidence_required": {
      "type": "array",
      "minItems": 4,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/non_empty_string" }
    },
    "accepted_evidence_refs": {
      "type": "array",
      "minItems": 12,
      "maxItems": 12,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/repo_ref" }
    },
    "blocked_actions": {
      "type": "array",
      "minItems": 7,
      "maxItems": 7,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/non_empty_string" }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "accepted_evidence_ref_count",
        "denial_reason_count",
        "reentry_evidence_required_count",
        "runtime_promotion_allowed_count",
        "runtime_enablement_count",
        "blocked_action_count"
      ],
      "properties": {
        "accepted_evidence_ref_count": { "type": "integer", "const": 12 },
        "denial_reason_count": { "type": "integer", "minimum": 3 },
        "reentry_evidence_required_count": { "type": "integer", "minimum": 4 },
        "runtime_promotion_allowed_count": { "type": "integer", "const": 0 },
        "runtime_enablement_count": { "type": "integer", "const": 0 },
        "blocked_action_count": { "type": "integer", "const": 7 }
      }
    },
    "validators": {
      "type": "array",
      "minItems": 3,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/non_empty_string" }
    },
    "next_action": { "$ref": "#/$defs/non_empty_string" }
  },
  "$defs": {
    "non_empty_string": { "type": "string", "minLength": 1 },
    "repo_ref": { "type": "string", "minLength": 1, "pattern": "^(examples|schemas|scripts|tests|docs)/" }
  }
}
