{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:forge-live-runtime-readiness-gate:1",
  "title": "Forge Live Runtime Readiness Gate",
  "description": "Foundation Mode gate that blocks live Forge state-write runtime registration until key custody, transport, replay, persistence, WORM lineage, tenant guard, UAO, rollback, and PB evidence exist.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "gate_id",
    "schema_ref",
    "schema_version",
    "bridge_ref",
    "source_bridge_ref",
    "source_admission_packet_ref",
    "evaluated_at",
    "foundation_mode",
    "readiness_status",
    "solver_outcome",
    "admission_decision",
    "live_runtime_authorized",
    "state_write_runtime_registered",
    "production_authorized",
    "external_effects_allowed",
    "commit_allowed",
    "required_evidence",
    "blocked_reasons",
    "required_controls",
    "next_allowed_action",
    "validators",
    "gate_hash"
  ],
  "properties": {
    "gate_id": {
      "type": "string",
      "const": "forge-live-runtime-readiness-gate.v1"
    },
    "schema_ref": {
      "type": "string",
      "const": "urn:mullusi:schema:forge-live-runtime-readiness-gate:1"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "bridge_ref": {
      "type": "string",
      "const": "forge_write_spine_bridge.v1"
    },
    "source_bridge_ref": {
      "type": "string",
      "const": "examples/forge_write_spine_bridge.foundation.json"
    },
    "source_admission_packet_ref": {
      "type": "string",
      "const": "examples/forge_state_write_admission_packet.foundation.json"
    },
    "evaluated_at": {
      "type": "string",
      "minLength": 1
    },
    "foundation_mode": {
      "type": "boolean",
      "const": true
    },
    "readiness_status": {
      "type": "string",
      "const": "blocked_awaiting_evidence"
    },
    "solver_outcome": {
      "type": "string",
      "const": "AwaitingEvidence"
    },
    "admission_decision": {
      "type": "string",
      "const": "block_live_runtime"
    },
    "live_runtime_authorized": {
      "type": "boolean",
      "const": false
    },
    "state_write_runtime_registered": {
      "type": "boolean",
      "const": false
    },
    "production_authorized": {
      "type": "boolean",
      "const": false
    },
    "external_effects_allowed": {
      "type": "boolean",
      "const": false
    },
    "commit_allowed": {
      "type": "boolean",
      "const": false
    },
    "required_evidence": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "prefixItems": [
        { "$ref": "#/$defs/managed_key_custody" },
        { "$ref": "#/$defs/confidential_transport" },
        { "$ref": "#/$defs/persistent_nonce_replay_store" },
        { "$ref": "#/$defs/independent_persistence_store" },
        { "$ref": "#/$defs/independent_worm_lineage" },
        { "$ref": "#/$defs/tenant_scope_guard" },
        { "$ref": "#/$defs/uao_no_bypass_runtime_proof" },
        { "$ref": "#/$defs/rollback_replay_recovery_plan" },
        { "$ref": "#/$defs/pb01_pb02_pb03_write_spine_closure" },
        { "$ref": "#/$defs/pb04_pb11_runtime_operational_closure" }
      ]
    },
    "blocked_reasons": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "prefixItems": [
        { "const": "managed_key_custody_missing" },
        { "const": "confidential_transport_missing" },
        { "const": "persistent_nonce_replay_store_missing" },
        { "const": "independent_persistence_store_missing" },
        { "const": "independent_worm_lineage_missing" },
        { "const": "tenant_scope_guard_missing" },
        { "const": "uao_no_bypass_runtime_proof_missing" },
        { "const": "rollback_replay_recovery_plan_missing" },
        { "const": "pb01_pb02_pb03_write_spine_closure_missing" },
        { "const": "pb04_pb11_runtime_operational_closure_missing" }
      ]
    },
    "required_controls": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "prefixItems": [
        { "const": "foundation_mode_runtime_block" },
        { "const": "managed_key_custody_required" },
        { "const": "confidential_transport_required" },
        { "const": "persistent_nonce_replay_store_required" },
        { "const": "independent_persistence_required" },
        { "const": "independent_worm_lineage_required" },
        { "const": "tenant_scope_guard_required" },
        { "const": "uao_no_bypass_runtime_proof_required" },
        { "const": "rollback_replay_recovery_required" },
        { "const": "pb01_pb11_evidence_required" }
      ]
    },
    "next_allowed_action": {
      "type": "string",
      "const": "collect_local_evidence_without_registering_runtime_authority"
    },
    "validators": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": {
        "$ref": "#/$defs/validator"
      }
    },
    "gate_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  },
  "$defs": {
    "evidence_base": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_id",
        "required",
        "present",
        "evidence_ref",
        "blocker_reason"
      ],
      "properties": {
        "evidence_id": { "type": "string" },
        "required": { "type": "boolean", "const": true },
        "present": { "type": "boolean", "const": false },
        "evidence_ref": { "type": "string", "const": "" },
        "blocker_reason": { "type": "string" }
      }
    },
    "managed_key_custody": {
      "allOf": [
        { "$ref": "#/$defs/evidence_base" },
        {
          "properties": {
            "evidence_id": { "const": "managed_key_custody" },
            "blocker_reason": { "const": "managed_key_custody_missing" }
          }
        }
      ]
    },
    "confidential_transport": {
      "allOf": [
        { "$ref": "#/$defs/evidence_base" },
        {
          "properties": {
            "evidence_id": { "const": "confidential_transport" },
            "blocker_reason": { "const": "confidential_transport_missing" }
          }
        }
      ]
    },
    "persistent_nonce_replay_store": {
      "allOf": [
        { "$ref": "#/$defs/evidence_base" },
        {
          "properties": {
            "evidence_id": { "const": "persistent_nonce_replay_store" },
            "blocker_reason": { "const": "persistent_nonce_replay_store_missing" }
          }
        }
      ]
    },
    "independent_persistence_store": {
      "allOf": [
        { "$ref": "#/$defs/evidence_base" },
        {
          "properties": {
            "evidence_id": { "const": "independent_persistence_store" },
            "blocker_reason": { "const": "independent_persistence_store_missing" }
          }
        }
      ]
    },
    "independent_worm_lineage": {
      "allOf": [
        { "$ref": "#/$defs/evidence_base" },
        {
          "properties": {
            "evidence_id": { "const": "independent_worm_lineage" },
            "blocker_reason": { "const": "independent_worm_lineage_missing" }
          }
        }
      ]
    },
    "tenant_scope_guard": {
      "allOf": [
        { "$ref": "#/$defs/evidence_base" },
        {
          "properties": {
            "evidence_id": { "const": "tenant_scope_guard" },
            "blocker_reason": { "const": "tenant_scope_guard_missing" }
          }
        }
      ]
    },
    "uao_no_bypass_runtime_proof": {
      "allOf": [
        { "$ref": "#/$defs/evidence_base" },
        {
          "properties": {
            "evidence_id": { "const": "uao_no_bypass_runtime_proof" },
            "blocker_reason": { "const": "uao_no_bypass_runtime_proof_missing" }
          }
        }
      ]
    },
    "rollback_replay_recovery_plan": {
      "allOf": [
        { "$ref": "#/$defs/evidence_base" },
        {
          "properties": {
            "evidence_id": { "const": "rollback_replay_recovery_plan" },
            "blocker_reason": { "const": "rollback_replay_recovery_plan_missing" }
          }
        }
      ]
    },
    "pb01_pb02_pb03_write_spine_closure": {
      "allOf": [
        { "$ref": "#/$defs/evidence_base" },
        {
          "properties": {
            "evidence_id": { "const": "pb01_pb02_pb03_write_spine_closure" },
            "blocker_reason": { "const": "pb01_pb02_pb03_write_spine_closure_missing" }
          }
        }
      ]
    },
    "pb04_pb11_runtime_operational_closure": {
      "allOf": [
        { "$ref": "#/$defs/evidence_base" },
        {
          "properties": {
            "evidence_id": { "const": "pb04_pb11_runtime_operational_closure" },
            "blocker_reason": { "const": "pb04_pb11_runtime_operational_closure_missing" }
          }
        }
      ]
    },
    "validator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "validator_id",
        "command",
        "required_for_closure"
      ],
      "properties": {
        "validator_id": {
          "type": "string",
          "const": "forge-live-runtime-readiness-gate"
        },
        "command": {
          "type": "string",
          "const": "python scripts/validate_forge_live_runtime_readiness_gate.py"
        },
        "required_for_closure": {
          "type": "boolean",
          "const": true
        }
      }
    }
  }
}
