{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:agentic-service-harness-live-producer-effect-receipt-packet:1",
  "title": "Agentic Service Harness Live Producer Effect Receipt Packet",
  "description": "Read-only packet for the live producer effect receipt witness. This packet defines the required receipt components while keeping the actual live effect receipt AwaitingEvidence and denying live producer authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "packet_id",
    "schema_version",
    "generated_at",
    "solver_outcome",
    "packet_status",
    "source_preflight_ref",
    "source_preflight_status",
    "planning_only",
    "read_only",
    "live_producer_implemented",
    "live_effect_observed",
    "effect_receipt_collected",
    "authority_granted",
    "terminal_closure",
    "required_components",
    "missing_evidence",
    "authority_denials",
    "effect_boundary",
    "validators",
    "next_action"
  ],
  "properties": {
    "packet_id": {
      "type": "string",
      "const": "agentic-service-harness-live-producer-effect-receipt-packet"
    },
    "schema_version": { "type": "integer", "const": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "solver_outcome": { "type": "string", "const": "AwaitingEvidence" },
    "packet_status": { "type": "string", "const": "blocked_awaiting_effect_receipt_components" },
    "source_preflight_ref": { "$ref": "#/$defs/evidence_ref" },
    "source_preflight_status": { "type": "string", "const": "AwaitingEvidence" },
    "planning_only": { "type": "boolean", "const": true },
    "read_only": { "type": "boolean", "const": true },
    "live_producer_implemented": { "type": "boolean", "const": false },
    "live_effect_observed": { "type": "boolean", "const": false },
    "effect_receipt_collected": { "type": "boolean", "const": false },
    "authority_granted": { "type": "boolean", "const": false },
    "terminal_closure": { "type": "boolean", "const": false },
    "required_components": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": { "$ref": "#/$defs/required_component" },
      "uniqueItems": true
    },
    "missing_evidence": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": { "$ref": "#/$defs/missing_evidence_item" },
      "uniqueItems": true
    },
    "authority_denials": { "$ref": "#/$defs/authority_denials" },
    "effect_boundary": { "$ref": "#/$defs/effect_boundary" },
    "validators": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/validator_ref" }
    },
    "next_action": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "evidence_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 320,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/#-]*$"
    },
    "required_component": {
      "type": "object",
      "additionalProperties": false,
      "required": ["component_id", "required_ref", "status", "blocks_live_producer"],
      "properties": {
        "component_id": {
          "type": "string",
          "enum": [
            "admitted_action_ref",
            "effect_receipt_ref",
            "effect_hash_ref",
            "effect_reconciliation_ref",
            "rollback_link_ref",
            "redaction_ref"
          ]
        },
        "required_ref": { "$ref": "#/$defs/evidence_ref" },
        "status": { "type": "string", "const": "AwaitingEvidence" },
        "blocks_live_producer": { "type": "boolean", "const": true }
      }
    },
    "missing_evidence_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence_id", "status", "blocks_live_producer"],
      "properties": {
        "evidence_id": {
          "type": "string",
          "enum": [
            "admitted_action_ref",
            "effect_receipt_ref",
            "effect_hash_ref",
            "effect_reconciliation_ref",
            "rollback_link_ref",
            "redaction_ref"
          ]
        },
        "status": { "type": "string", "const": "AwaitingEvidence" },
        "blocks_live_producer": { "type": "boolean", "const": true }
      }
    },
    "authority_denials": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ui_created",
        "mutation_endpoints_admitted",
        "external_adapter_integrated",
        "branch_write_enabled",
        "pull_request_creation_enabled",
        "deployment_enabled",
        "dns_mutation_enabled",
        "secret_mutation_enabled",
        "destructive_operation_enabled",
        "runtime_state_written",
        "live_execution_authorized"
      ],
      "properties": {
        "ui_created": { "type": "boolean", "const": false },
        "mutation_endpoints_admitted": { "type": "boolean", "const": false },
        "external_adapter_integrated": { "type": "boolean", "const": false },
        "branch_write_enabled": { "type": "boolean", "const": false },
        "pull_request_creation_enabled": { "type": "boolean", "const": false },
        "deployment_enabled": { "type": "boolean", "const": false },
        "dns_mutation_enabled": { "type": "boolean", "const": false },
        "secret_mutation_enabled": { "type": "boolean", "const": false },
        "destructive_operation_enabled": { "type": "boolean", "const": false },
        "runtime_state_written": { "type": "boolean", "const": false },
        "live_execution_authorized": { "type": "boolean", "const": false }
      }
    },
    "effect_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ui_created",
        "mutation_endpoints_admitted",
        "external_adapter_integrated",
        "branch_write_enabled",
        "pull_request_creation_enabled",
        "deployment_enabled",
        "dns_mutation_enabled",
        "secret_mutation_enabled",
        "destructive_operation_enabled",
        "runtime_state_written",
        "network_policy"
      ],
      "properties": {
        "ui_created": { "type": "boolean", "const": false },
        "mutation_endpoints_admitted": { "type": "boolean", "const": false },
        "external_adapter_integrated": { "type": "boolean", "const": false },
        "branch_write_enabled": { "type": "boolean", "const": false },
        "pull_request_creation_enabled": { "type": "boolean", "const": false },
        "deployment_enabled": { "type": "boolean", "const": false },
        "dns_mutation_enabled": { "type": "boolean", "const": false },
        "secret_mutation_enabled": { "type": "boolean", "const": false },
        "destructive_operation_enabled": { "type": "boolean", "const": false },
        "runtime_state_written": { "type": "boolean", "const": false },
        "network_policy": { "type": "string", "const": "none" }
      }
    },
    "validator_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["validator_id", "command", "required_for_closure"],
      "properties": {
        "validator_id": { "$ref": "#/$defs/identifier" },
        "command": { "type": "string", "minLength": 1 },
        "required_for_closure": { "type": "boolean", "const": true }
      }
    }
  }
}
