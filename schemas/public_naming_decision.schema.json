{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:public-naming-decision:1",
  "title": "Public Naming Decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "decision_id",
    "decision_date",
    "timezone",
    "product_name",
    "company_brand",
    "first_reference",
    "platform_term",
    "decision",
    "public_paid_launch_allowed",
    "approved_scopes",
    "blocked_scopes",
    "blocked_public_names",
    "open_gates",
    "capture_readiness",
    "mutation_rule"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1"
    },
    "decision_id": {
      "type": "string",
      "minLength": 1
    },
    "decision_date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "timezone": {
      "type": "string",
      "const": "America/New_York"
    },
    "product_name": {
      "type": "string",
      "const": "Mullu"
    },
    "company_brand": {
      "type": "string",
      "const": "Mullusi"
    },
    "first_reference": {
      "type": "string",
      "const": "Mullu, by Mullusi"
    },
    "platform_term": {
      "type": "string",
      "const": "Mullu Platform"
    },
    "decision": {
      "type": "string",
      "const": "proceed_internal_private_beta"
    },
    "public_paid_launch_allowed": {
      "type": "boolean",
      "const": false
    },
    "approved_scopes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "internal_alignment",
          "private_beta",
          "request_access_product_route",
          "research_product_planning"
        ]
      },
      "uniqueItems": true
    },
    "blocked_scopes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "paid_public_launch",
          "public_paid_advertising",
          "domain_forwarded_paid_product_traffic"
        ]
      },
      "uniqueItems": true
    },
    "blocked_public_names": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "open_gates": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "uspto_search",
          "wipo_search",
          "euipo_tmview_search",
          "close_variant_review",
          "domain_ownership",
          "legal_review"
        ]
      },
      "uniqueItems": true
    },
    "capture_readiness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_files_present",
        "required_files_total",
        "required_files_missing",
        "status"
      ],
      "properties": {
        "required_files_present": {
          "type": "integer",
          "minimum": 0
        },
        "required_files_total": {
          "type": "integer",
          "const": 32
        },
        "required_files_missing": {
          "type": "integer",
          "minimum": 0
        },
        "status": {
          "type": "string",
          "enum": [
            "blocked",
            "capture_ready_for_review"
          ]
        }
      }
    },
    "mutation_rule": {
      "type": "string",
      "minLength": 1
    }
  }
}
