{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mullusi:schema:governed-planning-profile-replay-recovery-witness:1",
  "title": "Governed Planning Profile Replay Recovery Witness",
  "description": "Read-only local replay/recovery witness for GovernedPlanningProfile runtime promotion that does not execute replay, rollback, or runtime authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "witness_id",
    "schema_version",
    "profile_id",
    "witnessed_at",
    "solver_outcome",
    "replay_recovery_witness_status",
    "replay_recovery_gate_satisfied",
    "local_witness_only",
    "read_only",
    "mutation_route",
    "runtime_behavior_change",
    "runtime_promotion_authorized",
    "execution_allowed",
    "dispatch_allowed",
    "runtime_replanning_enabled",
    "success_claim_allowed",
    "terminal_closure",
    "replay_execution_performed",
    "rollback_execution_performed",
    "source_runtime_promotion_approval_packet",
    "expected_plan_classes",
    "replay_recovery_controls",
    "scenario_replay_witnesses",
    "recovery_boundary",
    "promotion_gate_summary",
    "remaining_promotion_gates",
    "authority_denials",
    "evidence_refs",
    "validators",
    "next_action",
    "witness_hash"
  ],
  "properties": {
    "witness_id": {
      "type": "string",
      "pattern": "^governed-planning-profile-replay-recovery-witness-[a-f0-9]{16}$"
    },
    "schema_version": {
      "type": "string",
      "const": "governed_planning_profile_replay_recovery_witness.v1"
    },
    "profile_id": {
      "type": "string",
      "const": "governed-planning-profile-foundation-v1"
    },
    "witnessed_at": {
      "type": "string",
      "const": "2026-06-19T00:00:00Z"
    },
    "solver_outcome": {
      "type": "string",
      "const": "AwaitingEvidence"
    },
    "replay_recovery_witness_status": {
      "type": "string",
      "const": "CollectedNoEffect"
    },
    "replay_recovery_gate_satisfied": { "type": "boolean", "const": true },
    "local_witness_only": { "type": "boolean", "const": true },
    "read_only": { "type": "boolean", "const": true },
    "mutation_route": { "type": "boolean", "const": false },
    "runtime_behavior_change": { "type": "boolean", "const": false },
    "runtime_promotion_authorized": { "type": "boolean", "const": false },
    "execution_allowed": { "type": "boolean", "const": false },
    "dispatch_allowed": { "type": "boolean", "const": false },
    "runtime_replanning_enabled": { "type": "boolean", "const": false },
    "success_claim_allowed": { "type": "boolean", "const": false },
    "terminal_closure": { "type": "boolean", "const": false },
    "replay_execution_performed": { "type": "boolean", "const": false },
    "rollback_execution_performed": { "type": "boolean", "const": false },
    "source_runtime_promotion_approval_packet": {
      "$ref": "#/$defs/source_runtime_promotion_approval_packet"
    },
    "expected_plan_classes": {
      "type": "array",
      "prefixItems": [
        { "const": "uncompiled_conversation" },
        { "const": "read_only_search" },
        { "const": "compound_search_notification" },
        { "const": "high_risk_payment" },
        { "const": "world_contradiction_search" }
      ],
      "minItems": 5,
      "maxItems": 5
    },
    "replay_recovery_controls": {
      "type": "array",
      "prefixItems": [
        { "$ref": "#/$defs/control_source_approval_packet_valid" },
        { "$ref": "#/$defs/control_all_plan_classes_replay_probe_bound" },
        { "$ref": "#/$defs/control_zero_replay_mismatches" },
        { "$ref": "#/$defs/control_rollback_plan_documented" },
        { "$ref": "#/$defs/control_recovery_handoff_documented" },
        { "$ref": "#/$defs/control_authority_denials_preserved" },
        { "$ref": "#/$defs/control_foundation_no_effect_boundary_preserved" }
      ],
      "minItems": 7,
      "maxItems": 7
    },
    "scenario_replay_witnesses": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": { "$ref": "#/$defs/scenario_replay_witness" }
    },
    "recovery_boundary": { "$ref": "#/$defs/recovery_boundary" },
    "promotion_gate_summary": { "$ref": "#/$defs/promotion_gate_summary" },
    "remaining_promotion_gates": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": { "$ref": "#/$defs/remaining_promotion_gate" }
    },
    "authority_denials": { "$ref": "#/$defs/authority_denials" },
    "evidence_refs": { "$ref": "#/$defs/non_empty_string_array" },
    "validators": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/validator_ref" }
    },
    "next_action": {
      "type": "string",
      "const": "obtain terminal closure certificate before runtime promotion"
    },
    "witness_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  },
  "$defs": {
    "source_runtime_promotion_approval_packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packet_id",
        "packet_hash",
        "runtime_promotion_approval_status",
        "runtime_promotion_approval_collected",
        "runtime_promotion_gate_satisfied",
        "scenario_approval_count",
        "remaining_promotion_gate_count"
      ],
      "properties": {
        "packet_id": {
          "type": "string",
          "pattern": "^governed-planning-profile-runtime-promotion-approval-packet-[a-f0-9]{16}$"
        },
        "packet_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "runtime_promotion_approval_status": {
          "type": "string",
          "const": "ConditionallyApprovedNoEffect"
        },
        "runtime_promotion_approval_collected": { "type": "boolean", "const": true },
        "runtime_promotion_gate_satisfied": { "type": "boolean", "const": true },
        "scenario_approval_count": { "type": "integer", "const": 5 },
        "remaining_promotion_gate_count": { "type": "integer", "const": 2 }
      }
    },
    "replay_recovery_control_base": {
      "type": "object",
      "additionalProperties": false,
      "required": ["control_id", "status", "evidence_ref", "blocks_runtime_promotion"],
      "properties": {
        "control_id": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "const": "Pass" },
        "evidence_ref": { "type": "string", "minLength": 1 },
        "blocks_runtime_promotion": { "type": "boolean", "const": false }
      }
    },
    "control_source_approval_packet_valid": {
      "allOf": [
        { "$ref": "#/$defs/replay_recovery_control_base" },
        {
          "type": "object",
          "properties": { "control_id": { "const": "source_approval_packet_valid" } }
        }
      ]
    },
    "control_all_plan_classes_replay_probe_bound": {
      "allOf": [
        { "$ref": "#/$defs/replay_recovery_control_base" },
        {
          "type": "object",
          "properties": { "control_id": { "const": "all_plan_classes_replay_probe_bound" } }
        }
      ]
    },
    "control_zero_replay_mismatches": {
      "allOf": [
        { "$ref": "#/$defs/replay_recovery_control_base" },
        {
          "type": "object",
          "properties": { "control_id": { "const": "zero_replay_mismatches" } }
        }
      ]
    },
    "control_rollback_plan_documented": {
      "allOf": [
        { "$ref": "#/$defs/replay_recovery_control_base" },
        {
          "type": "object",
          "properties": { "control_id": { "const": "rollback_plan_documented" } }
        }
      ]
    },
    "control_recovery_handoff_documented": {
      "allOf": [
        { "$ref": "#/$defs/replay_recovery_control_base" },
        {
          "type": "object",
          "properties": { "control_id": { "const": "recovery_handoff_documented" } }
        }
      ]
    },
    "control_authority_denials_preserved": {
      "allOf": [
        { "$ref": "#/$defs/replay_recovery_control_base" },
        {
          "type": "object",
          "properties": { "control_id": { "const": "authority_denials_preserved" } }
        }
      ]
    },
    "control_foundation_no_effect_boundary_preserved": {
      "allOf": [
        { "$ref": "#/$defs/replay_recovery_control_base" },
        {
          "type": "object",
          "properties": { "control_id": { "const": "foundation_no_effect_boundary_preserved" } }
        }
      ]
    },
    "scenario_replay_witness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scenario_id",
        "plan_class",
        "source_approval_status",
        "operator_observation_ref",
        "replay_probe_ref",
        "replay_probe_status",
        "replay_mismatch_count",
        "recovery_path_ref",
        "rollback_path_documented",
        "incident_handoff_documented",
        "replay_execution_performed",
        "rollback_execution_performed",
        "runtime_promotion_ready"
      ],
      "properties": {
        "scenario_id": { "type": "string", "pattern": "^scenario-[a-z0-9-]+$" },
        "plan_class": {
          "type": "string",
          "enum": [
            "uncompiled_conversation",
            "read_only_search",
            "compound_search_notification",
            "high_risk_payment",
            "world_contradiction_search"
          ]
        },
        "source_approval_status": {
          "type": "string",
          "const": "ConditionallyApprovedNoEffect"
        },
        "operator_observation_ref": {
          "type": "string",
          "pattern": "^receipt://governed-planning-profile/operator-shadow-pilot/[a-z0-9_]+$"
        },
        "replay_probe_ref": {
          "type": "string",
          "pattern": "^hash://sha256/[a-f0-9]{64}$"
        },
        "replay_probe_status": {
          "type": "string",
          "const": "WitnessBound"
        },
        "replay_mismatch_count": { "type": "integer", "const": 0 },
        "recovery_path_ref": {
          "type": "string",
          "pattern": "^recovery://governed-planning-profile/[a-z0-9_]+$"
        },
        "rollback_path_documented": { "type": "boolean", "const": true },
        "incident_handoff_documented": { "type": "boolean", "const": true },
        "replay_execution_performed": { "type": "boolean", "const": false },
        "rollback_execution_performed": { "type": "boolean", "const": false },
        "runtime_promotion_ready": { "type": "boolean", "const": false }
      }
    },
    "recovery_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rollback_plan_documented",
        "recovery_handoff_documented",
        "incident_handoff_required_if_drift",
        "terminal_closure_required",
        "replay_execution_performed",
        "rollback_execution_performed"
      ],
      "properties": {
        "rollback_plan_documented": { "type": "boolean", "const": true },
        "recovery_handoff_documented": { "type": "boolean", "const": true },
        "incident_handoff_required_if_drift": { "type": "boolean", "const": true },
        "terminal_closure_required": { "type": "boolean", "const": true },
        "replay_execution_performed": { "type": "boolean", "const": false },
        "rollback_execution_performed": { "type": "boolean", "const": false }
      }
    },
    "promotion_gate_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "satisfied_promotion_gate_ids",
        "remaining_promotion_gate_ids",
        "replay_recovery_control_count",
        "scenario_witness_count",
        "runtime_promotion_authorized"
      ],
      "properties": {
        "satisfied_promotion_gate_ids": {
          "type": "array",
          "prefixItems": [
            { "const": "operator_shadow_pilot_observation" },
            { "const": "runtime_promotion_approval" },
            { "const": "replay_recovery_witness" }
          ],
          "minItems": 3,
          "maxItems": 3
        },
        "remaining_promotion_gate_ids": {
          "type": "array",
          "prefixItems": [
            { "const": "terminal_closure_certificate" }
          ],
          "minItems": 1,
          "maxItems": 1
        },
        "replay_recovery_control_count": { "type": "integer", "const": 7 },
        "scenario_witness_count": { "type": "integer", "const": 5 },
        "runtime_promotion_authorized": { "type": "boolean", "const": false }
      }
    },
    "remaining_promotion_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gate_id",
        "status",
        "required_evidence_ref",
        "blocks_runtime_promotion"
      ],
      "properties": {
        "gate_id": {
          "type": "string",
          "const": "terminal_closure_certificate"
        },
        "status": { "type": "string", "const": "AwaitingEvidence" },
        "required_evidence_ref": {
          "type": "string",
          "pattern": "^unknown://governed-planning-profile/[A-Za-z0-9._:/#-]+$"
        },
        "blocks_runtime_promotion": { "type": "boolean", "const": true }
      }
    },
    "authority_denials": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime_promotion_authorized",
        "execution_allowed",
        "dispatch_allowed",
        "runtime_replanning_enabled",
        "success_claim_allowed",
        "terminal_closure"
      ],
      "properties": {
        "runtime_promotion_authorized": { "type": "boolean", "const": false },
        "execution_allowed": { "type": "boolean", "const": false },
        "dispatch_allowed": { "type": "boolean", "const": false },
        "runtime_replanning_enabled": { "type": "boolean", "const": false },
        "success_claim_allowed": { "type": "boolean", "const": false },
        "terminal_closure": { "type": "boolean", "const": false }
      }
    },
    "validator_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["validator_id", "command"],
      "properties": {
        "validator_id": { "type": "string", "minLength": 1 },
        "command": { "type": "string", "minLength": 1 }
      }
    },
    "non_empty_string_array": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    }
  }
}
