# Purpose: governed swarm control-plane activation example.
# Governance scope: feature-flagged swarm route mount with append-only audit persistence.
# Dependencies: bundled mullu-control-plane runtime package and a writable audit-store path.
# Invariants: disabled by default; audit store required when enabled; optional runtime path must contain mcoi_runtime/swarm.
#
# Current runtime witness:
#   repository: tamirat-wubie/mullu-control-plane
#   runtime label: control-plane-bundled-runtime

# Enable the optional governed swarm route mount.
MULLU_GOVERNED_SWARM_ENABLED=true

# Required when enabled. Use an absolute persistent .jsonl file path in pilot/production.
# The parent directory must already exist and be writable before startup.
MULLU_GOVERNED_SWARM_AUDIT_STORE_PATH=/var/lib/mullu/governed-swarm/swarm-runs.jsonl

# Optional when the governed swarm runtime is loaded from a non-standard checkout.
# This path must contain mcoi_runtime/swarm.
MULLU_GOVERNED_SWARM_RUNTIME_PATH=/opt/mullu/mullu-control-plane/mcoi
