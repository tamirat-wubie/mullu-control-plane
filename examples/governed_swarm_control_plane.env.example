# Purpose: governed swarm control-plane activation example.
# Governance scope: feature-flagged swarm route mount with append-only audit persistence.
# Dependencies: mullu-governed-swarm runtime checkout/package and a writable audit-store path.
# Invariants: disabled by default; audit store required when enabled; runtime path must contain mcoi_runtime/swarm.

# Enable the optional governed swarm route mount.
MULLU_GOVERNED_SWARM_ENABLED=true

# Required when enabled. Use a persistent path in pilot/production.
MULLU_GOVERNED_SWARM_AUDIT_STORE_PATH=/var/lib/mullu/governed-swarm/swarm-runs.jsonl

# Optional when the governed swarm runtime is installed separately.
# This path must contain mcoi_runtime/swarm.
MULLU_GOVERNED_SWARM_RUNTIME_PATH=/opt/mullu/mullu-governed-swarm/mcoi
