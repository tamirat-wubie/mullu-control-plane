# Purpose: redacted operator template for finance email/calendar live receipt recovery.
# Governance scope: name-only binding guidance; do not commit secret values.
# Invariants:
#   - Worker URL and signing secret are required together.
#   - Exactly one connector token family may be bound for a recovery probe.
#   - Connector scope evidence must be read-only.

MULLU_EMAIL_CALENDAR_WORKER_URL=http://email-calendar-worker:8050/email-calendar/execute
MULLU_EMAIL_CALENDAR_WORKER_SECRET=<secret-from-secret-manager>

# Generic governed connector binding.
EMAIL_CALENDAR_CONNECTOR_TOKEN=<secret-from-secret-manager>
EMAIL_CALENDAR_CONNECTOR_ID=gmail
EMAIL_CALENDAR_CONNECTOR_SCOPE_ID=gmail.readonly

# Provider-specific alternatives. Leave unset unless used instead of EMAIL_CALENDAR_CONNECTOR_TOKEN.
GMAIL_ACCESS_TOKEN=
GMAIL_SCOPE_ID=gmail.readonly
GOOGLE_CALENDAR_ACCESS_TOKEN=
GOOGLE_CALENDAR_SCOPE_ID=calendar.events.readonly
MICROSOFT_GRAPH_ACCESS_TOKEN=
MICROSOFT_GRAPH_SCOPE_ID=mail.read
