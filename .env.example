# Mullu gateway deployment environment template.
# Copy to .env and fill every required value before `docker compose up`.
# .env must stay out of version control; this template carries no real secrets.

# --- Database ---
POSTGRES_PASSWORD=

# --- LLM backend (REQUIRED for a pilot/production stack) ---
# docker-compose.yml sets MULLU_ENV=pilot, which FORBIDS the stub backend
# (stub returns fake responses under a real audit label). You MUST pick a real
# backend here or the `mullu` API service crash-loops on boot and the whole
# stack never becomes healthy. Leave blank ONLY for local/test (MULLU_ENV=test).
# Example: anthropic | openai | gemini | groq | deepseek | together | ollama ...
MULLU_LLM_BACKEND=anthropic
# Provide the key that matches the backend above (only one is needed):
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Core gateway config ---
# Comma-separated allowed origins, e.g. https://gateway.mullusi.com
MULLU_CORS_ORIGINS=
# Base64-encoded 32-byte field-encryption key:  openssl rand -base64 32
MULLU_ENCRYPTION_KEY=
# Command-anchor signing secret:                openssl rand -hex 32
MULLU_COMMAND_ANCHOR_SECRET=
# Gateway approval callback secret:             openssl rand -hex 32
MULLU_GATEWAY_APPROVAL_SECRET=
# Capability worker shared secret:              openssl rand -hex 32
MULLU_CAPABILITY_WORKER_SECRET=

# --- Witness / conformance secrets ---
# CRITICAL: each of the three values below must be byte-identical to the
# GitHub Actions repository secret of the same name. The deployment-witness
# workflow re-derives the HMAC with the GitHub copy and compares; any drift
# yields signature mismatch and the witness never reaches deployment_claim:
# published. Generate once with `openssl rand -hex 32`, then set both places
# (this .env and `gh secret set <NAME>`).
MULLU_RUNTIME_WITNESS_SECRET=
MULLU_RUNTIME_CONFORMANCE_SECRET=
MULLU_DEPLOYMENT_WITNESS_SECRET=

# --- Optional adapter workers (only when running the `adapter-workers` profile) ---
# NOTE: the voice-worker service hard-requires OPENAI_API_KEY (set above) when
# the adapter-workers profile is enabled.
MULLU_BROWSER_WORKER_URL=
MULLU_BROWSER_WORKER_SECRET=
MULLU_DOCUMENT_WORKER_URL=
MULLU_DOCUMENT_WORKER_SECRET=
MULLU_VOICE_WORKER_URL=
MULLU_VOICE_WORKER_SECRET=
MULLU_EMAIL_CALENDAR_WORKER_URL=
MULLU_EMAIL_CALENDAR_WORKER_SECRET=
EMAIL_CALENDAR_CONNECTOR_TOKEN=
EMAIL_CALENDAR_CONNECTOR_ID=gmail
EMAIL_CALENDAR_CONNECTOR_SCOPE_ID=governed:gmail

# --- Govern Cloud private staging dependency (operator-gated, no public proxy) ---
MULLU_GOVERN_CLOUD_STAGING_ENABLED=false
MULLU_GOVERN_CLOUD_INTERNAL_URL=http://mullusi-govern-cloud-staging:8000
MULLU_GOVERN_CLOUD_PUBLIC_PROXY_ENABLED=false
MULLU_GOVERN_CLOUD_RENDER_SERVICE_ID=
MULLU_GOVERN_CLOUD_RENDER_DEPLOY_ID=
MULLU_GOVERN_CLOUD_IMAGE_TAG=
MULLU_GOVERN_CLOUD_DATABASE_PLAN=

# --- Nested-mind observation bridge (default off) ---
# Read-only bridge gate.
MULLU_NESTED_MIND_ENABLED=false
# Observation bridge gate. Does not enable live submission by itself.
MULLU_NESTED_MIND_OBSERVATION_BRIDGE_ENABLED=false
# Live record_observation submission gate. Keep false unless an operator is
# intentionally submitting a NestedMindObservationProposalPlan.
MULLU_NESTED_MIND_OBSERVATION_SUBMIT_ENABLED=false
# HTTPS base URL only; no credentials, query, or fragment.
MULLU_NESTED_MIND_BASE_URL=
# Optional bearer token. Never print or persist this value.
MULLU_NESTED_MIND_BEARER_TOKEN=
