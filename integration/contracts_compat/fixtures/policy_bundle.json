{
  "bundle_id": "bundle-governance-1",
  "name": "Governance DSL bundle",
  "version": {
    "version_id": "policy-version-1",
    "major": 1,
    "minor": 0,
    "patch": 0,
    "created_at": "2026-03-20T12:00:00+00:00",
    "description": "Initial governance bundle"
  },
  "rules": [
    {
      "rule_id": "rule-approval-admin",
      "name": "Require admin approval",
      "description": "Require approval for admin-scoped actions.",
      "effect": "require_approval",
      "conditions": [
        {
          "field_path": "subject.role",
          "operator": "eq",
          "expected_value": "admin"
        }
      ],
      "actions": [
        {
          "action_id": "action-approve",
          "kind": "set_approval_required",
          "parameters": {
            "required": true
          }
        }
      ],
      "scope": {
        "scope_id": "scope-global",
        "kind": "global",
        "ref_id": null,
        "description": ""
      },
      "priority": 10,
      "enabled": true,
      "metadata": {
        "owner": "governance"
      }
    }
  ],
  "created_at": "2026-03-20T12:00:00+00:00",
  "metadata": {
    "release": "v1"
  }
}
